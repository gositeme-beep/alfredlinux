# Build outputs and logs
*.log
build.log
binary.log
build-*.log
# Accidental `lb config` from repo root (canonical cwd is build/ — see ALFRED-LINUX-BUILD-TEST.txt)
.build/
config/binary
config/bootstrap
config/chroot
config/common
config/source

# Dockerized lb build (host-side log + container name)
lb-docker-build.log
lb-docker.containername
.lb-docker-watch.heartbeat
.lb-docker-watch.lock
.lb-supervisor-auth

# Entire live-build workspace (regenerates from config/ + hooks)
# Ignore build/* but keep tracked operator helpers under build/scripts/
build/*
!build/auto/
!build/auto/**
!build/scripts/
!build/scripts/**
binary/
chroot/
cache/
iso-output/*.iso
iso-output/*.iso.sha256
iso-output/*.iso.sig
iso-output/*.zsync
*.squashfs
*.squashfs.old-*

# Backups and tempfiles
*.bak
*.bak.*
*~
*.swp
.DS_Store

# Secrets — NEVER commit
pwd.txt
**/pwd.txt
.vault/
.kingdom/
.env
.env.*
*.key
*.pem
*.p12
*.pfx
id_rsa*
id_ed25519*
*_token*
*token*.txt
.htpasswd

# Server-side / commerce code that does NOT belong in the OS repo
commander-*.php
api/commander-*.php
pay/
account/
shield-*.conf
customer-*.db
customer-*.sql

# IDE / OS noise
.vscode/
.idea/
node_modules/
__pycache__/
*.pyc

# Alfred Kernel 7 bindeb-pkg outputs (large; present only on build host)
config/packages.chroot/linux-image-*.deb
config/packages.chroot/linux-headers-*.deb
config/packages.chroot/linux-libc-dev_*.deb

# Archive (keep separate)
archive/

# Staging inside build-assets (regenerable)
build-assets/chroot-staging/

# Large shipped media — keep on forge as Release artifacts or rsync mirror;
# remove these lines from .gitignore if you use Git LFS for them instead.
build-assets/videos/
build-assets/music/
build-assets/wallpapers/

# Packed kernel debs for ISO staging (README only is tracked)
build-assets/kernel-7.0.3-debs/*
!build-assets/kernel-7.0.3-debs/README.txt

# Source config tree (NOT a generated artifact) — must be tracked
!build/config/
!build/config/**

# Nested hooks/live under build/ is wrong layout (lb/Docker symlinks); ignore noise.
build/config/hooks/live/

# Forge mirror/docs rsynced into includes during dev (regenerable)
build/config/includes.chroot/build-assets/forge/

# Optional kernel archive drop dir under chroot includes (README only tracked)
build/config/includes.chroot/build-assets/kernel-7.0.3-debs/*
!build/config/includes.chroot/build-assets/kernel-7.0.3-debs/README.txt
