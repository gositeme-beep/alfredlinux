{
  "manifest_version": 3,
  "name": "Alfred Wallet",
  "version": "1.0.0",
  "description": "Solana wallet with GSM token support, Jupiter DEX swap, and QR/NFC payments",
  "author": "GoSiteMe Inc.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "https://gositeme.com/*",
    "https://api.mainnet-beta.solana.com/*",
    "https://quote-api.jup.ag/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "Alfred Wallet"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
