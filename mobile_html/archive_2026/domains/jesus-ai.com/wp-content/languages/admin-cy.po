msgstr "Nid oedd modd ychwanegu'r defnyddiwr i'r wefan hon."

#: wp-admin/user-new.php:351
msgid "That user is already a member of this site."
msgstr "Mae'r defnyddiwr hwnnw eisoes yn aelod o'r wefan."

