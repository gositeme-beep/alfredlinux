# GoCodeMe.com Environment Configuration

# Server Configuration
PORT=3000
NODE_ENV=development

# OpenRouter API Configuration (for Claude AI)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
CLAUDE_MODEL=anthropic/claude-3-sonnet

# code-server Configuration
CODE_SERVER_PORT=8080
CODE_SERVER_PASSWORD=your_secure_password_here
CODE_SERVER_WORKSPACE=/home/gositeme/domains/soundstudiopro.com/public_html

# Security
SESSION_SECRET=your_session_secret_here
JWT_SECRET=your_jwt_secret_here

# Database (optional for user management)
DATABASE_URL=sqlite://./gocodeme.db

# File System
ALLOWED_FILE_TYPES=.js,.ts,.jsx,.tsx,.html,.css,.php,.py,.json,.md,.txt
MAX_FILE_SIZE=10485760

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/gocodeme.log 