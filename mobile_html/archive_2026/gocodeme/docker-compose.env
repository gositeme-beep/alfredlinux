# Copy this to .env and fill in all values before running docker compose up

DA_HOST=https://gositeme.com:2222
DA_ADMIN_USER=admin
DA_ADMIN_PASS=YOUR_DA_ADMIN_PASSWORD

WHMCS_API_URL=https://gositeme.com/includes/api.php
WHMCS_API_IDENTIFIER=YOUR_WHMCS_API_IDENTIFIER
WHMCS_API_SECRET=YOUR_WHMCS_API_SECRET
WHMCS_WEBHOOK_SECRET=YOUR_RANDOM_WEBHOOK_SECRET_64CHARS

JWT_SECRET=YOUR_RANDOM_JWT_SECRET_64CHARS

ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
ANTHROPIC_MODEL=claude-sonnet-4-6
