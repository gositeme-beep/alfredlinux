{
  "manifest_version": 3,
  "name": "Alfred AI Assistant",
  "version": "1.0.0",
  "description": "Access Alfred AI's 1,290+ tools from any webpage. Chat, analyze pages, execute tools, and more.",
  "permissions": ["activeTab", "storage", "contextMenus", "notifications", "sidePanel"],
  "host_permissions": ["https://gositeme.com/*", "https://api.gositeme.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
