{
  "$schema": "https://raw.githubusercontent.com/nicedaytg/tauri-v2-schema/refs/heads/master/schema.json",
  "productName": "Pulse Social",
  "version": "1.0.0",
  "identifier": "com.gositeme.pulse-social",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "frontendDist": "../src",
    "devUrl": "http://localhost:1430"
  },
  "app": {
    "windows": [
      {
        "title": "Pulse Social — GoSiteMe",
        "width": 480,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 380,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src https://gositeme.com https://*.gositeme.com wss://gositeme.com; img-src 'self' https://gositeme.com data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "tooltip": "Pulse Social"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "GoSiteMe Social Network",
    "longDescription": "Pulse Social is the decentralized social network by GoSiteMe. Share posts, connect with friends, and engage with a privacy-first community.",
    "category": "SocialNetworking",
    "publisher": "GoSiteMe Inc.",
    "copyright": "Copyright © 2026 GoSiteMe Inc.",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": false,
        "installMode": "both",
        "languages": ["English", "French", "Spanish"]
      },
      "wix": null
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "signingIdentity": null
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://gositeme.com/api/app-updates.php?action=tauri_update&target={{target}}&arch={{arch}}&current_version={{current_version}}"
      ],
      "dialog": true
    }
  }
}
