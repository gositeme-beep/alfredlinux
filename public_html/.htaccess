# == BEGIN global-private-deny == (p16 2026-05-04)
# Belt-and-suspenders: deny dotfiles, env, logs, backups, swap files
# anywhere under DocumentRoot. PHP scripts that need these read them via
# absolute paths outside DocumentRoot.
<FilesMatch "^\.(env|git|svn|hg|DS_Store|htpasswd)">
    Require all denied
</FilesMatch>
<FilesMatch "\.(env|log|bak|save|swp|orig|sql|sqlite|sqlite3|key|pem|p12|pfx)(\..+)?$">
    Require all denied
</FilesMatch>
<FilesMatch "(^|/)(node_modules|vendor|tests?|spec)/">
    Require all denied
</FilesMatch>
# == END global-private-deny ==


