# AKJV Bible — reader (shared with gositeme.com)
RewriteRule ^bible/?$ /bible.php [QSA,L]
RewriteRule ^bible/read/?$ /bible-read.php [QSA,L]
RewriteRule ^bible/read/(.+)$ /bible-read.php [QSA,L]

# Bible Editions — redirect to gositeme.com canonical
RewriteRule ^bible/editions/?$ https://gositeme.com/bible/editions [R=301,L]
RewriteRule ^bible/heirloom(.*)$ https://gositeme.com/bible/heirloom$1 [R=301,L]
RewriteRule ^bible/children(.*)$ https://gositeme.com/bible/children$1 [R=301,L]
RewriteRule ^bible/chabad(.*)$ https://gositeme.com/bible/chabad$1 [R=301,L]
RewriteRule ^bible/church(.*)$ https://gositeme.com/bible/church$1 [R=301,L]
RewriteRule ^bible/pdf/(.+)$ https://gositeme.com/bible/pdf/$1 [R=301,L]

# Torrent API proxy (unified seeder on port 3202)
RewriteCond %{REQUEST_URI} ^/torrent-api/
RewriteRule ^torrent-api/(.*)$ http://127.0.0.1:3202/$1 [P,L]

# == BEGIN forge-auth-clear ==
# Force PIN re-prompt on every sign-in: delete forge_pin_ok cookie whenever
# user touches /forge/user/login, /forge/user/oauth2/.../callback, or /forge/user/logout.
# This makes the next /forge/ access fail the gate cookie check and bounce
# back to gositeme.com/forge-pin-gate.php for PIN entry.
<If "%{REQUEST_URI} =~ m#^/forge/user/(login|logout|oauth2/[^/]+/callback)#">
    Header always add Set-Cookie "forge_pin_ok=deleted; Path=/; Domain=.alfredlinux.com; Max-Age=0; Expires=Thu, 01 Jan 1970 00:00:00 GMT; Secure; HttpOnly; SameSite=Lax"
</If>
# == END forge-auth-clear ==



#PUBLIC# # == BEGIN forge-pin-gate ==
#PUBLIC# # Cross-domain PIN gate. If user has no forge_pin_ok cookie, bounce to gositeme.com
#PUBLIC# # which forces login + PIN, then HMAC-redirects to forge-pin-set.php which sets the cookie.
#PUBLIC# # Bypass: forge OAuth callbacks (so login can complete), static assets, the gate-set itself.
#PUBLIC# RewriteCond %{REQUEST_URI} ^/forge(/|$)
#PUBLIC# RewriteCond %{REQUEST_URI} !^/forge/user/oauth2/
#PUBLIC# RewriteCond %{REQUEST_URI} !^/forge/-/
#PUBLIC# RewriteCond %{REQUEST_URI} !^/forge/assets/
#PUBLIC# RewriteCond %{REQUEST_URI} !^/forge/avatars/
#PUBLIC# RewriteCond %{REQUEST_URI} !^/forge/api/healthz
#PUBLIC# RewriteCond %{REQUEST_URI} !^/forge/docs
#PUBLIC# RewriteCond %{HTTP_COOKIE} !(^|;\ *)forge_pin_ok=1
#PUBLIC# RewriteRule ^forge(/.*)?$ https://gositeme.com/forge-pin-gate.php?to=https://alfredlinux.com%{REQUEST_URI} [R=302,L,QSA]
#PUBLIC# # == END forge-pin-gate ==
# GoForge — Alfred Linux sovereign forge (app on port 3300)
RewriteCond %{REQUEST_URI} ^/forge(/|$)
# == BEGIN forge-docs-local ==
# Skip reverse-proxy for /forge/docs/* so Apache serves local GoForge docs.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^forge/docs/ - [END]
RewriteRule ^forge/docs/?$ /forge/docs/index.html [END]
# == END forge-docs-local ==
# GoForge: mod_dir can rewrite /forge/ → /forge/index.html before proxy, so Gitea sees /index.html and
# sets redirect_to=/forge/index.html; after OAuth that path has no route → 404. Treat as forge root.
RewriteRule ^forge/index\.html$ http://127.0.0.1:3300/ [P,L]

RewriteRule ^forge(/.*)?$ http://127.0.0.1:3300$1 [P,L]

# WebSocket tracker proxy (tracker on port 3201)
# Browsers connect to wss://alfredlinux.com/announce
RewriteCond %{HTTP:Upgrade} websocket [NC]
RewriteCond %{REQUEST_URI} ^/announce
RewriteRule ^announce(.*)$ ws://127.0.0.1:3201/$1 [P,L]

# HTTP tracker announce (for non-WebSocket clients)
RewriteCond %{REQUEST_URI} ^/announce
RewriteRule ^announce(.*)$ http://127.0.0.1:3201/announce$1 [P,L]

