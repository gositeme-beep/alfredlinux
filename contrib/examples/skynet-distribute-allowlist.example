# Example for ~/.config/alfred/skynet/distribute-allowlist (0280 alfred-skynet).
# One token per line: either full path or basename of argv[0] for `alfred-skynet distribute -- …`.
# If this file is missing or empty, distribute is unrestricted (previous behavior).
# If non-empty, argv[0] must match a line exactly (grep -xF).

ls
/usr/bin/rsync
