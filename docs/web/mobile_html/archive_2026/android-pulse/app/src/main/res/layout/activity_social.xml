<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A1A1A">

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progress_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:max="100"
        android:progressTint="#10B981"
        android:visibility="gone" />

    <!-- WebView with Pull-to-Refresh -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <WebView
            android:id="@+id/webview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#0A1A1A" />
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Bottom Navigation — Social Style -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#0E2424"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btn_feed"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:background="?android:attr/selectableItemBackground"
            android:contentDescription="Feed"
            android:tint="#10B981" />

        <ImageButton
            android:id="@+id/btn_search"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_menu_search"
            android:background="?android:attr/selectableItemBackground"
            android:contentDescription="Search"
            android:tint="#6EE7B7" />

        <ImageButton
            android:id="@+id/btn_post"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_menu_edit"
            android:background="?android:attr/selectableItemBackground"
            android:contentDescription="New Post"
            android:tint="#34D399" />

        <ImageButton
            android:id="@+id/btn_notifications"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_popup_reminder"
            android:background="?android:attr/selectableItemBackground"
            android:contentDescription="Notifications"
            android:tint="#6EE7B7" />

        <ImageButton
            android:id="@+id/btn_profile"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_menu_myplaces"
            android:background="?android:attr/selectableItemBackground"
            android:contentDescription="Profile"
            android:tint="#6EE7B7" />
    </LinearLayout>

</LinearLayout>
