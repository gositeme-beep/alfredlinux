{
  "name": "gocodeme",
  "version": "1.0.0",
  "description": "AI-Powered Web-Based Code Editor",
  "main": "src/server/index.js",
  "scripts": {
    "dev": "nodemon src/server/index.js",
    "start": "node src/server/index.js",
    "build": "npm run build:client",
    "build:client": "webpack --mode production",
    "install:code-server": "curl -fsSL https://code-server.dev/install.sh | sh",
    "setup": "npm install && npm run install:code-server"
  },
  "keywords": [
    "code-editor",
    "ai",
    "claude",
    "vscode",
    "web-based"
  ],
  "author": "GoCodeMe.com",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.5.0",
    "bcryptjs": "^3.0.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "pm2": "^6.0.8",
    "socket.io": "^4.7.2",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "css-loader": "^6.8.1",
    "html-webpack-plugin": "^5.5.3",
    "nodemon": "^3.0.1",
    "style-loader": "^3.3.3",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
