.card .sub{color:var(--muted);font-size:.85rem;font-style:italic;margin-bottom:.5rem}
.card p{color:var(--dim);font-size:.82rem;line-height:1.5}
.card .badge{display:inline-block;padding:.1rem .4rem;border-radius:3px;font-size:.7rem;margin-top:.5rem;background:rgba(255,215,0,.1);color:var(--gold);border:1px solid rgba(255,215,0,.15)}
</style>
</head>
<body>
