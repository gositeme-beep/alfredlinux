HUBEOF

# ── Desktop shortcuts for each edition ──
echo "[EDITIONS] Creating desktop shortcuts..."

# Local server launcher (fixes file:// CORS blocking of fetch)
cat > /usr/local/bin/alfred-bible-serve << 'SERVEEOF'
#!/bin/bash
# Launch a local HTTP server for offline Bible reading, then open browser.
# Fixes: browsers block fetch() on file:// URLs (CORS security).
BIBLE_DIR="/usr/share/alfred/bible"
PORT=$(shuf -i 9100-9199 -n 1)
PAGE="${1:-editions/hub.html}"
# Kill any previous bible server
pkill -f "python3 -m http.server.*--directory.*alfred/bible" 2>/dev/null
# Start server in background
python3 -m http.server "$PORT" --directory "$BIBLE_DIR" --bind 127.0.0.1 >/dev/null 2>&1 &
SERVER_PID=$!
sleep 0.3
xdg-open "http://127.0.0.1:${PORT}/${PAGE}" 2>/dev/null
# Auto-kill server after 4 hours of inactivity
( sleep 14400; kill "$SERVER_PID" 2>/dev/null ) &
SERVEEOF
chmod +x /usr/local/bin/alfred-bible-serve

for ED in heirloom children standard chabad church; do
    case "$ED" in
        heirloom) export DESK_NAME="Bible — Heirloom Edition"; export DESK_COMMENT="The Family Altar — 94 books, Perez genealogy, 57 prophecies";;
        children) export DESK_NAME="Bible — Children's Edition"; export DESK_COMMENT="Eden's Generation — 33 illustrated stories for ages 5-14";;
        standard) export DESK_NAME="Bible — Standard AKJV"; export DESK_COMMENT="Clean, readable — the pure Word restored";;
        chabad)   export DESK_NAME="Bible — Chabad House Edition"; export DESK_COMMENT="Hebrew-first RTL — 57 prophecies fulfilled in Yeshua";;
        church)   export DESK_NAME="Bible — Church & Synagogue"; export DESK_COMMENT="Pastoral guide, sermon index, Torah portions";;
    esac
    export DESK_ED="$ED"
    python3 <<'PYDESK'
import os
from pathlib import Path

ed = os.environ["DESK_ED"]
name = os.environ["DESK_NAME"]
comment = os.environ["DESK_COMMENT"]
if ed not in {"heirloom", "children", "standard", "chabad", "church"}:
    raise SystemExit(1)
out = Path(f"/usr/share/applications/alfred-bible-{ed}.desktop")
text = (
    "[Desktop Entry]\n"
    f"Name={name}\n"
    f"Comment={comment}\n"
    f"Exec=alfred-bible-serve editions/{ed}.html\n"
    "Icon=accessories-dictionary\n"
    "Terminal=false\n"
    "Type=Application\n"
    "Categories=Education;Reference;\n"
)
out.write_text(text, encoding="utf-8")
PYDESK
done

# Hub launcher shortcut
cat > /usr/share/applications/alfred-bible-editions.desktop << 'EOF'
[Desktop Entry]
Name=AKJV Bible Editions
Comment=Five editions, one truth — Heirloom, Children's, Standard, Chabad, Church
Exec=alfred-bible-serve editions/hub.html
Icon=accessories-dictionary
Terminal=false
Type=Application
Categories=Education;Reference;
EOF

# ── CLI shortcut: alfred-editions ──
cat > /usr/local/bin/alfred-editions << 'EDCLI'
#!/bin/bash
EDITIONS_DIR="/usr/share/alfred/bible/editions"
GOLD='\033[38;5;220m'; NC='\033[0m'; BOLD='\033[1m'; DIM='\033[2m'
echo -e "\n${GOLD}╔══════════════════════════════════════════════════════╗${NC}"
echo -e "${GOLD}║  AKJV Bible Editions — Alfred Linux 7.77             ║${NC}"
echo -e "${GOLD}║  Five editions, one truth.                            ║${NC}"
echo -e "${GOLD}╚══════════════════════════════════════════════════════╝${NC}\n"
echo -e "  ${GOLD}1.${NC} 👑 The Heirloom Edition      ${DIM}— Family altar, 94 books${NC}"
echo -e "  ${GOLD}2.${NC} 🌈 The Children's Bible      ${DIM}— Ages 5-14, 33 stories${NC}"
echo -e "  ${GOLD}3.${NC} 📖 The Standard AKJV         ${DIM}— Clean, universal${NC}"
echo -e "  ${GOLD}4.${NC} 🕎 The Chabad House Edition  ${DIM}— Hebrew-first, RTL${NC}"
echo -e "  ${GOLD}5.${NC} ⛪ Church & Synagogue        ${DIM}— Pastoral, sermon index${NC}"
echo ""
if [ -n "$1" ]; then
    case "$1" in
        1|heirloom) alfred-bible-serve editions/heirloom.html;;
        2|children) alfred-bible-serve editions/children.html;;
        3|standard) alfred-bible-serve editions/standard.html;;
        4|chabad) alfred-bible-serve editions/chabad.html;;
        5|church) alfred-bible-serve editions/church.html;;
        hub|all) alfred-bible-serve editions/hub.html;;
        *) echo "Usage: alfred-editions [1-5|heirloom|children|standard|chabad|church|hub]";;
    esac
else
    echo -e "  ${DIM}Open one:  alfred-editions 1${NC}"
    echo -e "  ${DIM}Open hub:  alfred-editions hub${NC}\n"
fi
EDCLI
chmod +x /usr/local/bin/alfred-editions

echo "[EDITIONS] ✝ All 5 Bible Editions installed to $EDITIONS_DIR"
echo "[EDITIONS]   → alfred-editions (CLI) or desktop shortcuts"

