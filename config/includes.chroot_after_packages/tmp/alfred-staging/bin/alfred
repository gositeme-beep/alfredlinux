#!/bin/sh
# /usr/bin/alfred — the sovereign assistant entry point
# Crown of Alfred Linux 7.77.1.0.0
export HERMES_HOME="${HERMES_HOME:-$HOME/.alfred/agent}"
export HERMES_PERSONA_FILE="${HERMES_PERSONA_FILE:-/usr/share/alfred/persona/alfred.md}"
export HERMES_BRAND="Alfred"
export ALFRED_BRAND="Alfred"
export ALFRED_MEMORY_URL="${ALFRED_MEMORY_URL:-http://127.0.0.1:37777}"
exec /opt/alfred-agent/.venv/bin/hermes "$@"
