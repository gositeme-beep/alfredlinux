#!/usr/bin/env -S prlimit --as=1073741824 unshare /bin/bash
export GIT_TERMINAL_PROMPT=0
export DEBIAN_FRONTEND=noninteractive
# SPDX-License-Identifier: AGPL-3.0-or-later
set +e

echo "[Genesis Forge] Engineering Execution Sandbox (bwrap) for 311..."

apt-get install -y --fix-broken -y bubblewrap || true

mkdir -p /etc/apparmor.d/alfred-isolated/ || true

# AppArmor Enforce mode
cat > /etc/apparmor.d/alfred-isolated/profile-311 << 'EOF'
profile alfred-sandbox-311 /usr/local/bin/alfred-util-298 flags=(enforce) {
  #include <abstractions/base>
  /usr/local/bin/alfred-util-298 rmix,
  /dev/null rw,
}
EOF

# Inject bubblewrap execution sandbox wrapper
cat > /usr/local/bin/alfred-util-298-wrapper << 'EOF'
#!/bin/bash
# Ephemeral Execution Sandbox
# Forces the binary into a read-only, isolated namespace where it cannot
# see the hard drive, network, or other processes.
bwrap \
  --unshare-all \
  --ro-bind /usr /usr \
  --symlink usr/lib /lib \
  --symlink usr/lib64 /lib64 \
  --symlink usr/bin /bin \
  --symlink usr/sbin /sbin \
  --ro-bind /usr/local/bin/alfred-util-298 /usr/local/bin/alfred-util-298 \
  --proc /proc \
  --dev /dev \
  --tmpfs /tmp \
  --new-session \
  /usr/local/bin/alfred-util-298 "$@"
EOF

[ -e "/usr/local/bin/alfred-util-298-wrapper" ] && chmod +x /usr/local/bin/alfred-util-298-wrapper || true

echo "[Genesis Forge] Ephemeral bwrap Sandbox Integrated."


