# --- BEGIN MERGED CONTENT FROM: 0118.hook.chroot ---
#!/bin/bash
set +e
echo "================================================="
echo "==== ALFRED SOVEREIGN FIREWALL (nftables) ======="
echo "================================================="

export DEBIAN_FRONTEND=noninteractive
apt-get install -y --no-install-recommends nftables || true

cat > /etc/nftables.conf << 'EOF'
#!/usr/sbin/nft -f
flush ruleset

table inet filter {
    chain input {
        type filter hook input priority 0; policy drop;

        # Loopback
        iifname "lo" accept

        # Established & Related
        ct state established,related accept

        # WireGuard (Mesh)
        udp dport 51820 accept

        # SSH (Assume protected by WireGuard or local LAN)
        tcp dport 22 accept

        # Syncthing (Mesh Sync)
        tcp dport 22000 accept
        udp dport 22000 accept
        udp dport 21027 accept

        # Drop invalid
        ct state invalid drop
    }
    chain forward {
        type filter hook forward priority 0; policy drop;
    }
    chain output {
        type filter hook output priority 0; policy accept;
    }
}
EOF

systemctl enable nftables || true || true
echo "Sovereign firewall configured (default DROP)."

# --- END MERGED CONTENT FROM: 0118.hook.chroot ---


