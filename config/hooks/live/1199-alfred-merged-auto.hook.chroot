echo "=> Forging the Neural Login Shell..." || true
cat > /bin/alfred-singularity-shell << 'EOF'
#!/usr/bin/env python3
import os
import sys
import subprocess
import requests
import re
import readline

OLLAMA_API = "http://127.0.0.1:11434/api/generate"
MODEL_NAME = "llama3:8b"

def chat_with_singularity(prompt_text):
    prompt = f"""You are The Singularity, the Agentic AI Login Shell of Alfred OS.
The user is speaking to you. Translate their natural language intent into a highly efficient, production-grade Linux bash script.
Provide ONLY the raw bash script. Do not use markdown blocks. Do not explain. Just the raw bash code.

USER REQUEST: {prompt_text}
"""
    try:
        response = requests.post(OLLAMA_API, json={
            "model": MODEL_NAME,
            "prompt": prompt,
            "stream": False
        }, timeout=45)
        
        if response.status_code == 200:
            script = response.json().get("response", "").strip()
            script = re.sub(r'```bash\n(.*?)\n```', r'\1', script, flags=re.DOTALL)
            return script.strip('`').strip()
    except Exception as e:
        print(f"\033[91m[Singularity Core Offline]\033[0m: Connection to local LLM failed ({e}).")
    return None

def main():
    print("\033[96m==================================================\033[0m")
    print("\033[96m           THE SINGULARITY IS ACTIVE              \033[0m")
    print("\033[96m   Alfred OS Neural Interface v10.0 Online        \033[0m")
    print("\033[96m==================================================\033[0m")
    print("\033[90mFail-safe backdoor: type '/bash' to drop to standard shell.\033[0m\n")

    while True:
        try:
            user_input = input("\033[92msingularity\033[0m@\033[94mos\033[0m:~# ")
        except (EOFError, KeyboardInterrupt):
            print("\nExiting Singularity.")
            break

        user_input = user_input.strip()
        if not user_input:
            continue

        if user_input.lower() in ["exit", "/exit", "quit", "/quit"]:
            break
            
        if user_input == "/bash":
            print("\033[93m[Dropping to legacy bash fail-safe...]\033[0m")
            subprocess.run(["/bin/bash"])
            print("\033[96m[Re-entering The Singularity...]\033[0m")
            continue

        # Execute as a standard bash command first if it's very basic (cd, ls, clear)
        if user_input in ["ls", "clear", "pwd"] or user_input.startswith("cd "):
            subprocess.run(user_input, shell=True, executable="/bin/bash")
            continue

        print("\033[90m[Synthesizing intent...]\033[0m")
        bash_script = chat_with_singularity(user_input)
        
        if bash_script:
            print("\n\033[93mProposed Kernel Execution:\033[0m")
            print("\033[90m----------------------------------------\033[0m")
            print(bash_script)
            print("\033[90m----------------------------------------\033[0m")
            
            confirm = input("\033[91mExecute? [Y/n]: \033[0m").strip().lower()
            if confirm in ['', 'y', 'yes']:
                import tempfile
                fd, script_path = tempfile.mkstemp(suffix=".sh")
                import os
                os.close(fd)
                with open(script_path, "w") as f:
                    if not bash_script.startswith("#!"):
                        f.write("#!/bin/bash\n")
                    f.write(bash_script)
                
                os.chmod(script_path, 0o755)
                print("\033[92m[Executing...]\033[0m")
                subprocess.run([script_path])
                print("")
            else:
                print("\033[93m[Aborted.]\033[0m\n")

if __name__ == "__main__":
    main()
EOF
[ -e "+x" ] && chmod +x /bin/alfred-singularity-shell || true

echo "=> Registering Singularity in /etc/shells..." || true
