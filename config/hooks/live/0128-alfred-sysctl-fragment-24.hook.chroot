#!/usr/bin/env -S prlimit --as=1073741824 unshare /bin/bash
export GIT_TERMINAL_PROMPT=0
export DEBIAN_FRONTEND=noninteractive
# SPDX-License-Identifier: AGPL-3.0-or-later
set +e
# [Genesis Forge] Granular Kernel Matrix: fs.suid_dumpable=0
# Extremely deep low-level kernel protection.
echo "[Genesis Forge] Applying granular sysctl: fs.suid_dumpable=0"
echo "fs.suid_dumpable=0" > /etc/sysctl.d/99-alfred-24.conf || true
sysctl -w fs.suid_dumpable=0 > /dev/null 2>&1 || true

exit 0
