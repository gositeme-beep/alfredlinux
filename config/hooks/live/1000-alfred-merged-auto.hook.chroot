#!/bin/bash
# 1000-alfred-shroud-of-obscurity.hook.chroot
# The Shroud of Obscurity: Keystroke Timing Equalization
set +e

echo "[1000] Configuring The Shroud of Obscurity (Keystroke Masking)"

# Keystroke dynamics can identify a user with 99% accuracy. 
