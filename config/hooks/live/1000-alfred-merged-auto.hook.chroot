#!/bin/bash
# 1000-alfred-loaves-and-fishes.hook.chroot
# The Loaves and Fishes: Bandwidth Swarm Replication
set +e

echo "[1000] Configuring The Loaves and Fishes (Bandwidth Swarm Replication)"

# We install apt-cacher-ng and IPFS to ensure that if any node in the local
# mesh network downloads a file, it is instantly cached and seeded locally.
# This allows 5,000 devices to pull an update using the bandwidth of just 1 device.

apt-get update && apt-get install -y apt-cacher-ng ipfs || true

# Configure apt-cacher-ng to broadcast its presence on the mesh
echo "Port: 3142" >> /etc/apt-cacher-ng/acng.conf
echo "PassThroughPattern: .*$" >> /etc/apt-cacher-ng/acng.conf

# Initialize an IPFS swarm config
cat << 'EOF' > /usr/local/bin/alfred-loaves-init
#!/bin/bash
# Initialize IPFS node for mesh replication
export IPFS_PATH=/var/lib/ipfs
if [ ! -d "$IPFS_PATH" ]; then
    ipfs init
    ipfs config profile apply lowpower
    # Enable automatic garbage collection
    ipfs config --json Datastore.GCPeriod '"1h"'
fi
EOF

[ -e "0755" ] && chmod 0755 /usr/local/bin/alfred-loaves-init

echo "[1000] The Loaves and Fishes are multiplying."

# --- END MERGED CONTENT FROM: 1000-alfred-loaves-and-fishes.hook.chroot ---


# --- BEGIN MERGED CONTENT FROM: 1000-alfred-pillar-of-salt.hook.chroot ---
#!/bin/bash
# 1000-alfred-pillar-of-salt.hook.chroot
# The Pillar of Salt: Radioactive Data Decay
set +e

echo "[1000] Configuring The Pillar of Salt (Radioactive Data Decay)"

# We install a cron job that mathematically "decays" highly sensitive directories
# if they are not explicitly renewed by the user. If the decay timer expires, 
# the files are turned to mathematical salt (shredded and zeroed).

mkdir -p /home/alfred/Radioactive_Vault

cat << 'EOF' > /usr/local/bin/alfred-radioactive-decay
#!/bin/bash
# Checks the last access time of the vault. If older than 7 days, obliterate it.
VAULT="/home/alfred/Radioactive_Vault"

if [ -d "$VAULT" ]; then
    # Get time since last modification in seconds
    LAST_MOD=$(stat -c %Y "$VAULT")
    NOW=$(date +%s)
    DIFF=$((NOW - LAST_MOD))
    
    # 7 days = 604800 seconds
    if [ "$DIFF" -gt 604800 ]; then
        echo "RADIOACTIVE DECAY THRESHOLD REACHED. SALTING THE VAULT."
        find "$VAULT" -type f -exec shred -u {} \;
        rm -rf "$VAULT"
        logger -p auth.alert "PILLAR_OF_SALT: Vault turned to salt due to 7-day inactivity."
    fi
fi
EOF

[ -e "0755" ] && chmod 0755 /usr/local/bin/alfred-radioactive-decay

# Run it every hour
cat << 'EOF' > /etc/cron.hourly/alfred-pillar-of-salt
#!/bin/bash
/usr/local/bin/alfred-radioactive-decay
EOF
[ -e "0755" ] && chmod 0755 /etc/cron.hourly/alfred-pillar-of-salt

echo "[1000] The Pillar of Salt is crystallizing."

# --- END MERGED CONTENT FROM: 1000-alfred-pillar-of-salt.hook.chroot ---


