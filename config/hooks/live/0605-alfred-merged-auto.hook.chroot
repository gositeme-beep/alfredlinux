#!/bin/bash
set +e
echo "================================================="
echo "==== ALFRED STARSHIP (Terminal HUD) ============="
echo "================================================="

export DEBIAN_FRONTEND=noninteractive

if [ -f /build-assets/starship ]; then
    [ -e "/build-assets/starship" ] && cp /build-assets/starship /usr/local/bin/
    [ -e "/usr/local/bin/starship" ] && chmod +x /usr/local/bin/starship
fi
if [ -f /build-assets/zoxide ]; then
    [ -e "/build-assets/zoxide" ] && cp /build-assets/zoxide /usr/local/bin/
    [ -e "/usr/local/bin/zoxide" ] && chmod +x /usr/local/bin/zoxide
fi

mkdir -p /home/gositeme/.config
cat << 'EOF' > /home/gositeme/.config/starship.toml
[character]
success_symbol = "[VAULT LOCKED â¯](bold green)"
error_symbol = "[BREACH DETECTED âœ—](bold red)"

[cmd_duration]
min_time = 500
format = "took [$duration](bold yellow)"
EOF
chown -R gositeme:gositeme /home/gositeme/.config 2>/dev/null || true

cat << 'EOF' >> /home/gositeme/.bashrc
eval "$(starship init bash)"
eval "$(zoxide init bash)"
EOF

