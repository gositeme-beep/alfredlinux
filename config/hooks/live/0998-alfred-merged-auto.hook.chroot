mkdir -p /etc/modprobe.d
cat << 'EOF' > /etc/modprobe.d/alfred-sea-of-glass.conf
options kvm_amd sev=1
options kvm_intel tdx=1
EOF

echo "[0998] The Sea of Glass is hardened."
#!/bin/bash
# 0998-alfred-seamless-garment.hook.chroot
# The Seamless Garment: MicroVM Sandboxing (gVisor)
set +e

echo "[0998] Configuring The Seamless Garment (gVisor MicroVM Sandboxing)"

# We install gVisor (runsc) to mathematically isolate critical desktop applications
# (like Tor Browser and the Crypto Wallet) from the host kernel.
# Even if a zero-day compromises the browser, it is trapped in a user-space kernel
# and cannot access the host machine's memory or files.

cat << 'EOF' > /usr/local/bin/alfred-install-gvisor
#!/bin/bash
# Download and install gVisor runsc locally during the chroot
curl -fsSL https://gvisor.dev/archive.key | apt-key add -
echo "deb https://storage.googleapis.com/gvisor/releases release main" > /etc/apt/sources.list.d/gvisor.list
apt-get update
apt-get install -y runsc || true
EOF

chmod +x /usr/local/bin/alfred-install-gvisor
# Execute the install script during the live-build chroot phase
/usr/local/bin/alfred-install-gvisor || true

# Override the default Docker runtime to strictly use the gVisor sandbox
mkdir -p /etc/docker
cat << 'EOF' > /etc/docker/daemon.json
{
    "default-runtime": "runsc",
    "runtimes": {
        "runsc": {
            "path": "/usr/bin/runsc"
        }
    }
}
EOF

echo "[0998] The Seamless Garment is woven."
#!/bin/bash
# 0998-alfred-staff-of-moses.hook.chroot
# The Staff of Moses: VLAN Subnet Cloaking & ICMP Dropping
set +e

echo "[0998] Configuring The Staff of Moses (VLAN Subnet Cloaking)"

# We configure NetworkManager dispatcher to automatically inject 802.1Q VLAN tags 
# and drop all ICMP (ping) responses the moment the user connects to a public WiFi network,
# rendering them mathematically invisible to local subnet scans (like Nmap).

mkdir -p /etc/NetworkManager/dispatcher.d
cat << 'EOF' > /etc/NetworkManager/dispatcher.d/99-staff-of-moses
#!/bin/bash
# NetworkManager Dispatcher Script

INTERFACE=$1
ACTION=$2

if [ "$ACTION" = "up" ]; then
    # Completely drop all incoming ICMP ping requests
    iptables -A INPUT -p icmp --icmp-type echo-request -j DROP
    iptables -A INPUT -p icmp --icmp-type timestamp-request -j DROP
    
    # Randomize the MAC address just in case NM didn't do it aggressively enough
    # (requires macchanger)
    macchanger -r "$INTERFACE" || true

    # Attempt to isolate traffic onto a randomized VLAN tag (e.g. 777)
    # This prevents cross-talk if the switch is misconfigured
    ip link add link "$INTERFACE" name "$INTERFACE.777" type vlan id 777 || true
    ip link set up "$INTERFACE.777" || true
fi

if [ "$ACTION" = "down" ]; then
    # Cleanup VLAN interfaces when disconnected
    ip link delete "$INTERFACE.777" 2>/dev/null || true
fi
EOF

chmod 0755 /etc/NetworkManager/dispatcher.d/99-staff-of-moses

echo "[0998] The Staff of Moses has parted the subnet."
#!/bin/bash
# 0998-alfred-the-144000.hook.chroot
# The 144,000: Decentralized Identity (DID) Node
set +e

echo "[0998] Configuring The 144,000 (W3C Decentralized Identity Node)"

# We install a lightweight DID generator to mathematically anchor the user's
# local OS identity, SSH keys, and system cryptographic roots to a W3C-compliant 
# Self-Sovereign Identity. The user is no longer "user 1000", they are an 
# irrevocable mathematical entity.

cat << 'EOF' > /usr/local/bin/alfred-did-generator
#!/bin/bash
# Generates a local W3C DID document based on the machine's primary Ed25519 SSH key
SSH_KEY_PUB="$HOME/.ssh/id_ed25519.pub"

if [ ! -f "$SSH_KEY_PUB" ]; then
    echo "Generating Sovereign SSH Keypair..."
    ssh-keygen -t ed25519 -f "$HOME/.ssh/id_ed25519" -N "" -q
fi

PUB_KEY_B64=$(awk '{print $2}' "$SSH_KEY_PUB")
DID_ID="did:key:z$(echo -n "$PUB_KEY_B64" | base64 -d | sha256sum | awk '{print $1}')"

mkdir -p "$HOME/.identity"
cat << JSON > "$HOME/.identity/did.json"
{
  "@context": [
    "https://www.w3.org/ns/did/v1",
    "https://w3id.org/security/suites/ed25519-2020/v1"
  ],
  "id": "$DID_ID",
  "authentication": [{
    "id": "$DID_ID#keys-1",
    "type": "Ed25519VerificationKey2020",
    "controller": "$DID_ID",
    "publicKeyBase64": "$PUB_KEY_B64"
  }]
}
JSON

echo "Sovereign Identity Anchored: $DID_ID"
EOF

chmod 0755 /usr/local/bin/alfred-did-generator

# Add it to the profile to ensure the DID is generated on first login
cat << 'EOF' > /etc/profile.d/alfred-144000-init.sh
if [ ! -f ~/.identity/did.json ]; then
    /usr/local/bin/alfred-did-generator
fi
EOF
chmod +x /etc/profile.d/alfred-144000-init.sh

echo "[0998] The 144,000 are sealed."
#!/bin/bash
# SPDX-License-Identifier: AGPL-3.0-or-later
# 0998-alfred-throne-room.hook.chroot
# The Throne Room: Zero-Trust Wayland Compositor Configuration
set +e

echo "[0998] Configuring The Throne Room (Zero-Trust Wayland Display)"

# We enforce strict Wayland protocol isolations so that XWayland compatibility
# layers and untrusted apps cannot capture the screen or log keystrokes.
# KWin config is modified to block screen capturing by default unless 
# explicitly authorized by the Sovereign.

mkdir -p /etc/xdg/kdeglobals.d || true
cat << 'EOF' > /etc/xdg/kdeglobals.d/99-throne-room.ini
[KWayland]
# Disable XWayland screen scraping globally
AllowX11ScreenCapture=false

[ScreenReader]
# Prevent accessibility APIs from being abused as keyloggers
Enabled=false
EOF

# Prevent unprivileged users from using the input subsystem directly
# to bypass Wayland protections (e.g. via /dev/input)
cat << 'EOF' > /etc/udev/rules.d/99-throne-room-input.rules
# Only root and input group can read raw input devices
SUBSYSTEM=="input", GROUP="input", MODE="0660"
# Ensure the alfred user is removed from input group unless absolutely necessary
EOF

echo "[0998] The Throne Room is sealed."

# === INJECTED: The Still Water (Cognitive Sanctuary Protocol) ===
cat > /usr/local/bin/alfred-still-water << 'EOF_STILL'
#!/bin/bash
kdialog --passivepopup "Entering The Still Water..." 2
docker pause $(docker ps -q) 2>/dev/null || true
logger -t alfred-sanctuary "All noisy processes suspended. Sanctuary active."
EOF_STILL
chmod +x /usr/local/bin/alfred-still-water
echo "[$(date -Is)] The Still Water is calm."


#!/bin/bash
# 0998-alfred-two-witnesses.hook.chroot
# The Two Witnesses: Multi-Party Sudo Authentication (YubiKey + PAM)
set +e

echo "[0998] Configuring The Two Witnesses (Multi-Party Sudo Auth)"

# We modify the PAM (Pluggable Authentication Modules) stack so that standard passwords
# are no longer sufficient to execute 'sudo'. Sudo will strictly require a physical U2F token
# (like a YubiKey) PRESSED simultaneously alongside the password.

# Require pam_u2f.so for sudo execution
sed -i '1i auth required pam_u2f.so cue' /etc/pam.d/sudo

# Also require it for su
sed -i '1i auth required pam_u2f.so cue' /etc/pam.d/su

# Setup a fallback warning in case users haven't enrolled their keys yet
cat << 'EOF' > /etc/profile.d/alfred-two-witnesses-warning.sh
if [ ! -f ~/.config/Yubico/u2f_keys ]; then
    echo "WARNING: The Two Witnesses protocol requires a U2F token for root access."
    echo "Please run 'pamu2fcfg > ~/.config/Yubico/u2f_keys' immediately to enroll."
fi
EOF
chmod +x /etc/profile.d/alfred-two-witnesses-warning.sh

echo "[0998] The Two Witnesses are standing guard."
#!/bin/sh
# 0998-alfred-upstream-packages.hook.chroot
# Fetches missing packages directly from upstream sources instead of skipping them.
# Ensuring Alfred Linux is truly "God-Tier".

set +e

echo "[UPSTREAM] Enabling Debian Contrib and Non-Free repos for Lutris..."
cat << 'EOF' > /etc/apt/sources.list.d/contrib-nonfree.list
deb http://deb.debian.org/debian trixie contrib non-free non-free-firmware
EOF
apt-get update

echo "[UPSTREAM] Installing Lutris..."
apt-get install -y --no-install-recommends lutris || true

echo "[UPSTREAM] Adding i2pd repository..."
apt-get install -y apt-transport-https lsb-release curl gnupg || true
curl -sL https://repo.i2pd.xyz/KEY.gpg | gpg --dearmor > /usr/share/keyrings/i2pd-archive-keyring.gpg
echo "deb [signed-by=/usr/share/keyrings/i2pd-archive-keyring.gpg] https://repo.i2pd.xyz/debian trixie main" > /etc/apt/sources.list.d/i2pd.list
apt-get update
apt-get install -y i2pd || true

echo "[UPSTREAM] Installing IPFS (Kubo)..."
wget -qO /tmp/kubo.tar.gz https://dist.ipfs.tech/kubo/v0.29.0/kubo_v0.29.0_linux-amd64.tar.gz
tar -xzf /tmp/kubo.tar.gz -C /tmp/
if [ -d /tmp/kubo ]; then
    cd /tmp/kubo && bash install.sh || true
fi
rm -rf /tmp/kubo*

echo "[UPSTREAM] Building Kloak from source..."
apt-get install -y build-essential git || true
cd /tmp
git clone https://github.com/vmonaco/kloak.git || true
if [ -d kloak ]; then
    cd kloak && make && make install
fi
rm -rf /tmp/kloak

echo "[UPSTREAM] Building Kalibrate-rtl from source..."
apt-get install -y autoconf libtool librtlsdr-dev || true
cd /tmp
git clone https://github.com/steve-m/kalibrate-rtl.git || true
if [ -d kalibrate-rtl ]; then
    cd kalibrate-rtl && ./bootstrap && ./configure && make && make install
fi
rm -rf /tmp/kalibrate-rtl

echo "[UPSTREAM] Installing Howdy (Facial Recognition)..."
curl -sL "https://keyserver.ubuntu.com/pks/lookup?op=get&search=0x32A37959C2FA5C3C99CEBC329598CAfb9AEE5027" | gpg --dearmor > /usr/share/keyrings/howdy.gpg || true
if [ -f /usr/share/keyrings/howdy.gpg ]; then
    echo "deb [signed-by=/usr/share/keyrings/howdy.gpg] http://ppa.launchpad.net/boltgolt/howdy/ubuntu jammy main" > /etc/apt/sources.list.d/howdy.list
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y howdy || true
fi

echo "[UPSTREAM] Installing Gamescope from Debian Sid..."
echo "deb http://deb.debian.org/debian sid main" > /etc/apt/sources.list.d/sid.list
cat << 'EOF' > /etc/apt/preferences.d/sid-pin
Package: *
Pin: release a=sid
Pin-Priority: 100
EOF
apt-get update
apt-get install -y -t sid gamescope || true

echo "[UPSTREAM] Installing Grafana..."
apt-get install -y apt-transport-https software-properties-common wget gnupg || true
wget -q -O - https://apt.grafana.com/gpg.key | gpg --dearmor > /usr/share/keyrings/grafana.gpg || true
echo "deb [signed-by=/usr/share/keyrings/grafana.gpg] https://apt.grafana.com stable main" > /etc/apt/sources.list.d/grafana.list
apt-get update
apt-get install -y grafana || true

echo "[UPSTREAM] Installing Terraform..."
wget -q -O - https://apt.releases.hashicorp.com/gpg | gpg --dearmor > /usr/share/keyrings/hashicorp-archive-keyring.gpg || true
echo "deb [signed-by=/usr/share/keyrings/hashicorp-archive-keyring.gpg] https://apt.releases.hashicorp.com trixie main" > /etc/apt/sources.list.d/hashicorp.list
apt-get update
apt-get install -y terraform || true

echo "[UPSTREAM] Installing mkusb and usb-pack-efi..."
curl -sL "https://keyserver.ubuntu.com/pks/lookup?op=get&search=0x54B8C8AC" | gpg --dearmor > /usr/share/keyrings/mkusb.gpg || true
if [ -f /usr/share/keyrings/mkusb.gpg ]; then
    echo "deb [signed-by=/usr/share/keyrings/mkusb.gpg] http://ppa.launchpad.net/mkusb/ppa/ubuntu jammy main" > /etc/apt/sources.list.d/mkusb.list
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y mkusb mkusb-nox usb-pack-efi || true
fi

echo "[UPSTREAM] All upstream packages processed!"
