#!/bin/sh
# 0998-alfred-upstream-packages.hook.chroot
# Fetches missing packages directly from upstream sources instead of skipping them.
# Ensuring Alfred Linux is truly "God-Tier".

set +e

echo "[UPSTREAM] Enabling Debian Contrib and Non-Free repos for Lutris..."
cat << 'EOF' > /etc/apt/sources.list.d/contrib-nonfree.list
deb http://deb.debian.org/debian trixie contrib non-free non-free-firmware
EOF
apt-get update

echo "[UPSTREAM] Installing Lutris..."
apt-get install -y --no-install-recommends lutris || true

echo "[UPSTREAM] Adding i2pd repository..."
apt-get install -y apt-transport-https lsb-release curl gnupg || true
curl -sL https://repo.i2pd.xyz/KEY.gpg | gpg --dearmor > /usr/share/keyrings/i2pd-archive-keyring.gpg || true
echo "deb https://repo.i2pd.xyz/debian trixie main" > /etc/apt/sources.list.d/i2pd.list
apt-get update
apt-get install -y i2pd || true

echo "[UPSTREAM] Installing IPFS (Kubo)..."
wget -qO /tmp/kubo.tar.gz https://dist.ipfs.tech/kubo/v0.29.0/kubo_v0.29.0_linux-amd64.tar.gz || true
tar -xzf /tmp/kubo.tar.gz -C /tmp/
if [ -d /tmp/kubo ]; then
    cd /tmp/kubo && bash install.sh || true
fi
rm -rf /tmp/kubo*

echo "[UPSTREAM] Building Kloak from source..."
apt-get install -y build-essential git || true
cd /tmp
git clone https://github.com/vmonaco/kloak.git || true
if [ -d kloak ]; then
    cd kloak && make && make install
fi
rm -rf /tmp/kloak

echo "[UPSTREAM] Building Kalibrate-rtl from source..."
apt-get install -y autoconf libtool librtlsdr-dev || true
cd /tmp
git clone https://github.com/steve-m/kalibrate-rtl.git || true
if [ -d kalibrate-rtl ]; then
    cd kalibrate-rtl && ./bootstrap && ./configure && make && make install
fi
rm -rf /tmp/kalibrate-rtl

echo "[UPSTREAM] Installing Howdy (Facial Recognition)..."

if [ -f /usr/share/keyrings/howdy.gpg ]; then
    echo "deb http://ppa.launchpad.net/boltgolt/howdy/ubuntu jammy main" > /etc/apt/sources.list.d/howdy.list
    apt-get update
 DEBIAN_FRONTEND=noninteractive apt-get install -y howdy || true
fi

echo "[UPSTREAM] Installing Gamescope from Debian Sid..."
echo "deb http://deb.debian.org/debian sid main" > /etc/apt/sources.list.d/sid.list
cat << 'EOF' > /etc/apt/preferences.d/sid-pin
Package: *
Pin: release a=sid
Pin-Priority: 100
EOF
apt-get update
apt-get install -y -t sid gamescope || true

echo "[UPSTREAM] Installing Grafana..."
apt-get install -y apt-transport-https software-properties-common wget gnupg || true
wget -q -O - https://apt.grafana.com/gpg.key | gpg --dearmor > /usr/share/keyrings/grafana.gpg || true
echo "deb https://apt.grafana.com stable main" > /etc/apt/sources.list.d/grafana.list
apt-get update
apt-get install -y grafana || true

echo "[UPSTREAM] Installing Terraform..."
wget -q -O - https://apt.releases.hashicorp.com/gpg | gpg --dearmor > /usr/share/keyrings/hashicorp-archive-keyring.gpg || true
echo "deb https://apt.releases.hashicorp.com trixie main" > /etc/apt/sources.list.d/hashicorp.list
apt-get update
apt-get install -y terraform || true

echo "[UPSTREAM] Installing mkusb and usb-pack-efi..."

if [ -f /usr/share/keyrings/mkusb.gpg ]; then
    echo "deb http://ppa.launchpad.net/mkusb/ppa/ubuntu jammy main" > /etc/apt/sources.list.d/mkusb.list
    apt-get update
 DEBIAN_FRONTEND=noninteractive apt-get install -y mkusb mkusb-nox usb-pack-efi || true
fi

echo "[UPSTREAM] All upstream packages processed!"

# --- END MERGED CONTENT FROM: 0998-alfred-upstream-packages.hook.chroot ---


