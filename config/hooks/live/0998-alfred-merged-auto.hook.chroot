#!/bin/bash
# 0998-alfred-two-witnesses.hook.chroot
# The Two Witnesses: Multi-Party Sudo Authentication (YubiKey + PAM)
set +e

echo "[0998] Configuring The Two Witnesses (Multi-Party Sudo Auth)"

# We modify the PAM (Pluggable Authentication Modules) stack so that standard passwords
# are no longer sufficient to execute 'sudo'. Sudo will strictly require a physical U2F token
# (like a YubiKey) PRESSED simultaneously alongside the password.

# Require pam_u2f.so for sudo execution
sed -i '1i auth required pam_u2f.so cue' /etc/pam.d/sudo

# Also require it for su
sed -i '1i auth required pam_u2f.so cue' /etc/pam.d/su

# Setup a fallback warning in case users haven't enrolled their keys yet
cat << 'EOF' > /etc/profile.d/alfred-two-witnesses-warning.sh
if [ ! -f ~/.config/Yubico/u2f_keys ]; then
    echo "WARNING: The Two Witnesses protocol requires a U2F token for root access."
    echo "Please run 'pamu2fcfg > ~/.config/Yubico/u2f_keys' immediately to enroll."
fi
EOF
[ -e "+x" ] && chmod +x /etc/profile.d/alfred-two-witnesses-warning.sh

echo "[0998] The Two Witnesses are standing guard."

# --- END MERGED CONTENT FROM: 0998-alfred-two-witnesses.hook.chroot ---


