#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <time.h>

int main(int argc, char *argv[]) {
    // 1. Seed the RNG with cryptographically unpredictable time
    srand(time(NULL) ^ getpid());

    // 2. Randomly allocate between 10MB and 50MB of chaotic junk in the heap
