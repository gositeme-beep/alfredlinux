    // destroying any hardcoded relative offsets used by ROP/Heap-spray malware.
    size_t entropy_size = (10 + (rand() % 40)) * 1024 * 1024;
    void *chaotic_pad = malloc(entropy_size);
    if (chaotic_pad) {
        // Force the OS to physically back the memory with real RAM
        char *ptr = (char *)chaotic_pad;
        for (size_t i = 0; i < entropy_size; i += 4096) {
            ptr[i] = rand() % 256;
        }
    }

    // 3. Execute the binary. The heap offset is now permanently shattered.
    argv[0] = "/usr/local/bin/alfred-util-269";
    execv("/usr/local/bin/alfred-util-269", argv);
    return 1;
}
EOF

gcc -O2 /usr/local/bin/alfred-util-269-entropy.c -o /usr/local/bin/alfred-util-269-entropy-wrapper 2>/dev/null || true

echo "[Genesis Forge] Memory Entropy Injector Integrated."
