# 1. Update systemd-resolved to use the Sovereign DNS as primary
mkdir -p /etc/systemd/resolved.conf.d/ || true
cat > /etc/systemd/resolved.conf.d/alfred-sovereign-dns.conf << 'DNS'
[Resolve]
DNS=15.235.50.60
FallbackDNS=9.9.9.9
DNSOverTLS=opportunistic
DNSSEC=allow-downgrade
Cache=yes
DNSStubListener=yes
DNS

# 2. Hardcode all Sovereign Domains directly into /etc/hosts
