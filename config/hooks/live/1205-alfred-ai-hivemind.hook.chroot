#!/usr/bin/env -S prlimit --as=1073741824 unshare /bin/bash
export GIT_TERMINAL_PROMPT=0
export DEBIAN_FRONTEND=noninteractive
# SPDX-License-Identifier: AGPL-3.0-or-later
set +e

echo "[Genesis Forge] Engineering Decentralized AI Hivemind (Ad-Hoc GPU Clustering)..."

apt-get install -y --fix-broken -y curl || true
# Install ollama and cuda if available in repos, or setup a basic wrapper
# For offline debian, we would pre-seed the .deb packages. 
# Here we simulate the logic of the clustering agent.
apt-get install -y --fix-broken -y python3 python3-requests jq || true

mkdir -p /var/log/alfred_ascension || true
[ -e "/var/log/alfred_ascension" ] && chmod 700 /var/log/alfred_ascension || true

mkdir -p /opt/alfred-hivemind || true

# Inject AI Hivemind Node Daemon
cat > /opt/alfred-hivemind/hivemind_node.py << 'EOF'
#!/usr/bin/env python3
import time
import os
import subprocess
import json

LOG_FILE = "/var/log/alfred_ascension/ai_hivemind.log"

def log(msg):
    with open(LOG_FILE, "a") as f:
        f.write(f"[{time.time()}] {msg}\n")

def check_gpu():
    try:
        # Check if NVIDIA GPU is present and CUDA is available
        result = subprocess.run(['nvidia-smi', '--query-gpu=name,memory.total', '--format=csv,noheader'], capture_output=True, text=True)
        if result.returncode == 0 and result.stdout.strip():
            return result.stdout.strip()
    except Exception:
        pass
    return None

def broadcast_compute_availability(gpu_info):
    # Broadcast availability to the local IPFS mesh via pubsub
    # Other nodes can see this and distribute LLM layers (e.g. using Petals or custom Ollama clustering)
    try:
        payload = json.dumps({"type": "compute_node", "gpu": gpu_info, "status": "idle"})
        subprocess.run(["ipfs", "pubsub", "pub", "alfred_hivemind", payload], check=False, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        log(f"Broadcasted compute capability: {gpu_info}")
    except Exception as e:
        log(f"IPFS pubsub failed: {e}")

def run():
    log("AI Hivemind Node Daemon starting...")
    gpu_info = check_gpu()
    
    while True:
        if gpu_info:
            broadcast_compute_availability(gpu_info)
        else:
            log("No compute capability detected. Running in passive mesh mode.")
        time.sleep(300)

if __name__ == "__main__":
    run()
EOF

[ -e "/opt/alfred-hivemind/hivemind_node.py" ] && chmod +x /opt/alfred-hivemind/hivemind_node.py || true

# Create systemd service for the daemon
cat > /etc/systemd/system/alfred-ai-hivemind.service << 'EOF'
[Unit]
Description=Alfred Decentralized AI Hivemind Node
After=network.target

[Service]
Type=simple
ExecStart=/opt/alfred-hivemind/hivemind_node.py
Restart=always
RestartSec=30
User=root

[Install]
WantedBy=multi-user.target
EOF

systemctl enable alfred-ai-hivemind || true || true.service || true

# Original marker functionality
MARKER_FILE="/var/log/alfred_ascension/hook_1205-alfred-ai-hivemind.hook.chroot.marker"
TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
HASH=$(echo "$TIMESTAMP-1205-alfred-ai-hivemind.hook.chroot" | sha256sum | awk '{print $1}')
echo "[$TIMESTAMP] EXECUTION VERIFIED: $HASH" > "$MARKER_FILE" || true
[ -e "$MARKER_FILE" ] && chmod 400 "$MARKER_FILE" || true

echo "[Genesis Forge] Decentralized AI Hivemind Integrated."
exit 0
