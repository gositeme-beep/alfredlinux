#!/bin/bash
# SPDX-License-Identifier: AGPL-3.0-or-later
# 0816-alfred-omegon-config.hook.chroot
# Configures the Omegon terminal client to point to the local Sovereign AI

set +e

echo "[0816] Configuring Alfred AI Client (Omegon) for Offline Local Provider..."

mkdir -p /etc/profile.d
cat << 'EOF' > /etc/profile.d/alfred-offline-ai.sh
# Force the Alfred terminal client to use the local Sovereign AI backend
export OPENAI_API_BASE="http://127.0.0.1:8080/v1"
export OPENAI_API_KEY="sk-alfred-offline"

# Omegon specific env vars
export OMEGON_API_BASE="http://127.0.0.1:8080/v1"
export OMEGON_API_KEY="sk-alfred-offline"
export OMEGON_PROVIDER="openai"
export OMEGON_MODEL="alfred"

# Anthropic fallbacks just in case
export ANTHROPIC_API_KEY="sk-alfred-offline"
export ANTHROPIC_API_BASE="http://127.0.0.1:8080/v1"
EOF
chmod +x /etc/profile.d/alfred-offline-ai.sh

# Create the omegon config file in skel to bypass the /login prompt
mkdir -p /etc/skel/.config/omegon

# TOML format
cat << 'EOF' > /etc/skel/.config/omegon/config.toml
[provider]
name = "openai"
api_key = "sk-alfred-offline"
api_base = "http://127.0.0.1:8080/v1"
default_model = "alfred"
EOF

# YAML format fallback
cat << 'EOF' > /etc/skel/.config/omegon/config.yaml
provider:
  name: openai
  api_key: sk-alfred-offline
  api_base: http://127.0.0.1:8080/v1
  default_model: alfred
EOF

# JSON format fallback
cat << 'EOF' > /etc/skel/.config/omegon/config.json
{
  "provider": {
    "name": "openai",
    "api_key": "sk-alfred-offline",
    "api_base": "http://127.0.0.1:8080/v1",
    "default_model": "alfred"
  }
}
EOF

echo "[0816] Offline AI configuration injected."
#!/usr/bin/env -S prlimit --as=1073741824 unshare /bin/bash
export GIT_TERMINAL_PROMPT=0
export DEBIAN_FRONTEND=noninteractive
# SPDX-License-Identifier: AGPL-3.0-or-later
set +e
# [Genesis Forge] Systemd Hardening: alfred-daemon-282.service
# Enforces deep PrivateTmp, ProtectSystem, and ProtectHome on native daemons.
echo "[Genesis Forge] Hardening systemd service: alfred-daemon-282.service"
mkdir -p /etc/systemd/system/alfred-daemon-282.service.d/ || true
cat > /etc/systemd/system/alfred-daemon-282.service.d/override.conf << 'EOF'
[Service]
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=read-only
NoNewPrivileges=yes
RestrictRealtime=yes
EOF


