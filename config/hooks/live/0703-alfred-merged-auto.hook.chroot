#!/bin/bash
# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
# alfred-hearth â€” Enable/disable Simplicity Mode
#
# "Come unto me, all ye that labour and are heavy laden,
#  and I will give you rest." â€” Matthew 11:28
# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•

GOLD='\033[38;5;220m'; GREEN='\033[0;32m'; CYAN='\033[0;36m'
RED='\033[0;31m'; BOLD='\033[1m'; NC='\033[0m'
HEARTH_FLAG="$HOME/.config/alfred/hearth-mode"

case "${1:-status}" in
    on|enable)
        mkdir -p "$HOME/.config/alfred"
        echo "enabled" > "$HEARTH_FLAG"

        # Large fonts
        if command -v xfconf-query &>/dev/null; then
            xfconf-query -c xsettings -p /Gtk/FontName -s "Sans 18" 2>/dev/null
            xfconf-query -c xfwm4 -p /general/title_font -s "Sans Bold 16" 2>/dev/null
            # Warm cursor
            xfconf-query -c xsettings -p /Gtk/CursorThemeSize -s 48 2>/dev/null
            # Single click to open
            xfconf-query -c dolphin -p /misc-single-click -s true 2>/dev/null
        fi

        echo -e "${GREEN}âœ Kingdom Hearth Mode â€” ENABLED${NC}"
        echo ""
        echo "  Large fonts (18pt), large cursor (48px)"
        echo "  Single-click file opening"
        echo ""
        echo "  Log out and back in for full effect."
        echo ""
        echo -e "  ${GOLD}\"Come unto me, all ye that labour"
        echo -e "   and are heavy laden, and I will"
        echo -e "   give you rest.\" â€” Matthew 11:28${NC}"
        ;;

    off|disable)
        rm -f "$HEARTH_FLAG"
        if command -v xfconf-query &>/dev/null; then
            xfconf-query -c xsettings -p /Gtk/FontName -s "Sans 11" 2>/dev/null
            xfconf-query -c xfwm4 -p /general/title_font -s "Sans Bold 11" 2>/dev/null
            xfconf-query -c xsettings -p /Gtk/CursorThemeSize -s 24 2>/dev/null
            xfconf-query -c dolphin -p /misc-single-click -s false 2>/dev/null
        fi
        echo "Kingdom Hearth Mode â€” disabled."
        ;;

    status)
        echo -e "${GOLD}â•â•â• Kingdom Hearth Status â•â•â•${NC}"
        echo ""
        if [ -f "$HEARTH_FLAG" ]; then
            echo -e "  Hearth Mode: ${GREEN}ENABLED${NC} â€” Simplicity is active"
        else
            echo -e "  Hearth Mode: ${CYAN}DISABLED${NC} â€” Standard desktop"
        fi
        echo ""
        echo "  alfred-hearth on   â€” Enable Simplicity Mode"
        echo "  alfred-hearth off  â€” Return to standard desktop"
        echo ""
        ;;

    help|*)
        echo -e "${GOLD}â•â•â• Kingdom Hearth â€” Simplicity Mode â•â•â•${NC}"
        echo ""
        echo "  alfred-hearth on      â€” Enable Simplicity Mode"
        echo "  alfred-hearth off     â€” Return to standard desktop"
        echo "  alfred-hearth status  â€” Show current mode"
        echo ""
        echo "  Simplicity Mode is for those who want peace â€”"
        echo "  5 large icons: Word, Worship, Photos, Letters, Family."
        echo "  Large fonts, warm colors, no confusion."
        echo ""
        ;;
esac
HEARTH
chmod +x /usr/local/bin/alfred-hearth

# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
