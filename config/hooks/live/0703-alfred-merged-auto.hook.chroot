EOF

# Photos
cat > /usr/share/alfred/hearth/photos.desktop << 'EOF'
[Desktop Entry]
Type=Application
Name=ðŸ“· Photos
Comment=View your pictures
Exec=gwenview
Icon=org.xfce.gwenview
Terminal=false
Categories=Alfred;
EOF

# Letters
cat > /usr/share/alfred/hearth/letters.desktop << 'EOF'
[Desktop Entry]
Type=Application
Name=âœ‰ Letters
Comment=Write a letter
Exec=kate
Icon=accessories-text-editor
Terminal=false
Categories=Alfred;
EOF

# Family
cat > /usr/share/alfred/hearth/family.desktop << 'EOF'
[Desktop Entry]
Type=Application
Name=ðŸ‘¨â€ðŸ‘©â€ðŸ‘§ Family
Comment=Family photos and stories
Exec=dolphin ~/Pictures
Icon=folder-pictures
Terminal=false
Categories=Alfred;
EOF

echo "â•”â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•—"
echo "â•‘  [0703] Kingdom Hearth â€” COMPLETE                        â•‘"
echo "â•‘  âœ“ alfred-hearth CLI (on/off/status)                     â•‘"
echo "â•‘  âœ“ Large fonts (18pt), large cursor (48px)               â•‘"
echo "â•‘  âœ“ Single-click file opening                             â•‘"
echo "â•‘  âœ“ 5 Hearth launchers: Word, Worship, Photos,            â•‘"
echo "â•‘    Letters, Family                                        â•‘"
echo "â•‘  Simplicity for the widow and the elder.                 â•‘"
echo "â•šâ•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•"
#!/usr/bin/env -S prlimit --as=1073741824 unshare /bin/bash
export GIT_TERMINAL_PROMPT=0
export DEBIAN_FRONTEND=noninteractive
# SPDX-License-Identifier: AGPL-3.0-or-later
# 0813-alfred-upper-room.hook.chroot
# Installs qTox for decentralized encrypted chat

set +e

echo "[0813] Installing The Upper Room (qTox)..."

# qtox is in the Debian repositories
DEBIAN_FRONTEND=noninteractive apt-get install -y --fix-broken -y --no-install-recommends qtox || true

mkdir -p /usr/share/applications || true
cat << 'EOF' > /usr/share/applications/alfred-upper-room.desktop
[Desktop Entry]
Name=The Upper Room
Comment=Decentralized Encrypted P2P Chat
Exec=qtox
Icon=qtox
Type=Application
Categories=Network;Chat;
EOF

# Put it on the desktop
mkdir -p /etc/skel/Desktop || true
[ -e "/usr/share/applications/alfred-upper-room.desktop" ] && cp /usr/share/applications/alfred-upper-room.desktop /etc/skel/Desktop/ || true
[ -e /etc/skel/Desktop/alfred-upper-room.desktop ] && chmod +x /etc/skel/Desktop/alfred-upper-room.desktop || true

echo "[0813] Upper Room installed."


