cat > /usr/local/bin/alfred-welcome-card.sh << 'EOF'
#!/bin/bash
set +e
CARD="/usr/share/alfred/welcome/kingdom-welcome.html"
ICON="/usr/share/alfred/welcome/al-2.png"
[ -f "$CARD" ] && command -v xdg-open >/dev/null 2>&1 && xdg-open "$CARD" >/dev/null 2>&1 &
if command -v zenity >/dev/null 2>&1 && [ -n "${DISPLAY:-}" ]; then
  if zenity --question --title="Welcome to the Kingdom of God Edition" --window-icon="$ICON" --width=640 --ok-label="Open Bible" --cancel-label="Open Worship" --text="Choose your first action. #2 AL is set as default wallpaper."; then
    command -v alfred-bible >/dev/null 2>&1 && alfred-bible >/dev/null 2>&1 &
  else
    command -v alfred-worship >/dev/null 2>&1 && alfred-worship >/dev/null 2>&1 &
  fi
fi
EOF
chmod 0755 /usr/local/bin/alfred-welcome-card.sh

# 4) First boot runner
echo "[WELCOME-02] Installing first-boot welcome..."
cat > /usr/local/bin/alfred-first-boot.sh << 'EOF'
