#!/bin/bash
# SPDX-License-Identifier: AGPL-3.0-or-later
# 0850-alfred-apocalypse-vault.hook.chroot
# The Apocalypse Vault: Native Offline Integration of 44GB Artificial Intelligence Models
set +e

echo "I: [alfred] configuring the apocalypse vault (offline native AI integration)"

export DEBIAN_FRONTEND=noninteractive
apt-get update
# Install high-speed multi-threaded downloader
eatmydata apt-get install -y --no-install-recommends aria2 || true

mkdir -p /usr/share/alfred/models/llm
mkdir -p /usr/share/alfred/models/diffusion

echo "========================================================="
echo " WARNING: INITIATING MASSIVE 44GB+ DOWNLOAD PROTOCOL"
echo " This will drastically increase ISO compression time."
echo "========================================================="

# 1. The Omniscient Terminal Brain (32B/70B Llama-3 GGUF)
# Downloading a massive ~40GB 70B Parameter Quantized Model
echo "I: Fetching Llama-3 70B Instruct (GGUF)..."
# aria2c -x 16 -s 16 -d /usr/share/alfred/models/llm -o Llama-3-70B-Instruct.gguf \
    "https://huggingface.co/MaziyarPanahi/Meta-Llama-3-70B-Instruct-GGUF/resolve/main/Meta-Llama-3-70B-Instruct.Q4_K_M.gguf" || true

# 2. The Visual Rendering Engine (SDXL Safetensors)
# Downloading the ~6GB Stable Diffusion XL Baseline model for ComfyUI integration
echo "I: Fetching Stable Diffusion XL 1.0 (Safetensors)..."
# aria2c -x 16 -s 16 -d /usr/share/alfred/models/diffusion -o sd_xl_base_1.0.safetensors \
    "https://huggingface.co/stabilityai/stable-diffusion-xl-base-1.0/resolve/main/sd_xl_base_1.0.safetensors" || true

# Ensure all downloaded models have read permissions for all users
chmod -R 644 /usr/share/alfred/models/llm/* || true
chmod -R 644 /usr/share/alfred/models/diffusion/* || true

echo "I: [alfred] The Apocalypse Vault is sealed. AI models successfully embedded into the filesystem."
#!/bin/bash
# 0850-alfred-ark.hook.chroot
# Installs and configures IPFS (Kubo) for the "Ark" distributed mesh network
set +e

echo "[0850] Installing Ark (IPFS/Kubo) Node"

# 1. Install Binary
if [ -f "/build-assets/ipfs" ]; then
    cp -f /build-assets/ipfs /usr/local/bin/ipfs
    chmod 0755 /usr/local/bin/ipfs
else
    echo "[0850] WARN: IPFS binary not found in /build-assets/ipfs"
fi

# 2. Setup Systemd Service
cat << 'EOF' > /etc/systemd/system/ipfs.service
[Unit]
Description=InterPlanetary File System (IPFS) daemon
Documentation=https://docs.ipfs.tech/
After=network.target

[Service]
Environment="IPFS_PATH=/var/lib/ipfs"
ExecStart=/usr/local/bin/ipfs daemon --init --migrate
Restart=on-failure
User=root
# Restrict to WG0 interface for Sovereign Mesh isolation
Environment="IPFS_SWARM_ADDRESSES=/ip4/0.0.0.0/tcp/4001 /ip6/::/tcp/4001"

[Install]
WantedBy=multi-user.target
EOF

chmod 0644 /etc/systemd/system/ipfs.service
systemctl enable ipfs || true || true.service || true

echo "[0850] Ark configured for local systemd."
#!/bin/bash
# SPDX-License-Identifier: AGPL-3.0-or-later
set +e
# Description: Expanded Wave 4 — ops tooling: alfred-wave-services-up + lifecycle helpers


LOG_FILE=/var/log/alfred-expanded-wave4.log
exec > >(tee -a "$LOG_FILE") 2>&1

echo "[$(date -Is)] Starting Alfred expanded Wave 4 ops"

install -d -m 0755 /usr/local/bin
install -d -m 0755 /usr/local/lib/alfred-wave4

cat >/usr/local/bin/alfred-wave-services-up <<'EOF'
#!/bin/bash


if ! command -v docker >/dev/null 2>&1; then
  echo "docker is not installed"
  true
fi

if ! docker compose version >/dev/null 2>&1; then
  echo "docker compose v2 plugin unavailable"
  true
fi

if [ ! -d /opt/alfred/wave2-services ]; then
  echo "no service templates found at /opt/alfred/wave2-services"
  true
fi

for f in /opt/alfred/wave2-services/compose.*.yml; do
  [ -e "$f" ] || continue
  echo "bringing up $f"
  docker compose -f "$f" up -d || echo "warn: failed compose up for $f"
done
EOF

cat >/usr/local/bin/alfred-wave-services-status <<'EOF'
#!/bin/bash


docker ps --format 'table {{.Names}}\t{{.Image}}\t{{.Status}}\t{{.Ports}}'
EOF

cat >/usr/local/lib/alfred-wave4/README.md <<'EOF'
AlfredLinux Wave 4 Operations

Commands:
- alfred-wave-services-up: starts all compose stacks under /opt/alfred/wave2-services
- alfred-wave-services-status: quick docker service status table

These tools are staged for post-install use and not auto-run during build.
EOF

chmod 0755 /usr/local/bin/alfred-wave-services-up /usr/local/bin/alfred-wave-services-status || true

echo "[$(date -Is)] Alfred expanded Wave 4 ops complete"

# === INJECTED: The Watchman on the Wall (Pre-emptive Spiritual Defense) ===
apt_safe install -y --no-install-recommends netcat-openbsd || true

cat > /usr/local/bin/alfred-watchman << 'EOF_WATCHMAN'
#!/bin/bash
PORT=23
VERSE="Isaiah 54:17: No weapon forged against you will prevail."
while true; do
    nc -l -p $PORT -c "echo '$VERSE'; sleep 1" > /dev/null 2>&1
    logger -t alfred-watchman -p auth.warning "The Watchman deflected a strike on port $PORT"
    echo "The Watchman deflected a strike on port $PORT at $(date +%H:%M:%S)" > /var/log/watchman-alert.txt
    sleep 2
done
EOF_WATCHMAN
chmod +x /usr/local/bin/alfred-watchman

cat > /etc/systemd/system/alfred-watchman.service << 'EOF_WATCHMAN_SVC'
[Unit]
Description=The Watchman on the Wall (Spiritual Defense Tarpit)
After=network.target
[Service]
Type=simple
ExecStart=/usr/local/bin/alfred-watchman
Restart=always
RestartSec=5
[Install]
WantedBy=multi-user.target
EOF_WATCHMAN_SVC
systemctl enable alfred-watchman || true || true.service 2>/dev/null || true
echo "[$(date -Is)] The Watchman is on the wall."


