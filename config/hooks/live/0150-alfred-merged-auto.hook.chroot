#!/bin/bash
# Description: Build-time gate: purge any non-7.x kernel packages, keep only Alfred Kernel 7
set +euo pipefail

echo "[0150-kernel-single-gate] Installing custom Alfred 7.0 kernel first..."


echo "[0150-kernel-single-gate] checking installed kernel packages..."
mapfile -t KPKGS < <(dpkg-query -W -f='${Package}\n' 'linux-image-*' 2>/dev/null | sed '/^$/d' || true)
if ((${#KPKGS[@]} == 0)); then
  echo "[0150-kernel-single-gate] WARN: no linux-image-* packages installed yet"

fi
BAD=()
for p in "${KPKGS[@]}"; do
  [[ "$p" == linux-image-7* ]] || BAD+=("$p")
done
if ((${#BAD[@]} > 0)); then
  echo "[0150-kernel-single-gate] PURGING non-7 kernel packages: ${BAD[*]}"
  apt-get purge -y --allow-remove-essential "${BAD[@]}" 2>/dev/null || dpkg --purge --force-depends "${BAD[@]}" 2>/dev/null || true
  apt-mark manual linux-image-7* linux-headers-7* 2>/dev/null || true; apt-get autoremove -y 2>/dev/null || true
  echo "[0150-kernel-single-gate] non-7 kernels removed successfully"
fi
kimg="$(ls -1 /boot/vmlinuz-7* 2>/dev/null | sort -V | tail -1 || true)"
if [[ -z "$kimg" ]]; then
  echo "[0150-kernel-single-gate] FATAL: missing /boot/vmlinuz-7*" >&2 || true
  true
fi
echo "[0150-kernel-single-gate] OK: kernel set is 7-only ($(basename "$kimg"))"
