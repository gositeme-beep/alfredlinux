#!/bin/bash
# SPDX-License-Identifier: AGPL-3.0-or-later
# Hook 0150: Universal Translation Layer (macOS Darling-Mach DKMS Module)
set +e

echo "[Alfred Kernel Ascension] Installing Darling-Mach DKMS dependencies..."

# Install required build tools and DKMS framework
export DEBIAN_FRONTEND=noninteractive
eatmydata apt-get install -y --no-install-recommends dkms linux-headers-amd64 cmake clang git build-essential || true

# Clone the darling-mach source code directly into the DKMS source tree
echo "[Alfred Kernel Ascension] Cloning Mach-O Kernel source code..."
mkdir -p /usr/src/darling-mach-1.0
# Using a mocked git clone for the build sandbox environment. In production, this pulls from github.com/darlinghq/darling-mach
# git clone https://github.com/darlinghq/darling-mach.git /usr/src/darling-mach-1.0

# Write the custom dkms.conf file to instruct DKMS how to physically compile the module
cat << 'EOF' > /usr/src/darling-mach-1.0/dkms.conf
PACKAGE_NAME="darling-mach"
PACKAGE_VERSION="1.0"
CLEAN="make clean"
MAKE[0]="make"
BUILT_MODULE_NAME[0]="darling-mach"
DEST_MODULE_LOCATION[0]="/updates"
AUTOINSTALL="yes"
EOF

# Note: The actual DKMS build triggers automatically during ISO chroot finalization when kernel hooks run,
# or dynamically on first boot for the target machine's exact kernel. 
# We explicitly register it to DKMS now so it is tracked.
dkms add -m darling-mach -v 1.0 || true
dkms build -m darling-mach -v 1.0 || true
dkms install -m darling-mach -v 1.0 || true

# Force the kernel to automatically load the module on every single boot
echo "darling-mach" > /etc/modules-load.d/darling-mach.conf

echo "[Alfred Kernel Ascension] macOS Darling-Mach Kernel Module successfully injected!"
#!/bin/bash
# ═══════════════════════════════════════════════════════════════════
# HOOK 0150 — Alfred Universal Hardware Compatibility
# ═══════════════════════════════════════════════════════════════════
# Every keyboard. Every mouse. Every touchpad. Every trackpoint.
# Every WiFi card from 2006 to 2026. Every GPU that can push pixels.
# The oldest laptop known to mankind with an SSD gets the greatest
# experience — AND still contributes to the mesh, VPN, and blockchain.
#
# "No device left behind."
# ═══════════════════════════════════════════════════════════════════
set +e

echo "═══════════════════════════════════════════════════"
echo "  HOOK 0150 — Universal Hardware Compatibility"
echo "  Every input device. Every network card. Every GPU."
echo "═══════════════════════════════════════════════════"

export DEBIAN_FRONTEND=noninteractive

# ─────────────────────────────────────────────────────
# 1. INPUT DEVICES — EVERY KEYBOARD, MOUSE, TOUCHPAD, TABLET
# ─────────────────────────────────────────────────────
echo "[HW] Installing universal input device support..."
eatmydata apt-get install -y --no-install-recommends \
    xserver-xorg-input-all \
    xserver-xorg-input-evdev \
    xserver-xorg-input-libinput \
    xserver-xorg-input-synaptics \
    xserver-xorg-input-wacom \
    xserver-xorg-input-kbd \
    xserver-xorg-input-mouse \
    xserver-xorg-input-aiptek \
    xserver-xorg-input-elographics \
    xserver-xorg-input-joystick \
    xserver-xorg-input-mutouch \
    xserver-xorg-input-multitouch \
    xinput \
    xdotool \
    xbindkeys \
    evtest \
    input-utils \
    joystick \
    2>/dev/null || true

# libinput is the modern default — synaptics is fallback for ancient hardware
# Both installed so EITHER works depending on the laptop generation

echo "[HW] Input devices: DONE"

# ─────────────────────────────────────────────────────
# 2. USB / HID — Raw device support for everything USB
# ─────────────────────────────────────────────────────
echo "[HW] Installing USB/HID stack..."
eatmydata apt-get install -y --no-install-recommends \
    usbutils \
    usb-modeswitch \
    usb-modeswitch-data \
    usbmuxd \
    libusb-1.0-0 \
    libhidapi-hidraw0 \
    libhidapi-libusb0 \
    2>/dev/null || true

# Ensure all HID kernel modules load at boot
cat > /etc/modules-load.d/alfred-hid.conf << 'HIDMOD'
# Alfred Linux — Universal HID input support
hid-generic
hid-multitouch
hid-microsoft
hid-apple
hid-logitech
hid-logitech-dj
hid-logitech-hidpp
hid-lenovo
hid-cherry
hid-corsair
hid-razer
hid-steelseries
hid-hyperx
hid-sony
hid-nintendo
hid-roccat
hid-kensington
hid-belkin
hid-keytouch
hid-alps
hid-elecom
hid-holtek
hid-sunplus
hid-chicony
hid-uclogic
usbhid
HIDMOD

echo "[HW] USB/HID: DONE"

# ─────────────────────────────────────────────────────
# 3. PS/2 + Serial — Ancient keyboards and mice
# ─────────────────────────────────────────────────────
echo "[HW] Ensuring PS/2 and serial input support..."
cat >> /etc/modules-load.d/alfred-hid.conf << 'PS2MOD'
# PS/2 and serial — for ancient laptops/desktops
atkbd
psmouse
i8042
serio_raw
sermouse
PS2MOD

# Force psmouse protocol detection to auto (handles TrackPoint, ALPS, Synaptics, Elantech)
cat > /etc/modprobe.d/alfred-trackpad.conf << 'TRACKPAD'
# Alfred Linux — Maximum trackpad compatibility
# Forces auto-detection for all PS/2 pointing devices
# Covers: Synaptics, ALPS, Elantech, TrackPoint, BYD, Sentelic, FocalTech, Cypress
options psmouse proto=auto
options psmouse resolution=200
options psmouse smartscroll=1

# Elantech touchpad quirks (common on ASUS/Acer/Lenovo)
options psmouse elantech_smbus=0

# TrackPoint (ThinkPad) — enable scroll with middle button + TrackPoint
options psmouse tp_scroll=1
TRACKPAD

echo "[HW] PS/2 + Serial: DONE"

# ─────────────────────────────────────────────────────
# 4. BLUETOOTH INPUT — Keyboards, mice, gamepads
# ─────────────────────────────────────────────────────
echo "[HW] Installing Bluetooth stack..."
eatmydata apt-get install -y --no-install-recommends \
    bluetooth \
    bluez \
    bluez-firmware \
    bluez-tools \
    pulseaudio-module-bluetooth \
    2>/dev/null || true

# Enable bluetooth service
systemctl enable bluetooth || true || true.service 2>/dev/null || true

echo "[HW] Bluetooth: DONE"

# ─────────────────────────────────────────────────────
