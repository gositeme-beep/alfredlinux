#!/bin/bash
# ═══════════════════════════════════════════════════════════════
# 0250-alfred-ai.hook.chroot — "Omahon: The Breath of God"
# ═══════════════════════════════════════════════════════════════
# Alfred Linux is the ONLY operating system on Earth that ships
# with a native AI agent harness, local LLM inference, and
# sovereign intelligence — offline, private, yours.
#
# "And the LORD God formed man of the dust of the ground,
#  and breathed into his nostrils the breath of life;
#  and man became a living soul." — Genesis 2:7
#
# Omahon = the breath. Alfred Linux = the living soul.
#
# Primary path: latest Omahon + Ollama on 127.0.0.1 (GPU when present — hook 0275).
# Default runtime needs no API keys. We still ship optional Python SDKs
# (anthropic, openai, groq, together) as BACKUP for operators who wire Omahon or
# scripts to cloud only when local inference is unavailable — never required.
# Offline-capable when weights/binaries are pre-staged in build-assets.
# One with the Lord — His breath first; silicon serves the household.
# ═══════════════════════════════════════════════════════════════
set -e

echo "═══════════════════════════════════════════════════════"
echo "  ALFRED AI AGENT LAYER — Omahon: The Breath of God"
echo "═══════════════════════════════════════════════════════"

# ── 1. Ollama — Local LLM Inference Engine ──
# Every other OS requires cloud AI. Alfred thinks locally.
echo "[AI] Installing Ollama (local LLM inference)..."
# MILITARY: Pre-staged binary preferred (air-gap safe), network fallback for dev builds
OLLAMA_VERSION="0.21.2"
if [ -f /build-assets/ollama ]; then
    echo "[AI] Using pre-staged Ollama binary (air-gap safe)"
    install -m 755 /build-assets/ollama /usr/local/bin/ollama
elif [ -f /build-assets/ollama-linux-amd64 ]; then
    install -m 755 /build-assets/ollama-linux-amd64 /usr/local/bin/ollama
else
    echo "[AI] No pre-staged binary — downloading Ollama ${OLLAMA_VERSION}..."
    wget -qO /tmp/ollama "https://github.com/ollama/ollama/releases/download/v${OLLAMA_VERSION}/ollama-linux-amd64" \
        && install -m 755 /tmp/ollama /usr/local/bin/ollama \
        && rm -f /tmp/ollama \
        || echo "[AI] WARNING: Ollama install failed — will need manual install"
fi

# Create ollama systemd service (starts on demand, not at boot)
cat > /etc/systemd/system/ollama.service << 'OLLAMA_SVC'
[Unit]
Description=Ollama Local LLM Service
After=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/ollama serve
Restart=on-failure
RestartSec=3
Environment="OLLAMA_HOST=127.0.0.1:11434"
Environment="OLLAMA_MODELS=/usr/share/ollama/models"

[Install]
WantedBy=multi-user.target
OLLAMA_SVC

mkdir -p /usr/share/ollama/models
systemctl enable ollama.service 2>/dev/null || true

# ── 2. Omahon — Sovereign AI Agent Harness ──
# 19MB single binary. Zero dependencies. Full autonomy.
# Native Rust. 10 inference providers. Persistent memory.
# Parallel task execution. Knowledge graph. Design tree.
# NO OTHER OPERATING SYSTEM SHIPS THIS.
echo "[AI] Installing Omahon AI Agent Harness..."
if [ -f /build-assets/omahon ]; then
    install -m 755 /build-assets/omahon /usr/local/bin/omahon
    echo "[AI] Omahon installed from build-assets"
else
    echo "[AI] WARNING: Omahon binary not found in build-assets — will need manual install"
fi

# Omahon default config for all users
mkdir -p /etc/skel/.config/omahon
cat > /etc/skel/.config/omahon/config.toml << 'OMAHON_CFG'
# Omahon — Alfred Linux default configuration
# The sovereign AI agent lives here.

[providers]
default = "ollama"

[providers.ollama]
base_url = "http://localhost:11434"
model = "phi3:mini"

# Optional cloud BACKUP — keys live in ~/.config/alfred/ai-providers.env (see
# /usr/share/alfred/ai-providers.env.example). Uncomment when your Omahon build
# exposes matching provider blocks (OpenAI-compatible URLs below).
# [providers.anthropic]
# model = "claude-sonnet-4-20250514"
# [providers.openai]          # base_url = "https://api.openai.com/v1"     OPENAI_API_KEY
# [providers.together]      # base_url = "https://api.together.xyz/v1"   TOGETHER_API_KEY
# [providers.groq]          # base_url = "https://api.groq.com/openai/v1" GROQ_API_KEY
# [providers.xai_grok]      # base_url = "https://api.x.ai/v1"           XAI_API_KEY

[memory]
enabled = true
path = "~/.local/share/omahon/memory.db"
auto_compact = true

[behavior]
auto_tier = true
think_level = "medium"

[ui]
theme = "dark"
OMAHON_CFG

# ── 3. Alfred Agent CLI — Smart AI Router ──
# One command. It figures out what's available and uses it.
echo "[AI] Creating alfred-ai command..."
cat > /usr/local/bin/alfred-ai << 'ALFRED_AI'
#!/bin/bash
# ═══════════════════════════════════════════════
# alfred-ai — The sovereign intelligence gateway
# ═══════════════════════════════════════════════
# Routes: 1) Omahon  2) Ollama  3) optional Claude if ANTHROPIC_API_KEY
# Optional keys for OpenAI, Together.ai, Groq, xAI Grok: ~/.config/alfred/ai-providers.env
# Run: alfred-ai keys   (shows template; copy, chmod 600, uncomment exports you need)

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
GOLD='\033[0;33m'
NC='\033[0m'

SECRETS="${HOME}/.config/alfred/ai-providers.env"
if [[ -f "$SECRETS" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "$SECRETS"
    set +a
fi

if [[ "${1:-}" == "keys" || "${1:-}" == "--keys" ]]; then
    echo -e "${GOLD}═══ Optional cloud API keys (backup / enrichment) ═══${NC}"
    echo ""
    echo "  Primary path stays Omahon + Ollama on this machine."
    echo "  Copy the template, restrict permissions, then uncomment only the providers you trust:"
    echo ""
    echo "    mkdir -p ~/.config/alfred"
    echo "    cp /usr/share/alfred/ai-providers.env.example ~/.config/alfred/ai-providers.env"
    echo "    chmod 600 ~/.config/alfred/ai-providers.env"
    echo "    \$EDITOR ~/.config/alfred/ai-providers.env"
    echo ""
    echo -e "${CYAN}── Template (${GOLD}/usr/share/alfred/ai-providers.env.example${CYAN}) ──${NC}"
    cat /usr/share/alfred/ai-providers.env.example 2>/dev/null || echo "(template missing)"
    echo ""
    exit 0
fi

# Start ollama if not running
if command -v ollama &>/dev/null && ! pgrep -x ollama &>/dev/null; then
    echo -e "${CYAN}Starting Ollama in background...${NC}"
    nohup ollama serve &>/dev/null &
    sleep 2
fi

if [ "$1" = "--status" ] || [ "$1" = "status" ]; then
    echo -e "${GOLD}═══ Alfred AI Status ═══${NC}"
    echo -n "Omahon:     " && (command -v omahon &>/dev/null && echo -e "${GREEN}INSTALLED${NC}" || echo -e "${RED}NOT FOUND${NC}")
    echo -n "Ollama:     " && (pgrep -x ollama &>/dev/null && echo -e "${GREEN}RUNNING${NC}" || echo -e "${RED}STOPPED${NC}")
    echo -e "${CYAN}Primary:${NC}   Omahon + Ollama (local, no keys required)"
    echo -e "${CYAN}Backup:${NC}    Claude CLI if installed + ANTHROPIC_API_KEY set"
    echo -n "Secrets file: " && { [[ -f "${HOME}/.config/alfred/ai-providers.env" ]] && echo -e "${GREEN}~/.config/alfred/ai-providers.env${NC}" || echo -e "${CYAN}none — run: alfred-ai keys${NC}"; }
    echo -n "ANTHROPIC:  " && ([ -n "${ANTHROPIC_API_KEY:-}" ] && echo -e "${GREEN}set${NC}" || echo -e "${CYAN}unset${NC}")
    echo -n "OPENAI:     " && ([ -n "${OPENAI_API_KEY:-}" ] && echo -e "${GREEN}set${NC}" || echo -e "${CYAN}unset${NC}")
    echo -n "TOGETHER:   " && ([ -n "${TOGETHER_API_KEY:-}" ] && echo -e "${GREEN}set${NC}" || echo -e "${CYAN}unset${NC}")
    echo -n "GROQ:       " && ([ -n "${GROQ_API_KEY:-}" ] && echo -e "${GREEN}set${NC}" || echo -e "${CYAN}unset${NC}")
    echo -n "XAI (Grok): " && ([ -n "${XAI_API_KEY:-}" ] && echo -e "${GREEN}set${NC}" || echo -e "${CYAN}unset${NC}")
    echo -n "pip SDKs:   " && (python3 -c "import anthropic, openai, groq, together" 2>/dev/null && echo -e "${GREEN}anthropic+openai+groq+together${NC}" || echo -e "${CYAN}partial/missing${NC}")
    echo ""
    echo -n "Models:     " && (ollama list 2>/dev/null | tail -n +2 | wc -l || echo "0") && echo " installed"
    echo -e "${GOLD}════════════════════════${NC}"
    exit 0
fi

if [ "$1" = "--pull" ] || [ "$1" = "pull" ]; then
    echo -e "${CYAN}Pulling recommended model (phi3:mini — 2.3GB)...${NC}"
    ollama pull phi3:mini
    exit $?
fi

if command -v omahon &>/dev/null; then
    exec omahon "$@"
elif command -v ollama &>/dev/null; then
    echo -e "${CYAN}Omahon not installed. Using Ollama directly.${NC}"
    echo -e "${CYAN}For the full agent experience: sudo apt install omahon${NC}"
    if [ -n "$1" ]; then
        exec ollama run phi3:mini "$*"
    else
        exec ollama run phi3:mini
    fi
elif command -v claude &>/dev/null && [ -n "${ANTHROPIC_API_KEY:-}" ]; then
    echo -e "${CYAN}Using optional Claude backup (cloud).${NC}"
    exec claude "$@"
else
    echo -e "${RED}No local AI tools available (Omahon + Ollama).${NC}"
    echo ""
    echo "Sovereign setup:"
    echo "  • Pre-stage /build-assets/omahon and ollama in the live-build tree, or"
    echo "  • Run alfred-ai pull once when you have connectivity to fetch phi3:mini, or"
    echo "  • Copy Ollama model blobs into /usr/share/ollama/models from removable media."
    echo ""
    echo "Optional backup: anthropic / openai / groq / together pip modules on disk."
    echo "Cloud keys (OpenAI, Together, Groq, xAI Grok, Anthropic):  alfred-ai keys"
    echo ""
    exit 1
fi
ALFRED_AI
chmod +x /usr/local/bin/alfred-ai

# ── 4. Optional cloud BACKUP libraries (pip) — primary remains Omahon+Ollama
echo "[AI] Installing optional backup AI SDKs (anthropic, openai, groq, together)..."
pip3 install --break-system-packages --no-cache-dir \
    anthropic \
    openai \
    groq \
    together \
    2>/dev/null || true

echo "[AI] Installing API key template for optional cloud providers..."
install -d -m 0755 /usr/share/alfred /etc/skel/.config/alfred
cat > /usr/share/alfred/ai-providers.env.example << 'AIENVEX'
# Alfred Linux — optional cloud API keys (enrichment / backup paths only).
# Primary intelligence: Omahon + Ollama on this machine (no keys required).
#
# Stewardship: treat keys like household keys — needful for honest work,
# never the master of the home (Matthew 6:24; Proverbs 3:5–6). Do not commit
# secrets to git; never paste keys into untrusted chat.
#
# 1) mkdir -p ~/.config/alfred
# 2) cp this file to ~/.config/alfred/ai-providers.env
# 3) chmod 600 ~/.config/alfred/ai-providers.env
# 4) Uncomment only the exports you use. alfred-ai loads that file automatically.

# --- Anthropic (Claude) — also used by alfred-ai fallback when local tools absent ---
#export ANTHROPIC_API_KEY=

# --- OpenAI (ChatGPT / API) ---
#export OPENAI_API_KEY=

# --- Together.ai (OpenAI-compatible: https://api.together.xyz/v1 ) ---
#export TOGETHER_API_KEY=

# --- GroqCloud (fast inference; OpenAI-compatible: https://api.groq.com/openai/v1 ) ---
#export GROQ_API_KEY=

# --- xAI Grok (see https://docs.x.ai for current env names; often XAI_API_KEY) ---
#export XAI_API_KEY=
AIENVEX
install -m 0644 /usr/share/alfred/ai-providers.env.example /etc/skel/.config/alfred/ai-providers.env.example

# ── 5. Desktop Integration ──
echo "[AI] Creating desktop entries..."
cat > /usr/share/applications/alfred-ai.desktop << 'DESK'
[Desktop Entry]
Name=Talk To Your Omputer
GenericName=Sovereign AI Agent
Comment=Talk to your computer — Omahon + Ollama; local first, no cloud keys required :)
Exec=xfce4-terminal -e "alfred-ai"
Icon=applications-science
Terminal=false
Type=Application
Categories=Development;Science;AI;
Keywords=ai;agent;llm;omahon;ollama;omputer;talk;local;sovereign;offline;
DESK

cat > /usr/share/applications/ollama.desktop << 'DESK2'
[Desktop Entry]
Name=Ollama
Comment=Local LLM inference — offline AI
Exec=xfce4-terminal -e "ollama run phi3:mini"
Icon=applications-science
Terminal=false
Type=Application
Categories=Development;Science;AI;
DESK2

# ── 6. First-boot AI setup hint ──
mkdir -p /etc/skel/.config/autostart
cat > /etc/skel/.config/autostart/alfred-ai-hint.desktop << 'HINT'
[Desktop Entry]
Type=Application
Name=Alfred AI Setup
Exec=bash -c 'if [ ! -f ~/.alfred-ai-setup-done ]; then notify-send "Talk To Your Omputer" "alfred-ai → Omahon + Ollama on your machine. No cloud keys to start. Optional keys: alfred-ai keys" -i applications-science; touch ~/.alfred-ai-setup-done; fi'
Hidden=false
NoDisplay=true
X-GNOME-Autostart-enabled=true
HINT

echo "═══════════════════════════════════════════════════════"
echo "  AI LAYER COMPLETE — The breath is in the machine"
echo "═══════════════════════════════════════════════════════"
