#!/bin/bash
# ═══════════════════════════════════════════════════════════════
# 0250-alfred-ai.hook.chroot — "Omahon: The Breath of God"
# ═══════════════════════════════════════════════════════════════
# Alfred Linux is the ONLY operating system on Earth that ships
# with a native AI agent harness, local LLM inference, and
# sovereign intelligence — offline, private, yours.
#
# "And the LORD God formed man of the dust of the ground,
#  and breathed into his nostrils the breath of life;
#  and man became a living soul." — Genesis 2:7
#
# Omahon = the breath. Alfred Linux = the living soul.
#
# Sovereign profile: no cloud inference, no third-party API keys — only
# Omahon + Ollama on 127.0.0.1. Models and memory evolve on your machine
# (local GPU when present — see hook 0275). Offline-capable once weights
# are present; air-gap friendly when binaries are pre-staged in build-assets.
# One with the Lord — His breath first; silicon serves the household.
# ═══════════════════════════════════════════════════════════════
set -e

echo "═══════════════════════════════════════════════════════"
echo "  ALFRED AI AGENT LAYER — Omahon: The Breath of God"
echo "═══════════════════════════════════════════════════════"

# ── 1. Ollama — Local LLM Inference Engine ──
# Every other OS requires cloud AI. Alfred thinks locally.
echo "[AI] Installing Ollama (local LLM inference)..."
# MILITARY: Pre-staged binary preferred (air-gap safe), network fallback for dev builds
OLLAMA_VERSION="0.6.2"
if [ -f /build-assets/ollama ]; then
    echo "[AI] Using pre-staged Ollama binary (air-gap safe)"
    install -m 755 /build-assets/ollama /usr/local/bin/ollama
elif [ -f /build-assets/ollama-linux-amd64 ]; then
    install -m 755 /build-assets/ollama-linux-amd64 /usr/local/bin/ollama
else
    echo "[AI] No pre-staged binary — downloading Ollama ${OLLAMA_VERSION}..."
    wget -qO /tmp/ollama "https://github.com/ollama/ollama/releases/download/v${OLLAMA_VERSION}/ollama-linux-amd64" \
        && install -m 755 /tmp/ollama /usr/local/bin/ollama \
        && rm -f /tmp/ollama \
        || echo "[AI] WARNING: Ollama install failed — will need manual install"
fi

# Create ollama systemd service (starts on demand, not at boot)
cat > /etc/systemd/system/ollama.service << 'OLLAMA_SVC'
[Unit]
Description=Ollama Local LLM Service
After=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/ollama serve
Restart=on-failure
RestartSec=3
Environment="OLLAMA_HOST=127.0.0.1:11434"
Environment="OLLAMA_MODELS=/usr/share/ollama/models"

[Install]
WantedBy=multi-user.target
OLLAMA_SVC

mkdir -p /usr/share/ollama/models
systemctl enable ollama.service 2>/dev/null || true

# ── 2. Omahon — Sovereign AI Agent Harness ──
# 19MB single binary. Zero dependencies. Full autonomy.
# Native Rust. 10 inference providers. Persistent memory.
# Parallel task execution. Knowledge graph. Design tree.
# NO OTHER OPERATING SYSTEM SHIPS THIS.
echo "[AI] Installing Omahon AI Agent Harness..."
if [ -f /build-assets/omahon ]; then
    install -m 755 /build-assets/omahon /usr/local/bin/omahon
    echo "[AI] Omahon installed from build-assets"
else
    echo "[AI] WARNING: Omahon binary not found in build-assets — will need manual install"
fi

# Omahon default config for all users
mkdir -p /etc/skel/.config/omahon
cat > /etc/skel/.config/omahon/config.toml << 'OMAHON_CFG'
# Omahon — Alfred Linux default configuration
# The sovereign AI agent lives here.

[providers]
default = "ollama"

[providers.ollama]
base_url = "http://localhost:11434"
model = "phi3:mini"

[memory]
enabled = true
path = "~/.local/share/omahon/memory.db"
auto_compact = true

[behavior]
auto_tier = true
think_level = "medium"

[ui]
theme = "dark"
OMAHON_CFG

# ── 3. Alfred Agent CLI — Smart AI Router ──
# One command. It figures out what's available and uses it.
echo "[AI] Creating alfred-ai command..."
cat > /usr/local/bin/alfred-ai << 'ALFRED_AI'
#!/bin/bash
# ═══════════════════════════════════════════════
# alfred-ai — The sovereign intelligence gateway
# ═══════════════════════════════════════════════
# Routes to local sovereign AI only:
#   1. Omahon (local agent harness — preferred)
#   2. Ollama direct (127.0.0.1 — if Omahon absent)
#   3. Helpful error (pull a model, pre-stage binaries, or use air-gapped media)

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
GOLD='\033[0;33m'
NC='\033[0m'

# Start ollama if not running
if command -v ollama &>/dev/null && ! pgrep -x ollama &>/dev/null; then
    echo -e "${CYAN}Starting Ollama in background...${NC}"
    nohup ollama serve &>/dev/null &
    sleep 2
fi

if [ "$1" = "--status" ] || [ "$1" = "status" ]; then
    echo -e "${GOLD}═══ Alfred AI Status ═══${NC}"
    echo -n "Omahon:     " && (command -v omahon &>/dev/null && echo -e "${GREEN}INSTALLED${NC}" || echo -e "${RED}NOT FOUND${NC}")
    echo -n "Ollama:     " && (pgrep -x ollama &>/dev/null && echo -e "${GREEN}RUNNING${NC}" || echo -e "${RED}STOPPED${NC}")
    echo -e "${CYAN}Profile:${NC}    sovereign-local (no cloud API keys in default path)"
    echo ""
    echo -n "Models:     " && (ollama list 2>/dev/null | tail -n +2 | wc -l || echo "0") && echo " installed"
    echo -e "${GOLD}════════════════════════${NC}"
    exit 0
fi

if [ "$1" = "--pull" ] || [ "$1" = "pull" ]; then
    echo -e "${CYAN}Pulling recommended model (phi3:mini — 2.3GB)...${NC}"
    ollama pull phi3:mini
    exit $?
fi

if command -v omahon &>/dev/null; then
    exec omahon "$@"
elif command -v ollama &>/dev/null; then
    echo -e "${CYAN}Omahon not installed. Using Ollama directly.${NC}"
    echo -e "${CYAN}For the full agent experience: sudo apt install omahon${NC}"
    if [ -n "$1" ]; then
        exec ollama run phi3:mini "$*"
    else
        exec ollama run phi3:mini
    fi
else
    echo -e "${RED}No local AI tools available.${NC}"
    echo ""
    echo "Sovereign setup (no cloud keys):"
    echo "  • Pre-stage /build-assets/omahon and ollama in the live-build tree, or"
    echo "  • Run alfred-ai pull once when you have connectivity to fetch phi3:mini, or"
    echo "  • Copy Ollama model blobs into /usr/share/ollama/models from removable media."
    echo ""
    exit 1
fi
ALFRED_AI
chmod +x /usr/local/bin/alfred-ai

# ── 4. Desktop Integration ──
echo "[AI] Creating desktop entries..."
cat > /usr/share/applications/alfred-ai.desktop << 'DESK'
[Desktop Entry]
Name=Alfred AI
Comment=Sovereign local AI — Omahon + Ollama (no cloud keys)
Exec=xfce4-terminal -e "alfred-ai"
Icon=applications-science
Terminal=false
Type=Application
Categories=Development;Science;AI;
Keywords=ai;agent;llm;omahon;ollama;local;sovereign;offline;
DESK

cat > /usr/share/applications/ollama.desktop << 'DESK2'
[Desktop Entry]
Name=Ollama
Comment=Local LLM inference — offline AI
Exec=xfce4-terminal -e "ollama run phi3:mini"
Icon=applications-science
Terminal=false
Type=Application
Categories=Development;Science;AI;
DESK2

# ── 5. First-boot AI setup hint ──
mkdir -p /etc/skel/.config/autostart
cat > /etc/skel/.config/autostart/alfred-ai-hint.desktop << 'HINT'
[Desktop Entry]
Type=Application
Name=Alfred AI Setup
Exec=bash -c 'if [ ! -f ~/.alfred-ai-setup-done ]; then notify-send "Alfred AI" "Local sovereign path: alfred-ai (Omahon + Ollama on this machine). No cloud API keys. Add models via alfred-ai pull when online once, or copy blobs from trusted media." -i applications-science; touch ~/.alfred-ai-setup-done; fi'
Hidden=false
NoDisplay=true
X-GNOME-Autostart-enabled=true
HINT

echo "═══════════════════════════════════════════════════════"
echo "  AI LAYER COMPLETE — The breath is in the machine"
echo "═══════════════════════════════════════════════════════"
