#!/bin/bash
# SPDX-License-Identifier: AGPL-3.0-or-later
# Hook 0115: The Crown of Thorns LUKS Nuke & Ghost Exfiltration Protocol
set +e

echo "[Alfred God-Tier] Installing Crown of Thorns & Ghost Exfil..."

# Install dependencies
apt-get install -y --no-install-recommends cryptsetup wipe rsync udev || true

# 1. Build the physical LUKS Nuke script
cat << 'EOF' > /usr/local/bin/alfred-luks-nuke
#!/bin/bash
# SHREDS LUKS HEADERS PERMANENTLY
DISK=$(lsblk -no pkname $(findmnt -no SOURCE /))
if [ -n "$DISK" ]; then
    echo "ENGAGING CROWN OF THORNS ON /dev/$DISK"
    head -c 16M /dev/urandom | dd of=/dev/$DISK bs=1M count=16 status=progress
    wipe -f /dev/$DISK
    echo b > /proc/sysrq-trigger
fi
EOF
chmod +x /usr/local/bin/alfred-luks-nuke

# 2. Build the Ghost Exfiltration Auto-Dump Udev Rule
# If a specific USB (e.g. labeled ALFRED_EXFIL) is plugged in, copy data THEN nuke.
mkdir -p /etc/udev/rules.d
cat << 'EOF' > /etc/udev/rules.d/99-alfred-exfil.rules
ACTION=="add", KERNEL=="sd[a-z][0-9]", ENV{ID_FS_LABEL}=="ALFRED_EXFIL", RUN+="/usr/local/bin/alfred-exfil-trigger %k"
EOF

# Build the trigger script
cat << 'EOF' > /usr/local/bin/alfred-exfil-trigger
#!/bin/bash
DEV="/dev/$1"
MOUNT_PT="/mnt/exfil"
mkdir -p $MOUNT_PT
mount $DEV $MOUNT_PT
# Silently dump the encrypted vault
rsync -av /vault/ $MOUNT_PT/
umount $MOUNT_PT
# Trigger the nuke to cover the tracks
/usr/local/bin/alfred-luks-nuke
EOF
chmod +x /usr/local/bin/alfred-exfil-trigger

# 3. Post-Quantum OpenSSH Server
# Forces the SSH daemon to use the sntrup761x25519-sha512@openssh.com lattice cryptographic tunnel
mkdir -p /etc/ssh
cat << 'EOF' > /etc/ssh/sshd_config.d/99-alfred-post-quantum.conf
# GoSiteMe Quantum Encryption Standard (GQES)
KexAlgorithms sntrup761x25519-sha512@openssh.com,curve25519-sha256,curve25519-sha256@libssh.org
Ciphers chacha20-poly1305@openssh.com,aes256-gcm@openssh.com
MACs hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com
EOF

# 4. LUKS FDE Argon2id Cryptographic Override
# Wraps the cryptsetup binary to mathematically force Argon2id key derivation for all disk encryption
cat << 'EOF' > /usr/local/sbin/cryptsetup
#!/bin/bash
# ALFRED LINUX - GQES L4 SOVEREIGN OVERRIDE
if [[ "$*" == *"luksFormat"* ]]; then
    exec /sbin/cryptsetup "$@" --type luks2 --pbkdf argon2id --pbkdf-memory 65536 --pbkdf-parallel 4 --pbkdf-force-iterations 4
else
    exec /sbin/cryptsetup "$@"
fi
EOF
chmod +x /usr/local/sbin/cryptsetup

# 5. Proximity Dead-Man Switch (Bluetooth Shield)
# Locks the screen (or triggers the Crown of Thorns) if the Commander's Bluetooth token (phone/ring) drops.
apt-get install -y --no-install-recommends bluez || true

cat << 'EOF' > /usr/local/bin/alfred-proximity-guard
#!/bin/bash
# ALFRED LINUX: PROXIMITY DEAD-MAN SWITCH
# Reads MAC address of token from /etc/alfred/proximity.mac

MAC_FILE="/etc/alfred/proximity.mac"

if [ ! -f "$MAC_FILE" ]; then
    echo "No Proximity MAC configured. Sleeping."

fi

TOKEN_MAC=$(cat "$MAC_FILE")
MISSING_COUNT=0

while true; do
    # Ping the Bluetooth token
    if hcitool name "$TOKEN_MAC" | grep -q "."; then
        MISSING_COUNT=0
    else
        MISSING_COUNT=$((MISSING_COUNT+1))
    fi

    # If missing for 3 consecutive checks (approx 15 seconds)
    if [ $MISSING_COUNT -ge 3 ]; then
        echo "[PANIC] Proximity Token Lost! Securing Workstation!"
        # SAFE MODE: Lock the screen immediately (Plasma/X11/Wayland agnostic fallback)
        loginctl lock-sessions
        
        # NOTE: If the user explicitly sets ALFRED_PROXIMITY_NUKE=1 in /etc/alfred/panic.conf,
        # we engage the Crown of Thorns instead of just locking.
        if grep -q "ALFRED_PROXIMITY_NUKE=1" /etc/alfred/panic.conf 2>/dev/null; then
            /usr/local/bin/alfred-luks-nuke
        fi
        
        # Reset count so we don't spam the locker
        MISSING_COUNT=0
    fi
    sleep 5
done
EOF
chmod +x /usr/local/bin/alfred-proximity-guard

cat << 'EOF' > /etc/systemd/system/alfred-proximity-guard.service
[Unit]
Description=Alfred Proximity Dead-Man Switch
After=bluetooth.target

[Service]
ExecStart=/usr/local/bin/alfred-proximity-guard
Restart=always
User=root

[Install]
WantedBy=multi-user.target
EOF
systemctl enable alfred-proximity-guard || true || true.service

echo "[Alfred God-Tier] Alpha Protocol: LUKS Nuke, Ghost Exfil, Proximity Guard, & Omni-Quantum Hardening successfully merged!"
#!/bin/bash
set +e
echo "=========================================="
echo "==== ALFRED SECURE BOOT MOK SHIM HOOK ===="
echo "=========================================="

mkdir -p /etc/default/grub.d || true
cat > /etc/default/grub.d/alfred-secure-boot.cfg << 'EOF'
# Force GRUB to recognize EFI and Secure Boot
GRUB_DISABLE_OS_PROBER=false
EOF

if dpkg -l | grep -q "shim-signed"; then
    echo "Secure Boot Shim successfully integrated."
else
    echo "WARNING: shim-signed is not installed. Secure Boot will fail."
fi
#!/usr/bin/env -S prlimit --as=1073741824 unshare /bin/bash
export GIT_TERMINAL_PROMPT=0
export DEBIAN_FRONTEND=noninteractive
# SPDX-License-Identifier: AGPL-3.0-or-later
set +e
# [Genesis Forge] Granular Kernel Matrix: net.ipv4.conf.all.rp_filter=1
# Extremely deep low-level kernel protection.
echo "[Genesis Forge] Applying granular sysctl: net.ipv4.conf.all.rp_filter=1"
echo "net.ipv4.conf.all.rp_filter=1" > /etc/sysctl.d/99-alfred-13.conf || true
sysctl -w net.ipv4.conf.all.rp_filter=1 > /dev/null 2>&1 || true


