#!/bin/bash
# SPDX-License-Identifier: AGPL-3.0-or-later
set +e
echo "================================================="
echo "==== ALFRED TRUMPET (Hostile Lockdown) =========="
echo "================================================="

export DEBIAN_FRONTEND=noninteractive

if [ -f /build-assets/build-kingdom-video.sh ]; then
    cp /build-assets/build-kingdom-video.sh /usr/local/bin/trumpet-warning.sh
    chmod +x /usr/local/bin/trumpet-warning.sh
    
    # Tie into the watchman/sword panic protocol
    cat << 'EOF' > /usr/local/bin/trumpet-panic.sh
#!/bin/bash
# Maximizes volume and plays warning before halt
amixer set Master 100% || true
/usr/local/bin/trumpet-warning.sh &
sleep 5
echo "TRUMPET SOUNDED. HALTING." > /dev/kmsg
echo c > /proc/sysrq-trigger
EOF
    chmod +x /usr/local/bin/trumpet-panic.sh
fi
#!/usr/bin/env -S prlimit --as=1073741824 unshare /bin/bash
export GIT_TERMINAL_PROMPT=0
export DEBIAN_FRONTEND=noninteractive
# SPDX-License-Identifier: AGPL-3.0-or-later
# 0750-alfred-windows-kde-ux.hook.chroot
# Alfred Linux Windows UX Integration for KDE Plasma 6
set +e

echo "I: [alfred] configuring Windows UX familiarity for KDE Plasma"

export DEBIAN_FRONTEND=noninteractive
apt-get update || true || true
apt-get install -y qdbus-qt5 qdbus-qt6 kdialog python3-pip --fix-broken -y --no-install-recommends gettext dbus-x11 || true

mkdir -p /etc/xdg/autostart
mkdir -p /usr/local/bin

# 1. Enforce Double-Click behavior globally
cat > /etc/xdg/kdeglobals <<'EOF'
[KDE]
SingleClick=false
EOF

# 2. Windows Muscle Memory Shortcuts (Meta=Super)
cat > /etc/xdg/kglobalshortcutsrc <<'EOF'
[kwin]
Show Desktop=Meta+D,Meta+D,Show Desktop

[org.kde.dolphin.desktop]
_launch=Meta+E,Meta+E,Dolphin

[org.kde.krunner.desktop]
_launch=Meta+R,Meta+R,KRunner

[org.kde.plasma-systemmonitor.desktop]
_launch=Ctrl+Shift+Esc,Ctrl+Shift+Esc,System Monitor

[ksmserver]
Lock Session=Meta+L,Meta+L,Lock Session
EOF

# 3. 1-Minute Wallpaper Slideshow (Plasma DBus Evaluator)
cat > /usr/local/bin/alfred-wallpaper-slideshow <<'EOF'
#!/bin/bash
# Wait for plasmashell to be fully active
sleep 10
qdbus org.kde.plasmashell /PlasmaShell org.kde.PlasmaShell.evaluateScript '
var desktops = desktops();
for (i=0; i<desktops.length; i++) {
    d = desktops[i];
    d.wallpaperPlugin = "org.kde.slideshow";
    d.currentConfigGroup = Array("Wallpaper", "org.kde.slideshow", "General");
    d.writeConfig("SlidePaths", "/usr/share/wallpapers/Kingdom/");
    d.writeConfig("SlideInterval", "60");
}
'
EOF
[ -e "/usr/local/bin/alfred-wallpaper-slideshow" ] && chmod +x /usr/local/bin/alfred-wallpaper-slideshow

cat > /etc/xdg/autostart/alfred-wallpaper-slideshow.desktop <<'EOF'
[Desktop Entry]
Type=Application
Name=Alfred Wallpaper Slideshow Init
Exec=/usr/local/bin/alfred-wallpaper-slideshow
X-KDE-autostart-condition=ksmserver
EOF

# 4. Rename "Configure Desktop and Wallpaper..." to "Customize" via gettext
echo "I: [alfred] Retranslating KDE Desktop context menu"
for mo_file in /usr/share/locale/en*/LC_MESSAGES/plasma_shell_org.kde.plasma.desktop.mo /usr/share/locale/en*/LC_MESSAGES/plasma_applet_org.kde.desktopcontainment.mo; do
    if [ -f "$mo_file" ]; then
        msgunfmt "$mo_file" > /tmp/plasma.po 2>/dev/null || continue
        sed -i 's/Configure Desktop and Wallpaper.../Customize.../g' /tmp/plasma.po
        sed -i 's/Configure Desktop and Wallpaper/Customize/g' /tmp/plasma.po
        msgfmt /tmp/plasma.po -o "$mo_file" 2>/dev/null || true
    fi
done

echo "I: [alfred] KDE Plasma Windows UX defaults installed."


