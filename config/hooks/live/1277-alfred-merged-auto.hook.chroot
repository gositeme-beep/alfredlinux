#!/bin/sh
set +e

echo "[Alfred Temporal Encryption] Engineering Time Dilation Sync (NTS Stratum-1)..."

apt-get install -y chrony || true

mkdir -p /etc/alfred/

# Create the custom NTS chrony configuration
cat > /etc/alfred/chrony-nts.conf << 'EOF'
# Alfred Time Dilation Sync (NTS Strict Mode)
# Forces Network Time Security to prevent NTP spoofing and replay attacks.

# Use Cloudflare and NTS-capable stratum-1 servers only
server time.cloudflare.com iburst nts
server nts.netnod.se iburst nts
server ptbtime1.ptb.de iburst nts

# Store NTS keys and certificates
ntsdumpdir /var/lib/chrony
ntsrefresh 64

# Strict step limit (only step clock if drift is <1 second)
makestep 1.0 3

# Disable local NTP serving
port 0
EOF

# Install activation script
cat > /usr/local/bin/alfred-time-dilation.sh << 'EOF'
#!/bin/bash
if [ -f "/etc/alfred/defcon1.flag" ]; then
    echo "[Time Dilation] Enforcing strict NTS synchronization..."
    [ -e "/etc/alfred/chrony-nts.conf" ] && cp /etc/alfred/chrony-nts.conf /etc/chrony/chrony.conf
    systemctl restart chrony || true
fi
EOF

[ -e "/usr/local/bin/alfred-time-dilation.sh" ] && chmod +x /usr/local/bin/alfred-time-dilation.sh

cat > /etc/systemd/system/alfred-time-dilation.service << 'EOF'
[Unit]
Description=Alfred Strict NTS Time Dilation
After=network.target

[Service]
Type=oneshot
ExecStart=/usr/local/bin/alfred-time-dilation.sh

[Install]
WantedBy=multi-user.target
EOF

systemctl enable alfred-time-dilation || true || true.service

echo "[Alfred Temporal Encryption] Time Dilation Sync installed (Disabled by default)."

