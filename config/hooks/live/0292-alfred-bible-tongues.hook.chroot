# ═══════════════════════════════════════════════════
# 5. BIBLE TONGUES CLI WRAPPER
# ═══════════════════════════════════════════════════
echo "[TONGUES-05] Installing Bible tongues extension..."

cat > /usr/local/bin/alfred-bible-lang << 'LANG'
#!/bin/bash
# ═══════════════════════════════════════════════════════════════
# alfred-bible-lang — Read the Word in other tongues
#
# "They began to speak with other tongues,
#  as the Spirit gave them utterance." — Acts 2:4
# ═══════════════════════════════════════════════════════════════

BIBLE_DIR="/usr/share/alfred/bible"
GOLD='\033[38;5;220m'; CYAN='\033[0;36m'; NC='\033[0m'; BOLD='\033[1m'

LANGUAGE="${1:-list}"

# Any code listed in languages.conf (add new tongues there + seed TSV only).
do_lookup() {
        CODE="$1"
        BOOK="${2:-}"
        CHAPTER="${3:-}"

        LINE=$(grep "^${CODE}|" "$BIBLE_DIR/languages.conf" 2>/dev/null)
        if [ -z "$LINE" ]; then
            echo "Language '$CODE' not found. Run: alfred-bible-lang list"
            exit 1
        fi

        FILE=$(echo "$LINE" | cut -d'|' -f3)
        NAME=$(echo "$LINE" | cut -d'|' -f2)
        SOURCE=$(echo "$LINE" | cut -d'|' -f4)

        BIBLE_FILE="$BIBLE_DIR/$FILE"
        SEED_FILE="$BIBLE_DIR/${FILE%.tsv}-seed.tsv"

        if [ -f "$BIBLE_FILE" ]; then
            ACTIVE_FILE="$BIBLE_FILE"
        elif [ -f "$SEED_FILE" ]; then
            ACTIVE_FILE="$SEED_FILE"
            echo -e "${GOLD}(Using seed Bible — key verses only. Full: alfred-bible download $CODE)${NC}"
            echo ""
        else
            echo "No Bible data for $NAME."
            exit 1
        fi

        if [ -z "$BOOK" ]; then
            TOTAL=$(tail -n +2 "$ACTIVE_FILE" | wc -l)
            LINE_NUM=$((RANDOM % TOTAL + 2))
            IFS=$'\t' read -r b c v text <<< "$(sed -n "${LINE_NUM}p" "$ACTIVE_FILE")"
            echo -e "${GOLD}✝ $b $c:$v${NC} ($NAME — $SOURCE)"
            echo "$text"
        elif [ -z "$CHAPTER" ]; then
            echo -e "${GOLD}✝ $BOOK${NC} ($NAME)"
            echo ""
            while IFS=$'\t' read -r b c v text; do
                [[ "$b" == "Book" ]] && continue
                if [[ "$b" == "$BOOK" ]]; then
                    echo -e "  ${CYAN}$c:$v${NC} $text"
                fi
            done < "$ACTIVE_FILE"
        else
            echo -e "${GOLD}✝ $BOOK $CHAPTER${NC} ($NAME)"
            echo ""
            while IFS=$'\t' read -r b c v text; do
                [[ "$b" == "Book" ]] && continue
                if [[ "$b" == "$BOOK" && "$c" == "$CHAPTER" ]]; then
                    echo -e "  ${CYAN}$v${NC} $text"
                fi
            done < "$ACTIVE_FILE"
        fi
}

case "$LANGUAGE" in
    list)
        echo -e "${GOLD}═══ Bible Languages — Tongues of Fire ═══${NC}"
        echo ""
        while IFS='|' read -r code name file source; do
            [[ "$code" =~ ^# ]] && continue
            BIBLE_FILE="$BIBLE_DIR/$file"
            SEED_FILE="$BIBLE_DIR/${file%.tsv}-seed.tsv"
            if [ -f "$BIBLE_FILE" ]; then
                COUNT=$(wc -l < "$BIBLE_FILE")
                echo -e "  ${CYAN}$code${NC} — $name ($source) — $COUNT verses"
            elif [ -f "$SEED_FILE" ]; then
                COUNT=$(wc -l < "$SEED_FILE")
                echo -e "  ${CYAN}$code${NC} — $name ($source) — $((COUNT-1)) key verses (seed)"
            else
                echo "  $code — $name — not installed"
            fi
        done < "$BIBLE_DIR/languages.conf"
        echo ""
        echo "  Usage: alfred-bible-lang <code> [book] [chapter]"
        echo "  Example: alfred-bible-lang es Salmos 23"
        echo "  Example: alfred-bible-lang fr Jean 3"
        echo "  Example: alfred-bible-lang ro Ioan 3"
        echo "  Example: alfred-bible-lang uk Івана 3"
        echo "  Example: alfred-bible-lang he"
        echo "  Example: alfred-bible-lang gr Ιωάννης 3"
        echo "  Example: alfred-bible-lang la Ioannes 3"
        echo "  Example: alfred-bible-lang zu Genesisi 1"
        echo "  Example: alfred-bible-lang am ዮሐንስ 3"
        echo "  Example: alfred-bible-lang ur یوحنا 3"
        echo "  Example: alfred-bible-lang fil \"Mga Taga-Filipos\" 4"
        ;;

    help|--help|-h)
        echo -e "${GOLD}═══ alfred-bible-lang — The Word in Every Tongue ═══${NC}"
        echo ""
        echo "  alfred-bible-lang list           — Show available languages"
        echo "  alfred-bible-lang es              — Random verse in Spanish"
        echo "  alfred-bible-lang fr Jean 3       — John 3 in French"
        echo "  alfred-bible-lang ro Ioan 3       — John 3 in Romanian (seed)"
        echo "  alfred-bible-lang he              — Random Hebrew verse"
        echo "  alfred-bible-lang gr              — Random Greek verse (LXX/NT seed)"
        echo "  alfred-bible-lang la Ioannes 3    — John 3 in Latin (seed)"
        echo "  alfred-bible-lang de Johannes 3   — John 3 in German (seed)"
        echo "  alfred-bible-lang zh 约翰福音 3     — John 3 in Chinese (seed)"
        echo "  alfred-bible-lang zu Genesisi 1    — Genesis 1 in Zulu (seed)"
        echo "  alfred-bible-lang am ዮሐንስ 3       — John 3 in Amharic (seed)"
        echo "  alfred-bible-lang ur یوحنا 3       — John 3 in Urdu (seed)"
        echo "  alfred-bible-lang fil \"Mga Taga-Filipos\" 4 — Philippians 4 in Filipino (seed)"
        echo ""
        echo "  \"They began to speak with other tongues,"
        echo "   as the Spirit gave them utterance.\" — Acts 2:4"
        ;;

    *)
        if ! grep -q "^${LANGUAGE}|" "$BIBLE_DIR/languages.conf" 2>/dev/null; then
            echo "Language '${LANGUAGE}' not found. Run: alfred-bible-lang list" >&2
            exit 1
        fi
        do_lookup "$LANGUAGE" "${2:-}" "${3:-}"
        ;;
esac
LANG
chmod +x /usr/local/bin/alfred-bible-lang

echo "[TONGUES-06] Desktop entry — public discovery on the ISO..."
mkdir -p /usr/share/applications
cat > /usr/share/applications/alfred-bible-tongues.desktop << 'DESKBT'
[Desktop Entry]
Name=Bible in Many Languages
Comment=34 tongues offline (seed verses) — Acts 2:4; no Internet required
Exec=x-terminal-emulator -e bash -c 'echo "══ Bible tongues (offline seeds) ══"; echo "List codes, then try a random verse or a book/chapter."; echo ""; alfred-bible-lang list; echo ""; echo "Try:  alfred-bible-lang es"; echo "      alfred-bible-lang ro Ioan 3"; echo "      alfred-bible tongues list"; echo ""; exec bash'
Icon=accessories-dictionary
Terminal=false
Type=Application
Categories=Education;Reference;
Keywords=bible;scripture;languages;multilingual;tongues;romanian;spanish;i18n;
DESKBT

echo "╔═══════════════════════════════════════════════════════════╗"
echo "║  [0292] Bible Tongues — COMPLETE                         ║"
echo "║  ✓ English AKJV (full) + 33 seed tongues — list for codes ║"
echo "║    (+ fil ur; Africa set) Acts 2:4                       ║"
echo "║  ✓ alfred-bible-lang — run: alfred-bible-lang list       ║"
echo "║  They spoke with other tongues. — Acts 2:4               ║"
echo "╚═══════════════════════════════════════════════════════════╝"
