#!/bin/bash
# ═══════════════════════════════════════════════════════════════════════════════
# HOOK 0292: Bible Tongues — The Word in Every Language
#
# "And they were all filled with the Holy Ghost, and began to speak
#  with other tongues, as the Spirit gave them utterance." — Acts 2:4
#
# Multilingual Bible: English (AKJV) plus seed tongues offline (Spanish,
# French, Hebrew, Greek, Latin, German, Portuguese, Russian, Chinese, Japanese,
# Arabic, Hindi, Italian, Romanian, Polish, Ukrainian, Korean, Turkish, Dutch,
# Vietnamese, Tagalog, Filipino, Urdu, Swahili, Amharic, Yoruba, Igbo, Hausa,
# Zulu, Xhosa, Afrikaans, Somali, Twi, …); full texts may be added under
# /usr/share/alfred/bible/*.tsv later.
#
# BUILD: v7.77 Kingdom of God Edition
# ═══════════════════════════════════════════════════════════════════════════════

set -e
chmod 1777 /tmp 2>/dev/null || true

echo "╔═══════════════════════════════════════════════════════════╗"
echo "║  [0292] Bible Tongues — The Word in Every Language       ║"
echo "║  'They began to speak with other tongues' — Acts 2:4    ║"
echo "╚═══════════════════════════════════════════════════════════╝"

BIBLE_DIR="/usr/share/alfred/bible"
mkdir -p "$BIBLE_DIR"

# ═══════════════════════════════════════════════════
# 1. LANGUAGE INDEX
# ═══════════════════════════════════════════════════
echo "[TONGUES-01] Creating language index..."

cat > "$BIBLE_DIR/languages.conf" << 'CONF'
# Alfred Bible — Supported Languages
# Format: code|name|file|source
en|English|akjv-bible.tsv|Authorized King Jesus Version — Perez Family Edition (AKJV)
es|Español|rvr-bible.tsv|Reina-Valera Revisada 1960
fr|Français|lsg-bible.tsv|Louis Segond 1910
he|עברית|hebrew-bible.tsv|Westminster Leningrad Codex (OT)
gr|Ἑλληνικά|greek-bible.tsv|LXX / Greek NT (public-domain samples)
la|Latina|latin-bible.tsv|Latin Vulgate-style (public-domain samples)
de|Deutsch|de-bible.tsv|Luther 1912 (public-domain samples)
pt|Português|pt-bible.tsv|Portuguese (public-domain samples)
ru|Русский|ru-bible.tsv|Russian Synodal-style (public-domain samples)
zh|中文|zh-bible.tsv|Chinese Union–style (public-domain samples)
ja|日本語|ja-bible.tsv|Japanese (public-domain samples)
ar|العربية|ar-bible.tsv|Arabic Van Dyke–style (public-domain samples)
hi|हिन्दी|hi-bible.tsv|Hindi (public-domain samples)
it|Italiano|it-bible.tsv|Italian Diodati-style (public-domain samples)
ro|Română|ro-bible.tsv|Romanian (traditional evangelical samples)
pl|Polski|pl-bible.tsv|Polish (public-domain samples)
uk|Українська|uk-bible.tsv|Ukrainian (public-domain samples)
ko|한국어|ko-bible.tsv|Korean (public-domain samples)
tr|Türkçe|tr-bible.tsv|Turkish (public-domain samples)
nl|Nederlands|nl-bible.tsv|Dutch Statenvertaling-style (public-domain samples)
vi|Tiếng Việt|vi-bible.tsv|Vietnamese (public-domain samples)
tl|Tagalog|tl-bible.tsv|Tagalog (public-domain samples)
fil|Filipino|fil-bible.tsv|Filipino Philippines (public-domain samples; same seed set as Tagalog)
ur|اردو|ur-bible.tsv|Urdu (public-domain samples)
sw|Kiswahili|sw-bible.tsv|Swahili (public-domain samples)
am|አማርኛ|am-bible.tsv|Amharic (public-domain samples)
yo|Yorùbá|yo-bible.tsv|Yoruba (public-domain samples)
ig|Igbo|ig-bible.tsv|Igbo (public-domain samples)
ha|Hausa|ha-bible.tsv|Hausa (public-domain samples)
zu|isiZulu|zu-bible.tsv|Zulu (public-domain samples)
xh|isiXhosa|xh-bible.tsv|Xhosa (public-domain samples)
af|Afrikaans|af-bible.tsv|Afrikaans (public-domain samples)
so|Soomaali|so-bible.tsv|Somali (public-domain samples)
tw|Twi|tw-bible.tsv|Twi / Akan (public-domain samples)
CONF

# ═══════════════════════════════════════════════════
# 2. SPANISH BIBLE — Reina-Valera 1960
# (Public domain portions / headers for verse lookup)
# ═══════════════════════════════════════════════════
echo "[TONGUES-02] Creating Spanish Bible seed..."

# We create a header + key verses so the system works offline
# Full Bible can be downloaded with: alfred-bible download es
cat > "$BIBLE_DIR/rvr-bible-seed.tsv" << 'SEED'
Book	Chapter	Verse	Text
Génesis	1	1	En el principio creó Dios los cielos y la tierra.
Génesis	1	2	Y la tierra estaba desordenada y vacía, y las tinieblas estaban sobre la faz del abismo, y el Espíritu de Dios se movía sobre la faz de las aguas.
Génesis	1	3	Y dijo Dios: Sea la luz; y fue la luz.
Salmos	23	1	Jehová es mi pastor; nada me faltará.
Salmos	23	2	En lugares de delicados pastos me hará descansar; junto a aguas de reposo me pastoreará.
Salmos	23	3	Confortará mi alma; me guiará por sendas de justicia por amor de su nombre.
Salmos	23	4	Aunque ande en valle de sombra de muerte, no temeré mal alguno, porque tú estarás conmigo; tu vara y tu cayado me infundirán aliento.
Salmos	91	1	El que habita al abrigo del Altísimo morará bajo la sombra del Omnipotente.
Salmos	91	2	Diré yo a Jehová: Esperanza mía, y castillo mío; mi Dios, en quien confiaré.
Juan	3	16	Porque de tal manera amó Dios al mundo, que ha dado a su Hijo unigénito, para que todo aquel que en él cree, no se pierda, mas tenga vida eterna.
Juan	14	6	Jesús le dijo: Yo soy el camino, y la verdad, y la vida; nadie viene al Padre, sino por mí.
Romanos	8	28	Y sabemos que a los que aman a Dios, todas las cosas les ayudan a bien, esto es, a los que conforme a su propósito son llamados.
Filipenses	4	13	Todo lo puedo en Cristo que me fortalece.
Apocalipsis	22	21	La gracia de nuestro Señor Jesucristo sea con todos vosotros. Amén.
SEED

# ═══════════════════════════════════════════════════
# 3. FRENCH BIBLE — Louis Segond 1910
# ═══════════════════════════════════════════════════
echo "[TONGUES-03] Creating French Bible seed..."

cat > "$BIBLE_DIR/lsg-bible-seed.tsv" << 'SEED'
Book	Chapter	Verse	Text
Genèse	1	1	Au commencement, Dieu créa les cieux et la terre.
Genèse	1	2	La terre était informe et vide: il y avait des ténèbres à la surface de l'abîme, et l'esprit de Dieu se mouvait au-dessus des eaux.
Genèse	1	3	Dieu dit: Que la lumière soit! Et la lumière fut.
Psaumes	23	1	L'Éternel est mon berger: je ne manquerai de rien.
Psaumes	23	2	Il me fait reposer dans de verts pâturages, il me dirige près des eaux paisibles.
Psaumes	23	3	Il restaure mon âme, il me conduit dans les sentiers de la justice, à cause de son nom.
Psaumes	23	4	Quand je marche dans la vallée de l'ombre de la mort, je ne crains aucun mal, car tu es avec moi: ta houlette et ton bâton me rassurent.
Psaumes	91	1	Celui qui demeure sous l'abri du Très Haut repose à l'ombre du Tout Puissant.
Jean	3	16	Car Dieu a tant aimé le monde qu'il a donné son Fils unique, afin que quiconque croit en lui ne périsse point, mais qu'il ait la vie éternelle.
Jean	14	6	Jésus lui dit: Je suis le chemin, la vérité, et la vie. Nul ne vient au Père que par moi.
Romains	8	28	Nous savons, du reste, que toutes choses concourent au bien de ceux qui aiment Dieu, de ceux qui sont appelés selon son dessein.
Philippiens	4	13	Je puis tout par celui qui me fortifie.
Apocalypse	22	21	Que la grâce du Seigneur Jésus soit avec tous!
SEED

# ═══════════════════════════════════════════════════
# 4. HEBREW BIBLE SEED (OT only — Tanakh)
# ═══════════════════════════════════════════════════
echo "[TONGUES-04] Creating Hebrew Bible seed..."

cat > "$BIBLE_DIR/hebrew-bible-seed.tsv" << 'SEED'
Book	Chapter	Verse	Text
בראשית	1	1	בְּרֵאשִׁ֖ית בָּרָ֣א אֱלֹהִ֑ים אֵ֥ת הַשָּׁמַ֖יִם וְאֵ֥ת הָאָֽרֶץ׃
בראשית	1	2	וְהָאָ֗רֶץ הָיְתָ֥ה תֹ֙הוּ֙ וָבֹ֔הוּ וְחֹ֖שֶׁךְ עַל־פְּנֵ֣י תְה֑וֹם וְר֣וּחַ אֱלֹהִ֔ים מְרַחֶ֖פֶת עַל־פְּנֵ֥י הַמָּֽיִם׃
בראשית	1	3	וַיֹּ֥אמֶר אֱלֹהִ֖ים יְהִ֣י א֑וֹר וַֽיְהִי־אֽוֹר׃
תהלים	23	1	מִזְמ֥וֹר לְדָוִ֑ד יְהוָ֥ה רֹ֝עִ֗י לֹ֣א אֶחְסָֽר׃
תהלים	23	2	בִּנְא֣וֹת דֶּ֭שֶׁא יַרְבִּיצֵ֑נִי עַל־מֵ֖י מְנֻח֣וֹת יְנַהֲלֵֽנִי׃
תהלים	23	3	נַפְשִׁ֥י יְשׁוֹבֵ֑ב יַֽנְחֵ֥נִי בְמַעְגְּלֵי־צֶ֝֗דֶק לְמַ֣עַן שְׁמֽוֹ׃
תהלים	23	4	גַּ֤ם כִּֽי־אֵלֵ֨ךְ בְּגֵ֪יא צַלְמָ֡וֶת לֹא־אִירָ֣א רָ֭ע כִּי־אַתָּ֣ה עִמָּדִ֑י שִׁבְטְךָ֥ וּ֝מִשְׁעַנְתֶּ֗ךָ הֵ֣מָּה יְנַֽחֲמֻֽנִי׃
SEED

# ═══════════════════════════════════════════════════
# 4b–4k. GREEK, LATIN, AND OTHER MAJOR TONGUES (seed corpora)
# ═══════════════════════════════════════════════════
echo "[TONGUES-04b] Greek (LXX/NT) seed..."
cat > "$BIBLE_DIR/greek-bible-seed.tsv" << 'SEED'
Book	Chapter	Verse	Text
Γένεσις	1	1	Ἐν ἀρχῇ ἐποίησεν ὁ θεὸς τὸν οὐρανὸν καὶ τὴν γῆν.
Γένεσις	1	2	ἡ δὲ γῆ ἦν ἀόρατος καὶ ἀκατασκεύαστος, καὶ σκότος ἐπάνω τῆς ἀβύσσου, καὶ πνεῦμα θεοῦ ἐπεφέρετο ἐπάνω τοῦ ὕδατος.
Γένεσις	1	3	καὶ εἶπεν ὁ θεός· γενηθήτω φῶς· καὶ ἐγένετο φῶς.
Ψαλμοί	23	1	Ψαλμὸς τῷ Δαυίδ· κύριος ποιμαίνει με, καὶ οὐδέν με ὑστερήσει.
Ψαλμοί	23	2	ἐν τόπῳ χλόης ἐκεῖ με ἐγέννησεν, ἐπὶ ὕδατος ἀναπαύσεως ἐξέθρεψέν με.
Ιωάννης	3	16	οὕτως γὰρ ἠγάπησεν ὁ θεὸς τὸν κόσμον, ὥστε τὸν υἱὸν αὐτοῦ τὸν μονογενῆ ἔδωκεν, ἵνα πᾶς ὁ πιστεύων εἰς αὐτὸν μὴ ἀπόληται ἀλλ' ἔχῃ ζωὴν αἰώνιον.
Ιωάννης	14	6	λέγει αὐτῷ ὁ Ἰησοῦς· ἐγώ εἰμι ἡ ὁδὸς καὶ ἡ ἀλήθεια καὶ ἡ ζωή· οὐδεὶς ἔρχεται πρὸς τὸν πατέρα εἰ μὴ δι' ἐμοῦ.
Πρὸς Ῥωμαίους	8	28	Οἴδαμεν δὲ ὅτι τοῖς ἀγαπῶσι τὸν θεὸν πάντα συνεργεῖ εἰς ἀγαθόν, τοῖς κατὰ πρόθεσιν κλητοῖς οὖσιν.
Πρὸς Φιλιππησίους	4	13	πάντα ἰσχύω ἐν τῷ ἐνδυναμοῦντί με.
Ἀποκάλυψις Ἰωάννου	22	21	ἡ χάρις τοῦ κυρίου Ἰησοῦ Χριστοῦ μετὰ πάντων.
SEED

echo "[TONGUES-04c] Latin (Vulgate-style) seed..."
cat > "$BIBLE_DIR/latin-bible-seed.tsv" << 'SEED'
