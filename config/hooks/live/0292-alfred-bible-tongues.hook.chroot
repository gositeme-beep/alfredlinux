#!/bin/bash
# SPDX-License-Identifier: AGPL-3.0-or-later
# ═══════════════════════════════════════════════════════════════════════════════
# HOOK 0292: Bible Tongues — The Word in Every Language
#
# "And they were all filled with the Holy Ghost, and began to speak
#  with other tongues, as the Spirit gave them utterance." — Acts 2:4
#
# Multilingual Bible support: 48 tongues in languages.conf (Acts 2:4 breadth).
# English: full AKJV Perez Family Edition when 0290 ships the TSV; es/fr/he rich seeds;
# 44 additional tongue-* two-verse seeds. alfred-bible-lang reads any installed code.
#
# BUILD: v7.77 Kingdom of God Edition
# ═══════════════════════════════════════════════════════════════════════════════

set -e
chmod 1777 /tmp 2>/dev/null || true

echo "╔═══════════════════════════════════════════════════════════╗"
echo "║  [0292] Bible Tongues — The Word in Every Language       ║"
echo "║  'They began to speak with other tongues' — Acts 2:4    ║"
echo "╚═══════════════════════════════════════════════════════════╝"

BIBLE_DIR="/usr/share/alfred/bible"
mkdir -p "$BIBLE_DIR"

# ═══════════════════════════════════════════════════
# 1. LANGUAGE INDEX
# ═══════════════════════════════════════════════════
echo "[TONGUES-01] Creating language index..."

cat > "$BIBLE_DIR/languages.conf" << 'CONF'
# Alfred Bible — Supported Languages (48 tongues • Acts 2:4)
# Format: code|name|file|source
en|English|akjv-bible.tsv|Authorized King Jesus Version — Perez Family Edition (full TSV from 0290)
es|Español|rvr-bible.tsv|Reina-Valera 1960 — rich seed in hook
es-419|Español (Latinoamérica)|tongue-es-419.tsv|Reina-Valera phrasing — seed verses
es-ES|Español (España)|tongue-es-ES.tsv|Reina-Valera phrasing — seed verses
fr|Français|lsg-bible.tsv|Louis Segond 1910 — rich seed in hook
he|עברית|hebrew-bible.tsv|Westminster Leningrad-style Tanakh seed
de|Deutsch|tongue-de.tsv|Luther-style German seed verses
pt|Português|tongue-pt.tsv|Portuguese evangelical seed verses
ru|Русский|tongue-ru.tsv|Russian Synodal-style seed verses
zh|中文（繁體）|tongue-zh.tsv|Traditional Chinese Protestant seed verses
ja|日本語|tongue-ja.tsv|Japanese Protestant seed verses
ar|العربية|tongue-ar.tsv|Arabic evangelical seed verses
hi|हिन्दी|tongue-hi.tsv|Hindi evangelical seed verses
it|Italiano|tongue-it.tsv|Italian evangelical seed verses
ro|Română|tongue-ro.tsv|Romanian evangelical seed verses
pl|Polski|tongue-pl.tsv|Polish evangelical seed verses
uk|Українська|tongue-uk.tsv|Ukrainian evangelical seed verses
ko|한국어|tongue-ko.tsv|Korean Protestant seed verses
tr|Türkçe|tongue-tr.tsv|Turkish evangelical seed verses
nl|Nederlands|tongue-nl.tsv|Dutch evangelical seed verses
vi|Tiếng Việt|tongue-vi.tsv|Vietnamese evangelical seed verses
tl|Tagalog|tongue-tl.tsv|Tagalog evangelical seed verses
ur|اردو|tongue-ur.tsv|Urdu evangelical seed verses
sw|Kiswahili|tongue-sw.tsv|Swahili evangelical seed verses
am|አማርኛ|tongue-am.tsv|Amharic evangelical seed verses
ig|Ígbò|tongue-ig.tsv|Igbo evangelical seed verses
yo|Yorùbá|tongue-yo.tsv|Yoruba evangelical seed verses
ha|Hausa|tongue-ha.tsv|Hausa evangelical seed verses
zu|isiZulu|tongue-zu.tsv|Zulu evangelical seed verses
xh|isiXhosa|tongue-xh.tsv|Xhosa evangelical seed verses
af|Afrikaans|tongue-af.tsv|Afrikaans evangelical seed verses
so|Soomaali|tongue-so.tsv|Somali evangelical seed verses
tw|Twi|tongue-tw.tsv|Twi evangelical seed verses
jam|Jamiekan Patois|tongue-jam.tsv|Jamaican Creole seed verses
id|Bahasa Indonesia|tongue-id.tsv|Indonesian evangelical seed verses
fa|فارسی|tongue-fa.tsv|Persian evangelical seed verses
my|မြန်မာ|tongue-my.tsv|Burmese evangelical seed verses
yi|ייִדיש|tongue-yi.tsv|Yiddish evangelical seed verses
ht|Kreyòl ayisyen|tongue-ht.tsv|Haitian Creole seed verses
el|Ἑλληνικά|tongue-el.tsv|Koine Greek seed verses
la|Latina|tongue-la.tsv|Latin Vulgate-style seed verses
lad|Ladino|tongue-lad.tsv|Ladino Judeo-Spanish seed verses
cbk|Chavacano|tongue-cbk.tsv|Chavacano de Zamboanga seed verses
ary|الدارجة (Maghrebi)|tongue-ary.tsv|Maghrebi Arabic — Latin seed script
arz|مصري|tongue-arz.tsv|Egyptian Arabic seed verses
apc|عربية شامية|tongue-apc.tsv|Levantine Arabic seed verses
afb|عربية خليجية|tongue-afb.tsv|Gulf Arabic seed verses
bn|বাংলা|tongue-bn.tsv|Bengali evangelical seed verses
CONF

# ═══════════════════════════════════════════════════
# 2. SPANISH BIBLE — Reina-Valera 1960
# (Public domain portions / headers for verse lookup)
# ═══════════════════════════════════════════════════
echo "[TONGUES-02] Creating Spanish Bible seed..."

# We create a header + key verses so the system works offline
# Full Bible can be downloaded with: alfred-bible download es
cat > "$BIBLE_DIR/rvr-bible-seed.tsv" << 'SEED'
Book	Chapter	Verse	Text
Génesis	1	1	En el principio creó Dios los cielos y la tierra.
Génesis	1	2	Y la tierra estaba desordenada y vacía, y las tinieblas estaban sobre la faz del abismo, y el Espíritu de Dios se movía sobre la faz de las aguas.
Génesis	1	3	Y dijo Dios: Sea la luz; y fue la luz.
Salmos	23	1	Jehová es mi pastor; nada me faltará.
Salmos	23	2	En lugares de delicados pastos me hará descansar; junto a aguas de reposo me pastoreará.
Salmos	23	3	Confortará mi alma; me guiará por sendas de justicia por amor de su nombre.
Salmos	23	4	Aunque ande en valle de sombra de muerte, no temeré mal alguno, porque tú estarás conmigo; tu vara y tu cayado me infundirán aliento.
Salmos	91	1	El que habita al abrigo del Altísimo morará bajo la sombra del Omnipotente.
Salmos	91	2	Diré yo a Jehová: Esperanza mía, y castillo mío; mi Dios, en quien confiaré.
Juan	3	16	Porque de tal manera amó Dios al mundo, que ha dado a su Hijo unigénito, para que todo aquel que en él cree, no se pierda, mas tenga vida eterna.
Juan	14	6	Jesús le dijo: Yo soy el camino, y la verdad, y la vida; nadie viene al Padre, sino por mí.
Romanos	8	28	Y sabemos que a los que aman a Dios, todas las cosas les ayudan a bien, esto es, a los que conforme a su propósito son llamados.
Filipenses	4	13	Todo lo puedo en Cristo que me fortalece.
Apocalipsis	22	21	La gracia de nuestro Señor Jesucristo sea con todos vosotros. Amén.
SEED

# ═══════════════════════════════════════════════════
# 3. FRENCH BIBLE — Louis Segond 1910
# ═══════════════════════════════════════════════════
echo "[TONGUES-03] Creating French Bible seed..."

cat > "$BIBLE_DIR/lsg-bible-seed.tsv" << 'SEED'
Book	Chapter	Verse	Text
Genèse	1	1	Au commencement, Dieu créa les cieux et la terre.
Genèse	1	2	La terre était informe et vide: il y avait des ténèbres à la surface de l'abîme, et l'esprit de Dieu se mouvait au-dessus des eaux.
Genèse	1	3	Dieu dit: Que la lumière soit! Et la lumière fut.
Psaumes	23	1	L'Éternel est mon berger: je ne manquerai de rien.
Psaumes	23	2	Il me fait reposer dans de verts pâturages, il me dirige près des eaux paisibles.
Psaumes	23	3	Il restaure mon âme, il me conduit dans les sentiers de la justice, à cause de son nom.
Psaumes	23	4	Quand je marche dans la vallée de l'ombre de la mort, je ne crains aucun mal, car tu es avec moi: ta houlette et ton bâton me rassurent.
Psaumes	91	1	Celui qui demeure sous l'abri du Très Haut repose à l'ombre du Tout Puissant.
Jean	3	16	Car Dieu a tant aimé le monde qu'il a donné son Fils unique, afin que quiconque croit en lui ne périsse point, mais qu'il ait la vie éternelle.
Jean	14	6	Jésus lui dit: Je suis le chemin, la vérité, et la vie. Nul ne vient au Père que par moi.
Romains	8	28	Nous savons, du reste, que toutes choses concourent au bien de ceux qui aiment Dieu, de ceux qui sont appelés selon son dessein.
Philippiens	4	13	Je puis tout par celui qui me fortifie.
Apocalypse	22	21	Que la grâce du Seigneur Jésus soit avec tous!
SEED

# ═══════════════════════════════════════════════════
# 4. HEBREW BIBLE SEED (OT only — Tanakh)
# ═══════════════════════════════════════════════════
echo "[TONGUES-04] Creating Hebrew Bible seed..."

cat > "$BIBLE_DIR/hebrew-bible-seed.tsv" << 'SEED'
Book	Chapter	Verse	Text
בראשית	1	1	בְּרֵאשִׁ֖ית בָּרָ֣א אֱלֹהִ֑ים אֵ֥ת הַשָּׁמַ֖יִם וְאֵ֥ת הָאָֽרֶץ׃
בראשית	1	2	וְהָאָ֗רֶץ הָיְתָ֥ה תֹ֙הוּ֙ וָבֹ֔הוּ וְחֹ֖שֶׁךְ עַל־פְּנֵ֣י תְה֑וֹם וְר֣וּחַ אֱלֹהִ֔ים מְרַחֶ֖פֶת עַל־פְּנֵ֥י הַמָּֽיִם׃
בראשית	1	3	וַיֹּ֥אמֶר אֱלֹהִ֖ים יְהִ֣י א֑וֹר וַֽיְהִי־אֽוֹר׃
תהלים	23	1	מִזְמ֥וֹר לְדָוִ֑ד יְהוָ֥ה רֹ֝עִ֗י לֹ֣א אֶחְסָֽר׃
תהלים	23	2	בִּנְא֣וֹת דֶּ֭שֶׁא יַרְבִּיצֵ֑נִי עַל־מֵ֖י מְנֻח֣וֹת יְנַהֲלֵֽנִי׃
תהלים	23	3	נַפְשִׁ֥י יְשׁוֹבֵ֑ב יַֽנְחֵ֥נִי בְמַעְגְּלֵי־צֶ֝֗דֶק לְמַ֣עַן שְׁמֽוֹ׃
תהלים	23	4	גַּ֤ם כִּֽי־אֵלֵ֨ךְ בְּגֵ֪יא צַלְמָ֡וֶת לֹא־אִירָ֣א רָ֭ע כִּי־אַתָּ֣ה עִמָּדִ֑י שִׁבְטְךָ֥ וּ֝מִשְׁעַנְתֶּ֗ךָ הֵ֣מָּה יְנַֽחֲמֻֽנִי׃
SEED

# ═══════════════════════════════════════════════════
# 4b. COMPACT SEEDS — tongue-* tables (Genesis 1:1 + John 3:16)
# ═══════════════════════════════════════════════════
echo "[TONGUES-04b] Installing compact tongue-* seed tables (44 languages)..."

cat > "$BIBLE_DIR/tongue-es-419-seed.tsv" << 'SEED_es-419'
Book	Chapter	Verse	Text
Genesis	1	1	En el principio creó Dios los cielos y la tierra.
John	3	16	Porque de tal manera amó Dios al mundo, que ha dado a su Hijo unigénito, para que todo aquel que en él cree, no se pierda, mas tenga vida eterna.
SEED_es-419

cat > "$BIBLE_DIR/tongue-es-ES-seed.tsv" << 'SEED_es-ES'
Book	Chapter	Verse	Text
Genesis	1	1	En el principio creó Dios los cielos y la tierra.
John	3	16	Porque de tal manera amó Dios al mundo, que ha dado a su Hijo unigénito, para que todo aquel que en él cree, no se pierda, mas tenga vida eterna.
SEED_es-ES

cat > "$BIBLE_DIR/tongue-de-seed.tsv" << 'SEED_de'
Book	Chapter	Verse	Text
Genesis	1	1	Am Anfang schuf Gott Himmel und Erde.
John	3	16	Also hat Gott die Welt geliebt, daß er seinen eingeborenen Sohn gab, auf daß alle, die an ihn glauben, nicht verloren werden, sondern das ewige Leben haben.
SEED_de

cat > "$BIBLE_DIR/tongue-pt-seed.tsv" << 'SEED_pt'
Book	Chapter	Verse	Text
Genesis	1	1	No princípio criou Deus os céus e a terra.
John	3	16	Porque Deus amou o mundo de tal maneira que deu o seu Filho unigênito, para que todo aquele que nele crê não pereça, mas tenha a vida eterna.
SEED_pt

cat > "$BIBLE_DIR/tongue-ru-seed.tsv" << 'SEED_ru'
Book	Chapter	Verse	Text
Genesis	1	1	В начале сотворил Бог небо и землю.
John	3	16	Ибо так возлюбил Бог мир, что отдал Сына Своего Единородного, дабы всякий верующий в Него не погиб, но имел жизнь вечную.
SEED_ru

cat > "$BIBLE_DIR/tongue-zh-seed.tsv" << 'SEED_zh'
Book	Chapter	Verse	Text
Genesis	1	1	起初　神創造天地。
John	3	16	神愛世人，甚至將他的獨生子賜給他們，叫一切信他的，不致滅亡，反得永生。
SEED_zh

cat > "$BIBLE_DIR/tongue-ja-seed.tsv" << 'SEED_ja'
Book	Chapter	Verse	Text
Genesis	1	1	はじめに、神が天と地を創造された。
John	3	16	神はそのひとり子をお与えになったほどに世を愛された。信じる者が滅びることなく永遠の命を得るためである。
SEED_ja

cat > "$BIBLE_DIR/tongue-ar-seed.tsv" << 'SEED_ar'
Book	Chapter	Verse	Text
Genesis	1	1	في البدء خلق الله السماوات والأرض.
John	3	16	لأنه هكذا أحب الله العالم حتى بذل ابنه الوحيد، لكي لا يهلك كل من يؤمن به، بل تكون له حياة أبدية.
