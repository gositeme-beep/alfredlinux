# --- BEGIN MERGED CONTENT FROM: 0105-alfred-wine-subsystem.hook.chroot ---
#!/bin/bash
# 0105-alfred-wine-subsystem.hook.chroot
# Enables i386 multiarch and installs Wine to run Windows .exe applications

set +e

echo "[0105] Enabling Wine Windows Subsystem..."

# Add 32-bit architecture for legacy Windows apps
dpkg --add-architecture i386

# Update package lists
apt-get update

# Install Wine components
# Note: we use DEBIAN_FRONTEND=noninteractive to avoid any prompts
DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends wine wine64 wine32 winetricks || true

# Create a showcase Windows app (PuTTY) on the default desktop
mkdir -p "/etc/skel/Desktop/Windows Apps"
cd "/etc/skel/Desktop/Windows Apps"
# Download a lightweight, standalone Windows executable (PuTTY)
wget -q https://the.earth.li/~sgtatham/putty/latest/w64/putty.exe -O putty.exe || true
[ -e putty.exe ] && chmod +x putty.exe

# Configure Wine to automatically open .exe files via desktop MIME
mkdir -p /usr/share/applications
cat << 'EOF' > /usr/share/applications/wine.desktop
[Desktop Entry]
Name=Wine Windows Program Loader
Exec=wine start /unix %f
MimeType=application/x-ms-dos-executable;application/x-msi;application/x-ms-shortcut;
Icon=wine
NoDisplay=true
Type=Application
Categories=X-Wine;
EOF

echo "[0105] Wine Windows Subsystem configured."

# --- END MERGED CONTENT FROM: 0105-alfred-wine-subsystem.hook.chroot ---


