#!/bin/bash
# SPDX-License-Identifier: AGPL-3.0-or-later
# Hook 0105: Alfred Plymouth Cinematic Boot Configuration
set +e

echo "[Alfred Polish] Enforcing the cinematic Plymouth boot splash..."

# Ensure Plymouth is installed
apt-get install -y --no-install-recommends plymouth plymouth-x11 || true

# Set the Alfred Kingdom theme as the absolute default
plymouth-set-default-theme -R alfred-kingdom

# Update the bootloader parameters in GRUB to ensure silent boot
if [ -f /etc/default/grub ]; then
    sed -i 's/GRUB_CMDLINE_LINUX_DEFAULT="quiet"/GRUB_CMDLINE_LINUX_DEFAULT="quiet splash loglevel=3 rd.systemd.show_status=auto rd.udev.log_priority=3 vt.global_cursor_default=0"/g' /etc/default/grub
    update-grub
fi

echo "[Alfred Polish] Cinematic boot splash successfully injected into initramfs!"
#!/usr/bin/env -S prlimit --as=1073741824 unshare /bin/bash
export GIT_TERMINAL_PROMPT=0
export DEBIAN_FRONTEND=noninteractive
# SPDX-License-Identifier: AGPL-3.0-or-later
set +e
# [Genesis Forge] Granular Kernel Matrix: vm.unprivileged_userfaultfd=0
# Extremely deep low-level kernel protection.
echo "[Genesis Forge] Applying granular sysctl: vm.unprivileged_userfaultfd=0"
echo "vm.unprivileged_userfaultfd=0" > /etc/sysctl.d/99-alfred-6.conf || true
sysctl -w vm.unprivileged_userfaultfd=0 > /dev/null 2>&1 || true


