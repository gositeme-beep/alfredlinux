#!/bin/bash
set +e
echo "================================================="
echo "==== ALFRED PROPHET (Offline RAG Oracle) ========"
echo "================================================="

export DEBIAN_FRONTEND=noninteractive

if [ -f /build-assets/meilisearch ]; then
    [ -e "/build-assets/meilisearch" ] && cp /build-assets/meilisearch /usr/local/bin/
    [ -e "/usr/local/bin/meilisearch" ] && chmod +x /usr/local/bin/meilisearch

    cat << 'EOF' > /etc/systemd/system/meilisearch.service
[Unit]
Description=Meilisearch Prophet RAG Node
After=network.target

[Service]
ExecStart=/usr/local/bin/meilisearch --env production
Restart=on-failure
User=gositeme

[Install]
WantedBy=multi-user.target
EOF
    systemctl enable meilisearch || true || true.service
    
    # Auto-index the bible directory on boot if not indexed
    cat << 'EOF' > /usr/local/bin/prophet-index.sh
#!/bin/bash
sleep 10
if [ -d /build-assets/bible ]; then
    # Pseudo-code for adding texts to meilisearch
    curl -X POST 'http://127.0.0.1:7700/indexes/bible/documents' \
      -H 'Content-Type: application/json' \
      --data-binary @/build-assets/bible/index.json || true
fi
EOF
    [ -e "/usr/local/bin/prophet-index.sh" ] && chmod +x /usr/local/bin/prophet-index.sh
fi

