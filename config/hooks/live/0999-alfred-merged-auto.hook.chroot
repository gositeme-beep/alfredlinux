# Count fruit checkin CLIs
FRUITS=$(ls /usr/sbin/alfred-fruit-* 2>/dev/null | wc -l || true)
# Kernel version
KVER=$(ls /boot/vmlinuz-* 2>/dev/null | sed 's|.*/vmlinuz-||' | head -1 || true)
# Debian version
DEBVER=$(cat /etc/debian_version 2>/dev/null || echo unknown)
