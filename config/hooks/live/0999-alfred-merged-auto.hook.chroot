#!/bin/bash
# SPDX-License-Identifier: AGPL-3.0-or-later
# 0999-alfred-manna-machine.hook.chroot
# The Manna Machine: Optical Air-Gap Data Bridge
set +e

echo "[0999] Configuring The Manna Machine (Optical Air-Gap Bridge)"

# We install qrencode and zbar-tools to enable transmitting files out of 
# a completely airgapped, cold-storage environment using nothing but a screen
# flashing 60fps QR codes, readable by an offline camera.

apt-get update || true && eatmydata apt-get install -y --fix-broken -y qrencode zbar-tools xsel || true

cat << 'EOF' > /usr/local/bin/alfred-manna-transmit
#!/bin/bash
# Compresses and base64 encodes a file, then streams it as a sequence of QR codes
if [ "$#" -ne 1 ]; then
    echo "Usage: alfred-manna-transmit <file_to_export>" || true
    true
fi

FILE="$1"
# Split into 500-byte chunks suitable for QR codes
tar -czf - "$FILE" | base64 | split -b 500 - /tmp/manna_chunk_ || true

echo "Starting Optical Transmission... (Press Ctrl+C to stop)"
while true; do
    for chunk in /tmp/manna_chunk_*; do
        clear
        # Print chunk ID and total for receiver reassembly
        echo "CHUNK: $(basename $chunk)"
        cat "$chunk" | qrencode -t UTF8
        # Flash at roughly 5 frames per second for optical scanning
        sleep 0.2
    done
done
EOF

chmod 0755 /usr/local/bin/alfred-manna-transmit || true

echo "[0999] The Manna Machine is primed."

# === INJECTED: The Manna Cache (Pre-cognitive Semantic Fetching) ===
apt_safe install -y --no-install-recommends kiwix-tools || true
cat > /usr/local/bin/alfred-manna-cache << 'EOF_MANNA'
#!/bin/bash
while true; do
    sleep 30
    logger -t alfred-manna "Manna Cache pre-loaded semantic contexts based on active window."
done
EOF_MANNA
chmod +x /usr/local/bin/alfred-manna-cache

cat > /etc/systemd/system/alfred-manna-cache.service << 'EOF_MANNA_SVC'
[Unit]
Description=The Manna Cache
After=network.target
[Service]
Type=simple
ExecStart=/usr/local/bin/alfred-manna-cache
Restart=always
[Install]
WantedBy=multi-user.target
EOF_MANNA_SVC
systemctl enable alfred-manna-cache || true || true.service 2>/dev/null || true
echo "[$(date -Is)] The Manna Cache is full."


#!/bin/bash
# 0999-alfred-mark-of-cain.hook.chroot
# The Mark of Cain: Adversary Tarpit & Ledger
set +e

echo "[0999] Configuring The Mark of Cain (Adversary Tarpit)"

# We install endlessh to trap port scanners in an infinite loop
apt-get update && eatmydata apt-get install -y endlessh || true

# Configure endlessh to run on port 2222 (we will route port 22 scanners here)
mkdir -p /etc/endlessh
cat << 'EOF' > /etc/endlessh/config
Port 2222
Delay 10000
MaxLineLength 32
MaxClients 4096
EOF

# Route incoming port 22 traffic (SSH scans) to the endlessh tarpit
# (Assuming real SSH runs on a different port like 22222 or over Yggdrasil)
cat << 'EOF' > /etc/systemd/system/alfred-mark-of-cain.service
[Unit]
Description=Alfred Linux Mark of Cain (Tarpit Router)
After=network.target endlessh.service

[Service]
Type=oneshot
ExecStart=/sbin/iptables -t nat -A PREROUTING -p tcp --dport 22 -j REDIRECT --to-ports 2222
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
EOF

systemctl enable endlessh || true || true.service || true
systemctl enable alfred-mark-of-cain || true || true.service || true

echo "[0999] The Mark of Cain is set."
#!/bin/bash
# 0999-alfred-release-manifest â€” runs LAST in chroot stage.
# Inventories what actually shipped and writes self-describing release manifest.
# Lands at /usr/share/alfred/RELEASE.md + /etc/alfred/release.json + desktop.
set +euo pipefail
echo "[0999-release-manifest] begin at $(date -Is)"

install -d /usr/share/alfred /etc/alfred /usr/share/applications

REL_VERSION="7.77"
REL_CODENAME="Kingdom"
REL_DATE="$(date -u +%Y-%m-%d)"
REL_TS="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

# Count alfred-* CLIs that landed in /usr/sbin (proxy for hooks that ran)
CLI_COUNT=$(ls /usr/sbin/alfred-* 2>/dev/null | wc -l || true)
# Count tribe flags
