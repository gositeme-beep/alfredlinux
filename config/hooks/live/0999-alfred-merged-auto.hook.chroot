SDE="${SOURCE_DATE_EPOCH:-unknown}"

# â”€â”€ /etc/alfred/release.json â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
cat >/etc/alfred/release.json <<JSON
{
