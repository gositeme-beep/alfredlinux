# --- BEGIN MERGED CONTENT FROM: 0155-alfred-windows-binfmt.hook.chroot ---
#!/bin/bash
# Hook 0155: Universal Translation Layer (Windows EXE binfmt_misc Registration)
set +e

echo "[Alfred Kernel Ascension] Hacking Linux binfmt_misc for native Windows execution..."

# Install Wine and the binfmt-support framework
export DEBIAN_FRONTEND=noninteractive
apt-get install -y --no-install-recommends wine64 binfmt-support || true

# Write the physical kernel binary format registration for MZ (Windows EXE) headers
mkdir -p /usr/share/binfmts
cat << 'EOF' > /usr/share/binfmts/wine
package wine
detector /usr/lib/wine/wine-binfmt-detector
interpreter /usr/local/bin/alfred-wine-wrapper
magic MZ
EOF

# Import the new binary format into the active kernel registry
# During live-build chroot, binfmt-support will automatically compile this into the final image
update-binfmts --import wine || true

echo "[Alfred Kernel Ascension] Windows .exe Kernel Registry successfully injected!"

# --- END MERGED CONTENT FROM: 0155-alfred-windows-binfmt.hook.chroot ---


#!/bin/bash
