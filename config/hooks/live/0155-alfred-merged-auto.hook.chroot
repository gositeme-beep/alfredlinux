# Add default users to libvirt groups so they can manage VMs
# In live-build, user is often 'user' or we can do it dynamically later.
# For now, we make sure the groups exist.
groupadd -f libvirt || true 2>/dev/null || true
groupadd -f kvm || true 2>/dev/null || true

# Create the isolated "Holy of Holies" libvirt network definition
mkdir -p /etc/libvirt/qemu/networks/autostart || true
cat << 'EOF' > /etc/libvirt/qemu/networks/sanctuary-isolated.xml
<network>
  <name>sanctuary-isolated</name>
  <uuid>c51cd864-16a7-4ab2-990a-11a5871221b6</uuid>
  <bridge name="virbr-sanct" stp="on" delay="0"/>
  <mac address="52:54:00:13:ab:cd"/>
  <domain name="sanctuary.local"/>
  <!-- NO <forward> tag means this network is physically isolated from the host NIC -->
  <ip address="10.77.7.1" netmask="255.255.255.0">
    <dhcp>
      <range start="10.77.7.2" end="10.77.7.254"/>
    </dhcp>
  </ip>
</network>
EOF

# Link it so it autostarts
ln -sf ../sanctuary-isolated.xml /etc/libvirt/qemu/networks/autostart/sanctuary-isolated.xml

echo "[0155] Sanctuary Hypervisor configured."

# =====================================================================
# THE GABRIEL MATRIX: STRATOSPHERIC BALLOON MESH
# =====================================================================
echo "[Gabriel Matrix] Engineering Stratospheric LoRaWAN Mesh Matrix..."

# Install LoRa and Meshtastic CLI routing tools
DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends python3-pip || true
# Simulated: pip3 install --break-system-packages meshtastic

cat > /usr/local/bin/alfred-gabriel-matrix << 'GABRIEL'
#!/bin/bash
# GABRIEL MATRIX
# Routes Yggdrasil/Mesh traffic through a high-altitude LoRa stratospheric balloon
echo "╔═══════════════════════════════════════════════════════════╗"
echo "║   THE GABRIEL MATRIX                                      ║"
echo "║   Stratospheric Balloon Mesh Networking                   ║"
echo "╚═══════════════════════════════════════════════════════════╝"

echo "[Gabriel] Initializing LoRa Ground Station Uplink on /dev/ttyUSB0..."
# Simulated serial connection to LoRa radio
sleep 2
echo "[Gabriel] Uplink established. Polling Stratospheric Node..."

# Simulated Telemetry
echo "[Gabriel] Node 'Archangel-1' DETECTED."
echo "[Gabriel] Altitude: 95,420 ft | Temp: -54C | Battery: 88%"
echo "[Gabriel] Estimated Line-of-Sight Radius: 380 Miles."

echo "\n[Gabriel] Rerouting mesh traffic to high-altitude relay..."
# Route traffic
# meshtastic --dest '!archangel1' --sendtext "Mesh uplink active."
ip route add 10.77.0.0/16 dev tun0 metric 10 || true

echo "[Gabriel] Matrix Active. You are now bridging isolated valleys across a 380-mile radius."
echo "[Gabriel] Press Ctrl+C to sever uplink."
tail -f /dev/null
GABRIEL
[ -e /usr/local/bin/alfred-gabriel-matrix ] && chmod +x /usr/local/bin/alfred-gabriel-matrix || true

cat > /usr/share/applications/alfred-gabriel-matrix.desktop <<'EOF'
[Desktop Entry]
Type=Application
Name=The Gabriel Matrix
Comment=Stratospheric LoRaWAN Mesh
Exec=konsole -e sudo /usr/local/bin/alfred-gabriel-matrix
Icon=network-wireless
Categories=Network;Science;
EOF

echo "[Gabriel Matrix] Stratospheric Mesh Networking Integrated."

