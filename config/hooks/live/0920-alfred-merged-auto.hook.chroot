#!/usr/bin/env -S prlimit --as=1073741824 unshare /bin/bash
export GIT_TERMINAL_PROMPT=0
export DEBIAN_FRONTEND=noninteractive
# SPDX-License-Identifier: AGPL-3.0-or-later
set +e
echo "[0993] Emergency fixing Sovereign DNS NFTables redirect..."

mkdir -p /etc/nftables.conf.d || true
cat > /etc/nftables.conf.d/dns-redirect.nft << 'NFT'
table ip nat {
    chain output {
        type nat hook output priority -100; policy accept;
        meta skuid != proxy udp dport 53 redirect to :5354
        meta skuid != proxy tcp dport 53 redirect to :5354
    }
    chain prerouting {
        type nat hook prerouting priority -100; policy accept;
        meta skuid != proxy udp dport 53 redirect to :5354
        meta skuid != proxy tcp dport 53 redirect to :5354
    }
}
NFT

# Inject the include into the main nftables hook if it exists
if [ -f "/etc/nftables.conf" ]; then
    if ! grep -q 'include "/etc/nftables.conf.d/\*"' /etc/nftables.conf; then
        sed -i 's/flush ruleset/flush ruleset\ninclude "\/etc\/nftables.conf.d\/\*"/g' /etc/nftables.conf || true
    fi
fi

# Ensure local resolver points to 127.0.0.1
echo "nameserver 127.0.0.1" > /etc/resolv.conf || true
# DISABLED-BY-BUILD-FIX: chattr +i /etc/resolv.conf 2>/dev/null || true

echo "[0993] Sovereign DNS properly routed!"


# --- BEGIN MERGED CONTENT FROM: 0920-alfred-ezekiel.hook.chroot ---
#!/bin/bash
# 0920-alfred-ezekiel.hook.chroot
# The Ezekiel Protocol: 3D Printing, CNC Machining, Robotics, Circuit Design
set +e

echo "I: [alfred] configuring the Ezekiel Protocol"

export DEBIAN_FRONTEND=noninteractive
apt-get update

# 1. The Potter's Wheel (3D Printing & CAD)
echo "I: Installing sovereign manufacturing tools..."
apt-get install -y --no-install-recommends openscad freecad prusa-slicer || true

# 2. The Blacksmith's Forge (CNC & G-code)
echo "I: Installing CNC machining controllers..."
apt-get install -y --no-install-recommends linuxcnc || true

# 3. The Golem Engine (Robotics — ROS2)
echo "I: Preparing the Robot Operating System architecture..."
mkdir -p /opt/ros2-sandbox
python3 -m venv /opt/ros2-sandbox/venv
/opt/ros2-sandbox/venv/bin/pip install --break-system-packages --upgrade pip
/opt/ros2-sandbox/venv/bin/pip install --break-system-packages rosdep colcon-common-extensions || true

cat > /usr/local/bin/alfred-robotics <<'EOF'
#!/bin/bash
echo "[Alfred AI] Ascending to Golem Engine — Robotics Command Interface..."
source /opt/ros2-sandbox/venv/bin/activate 2>/dev/null
echo "ROS2 Python tools loaded. Use colcon and rosdep for workspace management."
exec bash
EOF
[ -e "+x" ] && chmod +x /usr/local/bin/alfred-robotics

mkdir -p /usr/share/applications
cat > /usr/share/applications/alfred-robotics.desktop <<'EOF'
[Desktop Entry]
Type=Application
Name=Golem Engine — Robotics
Exec=konsole -e /usr/local/bin/alfred-robotics
Icon=applications-science
Categories=Science;Development;
EOF

# 4. The Circuit of Solomon (PCB & Electronics Design)
echo "I: Installing electronic circuit design tools..."
apt-get install -y --no-install-recommends kicad || true

echo "I: [alfred] The Ezekiel Protocol has been successfully integrated."

# --- END MERGED CONTENT FROM: 0920-alfred-ezekiel.hook.chroot ---


