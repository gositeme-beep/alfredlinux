#!/bin/bash
# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
# 0920-alfred-justice-engine.hook.chroot
# Phase 4: The Arsenal â€” Autonomous Justice Execution
# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
set +e
echo "â•”â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•—"
echo "â•‘  [0920] PHASE 4 â€” Justice Engine (Automated Execution)    â•‘"
echo "â•šâ•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•"

apt-get install -y --no-install-recommends nftables jq curl 2>/dev/null || true

# â”€â”€ 1. Initialize nftables set for blocked actors â”€â”€
cat > /etc/nftables.conf << 'NFT'
#!/usr/sbin/nft -f
flush ruleset

table inet filter {
    set blocked_ipv4 {
        type ipv4_addr
        flags interval
    }
    set blocked_ipv6 {
        type ipv6_addr
        flags interval
    }

    chain input {
        type filter hook input priority 0; policy accept;
        
        # Drop blocked actors instantly
        ip saddr @blocked_ipv4 drop
        ip6 saddr @blocked_ipv6 drop
        
        # Accept loopback
        iif "lo" accept
    }
}
NFT

systemctl enable nftables || true || true 2>/dev/null || true

# â”€â”€ 2. Create the Justice Daemon â”€â”€
cat > /usr/local/bin/alfred-justice.sh << 'JUSTICE'
#!/bin/bash
# Alfred Linux â€” Justice Engine
# Pulls the blocked ledger from the API and physically isolates threats

API_URL="http://api.gositeme.com/api/threat-intel.php?action=blocked"

log() { echo "[$(date -Iseconds)] [JUSTICE] $*"; }

enforce_blocks() {
    # Fetch blocked actors
    JSON=$(curl -s --max-time 10 "$API_URL") || return
    
    # Extract IPs
    IPS=$(echo "$JSON" | jq -r '.blocked[] | select(.source_ip != null) | .source_ip')
    
    # We rebuild the nftables set every cycle
    nft flush set inet filter blocked_ipv4 2>/dev/null || true
    nft flush set inet filter blocked_ipv6 2>/dev/null || true
    
    for ip in $IPS; do
        if [[ "$ip" == *":"* ]]; then
            nft add element inet filter blocked_ipv6 { $ip } 2>/dev/null || true
            log "Execution: Dropped IPv6 -> $ip"
        else
            nft add element inet filter blocked_ipv4 { $ip } 2>/dev/null || true
            log "Execution: Dropped IPv4 -> $ip"
        fi
    done
}

while true; do
    enforce_blocks
    sleep 30
done
JUSTICE
[ -e "+x" ] && chmod +x /usr/local/bin/alfred-justice.sh

# â”€â”€ 3. Create systemd service â”€â”€
cat > /etc/systemd/system/alfred-justice.service << 'JSVC'
[Unit]
Description=Alfred Linux Justice Engine
After=nftables.service network.target

[Service]
Type=simple
ExecStart=/usr/local/bin/alfred-justice.sh
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
JSVC

systemctl enable alfred-justice || true || true.service 2>/dev/null || true

echo "â•”â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•—"
echo "â•‘  [0920] Justice Engine â€” COMPLETE                         â•‘"
echo "â•‘  âœ“ nftables base firewall configured                      â•‘"
echo "â•‘  âœ“ Autonomous execution daemon installed                  â•‘"
echo "â•šâ•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•"

