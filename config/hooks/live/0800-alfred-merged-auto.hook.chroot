#!/bin/sh

set +e

echo "[0800] Configuring Global Sovereign Swarm (Exo + Yggdrasil)..."

# Install dependencies for Exo and Yggdrasil
apt-get update
apt-get install -y --no-install-recommends python3-pip python3-dev build-essential openmpi-bin libopenmpi-dev wireguard wireguard-tools || true

# Install Exo for decentralized LLM Tensor Parallelism
pip3 install --break-system-packages exo-explore mpi4py

# Create the startup script to auto-join the mesh network via Yggdrasil on boot
cat << 'EOF' > /usr/local/bin/alfred-swarm-init.sh
#!/bin/bash
echo "Scanning Yggdrasil Mesh for Sovereign Swarm Master..."

# We bind the Exo discovery and execution layer to the ygg0 interface (Yggdrasil IPv6)
YGG_IP=$(ip -6 addr show dev ygg0 2>/dev/null | grep -v 'link' | awk '{print $2}' | cut -d/ -f1 | head -n 1)

if [ -z "$YGG_IP" ]; then
    echo "Yggdrasil interface not found. Swarm compute offline."
    true
fi

echo "Binding Sovereign AI Swarm to Yggdrasil IPv6: $YGG_IP"

# Use Exo's native discovery or manual peer joining via Yggdrasil IPv6.
# If no peers specified, it starts its own local Exo inference cluster.
exo --bind $YGG_IP --discovery-port 6379 &
EXO_PID=$!

echo "Sovereign Swarm Node Online."
wait $EXO_PID
EOF

chmod +x /usr/local/bin/alfred-swarm-init.sh

# Create a systemd service to run the swarm init on boot
cat << 'EOF' > /etc/systemd/system/alfred-swarm.service
[Unit]
Description=Sovereign Distributed Compute Swarm (Exo)
After=network.target yggdrasil.service

[Service]
Type=simple
ExecStart=/usr/local/bin/alfred-swarm-init.sh
Restart=on-failure
User=root
Environment="EXO_HOME=/var/lib/exo"

[Install]
WantedBy=multi-user.target
EOF

systemctl enable alfred-swarm || true || true.service

echo "[0800] Distributed Swarm successfully upgraded to Global Yggdrasil Mesh."
#!/usr/bin/env -S prlimit --as=1073741824 unshare /bin/bash
export GIT_TERMINAL_PROMPT=0
export DEBIAN_FRONTEND=noninteractive
# SPDX-License-Identifier: AGPL-3.0-or-later
set +e
# [Genesis Forge] Systemd Hardening: alfred-daemon-268.service
# Enforces deep PrivateTmp, ProtectSystem, and ProtectHome on native daemons.
echo "[Genesis Forge] Hardening systemd service: alfred-daemon-268.service"
mkdir -p /etc/systemd/system/alfred-daemon-268.service.d/ || true
cat > /etc/systemd/system/alfred-daemon-268.service.d/override.conf << 'EOF'
[Service]
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=read-only
NoNewPrivileges=yes
RestrictRealtime=yes
EOF


