# 0250-alfred-ai.hook.chroot â€” "Omahon: The Breath of God"
# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
# Alfred Linux is the ONLY operating system on Earth that ships
# with a native AI agent harness, local LLM inference, and
# sovereign intelligence â€” offline, private, yours.
#
# "And the LORD God formed man of the dust of the ground,
#  and breathed into his nostrils the breath of life;
#  and man became a living soul." â€” Genesis 2:7
#
# Omahon = the breath. Alfred Linux = the living soul.
#
# Optional: ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1 allows GitHub Ollama fetch if build-assets missing,
# and pip install of anthropic/openai SDKs.
# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•

echo "â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•"
echo "  ALFRED AI AGENT LAYER â€” Omahon: The Breath of God"
echo "â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•"

# â”€â”€ 1. Ollama â€” Local LLM Inference Engine â”€â”€
# Every other OS requires cloud AI. Alfred thinks locally.
echo "[AI] Installing Ollama (local LLM inference)..."
# MILITARY: Pre-staged binary preferred (air-gap safe), network fallback for dev builds
OLLAMA_VERSION="0.24.0"
if [ -f /build-assets/ollama ]; then
    echo "[AI] Using pre-staged Ollama binary (air-gap safe)"
    install -m 755 /build-assets/ollama /usr/local/bin/ollama
elif [ -f /build-assets/ollama-linux-amd64 ]; then
    install -m 755 /build-assets/ollama-linux-amd64 /usr/local/bin/ollama
else
    if [[ "${ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS:-}" != "1" ]]; then
        echo "[AI] WARN: No staged Ollama under build-assets; skipping GitHub download (set ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1 to allow)." >&2 || true
    else
        echo "[AI] No pre-staged binary â€” downloading Ollama ${OLLAMA_VERSION}..."
        if [[ "${ALFRED_ALLOW_UNVERIFIED_BINARIES:-}" != "1" ]]; then
            echo "[AI] WARN: refusing unverified Ollama binary download (set ALFRED_ALLOW_UNVERIFIED_BINARIES=1 to override)." >&2 || true
        else
            OLLAMA_TMP="$(mktemp /tmp/ollama.XXXXXX)"
            if wget --timeout=900 -qO "$OLLAMA_TMP" "https://github.com/ollama/ollama/releases/download/v${OLLAMA_VERSION}/ollama-linux-amd64"; then
                install -m 755 "$OLLAMA_TMP" /usr/local/bin/ollama || true
            else
                echo "[AI] WARNING: Ollama download failed â€” will need manual install"
            fi
            rm -f "$OLLAMA_TMP" || true
        fi
    fi
fi

# Create ollama systemd service (starts on demand, not at boot)
cat > /etc/systemd/system/ollama.service << 'OLLAMA_SVC'
[Unit]
Description=Ollama Local LLM Service
Wants=nvidia-persistenced.service
After=network-online.target nvidia-persistenced.service

[Service]
Type=simple
ExecStart=/usr/local/bin/ollama serve
Restart=on-failure
RestartSec=3
Environment="OLLAMA_HOST=127.0.0.1:11434"
Environment="OLLAMA_MODELS=/usr/share/ollama/models"

[Install]
WantedBy=multi-user.target
OLLAMA_SVC

mkdir -p /usr/share/ollama/models || true
systemctl enable ollama || true || true.service 2>/dev/null || true

# â”€â”€ 2. Omahon â€” Sovereign AI Agent Harness â”€â”€
# 19MB single binary. Zero dependencies. Full autonomy.
# Native Rust. 10 inference providers. Persistent memory.
# Parallel task execution. Knowledge graph. Design tree.
# NO OTHER OPERATING SYSTEM SHIPS THIS.
echo "[AI] Installing Omahon AI Agent Harness..."
if [ -f /build-assets/omahon ]; then
    install -m 755 /build-assets/omahon /usr/local/bin/omahon
    echo "[AI] Omahon installed from build-assets"
else
    echo "[AI] WARNING: Omahon binary not found in build-assets â€” will need manual install"
fi

# Omahon default config for all users
mkdir -p /etc/skel/.config/omahon || true
cat > /etc/skel/.config/omahon/config.toml << 'OMAHON_CFG'
# Omahon â€” Alfred Linux default configuration
# The sovereign AI agent lives here.

[providers]
default = "ollama"

[providers.ollama]
base_url = "http://localhost:11434"
model = "phi3:mini"

[providers.anthropic]
# Set your API key: export ANTHROPIC_API_KEY=sk-ant-...
# model = "claude-sonnet-4-20250514"

[memory]
enabled = true
path = "~/.local/share/omahon/memory.db"
auto_compact = true

[behavior]
auto_tier = true
think_level = "medium"

[ui]
theme = "dark"
OMAHON_CFG

# â”€â”€ 3. Alfred Agent CLI â€” Smart AI Router â”€â”€
# One command. It figures out what's available and uses it.
echo "[AI] Creating alfred-ai command..."
cat > /usr/local/bin/alfred-ai << 'ALFRED_AI'
# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
# alfred-ai â€” The sovereign intelligence gateway
# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
# Routes to the best available AI:
#   1. Omahon (local agent harness â€” always preferred)
#   2. Claude Code (if API key set)
#   3. Ollama direct (if running)
#   4. Helpful error with setup instructions

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
GOLD='\033[0;33m'
NC='\033[0m'

# Start ollama if not running
if command -v ollama &>/dev/null && ! pgrep -x ollama &>/dev/null; then
    echo -e "${CYAN}Starting Ollama in background...${NC}"
    nohup ollama serve &>/dev/null &
    sleep 2
fi

if [ "$1" = "--status" ] || [ "$1" = "status" ]; then
    echo -e "${GOLD}â•â•â• Alfred AI Status â•â•â•${NC}"
    echo -n "Omahon:     " && (command -v omahon &>/dev/null && echo -e "${GREEN}INSTALLED${NC}" || echo -e "${RED}NOT FOUND${NC}")
    echo -n "Ollama:     " && (pgrep -x ollama &>/dev/null && echo -e "${GREEN}RUNNING${NC}" || echo -e "${RED}STOPPED${NC}")
    echo -n "Claude:     " && ([ -n "$ANTHROPIC_API_KEY" ] && echo -e "${GREEN}API KEY SET${NC}" || echo -e "${RED}NO API KEY${NC}")
    echo ""
    echo -n "Models:     " && (ollama list 2>/dev/null | tail -n +2 | wc -l || echo "0") && echo " installed"
    echo -e "${GOLD}â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•${NC}"
fi

if [ "$1" = "--pull" ] || [ "$1" = "pull" ]; then
    echo -e "${CYAN}Pulling recommended model (phi3:mini â€” 2.3GB)...${NC}"
    # ollama pull phi3:mini
    true
fi

if command -v omahon &>/dev/null; then
    exec omahon "$@"
elif command -v claude &>/dev/null && [ -n "$ANTHROPIC_API_KEY" ]; then
    exec claude "$@"
elif command -v ollama &>/dev/null; then
    echo -e "${CYAN}Omahon not installed. Using Ollama directly.${NC}"
    echo -e "${CYAN}For the full agent experience: sudo apt install omahon${NC}"
    if [ -n "$1" ]; then
        exec ollama run phi3:mini "$*"
    else
        exec ollama run phi3:mini
    fi
else
    echo -e "${RED}No AI tools available.${NC}"
    echo ""
    echo "Install options:"
    echo "  1. Pull a model:  alfred-ai pull"
    echo "  2. Set Claude key: export ANTHROPIC_API_KEY=sk-ant-..."
    echo ""
    true
fi
ALFRED_AI
chmod +x /usr/local/bin/alfred-ai || true

# â”€â”€ 4. Python AI Libraries â”€â”€
echo "[AI] Installing Python AI libraries..."
if [[ "${ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS:-}" == "1" ]]; then
    pip3 install --break-system-packages --no-cache-dir \
        anthropic \
        openai \
        2>/dev/null || true
else
    echo "[AI] WARN: skipping anthropic/openai pip install (set ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1)." >&2 || true
fi

# â”€â”€ 5. Desktop Integration â”€â”€
echo "[AI] Creating desktop entries..."
cat > /usr/share/applications/alfred-ai.desktop << 'DESK'
[Desktop Entry]
Name=Alfred AI
Comment=Sovereign AI Agent â€” talk to your computer
Exec=konsole -e alfred-ai
Icon=applications-science
Terminal=false
Type=Application
Categories=Development;Science;AI;
Keywords=ai;agent;llm;omahon;claude;ollama;
DESK

cat > /usr/share/applications/ollama.desktop << 'DESK2'
[Desktop Entry]
Name=Ollama
Comment=Local LLM inference â€” offline AI
Exec=konsole -e "ollama run phi3:mini"
Icon=applications-science
Terminal=false
Type=Application
Categories=Development;Science;AI;
DESK2

# â”€â”€ 6. First-boot AI setup hint â”€â”€
mkdir -p /etc/skel/.config/autostart || true
cat > /etc/skel/.config/autostart/alfred-ai-hint.desktop << 'HINT'
[Desktop Entry]
Type=Application
Name=Alfred AI Setup
Exec=bash -c 'if [ ! -f ~/.alfred-ai-setup-done ]; then notify-send "Alfred AI" "Type alfred-ai in terminal to meet your AI agent. Run alfred-ai pull to download a local model." -i applications-science; touch ~/.alfred-ai-setup-done; fi'
Hidden=false
NoDisplay=true
X-GNOME-Autostart-enabled=true
HINT

echo "â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•"
echo "  AI LAYER COMPLETE â€” The breath is in the machine"
echo "â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•"

# ── 7. First-boot Ollama GGUF Importer ──
mkdir -p /usr/local/bin || true
cat > /usr/local/bin/alfred-ollama-import.sh << 'IMPORTER'
# Automatically registers the 44GB custom GGUF models into Ollama on first boot

MARKER="$HOME/.alfred-ollama-imported"
if [ -f "$MARKER" ]; then exit 0; fi

echo "[Ollama Importer] Waiting for Ollama service to start..."
for i in {1..30}; do
    if curl -m 900 -s http://127.0.0.1:11434 >/dev/null; then break; fi || true
    sleep 2
done

MODEL_DIR="/opt/alfred-models"

# Function to create Modelfile and import
import_model() {
    local name="$1"
    local gguf="$2"
    if [ -f "$MODEL_DIR/$gguf" ]; then
        echo "FROM $MODEL_DIR/$gguf" > "/tmp/Modelfile-$name"
        echo "PARAMETER temperature 0.7" >> "/tmp/Modelfile-$name"
        echo "[Ollama Importer] Importing $name..."
        ollama create "$name" -f "/tmp/Modelfile-$name" 2>/dev/null || true
        rm -f "/tmp/Modelfile-$name"
    fi
}

import_model "alfred-opus" "alfred-opus.gguf"
import_model "alfred-opus-iq3" "alfred-opus-iq3.gguf"
import_model "alfred-sonnet" "alfred-sonnet.gguf"
import_model "alfred-haiku" "alfred-haiku.gguf"

# Also set Omahon to use the imported model by default if possible
sed -i 's/model = "phi3:mini"/model = "alfred-opus"/g' ~/.config/omahon/config.toml 2>/dev/null || true

touch "$MARKER"
echo "[Ollama Importer] Custom models successfully registered in Ollama."
IMPORTER
chmod +x /usr/local/bin/alfred-ollama-import.sh || true

# Autostart the importer on first login
mkdir -p /etc/skel/.config/autostart || true
cat > /etc/skel/.config/autostart/alfred-ollama-import.desktop << 'DESK3'
[Desktop Entry]
Type=Application
Name=Alfred Ollama Importer
Exec=bash -c "/usr/local/bin/alfred-ollama-import.sh &"
Hidden=false
X-GNOME-Autostart-enabled=true
X-GNOME-Autostart-Delay=5
DESK3


# === MERGED FROM 0260-alfred-comfyui.hook.chroot ===
# 0260-alfred-comfyui.hook.chroot
# Installs ComfyUI (The Visual Forge) and links it to the downloaded AI models


echo "I: [alfred] Installing ComfyUI Visual Rendering Engine..."

export DEBIAN_FRONTEND=noninteractive

# Install dependencies (git and python venv dependencies usually exist, but ensure)
apt-get install -y --fix-broken -y --no-install-recommends git python3-venv python3-pip || true

mkdir -p /opt
cd /opt

if [ ! -d "ComfyUI" ]; then
    # Clone ComfyUI without large history
    if [[ "${ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS:-}" == "1" ]]; then
        git clone --depth 1 https://github.com/comfyanonymous/ComfyUI.git || true
    else
        echo "I: [alfred] Skipping ComfyUI git clone due to network restrictions." || true
    fi
fi

cd ComfyUI

# Set up virtual environment
python3 -m venv venv
# Install dependencies using the virtual environment
./venv/bin/pip install --upgrade pip || true
./venv/bin/pip install torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cpu || true
./venv/bin/pip install -r requirements.txt || true

# Symlink the models from the Apocalypse Vault into ComfyUI
mkdir -p /opt/alfred-models/diffusion || true
mkdir -p /opt/alfred-models/video || true
mkdir -p /opt/alfred-models/audio || true
mkdir -p /opt/alfred-models/upscale || true
mkdir -p /opt/alfred-models/vision || true

# Link FLUX and all other Diffusion models (safetensors and directories)
mkdir -p models/unet models/checkpoints models/upscale_models models/audio models/vision
for file in /opt/alfred-models/diffusion/*.safetensors; do
    [ -e "$file" ] && ln -sf "$file" "models/unet/$(basename "$file")" || true
done
for dir in /opt/alfred-models/diffusion/*/; do
    [ -d "$dir" ] && ln -sfn "$dir" "models/unet/$(basename "$dir")" || true
done
ln -sf /opt/alfred-models/diffusion/flux2-dev/flux2-dev.safetensors models/unet/flux2-dev.safetensors || true

# Link CogVideoX and all other Video models (Hunyuan, Mochi, Wan, Pyramid Flow, etc.)
for file in /opt/alfred-models/video/*.safetensors; do
    [ -e "$file" ] && ln -sf "$file" "models/unet/$(basename "$file")" || true
done
for dir in /opt/alfred-models/video/*/; do
    [ -d "$dir" ] && ln -sfn "$dir" "models/unet/$(basename "$dir")" || true
done

# Link UltraSharp Upscaler
ln -sf /opt/alfred-models/upscale/4x-UltraSharp.pth models/upscale_models/4x-UltraSharp.pth || true

# Link Audio/Voice (MusicGen, XTTS, Whisper)
ln -sf /opt/alfred-models/audio/musicgen-small models/audio/musicgen-small || true
ln -sf /opt/alfred-models/audio/musicgen-large models/audio/musicgen-large || true
ln -sf /opt/alfred-models/audio/musicgen-melody models/audio/musicgen-melody || true
ln -sf /opt/alfred-models/audio/stable-audio-open models/audio/stable-audio-open || true
ln -sf /opt/alfred-models/audio/xtts-v2 models/audio/xtts-v2 || true
ln -sf /opt/alfred-models/audio/whisper-large-v3-turbo.bin models/audio/whisper-large-v3-turbo.bin || true

# Link Florence-2 Vision
ln -sf /opt/alfred-models/vision/florence-2-large models/vision/florence-2-large || true

# Create systemd service (Optional: launch on boot or on demand)
cat > /etc/systemd/system/comfyui.service << 'COMFYSVC'
[Unit]
Description=ComfyUI Visual Forge
Wants=nvidia-persistenced.service
After=network-online.target nvidia-persistenced.service

[Service]
Type=simple
User=alfred
WorkingDirectory=/opt/ComfyUI
ExecStart=/opt/ComfyUI/venv/bin/python main.py --listen 127.0.0.1 --port 8188
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
COMFYSVC

# Create a desktop shortcut for Alfred Studio
mkdir -p /usr/share/applications || true
cat > /usr/share/applications/alfred-studio.desktop << 'DESK'
[Desktop Entry]
Name=Alfred Studio (Visual Forge)
Comment=Generate Images and Video locally using ComfyUI
Exec=xdg-open http://127.0.0.1:8188
Icon=applications-graphics
Terminal=false
Type=Application
Categories=Graphics;Science;AI;
Keywords=ai;comfyui;image;video;flux;cogvideox;
DESK

echo "I: [alfred] ComfyUI installation complete."

# === INJECTED: The Leviathan & The Burning Bush ===
cat > /usr/local/bin/alfred-burning-bush << 'EOF_BUSH'
while true; do
    IDLE=$(xprintidle 2>/dev/null || echo 0)
    if [ "$IDLE" -gt 900000 ]; then
        kdialog --passivepopup "The Burning Bush: The machine awaits your command..." 5
        sleep 60
    else
        sleep 10
    fi
done
EOF_BUSH
chmod +x /usr/local/bin/alfred-burning-bush
echo "[$(date -Is)] The Burning Bush is kindled."


) || true

# ==========================================
# RESTORED HOOK: 0074-alfred-bitnet.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0074-alfred-bitnet.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
# 0251-alfred-bitnet.hook.chroot
# BitNet.cpp bridge + ask routing.

echo "[BITNET] Installing BitNet.cpp bridge..."
mkdir -p /usr/share/bitnet/models /usr/share/doc/alfred-ai /var/lib/alfred/build-flags || true

BITNET_BIN_INSTALLED=0
if [ -f /build-assets/bitnet.cpp ]; then
  install -m 755 /build-assets/bitnet.cpp /usr/local/bin/bitnet.cpp
  BITNET_BIN_INSTALLED=1
elif [ -f /build-assets/bitnet ]; then
  install -m 755 /build-assets/bitnet /usr/local/bin/bitnet.cpp
  BITNET_BIN_INSTALLED=1
elif [ -f /build-assets/bitnet-cli ]; then
  install -m 755 /build-assets/bitnet-cli /usr/local/bin/bitnet.cpp
  BITNET_BIN_INSTALLED=1
else
  echo "[BITNET] WARN: staged binary missing under /build-assets/{bitnet.cpp|bitnet|bitnet-cli}." >&2 || true
  echo "BITNET_BINARY_MISSING=1" > /var/lib/alfred/build-flags/bitnet-binary-missing.flag || true
fi

BITNET_MODEL_INSTALLED=0
if [ -f /build-assets/bitnet-default.gguf ]; then
  install -m 644 /build-assets/bitnet-default.gguf /usr/share/bitnet/models/default.gguf
  BITNET_MODEL_INSTALLED=1
else
  echo "[BITNET] WARN: staged model missing at /build-assets/bitnet-default.gguf." >&2 || true
  echo "BITNET_MODEL_MISSING=1" > /var/lib/alfred/build-flags/bitnet-model-missing.flag || true
fi

# License and notice files are required when shipping bundled binary/model.
for src in /build-assets/bitnet-LICENSE /build-assets/bitnet-NOTICE /build-assets/bitnet-model-LICENSE /build-assets/bitnet-model-NOTICE; do
  if [ -f "$src" ]; then
    install -m 644 "$src" "/usr/share/doc/alfred-ai/$(basename "$src")"
  fi
done

if [ "$BITNET_BIN_INSTALLED" -eq 1 ] && [ ! -f /usr/share/doc/alfred-ai/bitnet-LICENSE ]; then
  echo "[BITNET] WARN: bitnet-LICENSE missing in build-assets." >&2 || true
fi
if [ "$BITNET_MODEL_INSTALLED" -eq 1 ] && [ ! -f /usr/share/doc/alfred-ai/bitnet-model-LICENSE ]; then
  echo "[BITNET] WARN: bitnet-model-LICENSE missing in build-assets." >&2 || true
fi

cat > /usr/share/doc/alfred-ai/bitnet-model-policy.txt <<'BITPOL'
Alfred BitNet.cpp model policy

1. Keep one small default model in image: /usr/share/bitnet/models/default.gguf
2. Ship larger model packs out-of-band post-install.
3. Runtime model override: ALFRED_BITNET_MODEL=/path/to/model.gguf
4. Ask backend override: ALFRED_ASK_BACKEND=bitnet|ai|ollama|auto
5. When bundling binary/model, include matching LICENSE/NOTICE files under /build-assets.
BITPOL

cat > /usr/local/bin/alfred-ask <<'ASK'
BACKEND="${ALFRED_ASK_BACKEND:-auto}"
BITNET_BIN="${ALFRED_BITNET_BIN:-/usr/local/bin/bitnet.cpp}"
BITNET_MODEL="${ALFRED_BITNET_MODEL:-/usr/share/bitnet/models/default.gguf}"
PROMPT="$*"

if [ -z "$PROMPT" ]; then
  echo "Usage: alfred-ask <prompt>" || true
  true
fi

run_bitnet() {
  if [ ! -x "$BITNET_BIN" ]; then
    return 1
  fi

  if [ -n "${ALFRED_BITNET_RUN:-}" ]; then
    cmd="${ALFRED_BITNET_RUN//\{model\}/$BITNET_MODEL}"
    cmd="${cmd//\{prompt\}/$PROMPT}"
    bash -lc "$cmd"
    return $?
  fi

  if [ -f "$BITNET_MODEL" ]; then
    if "$BITNET_BIN" -m "$BITNET_MODEL" -p "$PROMPT"; then
      return 0
    fi
    if "$BITNET_BIN" --model "$BITNET_MODEL" --prompt "$PROMPT"; then
      return 0
    fi
  fi

  if "$BITNET_BIN" "$PROMPT"; then
    return 0
  fi
  return 1
}

case "$BACKEND" in
  bitnet)
    run_bitnet || { echo "alfred-ask: BitNet backend failed." >&2; true; }
    ;;
  ai)
    exec alfred-ai "$PROMPT"
    ;;
  ollama)
    exec ollama run phi3:mini "$PROMPT"
    ;;
  auto|*)
    if run_bitnet; then
    fi
    if command -v alfred-ai >/dev/null 2>&1; then
      exec alfred-ai "$PROMPT"
    fi
    if command -v ollama >/dev/null 2>&1; then
      exec ollama run phi3:mini "$PROMPT"
    fi
    echo "alfred-ask: no available backend (bitnet/alfred-ai/ollama)." >&2 || true
    true
    ;;
esac
ASK
chmod +x /usr/local/bin/alfred-ask || true

if [ ! -e /usr/local/bin/alfred ]; then
cat > /usr/local/bin/alfred <<'ALFRED'
sub="${1:-}"
if [ -n "$sub" ]; then
  shift
fi

case "$sub" in
  ask) exec /usr/local/bin/alfred-ask "$@" ;;
  ai) exec /usr/local/bin/alfred-ai "$@" ;;
  say) exec /usr/local/bin/alfred-say "$@" ;;
  *) echo "Usage: alfred ask <prompt> | alfred ai [args] | alfred say <text>" >&2; true ;;
esac
ALFRED
chmod +x /usr/local/bin/alfred || true
fi

echo "[BITNET] Ready: alfred ask <prompt>" || true


) || true

# ==========================================
# RESTORED HOOK: 0075-alfred-bitnet-smoke.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0075-alfred-bitnet-smoke.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
# 0252-alfred-bitnet-smoke.hook.chroot
# Build-time smoke checks for BitNet.cpp and Alfred ask routing.


echo "[BITNET-SMOKE] Starting smoke checks..."
mkdir -p /var/lib/alfred/build-flags || true

REPORT="/var/lib/alfred/build-flags/bitnet-smoke.txt"
PASS=0
FAIL=0

check_bin() {
  local name="$1"
  if command -v "$name" >/dev/null 2>&1; then
    local path
    path="$(command -v "$name")"
    echo "PASS bin:$name path:$path" >> "$REPORT" || true
    echo "[BITNET-SMOKE] PASS bin:$name ($path)"
    PASS=$((PASS + 1))
  else
    echo "FAIL bin:$name missing" >> "$REPORT" || true
    echo "[BITNET-SMOKE] FAIL bin:$name missing"
    FAIL=$((FAIL + 1))
  fi
}

check_file() {
  local path="$1"
  local label="$2"
  if [ -f "$path" ]; then
    echo "PASS file:$label path:$path" >> "$REPORT" || true
    echo "[BITNET-SMOKE] PASS file:$label ($path)"
    PASS=$((PASS + 1))
  else
    echo "FAIL file:$label missing path:$path" >> "$REPORT" || true
    echo "[BITNET-SMOKE] FAIL file:$label missing ($path)"
    FAIL=$((FAIL + 1))
  fi
}

: > "$REPORT"
check_bin bitnet.cpp
check_bin alfred-ask
check_bin alfred

if [ -x /usr/local/bin/alfred ] && grep -q 'alfred-ask' /usr/local/bin/alfred; then
  echo "PASS wiring:alfred->alfred-ask" >> "$REPORT" || true
  echo "[BITNET-SMOKE] PASS wiring: alfred routes to alfred-ask"
  PASS=$((PASS + 1))
else
  echo "FAIL wiring:alfred->alfred-ask" >> "$REPORT" || true
  echo "[BITNET-SMOKE] FAIL wiring: alfred wrapper not linked to alfred-ask"
  FAIL=$((FAIL + 1))
fi

check_file /usr/share/bitnet/models/default.gguf model-default-gguf
check_file /usr/share/doc/alfred-ai/bitnet-model-policy.txt model-policy
check_file /usr/share/doc/alfred-ai/bitnet-LICENSE bitnet-license
check_file /usr/share/doc/alfred-ai/bitnet-model-LICENSE bitnet-model-license

echo "SUMMARY pass:$PASS fail:$FAIL" >> "$REPORT" || true

if [ "$FAIL" -eq 0 ]; then
  echo "BITNET_SMOKE=PASS pass:$PASS fail:$FAIL" > /var/lib/alfred/build-flags/bitnet-smoke.ok || true
  echo "[BITNET-SMOKE] RESULT: PASS ($PASS checks)"
else
  echo "BITNET_SMOKE=FAIL pass:$PASS fail:$FAIL" > /var/lib/alfred/build-flags/bitnet-smoke.fail || true
  echo "[BITNET-SMOKE] RESULT: FAIL (pass:$PASS fail:$FAIL)"
fi

# Non-fatal by design: emit status and continue ISO build.

) || true

# ==========================================
# RESTORED HOOK: 0076-alfred-llamacpp.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0076-alfred-llamacpp.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
# Hook 0253 — llama.cpp install + build (CPU + multi-backend)
# Layered ABOVE existing 0250-ollama and 0251-bitnet to add the OpenAI-compat
# /v1/chat/completions HTTP server that LiteLLM bridges to.

echo "═══════════════════════════════════════════════════════"
echo "  ALFRED-LLM RUNTIME — llama.cpp HTTP server"
echo "═══════════════════════════════════════════════════════"

mkdir -p /usr/share/doc/alfred-llm /var/lib/alfred/build-flags || true

# Prefer pre-staged binary (air-gap safe). Fallback: build from source if allowed.
if [ -f /build-assets/llama-server ]; then
  echo "[LLAMA] Installing pre-staged llama-server binary"
  install -m 755 /build-assets/llama-server /usr/local/bin/llama-server
  install -m 755 /build-assets/llama-cli /usr/local/bin/llama-cli 2>/dev/null || true
elif [ -d /build-assets/llama.cpp-src ]; then
  echo "[LLAMA] Building llama.cpp from staged source"
  cd /build-assets/llama.cpp-src || true
  apt-get install -y --fix-broken -y --no-install-recommends build-essential cmake git || true
  cmake -B build -DLLAMA_NATIVE=OFF -DGGML_NATIVE=OFF \
        -DLLAMA_CURL=OFF -DGGML_AVX2=ON -DGGML_F16C=ON \
        -DCMAKE_BUILD_TYPE=Release
  cmake --build build --config Release -j$(nproc) --target llama-server llama-cli
  install -m 755 build/bin/llama-server /usr/local/bin/llama-server
  install -m 755 build/bin/llama-cli /usr/local/bin/llama-cli
else
  echo "[LLAMA] WARN: no /build-assets/llama-server or llama.cpp-src" >&2 || true
  echo "LLAMA_CPP_MISSING=1" > /var/lib/alfred/build-flags/llama-cpp-missing.flag || true
fi

# CUDA/ROCm/Vulkan variants — pre-staged only, don't build inside chroot
for variant in cuda rocm vulkan; do
  if [ -f /build-assets/llama-server-${variant} ]; then
    install -m 755 /build-assets/llama-server-${variant} /usr/local/bin/llama-server-${variant}
    echo "[LLAMA] Installed llama-server-${variant}"
  fi
done

# Auto-select wrapper: detects GPU at runtime and execs the right binary
cat > /usr/local/bin/llama-server-auto <<'WRAPPER'
# Auto-select llama-server backend based on detected hardware
if command -v nvidia-smi >/dev/null 2>&1 && nvidia-smi -L 2>/dev/null | grep -q GPU; then
  [ -x /usr/local/bin/llama-server-cuda ] && exec /usr/local/bin/llama-server-cuda "$@"
fi
if command -v rocm-smi >/dev/null 2>&1; then
  [ -x /usr/local/bin/llama-server-rocm ] && exec /usr/local/bin/llama-server-rocm "$@"
fi
if command -v vulkaninfo >/dev/null 2>&1 && vulkaninfo --summary 2>/dev/null | grep -q deviceName; then
  [ -x /usr/local/bin/llama-server-vulkan ] && exec /usr/local/bin/llama-server-vulkan "$@"
fi
exec /usr/local/bin/llama-server "$@"
WRAPPER
chmod +x /usr/local/bin/llama-server-auto || true

# License notice
cat > /usr/share/doc/alfred-llm/llama-cpp-LICENSE.txt <<'LIC'
llama.cpp by Georgi Gerganov and contributors. MIT License.
https://github.com/ggerganov/llama.cpp
Bundled with Alfred Linux as the local inference runtime for Alfred-LLM.
LIC

echo "[LLAMA] Done. Binaries:"
ls -la /usr/local/bin/llama-* 2>&1 | head -20


) || true

# ==========================================
# RESTORED HOOK: 0077-alfred-litellm.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0077-alfred-litellm.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
# Hook 0254 — LiteLLM Anthropic↔OpenAI bridge
# Provides /v1/messages (Anthropic) on port 4000 → /v1/chat/completions on 8080

echo "═══════════════════════════════════════════════════════"
echo "  ALFRED-BRAIN BRIDGE — LiteLLM Anthropic compat shim"
echo "═══════════════════════════════════════════════════════"

mkdir -p /etc/alfred-llm /usr/share/doc/alfred-llm /var/lib/alfred/build-flags || true

# Install python + pipx (Debian repo, air-gap safe)
DEBIAN_FRONTEND=noninteractive apt-get install -y --fix-broken -y --no-install-recommends \
  python3 python3-pip python3-venv pipx 2>&1 | tail -5 || true

# Install litellm via pipx into system path
if [ -d /build-assets/litellm-wheels ]; then
  echo "[LITELLM] Installing from staged wheels"
  python3 -m venv /opt/litellm-venv || true
  /opt/litellm-venv/bin/pip install --no-index --find-links=/build-assets/litellm-wheels 'litellm[proxy]' || true
  ln -sf /opt/litellm-venv/bin/litellm /usr/local/bin/litellm
elif [[ "${ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS:-}" == "1" ]]; then
  echo "[LITELLM] Installing from PyPI (network)"
  python3 -m venv /opt/litellm-venv || true
  /opt/litellm-venv/bin/pip install 'litellm[proxy]' || true
  ln -sf /opt/litellm-venv/bin/litellm /usr/local/bin/litellm
else
  echo "[LITELLM] WARN: no staged wheels and network downloads disabled" >&2 || true
  echo "LITELLM_MISSING=1" > /var/lib/alfred/build-flags/litellm-missing.flag || true
fi

# Bridge config — maps Anthropic model names to local llama-server backends
cat > /etc/alfred-llm/litellm.yaml <<'YAML'
# Alfred-Brain — Anthropic compatibility bridge
# Maps Claude model names to local Alfred-LLM backends
# Anthropic clients see: claude-opus-4-6 / claude-sonnet-4-6 / claude-haiku-4-5
# We serve them from local Qwen-Coder GGUFs via llama-server
model_list:
  - model_name: claude-opus-4-6
    litellm_params:
      model: openai/alfred-opus
      api_base: http://127.0.0.1:8082/v1
      api_key: alfred-local-no-key-needed
  - model_name: claude-sonnet-4-6
    litellm_params:
      model: openai/alfred-sonnet
      api_base: http://127.0.0.1:8081/v1
      api_key: alfred-local-no-key-needed
  - model_name: claude-haiku-4-5-20251001
    litellm_params:
      model: openai/alfred-haiku
      api_base: http://127.0.0.1:8080/v1
      api_key: alfred-local-no-key-needed
  # Generic aliases the user can pick directly
  - model_name: alfred-opus
    litellm_params:
      model: openai/alfred-opus
      api_base: http://127.0.0.1:8082/v1
      api_key: alfred-local-no-key-needed
  - model_name: alfred-sonnet
    litellm_params:
      model: openai/alfred-sonnet
      api_base: http://127.0.0.1:8081/v1
      api_key: alfred-local-no-key-needed
  - model_name: alfred-haiku
    litellm_params:
      model: openai/alfred-haiku
      api_base: http://127.0.0.1:8080/v1
      api_key: alfred-local-no-key-needed

litellm_settings:
  drop_params: true
  set_verbose: false

general_settings:
  master_key: alfred-local-no-key-needed
  port: 4000
  host: 127.0.0.1
YAML

cat > /usr/share/doc/alfred-llm/litellm-LICENSE.txt <<'LIC'
LiteLLM by BerriAI. MIT License.
https://github.com/BerriAI/litellm
Bundled with Alfred Linux as the Anthropic-compatibility bridge.
LIC

echo "[LITELLM] Bridge config written to /etc/alfred-llm/litellm.yaml"


) || true

# ==========================================
# RESTORED HOOK: 0078-alfred-dev-tools.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0078-alfred-dev-tools.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
# ═══════════════════════════════════════════════════════════════
# 0255-alfred-dev-tools.hook.chroot — "The Arsenal"
# ═══════════════════════════════════════════════════════════════
# Every language. Every database. Every build system.
# Ubuntu ships with Python. Fedora ships with Python + Ruby.
# Alfred ships with EVERYTHING.
#
# Optional: ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1 — other hooks use this for release
# binaries when build-assets are missing; also gates pip (yq), npm (@anthropic-ai/claude-code),
# NodeSource GPG fetch, and install-rust network rustup.
# ═══════════════════════════════════════════════════════════════
# Fix /tmp permissions (may be restricted by earlier hooks in chroot)
chmod 1777 /tmp 2>/dev/null || true

apt_update_nonfatal() {
    local tag="${1:-apt-update}"
    mkdir -p /var/lib/alfred/build-flags || true
    if ! apt-get update -qq 2>/dev/null || true; then
        echo "[DEV-APT] WARN: update failed (non-fatal): ${tag}" >&2 || true
        echo "${tag}_update_failed=$(date -Is)" >> /var/lib/alfred/build-flags/dev-tools-apt-failed || true
    fi
}

apt_nonfatal() {
    local tag="${1:-apt-install}"
    shift
    mkdir -p /var/lib/alfred/build-flags || true
    if ! apt-get install -y --fix-broken -y --no-install-recommends "$@" 2>/dev/null; then
        echo "[DEV-APT] WARN: install failed (non-fatal): ${tag} ($*)" >&2 || true
        echo "${tag}_install_failed=$(date -Is)" >> /var/lib/alfred/build-flags/dev-tools-apt-failed || true
    fi
}


echo "═══════════════════════════════════════════════════════"
echo "  ALFRED DEVELOPER ARSENAL — Every weapon, loaded"
echo "═══════════════════════════════════════════════════════"

export DEBIAN_FRONTEND=noninteractive

# ── 1. Node.js 20 LTS ──
# MILITARY: Pre-staged debs preferred (air-gap safe), repo fallback for dev builds
echo "[DEV] Installing Node.js 20 LTS..."
if [ -d /build-assets/nodejs-20-debs ]; then
    echo "[DEV] Using pre-staged Node.js debs (air-gap safe)"
    dpkg -i /build-assets/nodejs-20-debs/*.deb 2>/dev/null || apt-get -f install -y || true
else
    # Add NodeSource repo via GPG key + sources.list (no curl|bash)
    mkdir -p -m 755 /etc/apt/keyrings || true
    if [ -f /build-assets/nodesource-repo-gpg.key ]; then
        cp /build-assets/nodesource-repo-gpg.key /etc/apt/keyrings/nodesource.gpg || true
    elif [[ "${ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS:-}" == "1" ]]; then
        wget --timeout=900 -qO /etc/apt/keyrings/nodesource.gpg https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key 2>/dev/null || true
    else
        echo "[DEV] WARN: NodeSource GPG not staged; skipping NodeSource repo (set ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1)." >&2 || true
    fi
    if [ -f /etc/apt/keyrings/nodesource.gpg ] && [ -s /etc/apt/keyrings/nodesource.gpg ]; then
            > /etc/apt/sources.list.d/nodesource.list
        apt_update_nonfatal nodesource-index
        apt_nonfatal nodejs nodejs
    fi
fi
echo "[DEV] Node.js $(node --version 2>/dev/null || echo 'FAILED') / npm $(npm --version 2>/dev/null || echo 'FAILED')"

# ── 2. Go ──
echo "[DEV] Installing Go..."
apt_nonfatal golang golang-go

# ── 3. Rust — ready-to-install on first login ──
# We don't install the full toolchain in the ISO (saves 500MB)
# Instead we provide a one-command installer
echo "[DEV] Preparing Rust installer..."
mkdir -p /etc/skel/.bashrc.d || true
cat > /etc/skel/.bashrc.d/rust-ready.sh << 'RUST_READY'
# Rust environment
export CARGO_HOME="$HOME/.cargo"
export RUSTUP_HOME="$HOME/.rustup"
[ -f "$CARGO_HOME/env" ] && source "$CARGO_HOME/env"
RUST_READY

cat > /usr/local/bin/install-rust << 'INSTALL_RUST'
echo "Installing Rust toolchain..."
# MILITARY: Pre-staged rustup-init preferred (air-gap safe)
if [ -f /opt/alfred/build-assets/rustup-init ]; then
    /opt/alfred/build-assets/rustup-init -y
elif [ -f /build-assets/rustup-init ]; then
    /build-assets/rustup-init -y
else
    # Sealed / GA: no curl|sh rustup unless explicitly opted in at install time.
    if [[ "${ALFRED_ALLOW_RUSTUP_NETWORK:-}" != "1" && "${ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS:-}" != "1" ]]; then
        echo "install-rust: add rustup-init to build-assets (or /opt/alfred/build-assets/)." >&2 || true
        echo "install-rust: network rustup disabled (set ALFRED_ALLOW_RUSTUP_NETWORK=1 or ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1)." >&2 || true
        true
    fi
    _ru=$(mktemp) || true
    curl -m 900 --proto '=https' --tlsv1.2 -sSf -o "$_ru" https://sh.rustup.rs || true
    sh "$_ru" -s -- -y
    rm -f "$_ru" || true
fi
source "$HOME/.cargo/env"
echo "Rust $(rustc --version) installed!"
INSTALL_RUST
chmod +x /usr/local/bin/install-rust || true

# ── 4. Database Clients ──
# Every database client. Zero servers (keep it light).
echo "[DEV] Installing database clients..."
apt_nonfatal db-clients \
    mariadb-client \
    redis-tools \
    sqlite3 \

# ── 5. Build Tools ──
echo "[DEV] Installing build tools..."
apt_nonfatal db-clients \
    cmake \
    meson \
    ninja-build \
    pkg-config \
    libssl-dev \

# ── 6. Git Extensions ──
echo "[DEV] Installing git extensions..."
apt_nonfatal git-lfs git-lfs
git lfs install --system 2>/dev/null || true

# ── 7. GoForge CLI (Sovereign Git - replaces GitHub CLI) ──
# Alfred Linux uses GoForge, not GitHub. Sovereignty first.
echo "[DEV] Configuring GoForge CLI support..."
if [ -f /build-assets/goforge-cli ]; then
    install -m 755 /build-assets/goforge-cli /usr/local/bin/goforge
    echo "[DEV] GoForge CLI installed from build-assets"
else
    # Create a GoForge config hint for first-run
    cat > /usr/local/bin/goforge << 'GOFORGE_CLI'
echo "GoForge — Sovereign Git Forge"
echo ""
echo "GoForge is Alfred Linux's sovereign code forge."
echo "Configure: git remote add origin https://your-forge-url/user/repo.git"
echo ""
echo "For full GoForge CLI, visit: https://alfredlinux.com/forge/"
GOFORGE_CLI
    chmod +x /usr/local/bin/goforge || true
fi

# ── 8. Debug & Profiling Tools ──
echo "[DEV] Installing debug tools..."
apt_nonfatal db-clients \
    strace \
    ltrace \
    gdb \

# ── 9. JSON/YAML tools ──
echo "[DEV] Installing data tools..."
apt_nonfatal db-clients \
    jq \
# yq via pip (more reliable than snap)
if [[ "${ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS:-}" == "1" ]]; then
    pip3 install --break-system-packages --no-cache-dir yq 2>/dev/null || true
else
    echo "[DEV] WARN: skipping yq pip install (set ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1 or use apt jq-only)." >&2 || true
fi

# ── 10. Claude Code CLI ──
# Official Anthropic coding agent. Needs API key to function.
echo "[DEV] Installing Claude Code CLI..."
if [ -f /build-assets/claude-code.tar.gz ]; then
    echo "[DEV] Using pre-staged Claude Code (air-gap safe)"
    npm install -g /build-assets/claude-code.tar.gz 2>/dev/null || true
elif [[ "${ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS:-}" == "1" ]]; then
    npm install -g @anthropic-ai/claude-code 2>/dev/null || {
        echo "[DEV] Claude Code not available — install later with: npm install -g @anthropic-ai/claude-code"
    }
else
    echo "[DEV] WARN: skipping Claude Code npm install (stage claude-code.tar.gz or set ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1)." >&2 || true
fi

echo "═══════════════════════════════════════════════════════"
echo "  DEVELOPER ARSENAL COMPLETE"
echo "  Node.js + Go + Rust-ready + DB clients + Git LFS"
echo "  + GoForge CLI + Debug tools + jq + Claude Code"
echo "═══════════════════════════════════════════════════════"


) || true

# ==========================================
# RESTORED HOOK: 0079-alfred-agent-cleanroom.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0079-alfred-agent-cleanroom.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
# Hook 0255 — Alfred-Agent (clean-room Rust harness, claw-code fork)
# Default agent harness — MIT licensed, no copyright risk

echo "═══════════════════════════════════════════════════════"
echo "  ALFRED-AGENT — Clean-room Rust harness (default)"
echo "═══════════════════════════════════════════════════════"

mkdir -p /usr/share/doc/alfred-agent /etc/alfred-agent /var/lib/alfred/build-flags || true

# Prefer pre-staged binary
if [ -f /build-assets/alfred-agent ]; then
  echo "[AGENT] Installing pre-staged alfred-agent binary"
  install -m 755 /build-assets/alfred-agent /usr/local/bin/alfred-agent
elif [ -d /build-assets/claw-code-src ]; then
  echo "[AGENT] Building from staged claw-code source"
  apt-get install -y --fix-broken -y --no-install-recommends rustc cargo pkg-config libssl-dev || true
  cd /build-assets/claw-code-src/rust || true
  cargo build --release --bin claw 2>&1 | tail -10
  install -m 755 target/release/claw /usr/local/bin/alfred-agent || true
else
  echo "[AGENT] WARN: no /build-assets/alfred-agent or claw-code-src" >&2 || true
  echo "ALFRED_AGENT_MISSING=1" > /var/lib/alfred/build-flags/alfred-agent-missing.flag || true
fi

# Wrapper script that points the agent at our local LiteLLM bridge by default
cat > /usr/local/bin/alfred <<'WRAP'
# Alfred — local-first AI agent CLI
# Routes through alfred-bridge (LiteLLM) → alfred-llm (llama-server)
# Zero outbound packets to api.anthropic.com unless ANTHROPIC_BASE_URL overridden
export ANTHROPIC_BASE_URL="${ANTHROPIC_BASE_URL:-http://127.0.0.1:4000}"
export ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY:-alfred-local-no-key-needed}"
export ALFRED_BACKEND="${ALFRED_BACKEND:-cleanroom}"

case "$ALFRED_BACKEND" in
  original)
    if [ -x /opt/alfred-agent-original/bin/run.sh ]; then
      exec /opt/alfred-agent-original/bin/run.sh "$@"
    fi
    echo "[alfred] alfred-agent-original not installed, falling back to cleanroom" >&2 || true
    ;;
esac

