OUROBOROS
chmod +x /usr/local/bin/alfred-ouroboros || true

cat > /usr/share/applications/alfred-ouroboros.desktop <<'EOF'
[Desktop Entry]
Type=Application
Name=The Ouroboros Protocol
Comment=PXE Network Boot Replication
Exec=konsole -e sudo /usr/local/bin/alfred-ouroboros
Icon=network-server
Categories=System;Network;
EOF

echo "[Ouroboros Protocol] OS Replication Matrix Integrated."

# SPDX-License-Identifier: AGPL-3.0-or-later
# Alfred Ascension Lock: Applies immutable +a lock on logs at OS runtime.

echo "Creating Alfred Ascension Lock systemd service..."

cat > /etc/systemd/system/alfred-ascension-lock.service << 'EOF'
[Unit]
Description=Alfred Ascension Immutable Log Lock
After=local-fs.target
DefaultDependencies=no

[Service]
Type=oneshot
ExecStart=/usr/bin/chattr -R +a /var/log/alfred_ascension
RemainAfterExit=yes

