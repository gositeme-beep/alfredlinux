# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0135-enable-steam-i386.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later

echo "=== Alfred Linux: Enabling Multiarch & Non-Free for Steam ==="

# 1. Enable 32-bit architecture (required for Steam)
dpkg --add-architecture i386

# 2. Ensure non-free and non-free-firmware are in sources.list
# We use sed to append them if they are missing
if [ -f /etc/apt/sources.list ]; then
    sed -i -E 's/ main contrib$/ main contrib non-free non-free-firmware/' /etc/apt/sources.list
    sed -i -E 's/ main$/ main contrib non-free non-free-firmware/' /etc/apt/sources.list
fi

if [ -f /etc/apt/sources.list.d/debian.sources ]; then
    sed -i -E 's/Components: main$/Components: main contrib non-free non-free-firmware/' /etc/apt/sources.list.d/debian.sources
fi

# 3. Update apt to pull in the new i386 and non-free package indexes
apt-get update || true || true

# 4. Install Steam explicitly so it's ready out of the box
echo "Installing Steam Installer..."
apt-get install -y --fix-broken -y --no-install-recommends --no-remove steam-installer || echo "WARNING: Steam multiarch conflict detected. Skipped to preserve Desktop Environment." || true

echo "=== System Ready for Steam Installation ==="


) || true

