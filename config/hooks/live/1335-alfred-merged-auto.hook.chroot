#!/usr/bin/env bash
# Pause the build to allow the Swarm to inspect the DKMS make.log
echo "[Swarm] Halting build at 0089a for manual DKMS inspection..."
while true; do
  if [ -f "/tmp/resume_build" ]; then
    echo "[Swarm] Resume signal detected. Continuing to 0090..."
    rm -f /tmp/resume_build
    break
  fi
  sleep 5
done

#!/bin/bash
set +e
echo "=========================================="
echo "==== ALFRED SECURE BOOT MOK FACTORY ======"
echo "=========================================="

export DEBIAN_FRONTEND=noninteractive
apt-get install -y --no-install-recommends shim-signed sbsigntool efitools mokutil openssl dkms || true

mkdir -p /etc/default/grub.d || true
cat > /etc/default/grub.d/alfred-secure-boot.cfg << 'EOF'
# Force GRUB to recognize EFI and Secure Boot
GRUB_DISABLE_OS_PROBER=false
EOF

# Generate Kingdom MOK if it doesn't exist
MOK_DIR="/var/lib/alfred/mok"
mkdir -p "$MOK_DIR" || true
if [ ! -f "$MOK_DIR/MOK.priv" ]; then
    echo "Generating Kingdom Machine Owner Key (MOK)..."
    openssl req -new -x509 -newkey rsa:2048 -keyout "$MOK_DIR/MOK.priv" -outform DER -out "$MOK_DIR/MOK.der" -nodes -days 3650 -subj "/CN=Alfred Linux Kingdom MOK/"
    openssl x509 -in "$MOK_DIR/MOK.der" -inform DER -outform PEM -out "$MOK_DIR/MOK.pem"
fi

# Configure DKMS to auto-sign modules using this MOK
mkdir -p /etc/dkms/framework.conf.d || true
cat > /etc/dkms/framework.conf.d/alfred-mok.conf << EOF
sign_tool="/lib/modules/\$kernelver/build/scripts/sign-file"
sign_hash="sha256"
sign_key="$MOK_DIR/MOK.priv"
sign_cert="$MOK_DIR/MOK.der"
EOF

# Script to enroll the MOK on first boot
cat > /usr/local/sbin/alfred-enroll-mok << EOF
#!/bin/bash
echo "Enrolling Kingdom MOK into UEFI..."
echo "When prompted for a password, create a temporary one (e.g., 'alfred')."
echo "You will enter this password during the next reboot to confirm the key."
mokutil --import "$MOK_DIR/MOK.der"
echo "Please reboot to complete the Secure Boot chain of trust."
EOF
chmod +x /usr/local/sbin/alfred-enroll-mok || true

echo "Kingdom MOK Factory integrated. DKMS auto-signing enforced."
#!/bin/bash
set +e
echo "================================================="
echo "==== ALFRED SOVEREIGN FIREWALL (nftables) ======="
echo "================================================="

export DEBIAN_FRONTEND=noninteractive
apt-get install -y --no-install-recommends nftables || true

cat > /etc/nftables.conf << 'EOF'
#!/usr/sbin/nft -f
flush ruleset

table inet filter {
    chain input {
        type filter hook input priority 0; policy drop;

        # Loopback
        iifname "lo" accept

        # Established & Related
        ct state established,related accept

        # WireGuard (Mesh)
        udp dport 51820 accept

        # SSH (Assume protected by WireGuard or local LAN)
        tcp dport 22 accept

        # Syncthing (Mesh Sync)
        tcp dport 22000 accept
        udp dport 22000 accept
        udp dport 21027 accept

        # Drop invalid
        ct state invalid drop
    }
    chain forward {
        type filter hook forward priority 0; policy drop;
    }
    chain output {
        type filter hook output priority 0; policy accept;
    }
}
EOF

systemctl enable nftables || true || true
echo "Sovereign firewall configured (default DROP)."
#!/bin/bash
set +e
echo "================================================="
echo "==== ALFRED AI MEMORY SEAL (LUKS) ==============="
echo "================================================="

export DEBIAN_FRONTEND=noninteractive
apt-get install -y --no-install-recommends cryptsetup || true

cat > /usr/local/sbin/alfred-seal-memory << 'EOF'
#!/bin/bash
# Mounts the encrypted Omahon memory loopback
set +e
DB_PATH="$HOME/.local/share/omahon"
IMG_PATH="$HOME/.omahon_sealed.img"
mkdir -p "$DB_PATH"

if [ ! -f "$IMG_PATH" ]; then
    echo "Creating sealed memory for AI..."
    dd if=/dev/urandom of="$IMG_PATH" bs=1M count=100
    sudo cryptsetup luksFormat "$IMG_PATH"
    sudo cryptsetup luksOpen "$IMG_PATH" omahon_mem
    sudo mkfs.ext4 /dev/mapper/omahon_mem
    sudo cryptsetup luksClose omahon_mem
fi

echo "Unsealing AI memory..."
sudo cryptsetup luksOpen "$IMG_PATH" omahon_mem
sudo mount /dev/mapper/omahon_mem "$DB_PATH"
sudo chown -R $USER:$USER "$DB_PATH"
echo "AI memory unsealed and mounted."
EOF
chmod +x /usr/local/sbin/alfred-seal-memory

cat > /usr/local/sbin/alfred-seal-panic << 'EOF'
#!/bin/bash
# Instantly drops the AI memory keys
sudo umount -l "$HOME/.local/share/omahon" 2>/dev/null || true
sudo cryptsetup luksClose omahon_mem 2>/dev/null || true
echo "AI memory sealed and cryptographically shredded from RAM."
EOF
chmod +x /usr/local/sbin/alfred-seal-panic

echo "AI memory seal tools installed."
#!/bin/bash
# SPDX-License-Identifier: AGPL-3.0-or-later
# Alfred Linux â€” Kingdom Covenant Hardenings Hook
# Ensures hardenings, 777 hooks, and Kingdom Covenant attestations remain intact.

set +e

echo "=== Applying Kingdom Covenant Shield & Hardenings ==="

# 1. Attest to the Canonical Justice Domains & License
cat > /etc/kingdom-covenant.txt << 'EOF'
KINGDOM COVENANT LICENSE
------------------------
This system is protected by the Kingdom Covenant License.
Canonical Justice Domains: LAvocat.ca
Sovereign Rights Enforced. 24 Systems Active.
EOF

chmod 0444 /etc/kingdom-covenant.txt

# 2. Add to MOTD
if ! grep -q "Kingdom Covenant" /etc/motd 2>/dev/null; then
    echo "" >> /etc/motd
    echo "*** Protected by the Kingdom Covenant License ***" >> /etc/motd
    echo "*** Canonical Justice Domains: LAvocat.ca ***" >> /etc/motd
fi

# 3. Sanity Check 777 Hooks and Permissions
