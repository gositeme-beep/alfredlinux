# SPDX-License-Identifier: AGPL-3.0-or-later


echo "[0998] Kernel 7 initrd enforcer (Vanguard Hotfix)"

if [ ! -e /proc/self ]; then
  mount -t proc proc /proc 2>/dev/null || true
fi

