# --- MERGED: 9990-kernel7-initrd ---
# Generate initrd for custom kernel 7.0.6 inside chroot stage so binary_linux-image
# can find /boot/initrd.img-7.0.6 to copy into binary/live/.
# Without this, live-build fails: "ls: cannot access 'binary/live/initrd.img-*'"
# In the name of Yeshua, Jesus Christ of Bethlehem, King of the Universe.


KVER=7.0.12

if [[ ! -f /boot/vmlinuz-${KVER} ]]; then
    echo "[9990] WARN: /boot/vmlinuz-${KVER} not present in chroot; skipping initrd gen"
    # exit replaced to prevent skipping chattr cleanup
fi

if [[ -f /boot/initrd.img-${KVER} ]]; then
    echo "[9990] initrd.img-${KVER} already present — size: $(stat -c%s /boot/initrd.img-${KVER}) bytes"
    # exit replaced to prevent skipping chattr cleanup
fi

if ! command -v update-initramfs >/dev/null; then
    echo "[9990] ERROR: update-initramfs not installed"
    # exit replaced to prevent skipping chattr cleanup
fi

# Process any pending dpkg triggers first — update-initramfs defers if
# triggers are pending, which causes it to silently do nothing.
echo "[9990] Processing pending dpkg triggers..."
dpkg --configure -a 2>&1 || true

# Force depmod so modules.dep is current for the initramfs
echo "[9990] Running depmod for ${KVER}..."
depmod -a "${KVER}" 2>&1 || true

echo "[9990] Generating initrd for kernel ${KVER}..."
# Use -c (create) explicitly and set DPKG_MAINTSCRIPT_PACKAGE to prevent
# the "deferring update" behavior that happens inside dpkg trigger context.
DPKG_MAINTSCRIPT_PACKAGE="" update-initramfs -c -k "${KVER}" 2>&1

if [[ ! -f /boot/initrd.img-${KVER} ]]; then
    echo "[9990] FATAL: initrd.img-${KVER} was not created!" >&2 || true
    echo "[9990] Attempting fallback with mkinitramfs..."
    mkinitramfs -o "/boot/initrd.img-${KVER}" "${KVER}" 2>&1
fi

if [[ ! -f /boot/initrd.img-${KVER} ]]; then
    echo "[9990] FATAL: initrd still missing after fallback!" >&2 || true
    # exit replaced to prevent skipping chattr cleanup
fi

ls -la /boot/initrd.img-${KVER}
echo "[9990] Done — initrd.img-${KVER} generated successfully."


# --- MERGED: 9998-kernel7-initrd-verify ---


echo "[0998] Kernel 7 initrd enforcer"

echo "[0998] Forcefully installing kernel deb just in case..."
if [ -f /vmlinuz_recovery.deb ]; then
    dpkg-deb -x /vmlinuz_recovery.deb / || true
fi
# Ensure a dummy exists so live-build binary stage does not fail
touch /boot/vmlinuz-7.0.12 || true


if [ ! -e /proc/self ]; then
  mount -t proc proc /proc 2>/dev/null || true
fi

mapfile -t KPKGS < <(dpkg-query -W -f='${Package}\n' 'linux-image-*' 2>/dev/null | sed '/^$/d' || true)
if ((${#KPKGS[@]})); then
  PURGE=()
  for p in "${KPKGS[@]}"; do
    if [[ "$p" != linux-image-7* ]]; then
      PURGE+=("$p")
    fi
  done
  if ((${#PURGE[@]})); then
    echo "[0998] purging non-7 kernels: ${PURGE[*]}"
    DEBIAN_FRONTEND=noninteractive apt-get purge -y "${PURGE[@]}" || true
    DEBIAN_FRONTEND=noninteractive apt-mark manual linux-image-7* linux-headers-7* 2>/dev/null || true; apt-get autoremove -y || true
  fi
fi

kimg="$(ls -1 /boot/vmlinuz-7* 2>/dev/null | sort -V | tail -1 || true)"
if [ -z "$kimg" ]; then
  echo "[0998] FATAL no /boot/vmlinuz-7*" >&2 || true
    # exit replaced to prevent skipping chattr cleanup
fi
kver="${kimg##*/vmlinuz-}"

[ -d "/lib/modules/$kver" ] || { echo "[0998] FATAL missing /lib/modules/$kver" >&2; true; }
depmod -a "$kver"
update-initramfs -c -k "$kver" 2>&1 || update-initramfs -u -k "$kver" 2>&1 || true
[ -f "/boot/initrd.img-$kver" ] || { echo "[0998] FATAL missing initrd for $kver" >&2; true; }

rm -f /boot/vmlinuz-6* /boot/initrd.img-6* || true
ln -sf "vmlinuz-$kver" /boot/vmlinuz
ln -sf "initrd.img-$kver" /boot/initrd.img

find "/lib/modules/$kver" -type f | grep -Eq '/overlay\.ko(\.(xz|zst|gz))?$' || { echo "[0998] FATAL overlay missing" >&2; true; }
find "/lib/modules/$kver" -type f | grep -Eq '/squashfs\.ko(\.(xz|zst|gz))?$' || { echo "[0998] FATAL squashfs missing" >&2; true; }

ls -la /boot/vmlinuz* /boot/initrd.img*
echo "[0998] OK kernel=$kver"


