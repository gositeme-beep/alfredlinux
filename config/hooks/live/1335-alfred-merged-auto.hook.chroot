# SPDX-License-Identifier: AGPL-3.0-or-later
# ═══════════════════════════════════════════════════════════════
# Alfred Linux v7.77 — Calamares Graphical Installer
#
# Installs and brands Calamares for disk installation.
# BUILD: v7.77 (Installer)
# ═══════════════════════════════════════════════════════════════


export DEBIAN_FRONTEND=noninteractive
# ── apt_nonfatal helpers (injected: apt-swallow observability) ──
apt_update_nonfatal() {
    local tag="$1"
    mkdir -p /var/lib/alfred/build-flags || true
    if ! DEBIAN_FRONTEND=noninteractive apt-get update -qq 2>/dev/null || true; then
        echo "[WARN] apt-get update || true (${tag}) failed (nonfatal)" >&2 || true
        echo "${tag}_update_failed=$(date -Is)" >> /var/lib/alfred/build-flags/${tag}-apt-failed || true
    fi
}
apt_nonfatal() {
    local tag="$1"; shift
    mkdir -p /var/lib/alfred/build-flags || true
    if ! DEBIAN_FRONTEND=noninteractive apt-get install -y --fix-broken -y --no-install-recommends "$@" 2>/dev/null; then
        echo "[WARN] ${tag} install failed (nonfatal)" >&2 || true
        echo "${tag}_install_failed=$(date -Is)" >> /var/lib/alfred/build-flags/${tag}-apt-failed || true
    fi
}
export UCF_FORCE_CONFFNEW=1
export APT_LISTCHANGES_FRONTEND=none

echo "[Alfred Linux v7.77] Installing Calamares installer..."

# ── 1. Install Calamares and dependencies ──
# 0170 may have written /etc/calamares/modules/luksopenswaphookcfg.conf; force non-interactive merge.
# Install calamares — fail loudly if it doesn't work (no silent swallow).
apt-get install -y --fix-broken -y \
    -o Dpkg::Options::=--force-confdef \
    -o Dpkg::Options::=--force-confnew \
    calamares
# ── 2. Alfred branding for Calamares ──
BRAND_DIR="/etc/calamares/branding/alfred"
mkdir -p "$BRAND_DIR" || true

cat > "$BRAND_DIR/branding.desc" << 'BRAND'
---
componentName: alfred

strings:
    productName:         "Alfred Linux — Kingdom of God Edition"
    shortProductName:    "Alfred"
    version:             7.77
    shortVersion:        7.77
    versionedName:       "Alfred Linux 7.77 — Kingdom of God Edition"
    shortVersionedName:  "Alfred 7.77"
    bootloaderEntryName: "Alfred Linux 7.77"
    productUrl:          https://alfredlinux.com
    supportUrl:          https://gositeme.com/support.php
    knownIssuesUrl:      https://alfredlinux.com/issues
    releaseNotesUrl:     https://alfredlinux.com/release-notes

images:
    productLogo:         "alfred-logo.png"
    productIcon:         "alfred-icon.png"
    productWelcome:      "alfred-welcome.png"

slideshow:               "show.qml"

style:
    sidebarBackground:   "#0a0a14"
    sidebarText:         "#e8e8f0"
    sidebarTextSelect:   "#00D4FF"
    sidebarTextHighlight: "#00D4FF"
BRAND

# Generate branding images with ImageMagick
if command -v convert &>/dev/null; then
    # Product logo (128x128)
    convert -size 128x128 xc:'#00D4FF' \
        -fill '#0a0a14' -font 'DejaVu-Sans-Bold' -pointsize 80 \
        -gravity center -annotate +0+0 'A' \
        "$BRAND_DIR/alfred-logo.png" 2>/dev/null || true

    # Product icon (48x48)
    convert -size 48x48 xc:'#00D4FF' \
        -fill '#0a0a14' -font 'DejaVu-Sans-Bold' -pointsize 32 \
        -gravity center -annotate +0+0 'A' \
        "$BRAND_DIR/alfred-icon.png" 2>/dev/null || true

    # Welcome banner — prefer real artwork montage (4 images), then SVG, then text fallback.
    SRC_SVG="/usr/share/alfred/branding/alfred-installer-welcome.svg"
    IMG1="/build-assets/wallpapers/1080p/kingdom-throne-1080p.png"
    IMG2="/build-assets/wallpapers/1080p/new-jerusalem-1080p.png"
    IMG3="/build-assets/wallpapers/1080p/lion-of-judah-1080p.png"
    IMG4="/build-assets/wallpapers/1080p/eden-garden-1080p.png"
    if command -v convert &>/dev/null && [ -f "$IMG1" ] && [ -f "$IMG2" ] && [ -f "$IMG3" ] && [ -f "$IMG4" ]; then
        convert \
            \( "$IMG1" -resize 600x300^ -gravity center -extent 600x300 \) \
            \( "$IMG2" -resize 600x300^ -gravity center -extent 600x300 \) +append \
            \( "$IMG3" -resize 600x300^ -gravity center -extent 600x300 \) \
            \( "$IMG4" -resize 600x300^ -gravity center -extent 600x300 \) +append \
            -append \
            \( -size 1200x600 xc:'rgba(8,20,35,0.28)' \) -compose over -composite \
            -fill '#FFD700' -font 'DejaVu-Sans-Bold' -pointsize 46 -gravity north -annotate +0+26 '✝ Alfred Linux 7.77' \
            -fill '#00D4FF' -font 'DejaVu-Sans-Bold' -pointsize 24 -gravity south -annotate +0+34 'Kingdom of God Edition' \
            "$BRAND_DIR/alfred-welcome.png" 2>/dev/null || true
    elif [ -f "$SRC_SVG" ] && command -v rsvg-convert &>/dev/null; then
        rsvg-convert -w 1200 -h 600 "$SRC_SVG" -o "$BRAND_DIR/alfred-welcome.png" 2>/dev/null || true
    elif [ -f "$SRC_SVG" ] && command -v convert &>/dev/null; then
        convert -background '#081423' -density 150 "$SRC_SVG" -resize 1200x600 "$BRAND_DIR/alfred-welcome.png" 2>/dev/null || true
    else
        # Fallback: basic gradient
        convert -size 800x300 gradient:'#081423-#0d1f35' \
            -fill '#FFD700' -font 'DejaVu-Sans-Bold' -pointsize 42 \
            -gravity center -annotate +0-50 '✝ Alfred Linux 7.77' \
            -fill '#00D4FF' -font 'DejaVu-Sans-Bold' -pointsize 22 \
            -annotate +0+10 'Kingdom of God Edition' \
            -fill '#8a8a9a' -font 'DejaVu-Sans' -pointsize 16 \
            -annotate +0+50 'SOLI DEO GLORIA' \
            "$BRAND_DIR/alfred-welcome.png" 2>/dev/null || true
    fi
fi

# QML slideshow
cat > "$BRAND_DIR/show.qml" << 'QML'
import QtQuick 2.0;
import calamares.slideshow 1.0;

Presentation {
    id: presentation

    Slide {
        Rectangle {
            anchors.fill: parent
            color: "#0a0a14"
            Column {
                anchors.centerIn: parent
                spacing: 24
                Text {
                    text: "✝"
                    color: "#FFD700"
                    font.pixelSize: 64
                    anchors.horizontalCenter: parent.horizontalCenter
                }
                Text {
                    text: "Alfred Linux 7.77"
                    color: "#00D4FF"
                    font.pixelSize: 36
                    font.bold: true
                    anchors.horizontalCenter: parent.horizontalCenter
                }
                Text {
                    text: "Kingdom of God Edition"
                    color: "#FFD700"
                    font.pixelSize: 22
                    font.bold: true
                    anchors.horizontalCenter: parent.horizontalCenter
                }
                Text {
                    text: "'In the beginning God created\nthe heaven and the earth.'\n— Genesis 1:1"
                    color: "#e8e8f0"
                    font.pixelSize: 16
                    font.italic: true
                    horizontalAlignment: Text.AlignHCenter
                    anchors.horizontalCenter: parent.horizontalCenter
                }
            }
        }
    }

    Slide {
        Rectangle {
            anchors.fill: parent
            color: "#0a0a14"
            Column {
                anchors.centerIn: parent
                spacing: 20
                Text {
                    text: "📖  The Word of God"
                    color: "#FFD700"
                    font.pixelSize: 28
                    font.bold: true
                    anchors.horizontalCenter: parent.horizontalCenter
                }
                Text {
                    text: "39,482 verses of the\nAuthorized King Jesus Version\n\nA verse greets you at every terminal login.\nFamily Bible generator for your household.\nChildren's stories from Scripture.\n\n'Thy word is a lamp unto my feet,\nand a light unto my path.' — Psalm 119:105"
                    color: "#e8e8f0"
                    font.pixelSize: 15
                    horizontalAlignment: Text.AlignHCenter
                    anchors.horizontalCenter: parent.horizontalCenter
                }
            }
        }
    }

    Slide {
        Rectangle {
            anchors.fill: parent
            color: "#0a0a14"
            Column {
                anchors.centerIn: parent
                spacing: 20
                Text {
                    text: "♪  Kingdom Worship"
                    color: "#FFD700"
                    font.pixelSize: 28
                    font.bold: true
                    anchors.horizontalCenter: parent.horizontalCenter
                }
                Text {
                    text: "27 sacred tracks with synchronized lyrics\n\nJesus Christ The Light Our Universe\nby Elyon Light + Commander Danny William Perez\n\nOpen the music player — the album is already loaded.\n\n'Sing to the LORD a new song;\nsing to the LORD, all the earth.' — Psalm 96:1"
                    color: "#e8e8f0"
                    font.pixelSize: 15
                    horizontalAlignment: Text.AlignHCenter
                    anchors.horizontalCenter: parent.horizontalCenter
                }
            }
        }
    }

    Slide {
        Rectangle {
            anchors.fill: parent
            color: "#0a0a14"
            Column {
                anchors.centerIn: parent
                spacing: 20
                Text {
                    text: "🔐  Quantum-Safe Fortress"
                    color: "#00D4FF"
                    font.pixelSize: 28
                    font.bold: true
                    anchors.horizontalCenter: parent.horizontalCenter
                }
                Text {
                    text: "Kyber-1024 post-quantum encryption\nFull-disk encryption (LUKS2 + Kyber KEM)\nAlfred Browser — zero tracking\nAlfred IDE — sovereign development\nMesh network — connect the Kingdom\n\n'The horse is prepared against the day of battle,\nbut safety is of the LORD.' — Proverbs 21:31"
                    color: "#e8e8f0"
                    font.pixelSize: 15
                    horizontalAlignment: Text.AlignHCenter
                    anchors.horizontalCenter: parent.horizontalCenter
                }
            }
        }
    }

    Slide {
        Rectangle {
            anchors.fill: parent
            color: "#0a0a14"
            Column {
                anchors.centerIn: parent
                spacing: 24
                Text {
                    text: "✝"
                    color: "#FFD700"
                    font.pixelSize: 48
                    anchors.horizontalCenter: parent.horizontalCenter
                }
                Text {
                    text: "SOLI DEO GLORIA"
                    color: "#FFD700"
                    font.pixelSize: 24
                    font.bold: true
                    anchors.horizontalCenter: parent.horizontalCenter
                }
                Text {
                    text: "Built with love by Commander Danny William Perez\nand his daughter Eden Sarai, for the glory of God.\n\nAlfred Linux is sovereign computing —\nyour machine, your data, your freedom.\nAll honor to the Most High."
                    color: "#e8e8f0"
                    font.pixelSize: 15
                    horizontalAlignment: Text.AlignHCenter
                    anchors.horizontalCenter: parent.horizontalCenter
                }
                Text {
                    text: "alfredlinux.com"
                    color: "#00D4FF"
                    font.pixelSize: 14
                    anchors.horizontalCenter: parent.horizontalCenter
                }
            }
        }
    }
}
QML

# ── 3. Calamares settings ──
mkdir -p /etc/calamares/modules || true

cat > /etc/calamares/modules/welcome.conf << 'WELCOME'
---
showSupportUrl:         true
showKnownIssuesUrl:     true
showReleaseNotesUrl:    true

requirements:
    requiredStorage:    85.0
    requiredRam:        8.0
    internetCheckUrl:   http://gnu.org
    check:
        - storage
        - ram
        - power
        - root
        - screen
WELCOME

mkdir -p /etc/calamares || true
cat > /etc/calamares/settings.conf << 'SETTINGS'
modules-search: [ local, /usr/lib/calamares/modules ]

sequence:
  - show:
    - welcome
    - locale
    - keyboard
    - partition
    - users
    - summary
  - exec:
    - partition
    - mount
    - unpackfs
    - machineid
    - fstab
    - locale
    - keyboard
    - localecfg
    - luksbootkeyfile
    - users
    - displaymanager
    - networkcfg
    - hwclock
    - services-systemd
    - shellprocess@copy_models
    - bootloader
    - umount
  - show:
    - finished

branding: alfred
SETTINGS

# ── 3a. Calamares partition module: Force BTRFS for Snapshots ──
mkdir -p /etc/calamares/modules || true
cat > /etc/calamares/modules/partition.conf << 'PARTITION'
---
efiSystemPartition:     "/boot/efi"
userSwapChoices:
    - none
    - small
    - suspend
    - file
drawNestedPartitions:   false
alwaysShowPartitionLabels: true
initialPartitioningChoice: none
initialSwapChoice: none
defaultFileSystemType:  "btrfs"
availableFileSystemTypes:  ["btrfs", "ext4"]
PARTITION

# ── 3b. Calamares shellprocess module: copy AI models to installed system ──
mkdir -p /etc/calamares/modules || true
cat > /etc/calamares/modules/shellprocess@copy_models.conf << 'COPYMODELS'
---
dontChroot: true
timeout: 3600
script:
    - "-rm -f $$ROOT/opt/alfred-models"
    - "mkdir -p $$ROOT/opt/alfred-models"
    - "command cp -a /run/live/medium/live/alfred-models/* $$ROOT/opt/alfred-models/ 2>/dev/null || echo '[calamares] No model files to copy (live medium may not contain models)'"
    - "chown -R root:root $$ROOT/opt/alfred-models 2>/dev/null || true"
COPYMODELS

# ── 4. Application menu entry (always visible in System menu) ──
cat > /usr/share/applications/alfred-install.desktop << 'APPDESK'
[Desktop Entry]
Name=Install Alfred Linux
GenericName=System Installer
Comment=Install Alfred Linux to your hard drive
Exec=pkexec calamares
Icon=calamares
Type=Application
Categories=System;
Terminal=false
StartupNotify=true
Keywords=install;installer;calamares;disk;
APPDESK

# ── 5. Desktop shortcut for installer ──
mkdir -p /etc/skel/Desktop || true
cat > /etc/skel/Desktop/install-alfred-linux.desktop << 'DESK'
[Desktop Entry]
Name=Install Alfred Linux
Comment=Install Alfred Linux to your hard drive
Exec=pkexec calamares
Icon=calamares
Type=Application
Categories=System;
Terminal=false
StartupNotify=true
DESK
chmod +x /etc/skel/Desktop/install-alfred-linux.desktop || true

# Mark desktop file as trusted for Plasma (prevents "untrusted launcher" dialog)
# Plasma uses a checksum stored in gio metadata to trust desktop files
# We create a script that runs once at login to trust all skel desktop files
mkdir -p /etc/skel/.config/autostart || true
cat > /etc/skel/.config/autostart/trust-desktop-files.desktop << 'TRUST_AUTO'
[Desktop Entry]
Type=Application
Name=Trust Desktop Launchers
Exec=/usr/local/bin/alfred-trust-desktop
Hidden=false
NoDisplay=true
X-GNOME-Autostart-enabled=true
TRUST_AUTO
mkdir -p /etc/skel/.config/autostart || true

cat > /usr/local/bin/alfred-trust-desktop << 'TRUSTSCRIPT'
# Trust all .desktop files on the Desktop for Plasma
# This runs once at first login, then disables itself
DESKTOP_DIR="$HOME/Desktop"
if [[ -d "$DESKTOP_DIR" ]]; then
    for f in "$DESKTOP_DIR"/*.desktop; do
        [[ -f "$f" ]] || continue
        # Plasma trusts launchers by matching a hash of the file
        HASH=$(sha256sum "$f" | cut -d' ' -f1)
        chmod +x "$f" 2>/dev/null || true
        gio set "$f" metadata::trusted true 2>/dev/null || true
    done
fi
# Disable self after first run
rm -f "$HOME/.config/autostart/trust-desktop-files.desktop" 2>/dev/null || true
TRUSTSCRIPT
chmod +x /usr/local/bin/alfred-trust-desktop || true

# ── 6. "Install or Try" dialog on live boot ──
cat > /usr/local/bin/alfred-live-welcome << 'LIVEWELCOME'
# Show install prompt on live boot (only if not installed)
if [[ -f /run/live/medium/.disk/info ]] || [[ -d /run/live ]]; then
    # We're in a live session
    zenity --question \
        --width=400 --height=180 \
        --window-icon=calamares 2>/dev/null
    if [[ $? -eq 0 ]]; then
        pkexec calamares &
    fi
fi
LIVEWELCOME
chmod +x /usr/local/bin/alfred-live-welcome || true

# Autostart the welcome dialog in live sessions
cat > /etc/skel/.config/autostart/alfred-live-welcome.desktop << 'LIVEWELC_AUTO'
[Desktop Entry]
Type=Application
Name=Alfred Linux Welcome
Comment=Install or Try Alfred Linux
Exec=/usr/local/bin/alfred-live-welcome
Hidden=false
NoDisplay=true
X-GNOME-Autostart-enabled=true
LIVEWELC_AUTO

# ── 7. Ensure zenity is available for the dialog ──
apt_nonfatal installer-ui zenity

echo "[Alfred Linux v7.77] Calamares installer branded, configured, and install prompt enabled."

# ── 8. Fix Debian-branded desktop files left by calamares-settings-debian ──
if [[ -f /usr/share/applications/install-debian.desktop ]]; then
    sed -i 's/Name=Install Debian/Name=Install Alfred Linux/' /usr/share/applications/install-debian.desktop || true
    sed -i 's/Comment=Calamares.*$/Comment=Install Alfred Linux to your hard drive/' /usr/share/applications/install-debian.desktop || true
fi
