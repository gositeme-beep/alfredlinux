# ==========================================
# RESTORED HOOK: 0037-alfred-tabernacle.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0037-alfred-tabernacle.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
