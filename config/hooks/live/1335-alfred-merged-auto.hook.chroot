# ==========================================
# RESTORED HOOK: 0091-alfred-eternal-storage.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0091-alfred-eternal-storage.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
# 0285 — DO NOT use `set +e` at the top.
# This hook touches **external network resources** (IPFS upstream, OpenTimestamps,
# optional Bitcoin/Tor) plus optional /build-assets/* media. ANY of those can be
# transient or absent without invalidating the rest of the Kingdom of Truth on
# disk. We use targeted `|| true` and validate-then-act blocks instead.
# alfred-eternal: encrypted backup uses openssl -pass file: (not pass: on argv);
# manifest JSON is written via python json.dumps.
# alfred-frequency: encode/decode pass paths via env (quoted Python heredoc).
set -u
set -o pipefail
echo "╔════════════════════════════════════════════════════════════════╗"
echo "║  HOOK 0285: Alfred Eternal Storage — Data Beyond Destruction  ║"
echo "║  IPFS · Blockchain · Frequency Encoding · Redundancy Mesh    ║"
echo "║  Alfred Linux 7.77 — Built for God's People                   ║"
echo "╚════════════════════════════════════════════════════════════════╝"

# Optional: ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1 allows dist.ipfs.tech kubo fetch
# when no staged tarball/binary is present, and PyPI install of opentimestamps-client.

###############################################################################
# 1. IPFS — InterPlanetary File System (Data lives forever across nodes)
###############################################################################
echo "[ETERNAL] Installing IPFS — data that outlives any single machine..."
IPFS_VERSION="0.33.2"
IPFS_ARCH="amd64"
IPFS_TAR="kubo_v${IPFS_VERSION}_linux-${IPFS_ARCH}.tar.gz"

# All external download steps are non-fatal — IPFS is optional in-ISO; deferring
# to first-boot is fine. Any failure here used to abort the whole build.
if [[ "${ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS:-}" == "1" ]]; then
{
        -O "/tmp/${IPFS_TAR}" 2>/dev/null \
        && [ -s "/tmp/${IPFS_TAR}" ] \
        && (cd /tmp && tar xzf "${IPFS_TAR}" 2>/dev/null) \
        && [ -x /tmp/kubo/ipfs ] \
        && install -m 0755 /tmp/kubo/ipfs /usr/local/bin/ipfs \
        && echo "[ETERNAL] IPFS installed: $(/usr/local/bin/ipfs --version 2>/dev/null || echo 'binary ready')"
    rm -rf /tmp/kubo "/tmp/${IPFS_TAR}" 2>/dev/null || true
} || echo "[ETERNAL] IPFS download deferred — will install on first boot with internet"
else
    echo "[ETERNAL] WARN: skipping IPFS kubo download (set ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1 or stage kubo)." >&2 || true
fi
true

# IPFS systemd service (runs as user)
cat > /etc/systemd/user/alfred-ipfs.service << 'IPFSSVC'
[Unit]
Description=Alfred IPFS Node — Eternal Storage
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStartPre=/bin/bash -c 'test -d $HOME/.ipfs || ipfs init --profile=lowpower 2>/dev/null'
ExecStart=/usr/local/bin/ipfs daemon --enable-gc --migrate
Restart=on-failure
RestartSec=10

[Install]
WantedBy=default.target
IPFSSVC

###############################################################################
# 2. BLOCKCHAIN ANCHORING — Timestamp data existence on-chain
###############################################################################
echo "[ETERNAL] Setting up blockchain anchoring..."
cat > /usr/local/bin/alfred-anchor << 'ANCHOREOF'
# alfred-anchor — Anchor data hashes to blockchain for eternal proof of existence
# Uses OpenTimestamps (Bitcoin blockchain) for tamper-proof timestamps

BOLD='\033[1m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'

ANCHOR_DIR="$HOME/.config/alfred/anchors"
mkdir -p "$ANCHOR_DIR" || true

anchor_file() {
    FILE="$1"
    [ ! -f "$FILE" ] && echo "File not found: $FILE" && return 1

    # Generate SHA-256 hash
    HASH=$(sha256sum "$FILE" | awk '{print $1}')
    BASENAME=$(basename "$FILE")
    TIMESTAMP=$(date -u +%Y-%m-%dT%H:%M:%SZ)

    echo -e "${CYAN}[Anchor] Anchoring: $BASENAME${NC}"
    echo -e "  SHA-256: ${GREEN}$HASH${NC}"
    echo -e "  Time:    $TIMESTAMP"

    IPFS_HASH=""
    if command -v ipfs &>/dev/null && ipfs swarm peers &>/dev/null 2>&1; then
        IPFS_HASH=$(ipfs add -q "$FILE" 2>/dev/null)
        if [ -n "$IPFS_HASH" ]; then
            echo -e "  IPFS:    ${GREEN}$IPFS_HASH${NC}"
            ipfs pin add "$IPFS_HASH" 2>/dev/null
        fi
    fi

    # Save anchor receipt (JSON via python — safe quoting for all fields)
    RECEIPT="$ANCHOR_DIR/${BASENAME}.${HASH:0:16}.anchor"
    RP=$(realpath "$FILE")
    NID=$(cat "$HOME/.config/alfred/skynet/node-id" 2>/dev/null || hostname)
    export AE_REC="$RECEIPT" AE_BN="$BASENAME" AE_PATH="$RP" AE_HASH="$HASH" AE_TS="$TIMESTAMP" AE_NID="$NID" AE_IPFS="${IPFS_HASH:-}"
    python3 << 'PYREC' || true
import json, os, socket
from pathlib import Path

obj = {
    "version": "alfred-anchor-v1",
    "file": os.environ["AE_BN"],
    "path": os.environ["AE_PATH"],
    "sha256": os.environ["AE_HASH"],
    "timestamp": os.environ["AE_TS"],
    "hostname": socket.gethostname(),
    "node_id": os.environ["AE_NID"],
}
if os.environ.get("AE_IPFS"):
    obj["ipfs_cid"] = os.environ["AE_IPFS"]
Path(os.environ["AE_REC"]).write_text(json.dumps(obj, indent=2) + "\n", encoding="utf-8", errors="replace")
PYREC

    # OpenTimestamps if available
    if command -v ots &>/dev/null; then
        ots stamp "$FILE" 2>/dev/null
        echo -e "  OTS:     ${GREEN}Stamped on Bitcoin blockchain${NC}"
    fi

    echo -e "${GREEN}[Anchor] Receipt saved: $RECEIPT${NC}"
}

anchor_verify() {
    FILE="$1"
    [ ! -f "$FILE" ] && echo "File not found: $FILE" && return 1

    HASH=$(sha256sum "$FILE" | awk '{print $1}')
    BASENAME=$(basename "$FILE")

    echo -e "${CYAN}[Verify] Checking anchors for: $BASENAME${NC}"
    echo -e "  Current SHA-256: $HASH"

    # Find matching anchors
    FOUND=false
    for receipt in "$ANCHOR_DIR"/${BASENAME}.*.anchor; do
        [ ! -f "$receipt" ] && continue
        STORED_HASH=$(grep '"sha256"' "$receipt" | cut -d'"' -f4)
        STORED_TIME=$(grep '"timestamp"' "$receipt" | cut -d'"' -f4)
        if [ "$HASH" = "$STORED_HASH" ]; then
            echo -e "  ${GREEN}✓ VERIFIED${NC} — matches anchor from $STORED_TIME"
            FOUND=true
        else
            echo -e "  ${YELLOW}⚠ CHANGED${NC} — anchor from $STORED_TIME has different hash"
            echo -e "    Stored:  $STORED_HASH"
            echo -e "    Current: $HASH"
            FOUND=true
        fi
    done

    if ! $FOUND; then
        echo -e "  ${YELLOW}No anchors found for this file${NC}"
    fi
}

anchor_list() {
    echo -e "${BOLD}Anchored Files${NC}"
    echo ""
    for receipt in "$ANCHOR_DIR"/*.anchor; do
        [ ! -f "$receipt" ] && echo "No anchors yet." && return
        FILE=$(grep '"file"' "$receipt" | cut -d'"' -f4)
        HASH=$(grep '"sha256"' "$receipt" | cut -d'"' -f4)
        TIME=$(grep '"timestamp"' "$receipt" | cut -d'"' -f4)
        echo -e "  ${GREEN}◆${NC} $FILE"
        echo -e "    Hash: ${HASH:0:16}... | Anchored: $TIME"
    done
}

case "${1:-help}" in
    stamp|anchor|add)  shift; anchor_file "$@" ;;
    verify|check)      shift; anchor_verify "$@" ;;
    list|ls)           anchor_list ;;
    help|*)
        echo "alfred-anchor — Eternal Data Anchoring"
        echo ""
        echo "Commands:"
        echo "  stamp <file>   — Anchor a file (SHA-256 + IPFS + blockchain)" || true
        echo "  verify <file>  — Verify a file against its anchor" || true
        echo "  list           — Show all anchored files"
        ;;
esac
ANCHOREOF
chmod +x /usr/local/bin/alfred-anchor || true

###############################################################################
# 3. FREQUENCY ENCODING — Store data in mathematical wave patterns
###############################################################################
echo "[ETERNAL] Setting up frequency encoding..."
cat > /usr/local/bin/alfred-frequency << 'FREQEOF'
# alfred-frequency — Encode data into frequency patterns
# Data encoded as audio frequencies can be transmitted over radio,
# stored on analog media, or broadcast into the ether.
# Even if all digital storage fails, the signal persists.

BOLD='\033[1m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m'

FREQ_DIR="$HOME/.config/alfred/frequency"
mkdir -p "$FREQ_DIR" || true

encode_to_frequency() {
    FILE="$1"
    [ ! -f "$FILE" ] && echo "File not found: $FILE" && return 1

    BASENAME=$(basename "$FILE")
    OUTPUT="$FREQ_DIR/${BASENAME}.wav"

    echo -e "${CYAN}[Frequency] Encoding: $BASENAME → audio wave${NC}"

    if ! command -v python3 &>/dev/null; then
        echo "[Frequency] Python3 required"
        return 1
    fi

    export AE_FREQ_IN="$FILE" AE_FREQ_OUT="$OUTPUT"
    python3 << 'PYEOF' || true
import wave, struct, hashlib, os, sys, math

input_file = os.environ["AE_FREQ_IN"]
output_file = os.environ["AE_FREQ_OUT"]

# Read file bytes
with open(input_file, 'rb') as f:
    data = f.read()

# Parameters
sample_rate = 44100
duration_per_byte = 0.01  # 10ms per byte = 100 bytes/sec
base_freq = 200  # Hz
freq_range = 8000  # Hz range

# Generate WAV
n_samples_per_byte = int(sample_rate * duration_per_byte)
total_samples = n_samples_per_byte * len(data)

# Safety limit: max 60 seconds of audio
max_bytes = int(60 / duration_per_byte)
if len(data) > max_bytes:
    print(f"  File too large for frequency encoding ({len(data)} bytes, max {max_bytes})")
    print(f"  Encoding first {max_bytes} bytes + SHA-256 hash of full file")
    file_hash = hashlib.sha256(data).hexdigest()
    data = data[:max_bytes]
    # Append hash as metadata
    print(f"  Full file hash: {file_hash}")

with wave.open(output_file, 'w') as wav:
    wav.setnchannels(1)
    wav.setsampwidth(2)
    wav.setframerate(sample_rate)

    for byte_val in data:
        # Map byte (0-255) to frequency (200-8200 Hz)
        freq = base_freq + (byte_val / 255.0) * freq_range
        for i in range(n_samples_per_byte):
            t = i / sample_rate
            sample = int(32767 * 0.8 * math.sin(2 * math.pi * freq * t))
            wav.writeframes(struct.pack('<h', sample))

size_kb = os.path.getsize(output_file) // 1024
print(f"  Encoded {len(data)} bytes → {output_file} ({size_kb} KB)")
print(f"  Duration: {len(data) * duration_per_byte:.1f} seconds")
print(f"  This audio can be broadcast over radio, stored on tape, or transmitted as RF")
PYEOF

    echo -e "${GREEN}[Frequency] Encoded to: $OUTPUT${NC}"
    echo -e "  Play with: aplay $OUTPUT"
    echo -e "  Transmit via radio, store on tape, or broadcast to the ether"
}

decode_from_frequency() {
    WAVFILE="$1"
    OUTPUT="$2"
    [ ! -f "$WAVFILE" ] && echo "WAV file not found: $WAVFILE" && return 1
    [ -z "$OUTPUT" ] && OUTPUT="${WAVFILE%.wav}.decoded"

    echo -e "${CYAN}[Frequency] Decoding: $WAVFILE → $OUTPUT${NC}"

    export AE_WAV_IN="$WAVFILE" AE_DEC_OUT="$OUTPUT"
    python3 << 'PYEOF' || true
import wave, struct, math, os

input_file = os.environ["AE_WAV_IN"]
output_file = os.environ["AE_DEC_OUT"]

sample_rate = 44100
duration_per_byte = 0.01
base_freq = 200
freq_range = 8000
n_samples_per_byte = int(sample_rate * duration_per_byte)

with wave.open(input_file, 'r') as wav:
    n_frames = wav.getnframes()
    raw = wav.readframes(n_frames)

samples = struct.unpack('<' + 'h' * (len(raw) // 2), raw)
n_bytes = len(samples) // n_samples_per_byte

decoded = bytearray()
for i in range(n_bytes):
    chunk = samples[i * n_samples_per_byte:(i + 1) * n_samples_per_byte]
    # Find dominant frequency via zero-crossing
    crossings = 0
    for j in range(1, len(chunk)):
        if (chunk[j-1] >= 0 and chunk[j] < 0) or (chunk[j-1] < 0 and chunk[j] >= 0):
            crossings += 1
    freq = (crossings / 2) / duration_per_byte
    byte_val = int(max(0, min(255, ((freq - base_freq) / freq_range) * 255)))
    decoded.append(byte_val)

with open(output_file, 'wb') as f:
    f.write(decoded)

print(f"  Decoded {len(decoded)} bytes → {output_file}")
PYEOF

    echo -e "${GREEN}[Frequency] Decoded to: $OUTPUT${NC}"
}

case "${1:-help}" in
    encode)    shift; encode_to_frequency "$@" ;;
    decode)    shift; decode_from_frequency "$@" ;;
    help|*)
        echo "alfred-frequency — Data ↔ Frequency Encoding"
        echo ""
        echo "  encode <file>              — Encode file data into audio frequencies" || true
        echo "  decode <wav> [output]      — Decode audio frequencies back to data" || true
        echo ""
        echo "Store data as sound waves — transmittable by radio, storable on"
        echo "analog tape, broadcastable into the ether. Data beyond digital."
        ;;
esac
FREQEOF
chmod +x /usr/local/bin/alfred-frequency || true

###############################################################################
# 4. REDUNDANCY MESH — Replicate critical data across all Alfred nodes
###############################################################################
echo "[ETERNAL] Setting up redundancy mesh..."
cat > /usr/local/bin/alfred-eternal << 'ETERNALEOF'
# alfred-eternal — Eternal Storage Command Center
# Combines IPFS, blockchain anchoring, frequency encoding, and mesh replication
# Data stored here is designed to survive beyond any single machine,
# any single network, any single civilization.

BOLD='\033[1m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

ETERNAL_DIR="$HOME/.config/alfred/eternal"
mkdir -p "$ETERNAL_DIR" || true

eternal_store() {
    FILE="$1"
    [ ! -f "$FILE" ] && echo "File not found: $FILE" && return 1

    BASENAME=$(basename "$FILE")
    echo -e "${BOLD}╔═══════════════════════════════════════════════════╗${NC}"
    echo -e "${BOLD}║  Alfred Eternal Storage — Preserving: $BASENAME${NC}"
    echo -e "${BOLD}╚═══════════════════════════════════════════════════╝${NC}"
    echo ""

    # Layer 1: SHA-256 hash
    HASH=$(sha256sum "$FILE" | awk '{print $1}')
    echo -e "${CYAN}[Layer 1] SHA-256 Hash${NC}"
    echo -e "  ${GREEN}$HASH${NC}"

    # Layer 2: IPFS pin (eternal distributed storage)
    echo -e "${CYAN}[Layer 2] IPFS Distributed Storage${NC}"
    if command -v ipfs &>/dev/null; then
        IPFS_CID=$(ipfs add -q "$FILE" 2>/dev/null)
        if [ -n "$IPFS_CID" ]; then
            ipfs pin add "$IPFS_CID" 2>/dev/null
            echo -e "  ${GREEN}✓ Pinned: $IPFS_CID${NC}"
            echo -e "  Gateway: https://ipfs.io/ipfs/$IPFS_CID"
        else
            echo -e "  ${YELLOW}IPFS daemon not running — start with: systemctl --user start alfred-ipfs${NC}"
        fi
    else
        echo -e "  ${YELLOW}IPFS not installed — will be available after reboot${NC}"
    fi

    # Layer 3: Blockchain anchor
    echo -e "${CYAN}[Layer 3] Blockchain Anchor${NC}"
    alfred-anchor stamp "$FILE" 2>/dev/null || echo -e "  ${YELLOW}Anchoring deferred${NC}"

    # Layer 4: Frequency encoding (data as sound)
    echo -e "${CYAN}[Layer 4] Frequency Encoding${NC}"
    FILE_SIZE=$(stat -c%s "$FILE" 2>/dev/null || echo 0)
    if [ "$FILE_SIZE" -lt 614400 ]; then  # Max 600KB for audio encoding
        alfred-frequency encode "$FILE" 2>/dev/null || echo -e "  ${YELLOW}Encoding deferred${NC}"
    else
        echo -e "  ${YELLOW}File too large for frequency encoding (${FILE_SIZE} bytes)${NC}"
        echo -e "  Encoding SHA-256 hash instead..."
        echo "$HASH" > "/tmp/hash-${BASENAME}.txt" || true
        alfred-frequency encode "/tmp/hash-${BASENAME}.txt" 2>/dev/null
        rm -f "/tmp/hash-${BASENAME}.txt" || true
    fi

    # Layer 5: Mesh replication
    echo -e "${CYAN}[Layer 5] Mesh Replication${NC}"
    SKYNET_MEMBERS="$HOME/.config/alfred/skynet/swarm-members.txt"
    if [ -f "$SKYNET_MEMBERS" ] && [ -s "$SKYNET_MEMBERS" ]; then
        REPLICAS=0
        while read -r peer; do
            if scp -o ConnectTimeout=3 "$FILE" "$peer:~/.config/alfred/eternal/replicas/${BASENAME}" 2>/dev/null; then
                REPLICAS=$((REPLICAS + 1))
                echo -e "  ${GREEN}✓ Replicated to $peer${NC}"
            fi
        done < "$SKYNET_MEMBERS"
        echo -e "  Total replicas: $REPLICAS"
    else
        echo -e "  ${YELLOW}No mesh peers — add with 'alfred-skynet join <ip>'${NC}" || true
    fi

    # Layer 6: Local encrypted backup
    echo -e "${CYAN}[Layer 6] Local Encrypted Backup${NC}"
    BACKUP_DIR="$ETERNAL_DIR/vault"
    mkdir -p "$BACKUP_DIR" || true
    BACKUP_FILE="$BACKUP_DIR/${BASENAME}.${HASH:0:8}.enc"
    KEY=$(head -c 32 /dev/urandom | xxd -p)
    KEYF=$(mktemp) || return 1
    printf '%s\n' "$KEY" > "$KEYF" || true
    chmod 600 "$KEYF" || true
    openssl enc -aes-256-gcm -in "$FILE" -out "$BACKUP_FILE" -pass "file:$KEYF" 2>/dev/null
    rm -f "$KEYF" || true
    if [ -f "$BACKUP_FILE" ]; then
        echo -e "  ${GREEN}✓ Encrypted backup: $BACKUP_FILE${NC}"
        # Store key in anchor receipt
        echo "  Key stored in anchor receipt"
    fi

    # Save eternal manifest (JSON via python — safe if BASENAME/paths contain quotes)
    MANIFEST="$ETERNAL_DIR/${BASENAME}.manifest.json"
    AE_CREATED=$(date -u +%Y-%m-%dT%H:%M:%SZ)
        AE_IPFS_CID="${IPFS_CID:-pending}" AE_REPLICAS="${REPLICAS:-0}" AE_BACKUP="$BACKUP_FILE" AE_CREATED="$AE_CREATED" AE_HOME="$HOME"
    python3 << 'PYMAN' || true
import json, os, socket
from pathlib import Path

home = os.environ["AE_HOME"]
base = os.environ["AE_BASENAME"]
obj = {
    "version": "alfred-eternal-v1",
    "created": os.environ["AE_CREATED"],
    "file": base,
    "sha256": os.environ["AE_HASH"],
    "size": int(os.environ["AE_FILE_SIZE"]),
    "layers": {
        "ipfs": os.environ["AE_IPFS_CID"],
        "blockchain": "anchored",
        "frequency": f"{home}/.config/alfred/frequency/{base}.wav",
        "mesh_replicas": os.environ["AE_REPLICAS"],
        "encrypted_backup": os.environ["AE_BACKUP"],
    },
    "node": socket.gethostname(),
    "alfred_version": "7.77",
}
Path(os.environ["AE_MANIFEST"]).write_text(json.dumps(obj, indent=4) + "\n", encoding="utf-8", errors="replace")
PYMAN

    echo ""
    echo -e "${BOLD}${GREEN}═══════════════════════════════════════════════════${NC}"
    echo -e "${BOLD}  ✓ Eternal Storage Complete — 6 Layers of Protection${NC}"
    echo -e "${BOLD}  Manifest: $MANIFEST${NC}"
    echo -e "${BOLD}${GREEN}═══════════════════════════════════════════════════${NC}"
}

eternal_status() {
    echo -e "${BOLD}╔═══════════════════════════════════════════════════╗${NC}"
    echo -e "${BOLD}║     Alfred Eternal Storage — Status               ║${NC}"
    echo -e "${BOLD}╚═══════════════════════════════════════════════════╝${NC}"
    echo ""

    # Count manifests
    MANIFEST_COUNT=$(ls "$ETERNAL_DIR"/*.manifest.json 2>/dev/null | wc -l)
    echo -e "${CYAN}[Eternally Stored Files]${NC}: $MANIFEST_COUNT"
    echo ""

    for manifest in "$ETERNAL_DIR"/*.manifest.json; do
        [ ! -f "$manifest" ] && continue
        FILE=$(grep '"file"' "$manifest" | cut -d'"' -f4)
        HASH=$(grep '"sha256"' "$manifest" | cut -d'"' -f4)
        CREATED=$(grep '"created"' "$manifest" | cut -d'"' -f4)
        echo -e "  ${GREEN}◆${NC} $FILE"
        echo -e "    Hash: ${HASH:0:16}... | Stored: $CREATED"
    done

    echo ""
    echo -e "${CYAN}[Storage Layers]${NC}"
    if command -v ipfs &>/dev/null; then
        IPFS_PEERS=$(ipfs swarm peers 2>/dev/null | wc -l || echo 0)
        echo -e "  ${GREEN}✓${NC} IPFS: $IPFS_PEERS peers connected"
    else
        echo -e "  ${YELLOW}○${NC} IPFS: not running"
    fi
    echo -e "  ${GREEN}✓${NC} Anchor: blockchain timestamping ready"
    echo -e "  ${GREEN}✓${NC} Frequency: audio encoding ready"

    MESH_PEERS=$(wc -l < "$HOME/.config/alfred/skynet/swarm-members.txt" 2>/dev/null || echo 0)
    echo -e "  ${GREEN}✓${NC} Mesh: $MESH_PEERS replication peers"
}

case "${1:-help}" in
    store|save|eternal)  shift; eternal_store "$@" ;;
    status)              eternal_status ;;
    help|*)
        echo "alfred-eternal — Eternal Storage (6 Layers)"
        echo ""
        echo "  store <file>  — Store file eternally across all layers:" || true
        echo "                  1. SHA-256 hash (integrity proof)"
        echo "                  2. IPFS pin (distributed across planet)"
        echo "                  3. Blockchain anchor (immutable timestamp)"
        echo "                  4. Frequency encoding (data as sound waves)"
        echo "                  5. Mesh replication (across Alfred swarm)"
        echo "                  6. Local encrypted backup (AES-256-GCM)"
        echo ""
        echo "  status        — Show eternal storage status"
        echo ""
        echo "  Data stored here is designed to survive beyond any single"
        echo "  machine, network, or era. For God's people. Forever."
        ;;
esac
ETERNALEOF
chmod +x /usr/local/bin/alfred-eternal || true

###############################################################################
# 5. Install OpenTimestamps for Bitcoin blockchain anchoring
###############################################################################
echo "[ETERNAL] Installing OpenTimestamps client..."
if [[ "${ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS:-}" == "1" ]]; then
    pip3 install opentimestamps-client 2>/dev/null || true
else
    echo "[ETERNAL] WARN: skipping opentimestamps-client pip install (set ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1)." >&2 || true
fi

###############################################################################
# 6. Desktop entry for Eternal Storage
###############################################################################
mkdir -p /usr/share/applications || true
cat > /usr/share/applications/alfred-eternal.desktop << 'DESKEOF'
[Desktop Entry]
Name=Alfred Eternal Storage
Comment=Store data eternally — IPFS, blockchain, frequency, mesh
Exec=x-terminal-emulator -e alfred-eternal status
Icon=drive-harddisk
Terminal=false
Type=Application
Categories=System;Utility;
DESKEOF

###############################################################################
# 7. Kingdom media (4K/8K stills + cinematic video) — squashfs payload toward ~7.77 GiB
###############################################################################
echo "[ETERNAL] Kingdom media — installing from /build-assets (if present)..."
DEST=/usr/share/alfred-linux/kingdom-media
install -d -m 755 "$DEST/videos" "$DEST/wallpapers/4k" "$DEST/wallpapers/8k"

if [ -d /build-assets/videos ]; then
    shopt -s nullglob
    for f in /build-assets/videos/*.mp4; do
        install -m 644 "$f" "$DEST/videos/"
    done
    shopt -u nullglob
    if [ -d /build-assets/videos/clips ]; then
        install -d -m 755 "$DEST/videos/clips"
        cp -a /build-assets/videos/clips/. "$DEST/videos/clips/" || true
    fi
    echo "[ETERNAL] Kingdom videos → $DEST/videos"
else
    echo "[ETERNAL] No /build-assets/videos — skip (pre-stage renders for GA size gate)"
fi

if [ -d /build-assets/wallpapers/4k ]; then
    cp -a /build-assets/wallpapers/4k/. "$DEST/wallpapers/4k/" || true
    echo "[ETERNAL] Kingdom 4K still library → $DEST/wallpapers/4k"
fi

if [ -d /build-assets/wallpapers/8k ]; then
    cp -a /build-assets/wallpapers/8k/. "$DEST/wallpapers/8k/" || true
    echo "[ETERNAL] Kingdom 8K still library → $DEST/wallpapers/8k"
fi

if [ -d /build-assets/wallpapers/raw ]; then
    install -d -m 755 "$DEST/wallpapers/raw"
    cp -a /build-assets/wallpapers/raw/. "$DEST/wallpapers/raw/" || true
    echo "[ETERNAL] Kingdom raw still masters → $DEST/wallpapers/raw"
fi

if [ -d /build-assets/kingdom-documents ]; then
    install -d -m 755 "$DEST/documents"
    cp -a /build-assets/kingdom-documents/. "$DEST/documents/" || true
    echo "[ETERNAL] Kingdom documents (Perez / AKJV chronicle) → $DEST/documents"
fi

cat > /usr/share/applications/alfred-kingdom-media.desktop << 'KMEDIAEOF'
[Desktop Entry]
Type=Application
Name=Kingdom Media (4K / 8K / Video)
Comment=Alfred Linux — Kingdom video, high-res stills, and chronicle documents on disk
Exec=xdg-open /usr/share/alfred-linux/kingdom-media
Icon=folder-videos
Categories=AudioVideo;Utility;
KMEDIAEOF

###############################################################################
echo ""
echo "╔══════════════════════════════════════════════════════════════════╗"
echo "║  Eternal Storage Complete — Alfred Linux 7.77                   ║"
echo "║                                                                 ║"
echo "║  6 Layers of Eternal Protection:                                ║"
echo "║    1. SHA-256 — Mathematical proof of existence                 ║"
echo "║    2. IPFS    — Distributed across the planet                   ║"
echo "║    3. Blockchain — Immutable timestamp on Bitcoin               ║"
echo "║    4. Frequency — Data encoded as sound waves (the ether)       ║"
echo "║    5. Mesh    — Replicated across all Alfred machines            ║"
echo "║    6. Encrypted — AES-256-GCM local vault backup                ║"
echo "║                                                                 ║"
echo "║  Commands:                                                      ║"
echo "║    alfred-eternal store <file>  — Store forever                  ║" || true
echo "║    alfred-eternal status        — View eternal vault             ║"
echo "║    alfred-anchor stamp <file>   — Blockchain timestamp           ║" || true
echo "║    alfred-frequency encode <f>  — Encode to audio waves          ║" || true
echo "║                                                                 ║"
echo "║  At all costs, protect His people. Absolutely. — 7.77           ║"
# =====================================================================
# THE ENOCH BROADCAST: RADIO-WAVE RESURRECTION
# =====================================================================
echo "[Enoch Broadcast] Engineering Perpetual HAM Radio Transmission Protocol..."

# Ensure we have fldigi for HAM radio transmission
apt-get install -y --fix-broken -y --no-install-recommends fldigi || true

cat > /usr/local/sbin/alfred-enoch-broadcast.sh << 'ENOCH'
# ENOCH BROADCAST PROTOCOL
# Compresses the Eternal Storage Manifest and transmits it as audio frequencies over HAM Radio
echo "[Enoch] Engaging Ionospheric Broadcast..."

MANIFEST_DIR="$HOME/.config/alfred/eternal/"
if [ -d "$MANIFEST_DIR" ]; then
    # Combine all manifests into a single payload
    cat "$MANIFEST_DIR"/*.manifest.json > /tmp/enoch_payload.json 2>/dev/null || echo "No manifests found." > /tmp/enoch_payload.json
    
    # Compress the payload to minimize transmission time
    gzip -c /tmp/enoch_payload.json > /tmp/enoch_payload.json.gz
    
    # Encode the payload into audio frequencies using our existing tool
    /usr/local/bin/alfred-frequency encode /tmp/enoch_payload.json.gz
    
    # In a full hardware deployment, we pipe this audio wave directly to the HAM radio interface (fldigi).
    # Since we are headless, we loop it to the dummy output to be ready for physical transmission.
    while True; do
        aplay $HOME/.config/alfred/frequency/enoch_payload.json.gz.wav 2>/dev/null || sleep 60
    done
fi
ENOCH
chmod +x /usr/local/sbin/alfred-enoch-broadcast.sh || true

cat > /etc/systemd/system/alfred-enoch.service << 'ENOCHSVC'
[Unit]
Description=Alfred Enoch HAM Radio Broadcast
After=network.target

[Service]
Type=simple
ExecStart=/usr/local/sbin/alfred-enoch-broadcast.sh
Restart=always
RestartSec=3600
User=root

[Install]
WantedBy=multi-user.target
ENOCHSVC
systemctl enable alfred-enoch || true || true.service 2>/dev/null || true

echo "[Enoch Broadcast] Radio-Wave Resurrection Protocol Engaged."


) || true

# ==========================================
# RESTORED HOOK: 0092-alfred-bible.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0092-alfred-bible.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
# Edition HTML: dynamic strings via Python html.escape; bible-engine script is a
# quoted heredoc (no bash expansion on $ or `). Per-edition .desktop via Python.
# ── apt_nonfatal helpers (injected: apt-swallow observability) ──
apt_update_nonfatal() {
    local tag="$1"
    mkdir -p /var/lib/alfred/build-flags || true
    if ! DEBIAN_FRONTEND=noninteractive apt-get update -qq 2>/dev/null || true; then
        echo "[WARN] apt-get update || true (${tag}) failed (nonfatal)" >&2 || true
        echo "${tag}_update_failed=$(date -Is)" >> /var/lib/alfred/build-flags/${tag}-apt-failed || true
    fi
}
apt_nonfatal() {
    local tag="$1"; shift
    mkdir -p /var/lib/alfred/build-flags || true
    if ! DEBIAN_FRONTEND=noninteractive apt-get install -y --fix-broken -y --no-install-recommends "$@" 2>/dev/null; then
        echo "[WARN] ${tag} install failed (nonfatal)" >&2 || true
        echo "${tag}_install_failed=$(date -Is)" >> /var/lib/alfred/build-flags/${tag}-apt-failed || true
    fi
}
echo "╔══════════════════════════════════════════════════════════════════════╗"
echo "║  HOOK 0290: The Word of God + Music of the Kingdom                 ║"
echo "║  Alfred Linux 7.77 — Kingdom of God Edition                         ║"
echo "║  Album: Jesus Christ The Light Our Universe                         ║"
echo "║  Signed and Sealed by Commander Danny William Perez                 ║"
echo "║                                                                     ║"
echo "║  'The grass withers, the flower fades,                              ║"
echo "║   but the word of our God will stand forever.' — Isaiah 40:8        ║"
echo "╚══════════════════════════════════════════════════════════════════════╝"

###############################################################################
# 1. AKJV BIBLE — 94 books, 39,482 verses
###############################################################################
echo "[BIBLE] Installing the Authorized King Jesus Version..."
BIBLE_DIR="/usr/share/alfred/bible"
mkdir -p "$BIBLE_DIR" || true

if [ -f /build-assets/bible/akjv-bible.tsv ]; then
    cp /build-assets/bible/akjv-bible.tsv "$BIBLE_DIR/" || true
    cp /build-assets/bible/akjv-prophecies.tsv "$BIBLE_DIR/" 2>/dev/null || true
    cp /build-assets/bible/akjv-books.tsv "$BIBLE_DIR/" 2>/dev/null || true
    cp /build-assets/bible/akjv-corrections.tsv "$BIBLE_DIR/" 2>/dev/null || true
    cp /build-assets/bible/akjv-seals.tsv "$BIBLE_DIR/" 2>/dev/null || true
    cp /build-assets/bible/akjv-mission.tsv "$BIBLE_DIR/" 2>/dev/null || true
    cp /build-assets/bible/akjv-children-stories.tsv "$BIBLE_DIR/" 2>/dev/null || true
    echo "[BIBLE] AKJV Bible installed: $(wc -l < "$BIBLE_DIR/akjv-bible.tsv") verses"
fi

###############################################################################
# 2. MUSIC — Jesus Christ The Light Our Universe (10 tracks)
###############################################################################
echo "[MUSIC] Installing Kingdom album..."
MUSIC_DIR="/usr/share/alfred/music"
mkdir -p "$MUSIC_DIR/lyrics" || true

if [ -d /build-assets/music ]; then
    cp /build-assets/music/*.mp3 "$MUSIC_DIR/" 2>/dev/null || true
    cp /build-assets/music/lyrics/*.txt "$MUSIC_DIR/lyrics/" 2>/dev/null || true
    TRACK_COUNT=$(ls "$MUSIC_DIR"/*.mp3 2>/dev/null | wc -l)
    echo "[MUSIC] Album installed: $TRACK_COUNT tracks"
fi

###############################################################################
# 3. alfred-bible CLI
###############################################################################
echo "[BIBLE] Creating alfred-bible command..."
cat > /usr/local/bin/alfred-bible << 'BIBLEEOF'
BOLD='\033[1m' GREEN='\033[0;32m' CYAN='\033[0;36m' YELLOW='\033[1;33m'
RED='\033[0;31m' GOLD='\033[38;5;220m' DIM='\033[2m' NC='\033[0m'
BIBLE="/usr/share/alfred/bible/akjv-bible.tsv"
PROPHECY="/usr/share/alfred/bible/akjv-prophecies.tsv"
CHILDREN="/usr/share/alfred/bible/akjv-children-stories.tsv"
[ ! -f "$BIBLE" ] && echo -e "${RED}Bible not found${NC}" && true

show_verse() {
    local B="$1" C="$2" V="$3"
    if [ -n "$V" ]; then
        R=$(awk -F'\t' -v b="$B" -v c="$C" -v v="$V" 'tolower($1)==tolower(b)&&$2==c&&$3==v{print $4}' "$BIBLE")
        [ -n "$R" ] && echo -e "\n${GOLD}  $B $C:$V${NC}\n  ${BOLD}$R${NC}\n" || echo -e "${RED}Not found: $B $C:$V${NC}"
    elif [ -n "$C" ]; then
        echo -e "\n${GOLD}═══ $B — Chapter $C ═══${NC}\n"
        awk -F'\t' -v b="$B" -v c="$C" 'tolower($1)==tolower(b)&&$2==c{printf "  \033[38;5;220m%d\033[0m  %s\n",$3,$4}' "$BIBLE"
        echo ""
    else
        echo -e "${CYAN}Chapters in $B:${NC}"
        awk -F'\t' -v b="$B" 'tolower($1)==tolower(b){ch[$2]++}END{for(c in ch)printf "  Ch %s (%d verses)\n",c,ch[c]}' "$BIBLE" | sort -t' ' -k2 -n
    fi
}

search_bible() {
    local Q="$*"; [ -z "$Q" ] && echo "Usage: alfred-bible search <phrase>" && return
    echo -e "\n${CYAN}Searching: ${BOLD}$Q${NC}\n${DIM}────────────────────────────${NC}"
    grep -i "$Q" "$BIBLE" | head -20 | while IFS=$'\t' read -r b c v t; do
        echo -e "  ${GOLD}$b $c:$v${NC}\n  $t\n"
    done
    echo -e "${DIM}Found $(grep -ci "$Q" "$BIBLE") matches (showing 20)${NC}"
}

daily_verse() {
    local D=$(date +%j) T=$(($(wc -l < "$BIBLE")-1)) L=$((D%T+2))
    IFS=$'\t' read -r b c v t <<< "$(sed -n "${L}p" "$BIBLE")"
    echo -e "\n${GOLD}╔══════════════════════════════════════════╗${NC}"
    echo -e "${GOLD}║     Daily Verse — $(date +%B\ %d,\ %Y)        ║${NC}"
    echo -e "${GOLD}╚══════════════════════════════════════════╝${NC}"
    echo -e "\n  ${BOLD}\"$t\"${NC}\n\n  ${GOLD}— $b $c:$v (AKJV)${NC}\n  ${DIM}Perez Family Edition${NC}\n"
}

random_verse() {
    local T=$(($(wc -l < "$BIBLE")-1)) L=$((RANDOM%T+2))
    IFS=$'\t' read -r b c v t <<< "$(sed -n "${L}p" "$BIBLE")"
    echo -e "\n  ${BOLD}\"$t\"${NC}\n  ${GOLD}— $b $c:$v (AKJV)${NC}\n"
}

list_books() {
    echo -e "\n${GOLD}AKJV Bible — 94 Books — Perez Family Edition${NC}\n"
    awk -F'\t' 'NR>1{b[$1]++;c[$1" "$2]=1}END{for(x in b)printf "  %-25s %5d verses\n",x,b[x]}' "$BIBLE" | sort
}

show_prophecies() {
    [ ! -f "$PROPHECY" ] && echo "No prophecy data" && return
    echo -e "\n${GOLD}═══ 57 Messianic Prophecies — Fulfilled in Jesus Christ ═══${NC}\n"
    tail -n+2 "$PROPHECY" | while IFS=$'\t' read -r num title tanakh nt cat; do
        echo -e "  ${GOLD}#$num${NC} ${BOLD}$title${NC}"
        echo -e "    ${CYAN}Prophecy:${NC} $tanakh → ${GREEN}Fulfilled:${NC} $nt  ${DIM}($cat)${NC}\n"
    done
}

show_children() {
    [ ! -f "$CHILDREN" ] && echo "No children's stories" && return
    echo -e "\n${GOLD}╔══════════════════════════════════════════╗${NC}"
    echo -e "${GOLD}║  Eden's Bible Stories — For Ages 4-12    ║${NC}"
    echo -e "${GOLD}║  33 Stories in English, French & Hebrew   ║${NC}"
    echo -e "${GOLD}╚══════════════════════════════════════════╝${NC}\n"
    if [ -z "$1" ]; then
        tail -n+2 "$CHILDREN" | while IFS=$'\t' read -r num test sec ref title rest; do
            echo -e "  ${GOLD}$num.${NC} ${BOLD}$title${NC}  ${DIM}($ref)${NC}"
        done
        echo -e "\n  ${DIM}Usage: alfred-bible children <number>${NC}\n" || true
    else
        LINE=$(awk -F'\t' -v n="$1" 'NR>1&&$1==n' "$CHILDREN")
        if [ -n "$LINE" ]; then
            TITLE=$(echo "$LINE" | cut -f5)
            REF=$(echo "$LINE" | cut -f4)
            TEXT=$(echo "$LINE" | cut -f6)
            MORAL=$(echo "$LINE" | cut -f7)
            CONN=$(echo "$LINE" | cut -f14)
            echo -e "\n${GOLD}═══ $TITLE ═══${NC}"
            echo -e "${DIM}Scripture: $REF${NC}\n"
            echo -e "$TEXT\n"
            echo -e "${GREEN}Moral:${NC} $MORAL\n"
            [ -n "$CONN" ] && echo -e "${CYAN}Family Connection:${NC} $CONN\n"
        fi
    fi
}

parse_quick() {
    local I="$*"
    if echo "$I" | grep -qE '^[A-Za-z ]+[0-9]+:[0-9]+$'; then
        local B=$(echo "$I"|sed -E 's/[0-9]+:[0-9]+$//'|xargs) C=$(echo "$I"|grep -oE '[0-9]+:'|tr -d:) V=$(echo "$I"|grep -oE ':[0-9]+'|tr -d:)
        show_verse "$B" "$C" "$V"; return 0
    fi; return 1
}

show_help() {
    echo -e "\n${GOLD}╔══════════════════════════════════════════════════════╗${NC}"
    echo -e "${GOLD}║  alfred-bible — The Word of God in Your Terminal     ║${NC}"
    echo -e "${GOLD}║  AKJV · 94 Books · 39,482 Verses · Perez Family Ed  ║${NC}"
    echo -e "${GOLD}╚══════════════════════════════════════════════════════╝${NC}\n"
    echo "  read <Book> [Ch] [Vs]    Read scripture" || true
    echo "  search <phrase>          Search 39,482 verses" || true
    echo "  daily                    Today's verse"
    echo "  random                   Random verse"
    echo "  books                    List all 94 books"
    echo "  prophecies               57 Messianic prophecies"
    echo "  children [number]        Eden's 33 Bible stories"
    echo "  john 3:16                Quick reference"
    echo -e "\n  ${DIM}'The word of our God will stand forever.' — Isaiah 40:8${NC}\n"
}

case "${1:-help}" in
    read) shift; show_verse "$@";;
    search|find|grep) shift; search_bible "$@";;
    daily|today) daily_verse;;
    random) random_verse;;
    books|list) list_books;;
    prophecies|prophecy) show_prophecies;;
    children|kids|eden|stories) shift; show_children "$@";;
    help|--help|-h) show_help;;
    *) parse_quick "$@" || show_help;;
esac
BIBLEEOF
chmod +x /usr/local/bin/alfred-bible || true

###############################################################################
# 4. alfred-music CLI — Play the Kingdom album
###############################################################################
echo "[MUSIC] Creating alfred-music command..."
cat > /usr/local/bin/alfred-music << 'MUSICEOF'
BOLD='\033[1m' GOLD='\033[38;5;220m' CYAN='\033[0;36m' DIM='\033[2m' NC='\033[0m'
MUSIC_DIR="/usr/share/alfred/music"
LYRICS_DIR="$MUSIC_DIR/lyrics"

list_tracks() {
    echo -e "\n${GOLD}╔══════════════════════════════════════════════════════╗${NC}"
    echo -e "${GOLD}║  Jesus Christ The Light Our Universe                 ║${NC}"
    echo -e "${GOLD}║  Artists: Elyon Light + Commander Danny William Perez║${NC}"
    echo -e "${GOLD}║  Alfred Linux 7.77 — Kingdom of God Edition          ║${NC}"
    echo -e "${GOLD}╚══════════════════════════════════════════════════════╝${NC}\n"
    local i=1
    for f in "$MUSIC_DIR"/*.mp3; do
        NAME=$(basename "$f" .mp3 | sed 's/^[0-9]*-//' | tr '-' ' ')
        DUR=$(ffprobe -v quiet -show_entries format=duration -of csv=p=0 "$f" 2>/dev/null | cut -d. -f1)
        [ -n "$DUR" ] && MIN=$((DUR/60)) SEC=$((DUR%60)) DSTR="$(printf '%d:%02d' $MIN $SEC)" || DSTR="--:--"
        printf "  ${GOLD}%2d.${NC} %-30s ${DIM}%s${NC}\n" "$i" "$NAME" "$DSTR"
        i=$((i+1))
    done
    echo -e "\n  ${DIM}Usage: alfred-music play [number|all]  |  alfred-music lyrics [number]${NC}\n"
}

play_track() {
    local FILES=("$MUSIC_DIR"/*.mp3)
    if [ "$1" = "all" ] || [ -z "$1" ]; then
        echo -e "${GOLD}Playing entire album...${NC}"
        for f in "${FILES[@]}"; do
            NAME=$(basename "$f" .mp3 | sed 's/^[0-9]*-//' | tr '-' ' ')
            echo -e "  ${GOLD}♪${NC} $NAME"
        done
        if command -v mpv >/dev/null 2>&1; then
            mpv --no-video "${FILES[@]}"
        elif command -v ffplay >/dev/null 2>&1; then
            for f in "${FILES[@]}"; do ffplay -nodisp -autoexit "$f" 2>/dev/null; done
        elif command -v aplay >/dev/null 2>&1; then
            echo -e "${CYAN}Install mpv for best playback: sudo apt install mpv${NC}"
        else
            echo -e "${CYAN}Install mpv: sudo apt install mpv${NC}"
        fi
    else
        local IDX=$(($1-1))
        [ -z "${FILES[$IDX]}" ] && echo "Track $1 not found" && return
        NAME=$(basename "${FILES[$IDX]}" .mp3 | sed 's/^[0-9]*-//' | tr '-' ' ')
        echo -e "\n  ${GOLD}♪ Now Playing: $NAME${NC}\n"
        if command -v mpv >/dev/null 2>&1; then
            mpv --no-video "${FILES[$IDX]}"
        elif command -v ffplay >/dev/null 2>&1; then
            ffplay -nodisp -autoexit "${FILES[$IDX]}" 2>/dev/null
        else
            echo -e "${CYAN}Install mpv: sudo apt install mpv${NC}"
        fi
    fi
}

show_lyrics() {
    local LYRIC_FILES=("$LYRICS_DIR"/*.txt)
    if [ -z "$1" ]; then
        echo -e "\n${GOLD}Available lyrics:${NC}\n"
        local i=1
        for f in "${LYRIC_FILES[@]}"; do
            echo "  $i. $(basename "$f" .txt)"
            i=$((i+1))
        done
        echo ""
    else
        local IDX=$(($1-1))
        if [ -n "${LYRIC_FILES[$IDX]}" ] && [ -f "${LYRIC_FILES[$IDX]}" ]; then
            echo -e "\n${GOLD}═══ $(basename "${LYRIC_FILES[$IDX]}" .txt) ═══${NC}\n"
            cat "${LYRIC_FILES[$IDX]}"
            echo ""
        fi
    fi
}

case "${1:-list}" in
    play|p) shift; play_track "$@";;
    list|ls|tracks) list_tracks;;
    lyrics|lyric|l) shift; show_lyrics "$@";;
    help|--help|-h)
        echo -e "\n${GOLD}alfred-music${NC} — Kingdom of God Edition album player"
        echo "  list              Show all tracks"
        echo "  play [n|all]      Play track or full album"
        echo "  lyrics [n]        Show lyrics"
        echo "";;
    *) list_tracks;;
esac
MUSICEOF
