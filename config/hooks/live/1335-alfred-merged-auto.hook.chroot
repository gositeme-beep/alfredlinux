    systemsettings \
    plasma-systemmonitor \
    kde-config-sddm \
    kde-config-screenlocker \
    polkit-kde-agent-1 \
    systemd-timesyncd \
    locales-all \
    kde-plasma-desktop

# Enable time sync daemon so time automatically sets
systemctl enable systemd-timesyncd || true || true || true

echo "=== KDE Settings Modules Installed ==="


