# ==========================================
# RESTORED HOOK: 0450-alfred-trumpet-lockdown.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0450-alfred-trumpet-lockdown.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
echo "================================================="
echo "==== ALFRED TRUMPET (Hostile Lockdown) =========="
echo "================================================="

export DEBIAN_FRONTEND=noninteractive

if [ -f /build-assets/build-kingdom-video.sh ]; then
    cp /build-assets/build-kingdom-video.sh /usr/local/bin/trumpet-warning.sh || true
    chmod +x /usr/local/bin/trumpet-warning.sh || true
    
    # Tie into the watchman/sword panic protocol
    cat << 'EOF' > /usr/local/bin/trumpet-panic.sh
# Maximizes volume and plays warning before halt
amixer set Master 100% || true
/usr/local/bin/trumpet-warning.sh &
sleep 5
echo "TRUMPET SOUNDED. HALTING." > /dev/kmsg || true
echo c > /proc/sysrq-trigger || true
EOF
    chmod +x /usr/local/bin/trumpet-panic.sh || true
fi


) || true

# ==========================================
# RESTORED HOOK: 0451-alfred-mesh-dns.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0451-alfred-mesh-dns.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
echo "================================================="
echo "==== ALFRED MESH DNS (Decentralized Naming) ====="
echo "================================================="

export DEBIAN_FRONTEND=noninteractive

# If custom DNS binary exists, install it
if [ -f /build-assets/kingdom-dns ]; then
    install -m 755 /build-assets/kingdom-dns /usr/local/bin/kingdom-dns
    echo "Custom Kingdom DNS binary installed."
fi

# Configure systemd-resolved for sovereign domains
mkdir -p /etc/systemd/resolved.conf.d/ || true
cat > /etc/systemd/resolved.conf.d/kingdom-mesh.conf << 'EOF'
[Resolve]
# Route .kingdom and .alfred domains exclusively over the mesh (wg0)
# Replace 10.0.0.1 with the actual Kingdom Relay IP
DNS=10.0.0.1
Domains=~kingdom ~alfred
EOF

echo "Mesh DNS configured."


) || true

