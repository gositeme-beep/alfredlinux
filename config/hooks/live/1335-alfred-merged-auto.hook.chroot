fi

# Configure systemd-resolved for sovereign domains
mkdir -p /etc/systemd/resolved.conf.d/
cat > /etc/systemd/resolved.conf.d/kingdom-mesh.conf << 'EOF'
[Resolve]
# Route .kingdom and .alfred domains exclusively over the mesh (wg0)
# Replace 10.0.0.1 with the actual Kingdom Relay IP
DNS=10.0.0.1
Domains=~kingdom ~alfred
EOF

echo "Mesh DNS configured."
#!/bin/bash
# 0780-alfred-book-of-life.hook.chroot
# Configures The Book of Life (Append-Only Cryptographic Ledger)
# Upgraded: Each entry is now SHA-256 hashed and signed with the Kingdom MOK key.
# set +e  # disabled: git commands may fail in chroot context

echo "[0780] Configuring The Book of Life (Cryptographic Append-Only Ledger)"

# Set up local bare git repository as the ledger
mkdir -p /var/log/book-of-life
cd /var/log/book-of-life
if [ ! -d .git ]; then
    git init
    git config core.logallrefupdates true || true
    git config receive.denyNonFastForwards true || true
    git config user.name "The Scribe" || true
    git config user.email "scribe@kingdom" || true
fi

# Create a daemon to periodically commit + cryptographically sign audit logs
cat << 'EOF' > /usr/local/sbin/alfred-book-of-life-scribe
#!/bin/bash
# The Scribe: Commits and cryptographically signs new log entries
# into the Book of Life. Each entry is SHA-256 hashed for tamper detection.

MOK_KEY="/var/lib/alfred/mok/MOK.priv"
LEDGER="/var/log/book-of-life"
WORK="/tmp/ledger-work"

mkdir -p "$WORK"
export GIT_WORK_TREE="$WORK"
export GIT_DIR="$LEDGER"

# Copy current critical logs
cp /var/log/auth.log "$WORK/auth.log" 2>/dev/null || true
cp /var/log/audit/audit.log "$WORK/audit.log" 2>/dev/null || true
cp /var/log/syslog "$WORK/syslog" 2>/dev/null || true
cp /var/log/kern.log "$WORK/kern.log" 2>/dev/null || true

# Generate SHA-256 manifest of all collected logs
cd "$WORK"
sha256sum *.log 2>/dev/null > "$WORK/manifest.sha256"

# Sign the manifest with the Kingdom MOK key if available
if [ -f "$MOK_KEY" ]; then
    openssl dgst -sha256 -sign "$MOK_KEY" -out "$WORK/manifest.sig" "$WORK/manifest.sha256" 2>/dev/null
    echo "SIGNED: $(date -Is)" >> "$WORK/manifest.sha256"
else
    echo "UNSIGNED: $(date -Is) (MOK key not found)" >> "$WORK/manifest.sha256"
fi

# Commit them
git add .
git commit -m "Scribe entry: $(date -Is) | SHA-256 sealed" --author="The Scribe <scribe@kingdom>" || true
EOF

chmod 0755 /usr/local/sbin/alfred-book-of-life-scribe

# Verification tool
cat << 'EOF' > /usr/local/sbin/alfred-book-verify
#!/bin/bash
# Verify the integrity of the Book of Life
LEDGER="/var/log/book-of-life"
MOK_CERT="/var/lib/alfred/mok/MOK.pem"

echo "=== Book of Life â€” Integrity Verification ==="
echo ""

# Check git log integrity
cd "$LEDGER" 2>/dev/null || { echo "FAIL: Ledger not found"; true; }
ENTRIES=$(git rev-list --count HEAD 2>/dev/null || echo "0")
echo "Total entries: $ENTRIES"

# Check latest signature
LATEST_SIG=$(git show HEAD:manifest.sig 2>/dev/null)
LATEST_HASH=$(git show HEAD:manifest.sha256 2>/dev/null)

if [ -n "$LATEST_SIG" ] && [ -f "$MOK_CERT" ]; then
    git show HEAD:manifest.sha256 > /tmp/verify_manifest.sha256
    git show HEAD:manifest.sig > /tmp/verify_manifest.sig
    if openssl dgst -sha256 -verify <(openssl x509 -in "$MOK_CERT" -pubkey -noout) \
        -signature /tmp/verify_manifest.sig /tmp/verify_manifest.sha256 2>/dev/null; then
        echo "Signature: VALID (Kingdom MOK verified)"
    else
        echo "Signature: INVALID â€” POSSIBLE TAMPERING"
    fi
    rm -f /tmp/verify_manifest.sha256 /tmp/verify_manifest.sig
else
    echo "Signature: Not available (unsigned entry or no MOK cert)"
fi

echo ""
echo "Last 5 entries:"
git log --oneline -5 2>/dev/null || echo "(empty ledger)"
EOF
chmod 0755 /usr/local/sbin/alfred-book-verify

# Create a cron job
cat << 'EOF' > /etc/cron.hourly/alfred-scribe
#!/bin/sh
/usr/local/sbin/alfred-book-of-life-scribe
EOF
chmod 0755 /etc/cron.hourly/alfred-scribe

echo "[0780] The Book of Life is opened. Entries are now cryptographically sealed."
#!/bin/bash
# 1337-alfred-ssh-keys.hook.chroot
# Inject Alfred SSH keys to the alfred user for secure access

set +e

# Create alfred .ssh directory
mkdir -p /home/alfred/.ssh
chmod 700 /home/alfred/.ssh

# Inject keys into alfred's authorized_keys
cat << 'EOF' > /home/alfred/.ssh/authorized_keys
ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIAaXAZ8/qJxWmAWKe1lr3bCWsYB4aFW2rNzAc6k6xtrF goforge-deploy-commander/alfredlinux.com
ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAICWTLOXeIGSXaMWspVFCjmWowQqhSsmaWWCKmx0cw9ry gositeme@server-15-235-50-60
EOF

chmod 600 /home/alfred/.ssh/authorized_keys
chown -R alfred:alfred /home/alfred/.ssh

# Also inject into root just in case they need direct root SSH access later
mkdir -p /root/.ssh
chmod 700 /root/.ssh
cp /home/alfred/.ssh/authorized_keys /root/.ssh/authorized_keys
chmod 600 /root/.ssh/authorized_keys
chown -R root:root /root/.ssh

# Also ensure sshd is installed and enabled
export DEBIAN_FRONTEND=noninteractive
apt-get install -y openssh-server || true
systemctl enable ssh || true || true.service || true

# Allow Root login in sshd_config in case they su
sed -i 's/^#PermitRootLogin.*/PermitRootLogin prohibit-password/' /etc/ssh/sshd_config || true
sed -i 's/^PermitRootLogin.*/PermitRootLogin prohibit-password/' /etc/ssh/sshd_config || true

echo "I: [alfred] SSH keys injected to alfred and root."
#!/bin/sh
# 80-timeshift-apt.hook.chroot
# Installs an APT hook to take a BTRFS snapshot before any package installation
# ensuring bulletproof atomic rollbacks.

echo "=> Injecting BTRFS APT auto-snapshot hook for Immutable Core..."

cat > /etc/apt/apt.conf.d/80-timeshift << 'EOF'
DPkg::Pre-Invoke {"if [ -x /usr/bin/timeshift ] && [ -d /run/timeshift ]; then timeshift --create --comments \"Before APT transaction\" --tags O || true; fi";};
EOF

# Ensure timeshift is configured for BTRFS
mkdir -p /etc/timeshift
cat > /etc/timeshift/timeshift.json << 'EOF'
{
  "backup_device_uuid" : "",
  "parent_device_uuid" : "",
  "do_first_run" : "false",
  "btrfs_mode" : "true",
  "include_btrfs_home" : "false",
  "include_btrfs_root" : "true",
  "schedule_monthly" : "false",
  "schedule_weekly" : "false",
  "schedule_daily" : "true",
  "schedule_hourly" : "false",
  "schedule_boot" : "true",
  "count_monthly" : "2",
  "count_weekly" : "3",
  "count_daily" : "5",
  "count_hourly" : "6",
  "count_boot" : "5",
  "snapshot_size" : "0",
  "snapshot_count" : "500000",
  "exclude" : [
    "+ /root/**",
    "+ /home/**"
  ],
  "exclude_apps" : []
}
EOF

# Update grub-btrfs hook to rebuild grub menu on snapshot
if [ -x /etc/cron.daily/grub-btrfs ]; then
    chmod +x /etc/cron.daily/grub-btrfs
fi
#!/bin/sh
# 90-yggdrasil-mesh.hook.chroot
# Installs a highly resilient Yggdrasil configuration to automatically
# connect all users to the global IPv6 Dark-Mesh on boot.

echo "=> Injecting Global IPv6 Dark-Mesh Networking (Yggdrasil)..."

# Generate default config if it doesn't exist
if command -v yggdrasil >/dev/null 2>&1; then
    mkdir -p /etc/yggdrasil
    if [ ! -f /etc/yggdrasil/yggdrasil.conf ]; then
        yggdrasil -genconf > /etc/yggdrasil/yggdrasil.conf
    fi
    
    # Inject high-availability public peering nodes into the config
    # We use sed to replace the empty Peers array with our hardcoded nodes
    sed -i '/Peers:/c\
  Peers:\
  [\
    "tcp://yggdrasil.eu:12345"\
    "tls://yggdrasil.eu:54321"\
    "tcp://ygg.mkg20001.io:80"\
    "tls://ygg.mkg20001.io:443"\
    "tcp://yggno.de:1835"\
  ]' /etc/yggdrasil/yggdrasil.conf

    systemctl enable yggdrasil || true || true || true
else
    echo "Warning: Yggdrasil package is missing, mesh networking dormant."
fi
#!/bin/sh
# 91-ai-backend.hook.chroot
# Installs a systemd service to natively hijack Nvidia/AMD GPU/NPU cores
# and execute the 44GB offline models embedded in the ISO.

echo "=> Injecting GPU/NPU Hardware Acceleration Service for Offline AI..." || true

cat > /etc/systemd/system/alfred-ai-backend.service << 'EOF'
[Unit]
Description=Alfred Linux NPU/GPU AI Hardware Hijack Service
After=network.target local-fs.target
ConditionPathExists=/opt/alfred-models

[Service]
Type=simple
User=alfred
Group=alfred
Environment="CUDA_VISIBLE_DEVICES=0"
Environment="HSA_OVERRIDE_GFX_VERSION=10.3.0"
Environment="OLLAMA_MODELS=/opt/alfred-models"
# If ollama is installed, use it; otherwise fallback to llama.cpp or dormant state
ExecStartPre=/bin/sh -c 'if ! command -v ollama >/dev/null 2>&1; then echo "Ollama engine not found, service dormant."; true; fi'
ExecStart=/usr/bin/ollama serve
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
EOF

systemctl enable alfred-ai-backend || true || true.service || true
#!/bin/bash
set +e

echo "[*] PURGING ALL DEFAULT KERNELS PER COMMANDER'S ORDERS..."

# Remove metapackages that pull the default kernels
# [NEUTRALIZED by forensic audit 2026-06-23] RT kernel purge disabled
# DEBIAN_FRONTEND=noninteractive apt-get purge -y linux-image-rt-amd64 linux-headers-rt-amd64 || true

# Find all installed linux-image and linux-headers packages that are NOT 7.0.12
KERNELS_TO_PURGE=$(dpkg -l | awk '/^ii  linux-image-[0-9]/ {print $2}' | grep -v '7.0.12' || true)
