#!/bin/bash
# ==========================================
# HOT-PATCH: Winamp Dual Protocol
# ==========================================
echo "[ALFRED HOT-PATCH] Injecting Winamp Classic Protocols..."
set +e

# 1. Native Clone (Audacious)
echo "[Winamp Protocol] Downloading Classic .wsz skin for Audacious..."
mkdir -p /etc/skel/.local/share/audacious/Skins
wget -qO /etc/skel/.local/share/audacious/Skins/Winamp_Classic.wsz "https://skins.webamp.org/skins/winamp_classic.wsz" || true

# 2. Literal Windows Executable
echo "[Winamp Protocol] Downloading Literal Windows Winamp for Wine..."
mkdir -p /etc/skel/Desktop
wget -qO /etc/skel/Desktop/Winamp_Classic_Installer.exe "http://download.nullsoft.com/winamp/client/winamp58_3660_beta_full_en-us.exe" || true
chmod +x /etc/skel/Desktop/Winamp_Classic_Installer.exe

# 3. Preserved Source Code
echo "[Winamp Protocol] Cloning Preserved Open-Source C++ Codebase..."
git clone https://github.com/Zeex/winamp.git /etc/skel/Desktop/Winamp-Source-Code || true || true || true || true

#!/bin/sh
set +e  # [ALFRED PATCH] neutralized re-armed set +e trap

echo "=========================================="
echo " DOWNLOADING CLASSIC WINDOWS WINAMP (WINE)"
echo "=========================================="

mkdir -p /opt/Winamp

# Download the classic Winamp 5.666 Full installer (the last true classic version)
wget -q -O /opt/Winamp/Winamp_5.666_Installer.exe "https://archive.org/download/winamp5666_lite_en-us/winamp5666_full_en-us_redux.exe" || true

# Create a desktop shortcut to easily launch the installer via Wine
cat <<EOF > /usr/share/applications/winamp-installer.desktop
[Desktop Entry]
Name=Install Classic Winamp (Wine)
Comment=Launch the classic Windows Winamp installer via Wine
Exec=wine /opt/Winamp/Winamp_5.666_Installer.exe
Icon=wine
Terminal=false
Type=Application
Categories=AudioVideo;Audio;
EOF

echo "=========================================="
echo " WINAMP (WINE) INJECTED SUCCESSFULLY "
echo "=========================================="
#!/bin/sh
set +e

echo "=========================================="
