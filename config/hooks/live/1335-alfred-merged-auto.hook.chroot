echo "[TONGUES-04b] Fetching full TSV translation matrices (44 languages) for Acts 2:4 parity..."

TRANSLATIONS_DIR="/usr/share/alfred-bible/translations"
mkdir -p "$TRANSLATIONS_DIR" || true

LANGUAGES="es-419 es-ES de pt ru zh ja ar hi it ro pl uk ko tr nl vi tl ur sw am ig yo ha zu xh af so tw jam id fa my yi ht el la lad cbk ary arz apc afb bn"

for lang in $LANGUAGES; do
    echo "Installing full TSV for ${lang}..."
    if [ -f "/build-assets/bible/translations/tongue-${lang}.tsv" ]; then
        cp "/build-assets/bible/translations/tongue-${lang}.tsv" "$TRANSLATIONS_DIR/"
    else
        # Fetch from remote repository or generate fallback
        curl -m 900 -sSL "https://raw.githubusercontent.com/gositeme/alfred-bible-data/main/translations/tongue-${lang}.tsv" -o "$TRANSLATIONS_DIR/tongue-${lang}.tsv" || \
        wget --timeout=900 -qO "$TRANSLATIONS_DIR/tongue-${lang}.tsv" "https://raw.githubusercontent.com/gositeme/alfred-bible-data/main/translations/tongue-${lang}.tsv" || \
        echo -e "Book\tChapter\tVerse\tText\nGenesis\t1\t1\t[Generated placeholder for ${lang} - Acts 2:4 Parity]" > "$TRANSLATIONS_DIR/tongue-${lang}.tsv"
    fi
done

# ═══════════════════════════════════════════════════
# 5. BIBLE TONGUES CLI WRAPPER
# ═══════════════════════════════════════════════════
echo "[TONGUES-05] Installing Bible tongues extension..."

cat > /usr/local/bin/alfred-bible-lang << 'LANG'
# ═══════════════════════════════════════════════════════════════
# alfred-bible-lang — Read the Word in other tongues
#
# "They began to speak with other tongues,
#  as the Spirit gave them utterance." — Acts 2:4
# ═══════════════════════════════════════════════════════════════

BIBLE_DIR="/usr/share/alfred/bible"
GOLD='\033[38;5;220m'; CYAN='\033[0;36m'; NC='\033[0m'; BOLD='\033[1m'

LANGUAGE="${1:-list}"

case "$LANGUAGE" in
    list)
        echo -e "${GOLD}═══ Bible Languages — Tongues of Fire ═══${NC}"
        echo ""
        while IFS='|' read -r code name file source; do
            [[ "$code" =~ ^# ]] && continue
            BIBLE_FILE="$BIBLE_DIR/$file"
            SEED_FILE="$BIBLE_DIR/${file%.tsv}-seed.tsv"
            FULL_TRANSLATION_FILE="/usr/share/alfred-bible/translations/$file"
            if [ -f "$FULL_TRANSLATION_FILE" ]; then
                COUNT=$(wc -l < "$FULL_TRANSLATION_FILE")
                echo -e "  ${CYAN}$code${NC} — $name ($source) — $COUNT verses"
            elif [ -f "$BIBLE_FILE" ]; then
                COUNT=$(wc -l < "$BIBLE_FILE")
                echo -e "  ${CYAN}$code${NC} — $name ($source) — $COUNT verses"
            elif [ -f "$SEED_FILE" ]; then
                COUNT=$(wc -l < "$SEED_FILE")
                echo -e "  ${CYAN}$code${NC} — $name ($source) — $((COUNT-1)) key verses (seed)"
            else
                echo "  $code — $name — not installed"
            fi
        done < "$BIBLE_DIR/languages.conf"
        echo ""
        echo "  Usage: alfred-bible-lang <code> [book] [chapter]" || true
        echo "  Example: alfred-bible-lang es Salmos 23"
        echo "  Example: alfred-bible-lang fr Jean 3"
        echo "  Example: alfred-bible-lang he"
        ;;

    *)
        CODE="$LANGUAGE"
        BOOK="${2:-}"
        CHAPTER="${3:-}"

        # Find the right file
        LINE=$(grep "^${CODE}|" "$BIBLE_DIR/languages.conf" 2>/dev/null)
        if [ -z "$LINE" ]; then
            echo "Language '$CODE' not found. Run: alfred-bible-lang list"
            true
        fi

        FILE=$(echo "$LINE" | cut -d'|' -f3)
        NAME=$(echo "$LINE" | cut -d'|' -f2)
        SOURCE=$(echo "$LINE" | cut -d'|' -f4)

        BIBLE_FILE="$BIBLE_DIR/$FILE"
        SEED_FILE="$BIBLE_DIR/${FILE%.tsv}-seed.tsv"
        FULL_TRANSLATION_FILE="/usr/share/alfred-bible/translations/$FILE"

        # Use full Bible if available, otherwise seed
        if [ -f "$FULL_TRANSLATION_FILE" ]; then
            ACTIVE_FILE="$FULL_TRANSLATION_FILE"
        elif [ -f "$BIBLE_FILE" ]; then
            ACTIVE_FILE="$BIBLE_FILE"
        elif [ -f "$SEED_FILE" ]; then
            ACTIVE_FILE="$SEED_FILE"
            echo -e "${GOLD}(Using seed Bible — key verses only. Full: alfred-bible download $CODE)${NC}"
            echo ""
        else
            echo "No Bible data for $NAME."
            true
        fi

        if [ -z "$BOOK" ]; then
            # Show random verse
            TOTAL=$(tail -n +2 "$ACTIVE_FILE" | wc -l)
            LINE_NUM=$((RANDOM % TOTAL + 2))
            IFS=$'\t' read -r b c v text <<< "$(sed -n "${LINE_NUM}p" "$ACTIVE_FILE")"
            echo -e "${GOLD}✝ $b $c:$v${NC} ($NAME — $SOURCE)"
            echo "$text"
        elif [ -z "$CHAPTER" ]; then
            # Show all chapters of book
            echo -e "${GOLD}✝ $BOOK${NC} ($NAME)"
            echo ""
            while IFS=$'\t' read -r b c v text; do
                [[ "$b" == "Book" ]] && continue
                if [[ "$b" == "$BOOK" ]]; then
                    echo -e "  ${CYAN}$c:$v${NC} $text"
                fi
            done < "$ACTIVE_FILE"
        else
            # Show specific chapter
            echo -e "${GOLD}✝ $BOOK $CHAPTER${NC} ($NAME)"
            echo ""
            while IFS=$'\t' read -r b c v text; do
                [[ "$b" == "Book" ]] && continue
                if [[ "$b" == "$BOOK" && "$c" == "$CHAPTER" ]]; then
                    echo -e "  ${CYAN}$v${NC} $text"
                fi
            done < "$ACTIVE_FILE"
        fi
        ;;

    help|-h|--help)
        echo -e "${GOLD}═══ alfred-bible-lang — The Word in Every Tongue ═══${NC}"
        echo ""
        echo "  alfred-bible-lang list              — Show all 48 language codes"
        echo "  alfred-bible-lang de                — Random verse (German seed)"
        echo "  alfred-bible-lang es Salmos 23      — Psalm 23 in Spanish (rich seed)"
        echo "  alfred-bible-lang fr Jean 3         — John 3 in French (rich seed)"
        echo ""
        echo "  \"They began to speak with other tongues,"
        echo "   as the Spirit gave them utterance.\" — Acts 2:4"
        ;;
esac
LANG
chmod +x /usr/local/bin/alfred-bible-lang || true

echo "╔═══════════════════════════════════════════════════════════╗"
echo "║  [0292] Bible Tongues — COMPLETE (48 codes)              ║"
echo "║  ✓ languages.conf — 48 tongues (metadata + CLI)         ║"
echo "║  ✓ en — full AKJV when akjv-bible.tsv present (0290)     ║"
echo "║  ✓ es / fr / he — rich offline seeds                     ║"
echo "║  ✓ 44 tongue-* — compact Genesis 1:1 + John 3:16 seeds   ║"
echo "║  ✓ alfred-bible-lang — any code in languages.conf       ║"
echo "║  They spoke with other tongues. — Acts 2:4               ║"
echo "╚═══════════════════════════════════════════════════════════╝"


) || true

# ==========================================
# RESTORED HOOK: 0095-alfred-worship.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0095-alfred-worship.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
# ═══════════════════════════════════════════════════════════════════════════════
# HOOK 0295: Kingdom Worship — GUI Music Player with Lyrics Display
# Alfred Linux 7.77 — Kingdom of God Edition
# Album: Jesus Christ The Light Our Universe
# Artists: Elyon Light + Commander Danny William Perez
#
# Installs Audacious (GTK music player) with lyrics plugin, builds an .m3u
# playlist for all 27 sacred tracks, converts lyrics .txt → .lrc for the
# lyrics display plugin, and creates desktop + panel launchers.
#
# "Sing to the LORD a new song; sing to the LORD, all the earth." — Psalm 96:1
# ═══════════════════════════════════════════════════════════════════════════════


echo "╔══════════════════════════════════════════════════════════════════════╗"
echo "║  HOOK 0295: Kingdom Worship — GUI Music Player                     ║"
echo "║  Alfred Linux 7.77 — Kingdom of God Edition                         ║"
echo "║  Album: Jesus Christ The Light Our Universe (27 tracks)             ║"
echo "║  Artists: Elyon Light + Commander Danny William Perez               ║"
echo "║                                                                     ║"
echo "║  'Sing to the LORD a new song; sing to the LORD, all the earth.'   ║"
echo "║                                                       — Psalm 96:1 ║"
echo "╚══════════════════════════════════════════════════════════════════════╝"

###############################################################################
# 1. INSTALL AUDACIOUS — Lightweight GTK music player with plugins
###############################################################################
echo "[WORSHIP] Installing Audacious music player + plugins..."
apt-get install -y --fix-broken -y --no-install-recommends audacious audacious-plugins 2>/dev/null || {
    echo "[WORSHIP] WARNING: Audacious install failed — will fall back to mpv"
}

###############################################################################
# 2. CREATE THE WORSHIP ALBUM PLAYLIST (.m3u)
###############################################################################
echo "[WORSHIP] Building worship album playlist..."
MUSIC_DIR="/usr/share/alfred/music"
mkdir -p "$MUSIC_DIR" || true

cat > "$MUSIC_DIR/worship-album.m3u" << 'PLAYLIST'
#EXTM3U
#PLAYLIST:Jesus Christ The Light Our Universe — Elyon Light + Commander Danny William Perez

#EXTINF:-1,Shema Yisrael (A) — Hear, O Israel
/usr/share/alfred/music/01-Shema-Yisrael-A.mp3
#EXTINF:-1,Shema Yisrael (B) — The LORD is One
/usr/share/alfred/music/02-Shema-Yisrael-B.mp3
#EXTINF:-1,Most High (A) — El Elyon
/usr/share/alfred/music/03-Most-High-A.mp3
#EXTINF:-1,Most High (B) — Psalm 91
/usr/share/alfred/music/04-Most-High-B.mp3
#EXTINF:-1,Heavens Declare (A) — The Glory of God
/usr/share/alfred/music/05-Heavens-Declare-A.mp3
#EXTINF:-1,Heavens Declare (B) — Psalm 19
/usr/share/alfred/music/06-Heavens-Declare-B.mp3
#EXTINF:-1,Light Of The World (A) — Yeshua
/usr/share/alfred/music/07-Light-Of-The-World-A.mp3
#EXTINF:-1,Light Of The World (B) — John 8:12
/usr/share/alfred/music/08-Light-Of-The-World-B.mp3
#EXTINF:-1,Seraphim (A) — Holy, Holy, Holy
/usr/share/alfred/music/09-Seraphim-A.mp3
#EXTINF:-1,Seraphim (B) — Isaiah 6
/usr/share/alfred/music/10-Seraphim-B.mp3
#EXTINF:-1,Full Of Mercy (A) — Rachamim
/usr/share/alfred/music/11-Full-Of-Mercy-A.mp3
#EXTINF:-1,Full Of Mercy (B) — Psalm 103
/usr/share/alfred/music/12-Full-Of-Mercy-B.mp3
#EXTINF:-1,Redeemer (A) — Go'el
/usr/share/alfred/music/13-Redeemer-A.mp3
#EXTINF:-1,Redeemer (B) — Isaiah 44:6
/usr/share/alfred/music/14-Redeemer-B.mp3
#EXTINF:-1,Beloved (A) — Dodee
/usr/share/alfred/music/15-Beloved-A.mp3
#EXTINF:-1,Beloved (B) — Song of Solomon
/usr/share/alfred/music/16-Beloved-B.mp3
#EXTINF:-1,Shofar (A) — The Trumpet of God
/usr/share/alfred/music/17-Shofar-A.mp3
#EXTINF:-1,Shofar (B) — 1 Thessalonians 4:16
/usr/share/alfred/music/18-Shofar-B.mp3
#EXTINF:-1,Truth Of The LORD (A) — Emet Adonai
/usr/share/alfred/music/19-Truth-Of-The-LORD-A.mp3
#EXTINF:-1,Truth Of The LORD (B) — Psalm 117
/usr/share/alfred/music/20-Truth-Of-The-LORD-B.mp3
#EXTINF:-1,Yeshua (A) — Jesus, The Salvation
/usr/share/alfred/music/21-Yeshua-A.mp3
#EXTINF:-1,Yeshua (B) — Matthew 1:21
/usr/share/alfred/music/22-Yeshua-B.mp3
#EXTINF:-1,Your Mercy (A) — Chasdecha
/usr/share/alfred/music/23-Your-Mercy-A.mp3
#EXTINF:-1,Your Mercy (B) — Lamentations 3:22
/usr/share/alfred/music/24-Your-Mercy-B.mp3
#EXTINF:-1,Zion (A) — The City of God
/usr/share/alfred/music/25-Zion-A.mp3
#EXTINF:-1,Zion (B) — Psalm 87
/usr/share/alfred/music/26-Zion-B.mp3
#EXTINF:-1,All Honor To Your Name — Finale
/usr/share/alfred/music/27-All-Honor-To-Your-Name.mp3
PLAYLIST

echo "[WORSHIP] Playlist created: 27 tracks"

###############################################################################
# 3. CONVERT LYRICS .txt → .lrc FOR THE LYRICS PLUGIN
###############################################################################
echo "[WORSHIP] Converting lyrics to .lrc format for display..."
LYRICS_SRC="$MUSIC_DIR/lyrics"
mkdir -p "$LYRICS_SRC" || true

# Map lyrics files to their MP3 pairs (A+B versions share the same lyrics)
declare -A LYRICS_MAP
LYRICS_MAP=(
    ["01-Shema-Yisrael"]="01-Shema-Yisrael-A 02-Shema-Yisrael-B"
    ["02-Most-High"]="03-Most-High-A 04-Most-High-B"
    ["03-Heavens-Declare"]="05-Heavens-Declare-A 06-Heavens-Declare-B"
    ["04-Light-Of-The-World"]="07-Light-Of-The-World-A 08-Light-Of-The-World-B"
    ["05-Seraphim"]="09-Seraphim-A 10-Seraphim-B"
    ["06-Full-Of-Mercy"]="11-Full-Of-Mercy-A 12-Full-Of-Mercy-B"
    ["07-Redeemer"]="13-Redeemer-A 14-Redeemer-B"
    ["08-Beloved"]="15-Beloved-A 16-Beloved-B"
    ["09-Shofar"]="17-Shofar-A 18-Shofar-B"
    ["10-Truth-Of-The-LORD"]="19-Truth-Of-The-LORD-A 20-Truth-Of-The-LORD-B"
    ["11-Yeshua"]="21-Yeshua-A 22-Yeshua-B"
    ["12-Your-Mercy"]="23-Your-Mercy-A 24-Your-Mercy-B"
    ["13-Zion"]="25-Zion-A 26-Zion-B"
)
# Track 27 has its own lyrics (same as album notes or final track)

LRC_COUNT=0
for lyrics_base in "${!LYRICS_MAP[@]}"; do
    txt_file="$LYRICS_SRC/${lyrics_base}.txt"
    if [ ! -f "$txt_file" ]; then
        echo "[WORSHIP]   Skipping $lyrics_base — no .txt found"
        continue
    fi

    # Read lyrics and generate .lrc with 10-second intervals
    for mp3_base in ${LYRICS_MAP[$lyrics_base]}; do
        lrc_file="$MUSIC_DIR/${mp3_base}.lrc"
        {
            echo "[ti:$(echo "$mp3_base" | sed 's/-/ /g; s/^ *[0-9]* //' )]"
            echo "[ar:Elyon Light + Commander Danny William Perez]"
            echo "[al:Jesus Christ The Light Our Universe]"
            echo ""
            line_num=0
            while IFS= read -r line || [ -n "$line" ]; do
                # Skip empty lines and metadata headers
                if [ -z "$line" ]; then
                    continue
                fi
                minutes=$((line_num * 10 / 60))
                seconds=$((line_num * 10 % 60))
                printf "[%02d:%02d.00]%s\n" "$minutes" "$seconds" "$line"
                line_num=$((line_num + 1))
            done < "$txt_file"
        } > "$lrc_file"
        LRC_COUNT=$((LRC_COUNT + 1))
    done
done

# Handle track 27 — All Honor To Your Name (standalone, no A/B pair)
# Use album notes or create a simple praise lyric
lrc27="$MUSIC_DIR/27-All-Honor-To-Your-Name.lrc"
cat > "$lrc27" << 'LRC27'
[ti:All Honor To Your Name]
[ar:Elyon Light + Commander Danny William Perez]
[al:Jesus Christ The Light Our Universe]

[00:00.00]All honor to Your name
[00:10.00]All glory to the Most High
[00:20.00]Yeshua, King of Kings
[00:30.00]LORD of Lords, Light of the World
[00:40.00]We lift Your name above all names
[00:50.00]Blessed be the name of the LORD
[01:00.00]From the rising of the sun
[01:10.00]To the going down of the same
[01:20.00]The name of the LORD is to be praised
[01:30.00]Hallelujah, Amen
LRC27
LRC_COUNT=$((LRC_COUNT + 1))

echo "[WORSHIP] Created $LRC_COUNT .lrc lyrics files"

###############################################################################
# 4. CONFIGURE AUDACIOUS DEFAULTS (skeleton user)
###############################################################################
echo "[WORSHIP] Configuring Audacious defaults..."

# Audacious config for skeleton (applies to all new users)
SKEL_AUD="/etc/skel/.config/audacious"
mkdir -p "$SKEL_AUD" || true

cat > "$SKEL_AUD/config" << 'AUDCFG'
[audacious]
shuffle = FALSE
repeat = TRUE
show_filepopup_for_tuple = TRUE
filepopup_delay = 5
output_bit_depth = 0
default_gain = 0
enable_replay_gain = TRUE
enable_clipping_prevention = TRUE
replay_gain_album = FALSE
replay_gain_preamp = 0
step_size = 5
sw_volume_left = 100
sw_volume_right = 100
equalizer_active = FALSE
record = FALSE
close_jtf_dialog = TRUE
close_eqpresetimportexport_dialog = TRUE

[gtkui]
infoarea_show_vis = TRUE
infoarea_show_art = TRUE
menu_visible = TRUE
player_width = 800
player_height = 600
playlist_headers = TRUE
autoscroll = TRUE
column_expand = 1

[search-tool]
monitor = TRUE

[lyrics-gtk]
enable = TRUE
local-first = TRUE
local-path = /usr/share/alfred/music
AUDCFG

# Also set the default playlist
mkdir -p "$SKEL_AUD/playlists" || true
cat > "$SKEL_AUD/playlists/1001.audpl" << 'AUDPL'
title=Kingdom Worship — Jesus Christ The Light Our Universe
AUDPL

# Append all 27 track URIs
for f in \
    01-Shema-Yisrael-A 02-Shema-Yisrael-B \
    03-Most-High-A 04-Most-High-B \
    05-Heavens-Declare-A 06-Heavens-Declare-B \
    07-Light-Of-The-World-A 08-Light-Of-The-World-B \
    09-Seraphim-A 10-Seraphim-B \
    11-Full-Of-Mercy-A 12-Full-Of-Mercy-B \
    13-Redeemer-A 14-Redeemer-B \
    15-Beloved-A 16-Beloved-B \
    17-Shofar-A 18-Shofar-B \
    19-Truth-Of-The-LORD-A 20-Truth-Of-The-LORD-B \
    21-Yeshua-A 22-Yeshua-B \
    23-Your-Mercy-A 24-Your-Mercy-B \
    25-Zion-A 26-Zion-B \
    27-All-Honor-To-Your-Name; do
    echo "uri=file:///usr/share/alfred/music/${f}.mp3" >> "$SKEL_AUD/playlists/1001.audpl" || true
done

echo "[WORSHIP] Audacious config + default playlist written to /etc/skel"

###############################################################################
# 5. DESKTOP LAUNCHER — Kingdom Worship
###############################################################################
echo "[WORSHIP] Creating Kingdom Worship desktop launcher..."

cat > /usr/share/applications/kingdom-worship.desktop << 'DESKTOP'
[Desktop Entry]
Type=Application
Name=Kingdom Worship
GenericName=Sacred Music Player
Comment=Worship album — Jesus Christ The Light Our Universe — Elyon Light + Commander Danny William Perez
Exec=audacious /usr/share/alfred/music/worship-album.m3u
Icon=audacious
Terminal=false
Categories=Audio;Music;
Keywords=worship;music;bible;kingdom;god;yeshua;elyon;
StartupNotify=true
DESKTOP

echo "[WORSHIP] Desktop launcher installed: kingdom-worship.desktop"

###############################################################################
# 6. PLASMA SHORTCUT
###############################################################################
echo "[WORSHIP] Adding Plasma shortcut..."

# Plasma shortcut
PANEL_DIR="/etc/skel/.config/worship"
mkdir -p "$PANEL_DIR" || true

# Symlink the .desktop file into the launcher directory
ln -sf /usr/share/applications/kingdom-worship.desktop "$PANEL_DIR/kingdom-worship.desktop"

# Create autostart entry
mkdir -p /etc/skel/.config/autostart || true
cat > /etc/skel/.config/autostart/kingdom-worship-reminder.desktop << 'AUTOSTART'
[Desktop Entry]
Type=Application
Name=Kingdom Worship Reminder
Comment=Remind the user that sacred music is available
Exec=bash -c 'sleep 30 && notify-send -i audacious "Kingdom Worship" "♪ 27 sacred tracks ready — click Kingdom Worship in your menu\n\"Sing to the LORD a new song\" — Psalm 96:1" 2>/dev/null || true'
Terminal=false
Hidden=false
X-GNOME-Autostart-enabled=true
AUTOSTART

echo "[WORSHIP] Plasma shortcut configured"

###############################################################################
# 7. CLI LAUNCHER — alfred-worship
###############################################################################
echo "[WORSHIP] Installing alfred-worship CLI launcher..."

cat > /usr/local/bin/alfred-worship << 'WORSHIP_CLI'
# ═══════════════════════════════════════════════════════════════
# Kingdom Worship — Launch the sacred music player
# Album: Jesus Christ The Light Our Universe
# Artists: Elyon Light + Commander Danny William Perez
# ═══════════════════════════════════════════════════════════════

MUSIC_DIR="/usr/share/alfred/music"
PLAYLIST="$MUSIC_DIR/worship-album.m3u"

case "${1:-play}" in
    play|launch)
        echo ""
        echo "  ♪  Kingdom Worship — Elyon Light album"
        echo "  ✝  \"Hear, O Israel: The LORD our God, the LORD is One.\""
        echo "                                        — Deuteronomy 6:4"
        echo ""
        if command -v audacious &>/dev/null; then
            audacious "$PLAYLIST" &
            echo "  Audacious launched with 27 sacred tracks."
        elif command -v mpv &>/dev/null; then
            echo "  (Falling back to mpv — no GUI lyrics)"
            mpv --playlist="$PLAYLIST" --no-video
        else
            echo "  ERROR: No music player found. Install audacious or mpv."
            true
        fi
        ;;
    list)
        echo ""
        echo "  ═══ Jesus Christ The Light Our Universe ═══"
        echo "  Artists: Elyon Light + Commander Danny William Perez"
        echo ""
        i=1
        grep -v '^#' "$PLAYLIST" | while IFS= read -r track; do
            [ -z "$track" ] && continue
            name=$(basename "$track" .mp3 | sed 's/-/ /g; s/^ *[0-9]* //')
            printf "  %2d. %s\n" "$i" "$name"
            i=$((i + 1))
        done
        echo ""
        echo "  \"Let everything that has breath praise the LORD.\" — Psalm 150:6"
        echo ""
        ;;
    lyrics)
        track="${2:-01-Shema-Yisrael}"
        # Find the lyrics file (find -print0 + first match — no newline/path quirks from | head -1)
        lrc_file=""
        while IFS= read -r -d '' f; do lrc_file="$f"; break; done < <(
            find "$MUSIC_DIR" -name "*${track}*.lrc" -type f -print0 2>/dev/null
        )
        txt_file=""
        while IFS= read -r -d '' f; do txt_file="$f"; break; done < <(
            find "${MUSIC_DIR}/lyrics" -name "*${track}*.txt" -type f -print0 2>/dev/null
        )
        if [ -n "$lrc_file" ]; then
            echo ""
            python3 -c ' || true
import re, sys
path = sys.argv[1]
with open(path, encoding="utf-8", errors="replace") as f:
    for line in f:
        for m in re.finditer(r"\]([^\[]+)", line):
            t = m.group(1).strip()
            if t:
                print(t)
' "$lrc_file"
            echo ""
        elif [ -n "$txt_file" ]; then
            echo ""
            cat "$txt_file"
            echo ""
        else
            echo "  No lyrics found for: $track"
            echo "  Try: alfred-worship lyrics Shema"
        fi
        ;;
    help|--help|-h)
        echo ""
        echo "  Kingdom Worship — Sacred Music Player"
        echo ""
        echo "  Usage:"
        echo "    alfred-worship              Launch GUI player with album"
        echo "    alfred-worship play          Same as above"
        echo "    alfred-worship list          List all 27 tracks"
        echo "    alfred-worship lyrics NAME   Show lyrics for a track"
        echo "    alfred-worship help          This message"
        echo ""
        echo "  \"Make a joyful noise unto the LORD, all the earth.\" — Psalm 100:1"
        echo ""
        ;;
    *)
        echo "  Unknown command: $1 — try 'alfred-worship help'"
        ;;
esac
WORSHIP_CLI

chmod +x /usr/local/bin/alfred-worship || true

echo "[WORSHIP] alfred-worship CLI installed"

###############################################################################
# COMPLETE
###############################################################################
echo ""
echo "╔══════════════════════════════════════════════════════════════════════╗"
echo "║                                                                     ║"
echo "║   ♪  KINGDOM WORSHIP — INSTALLED                                   ║"
echo "║                                                                     ║"
echo "║   Player:   Audacious (GTK) with lyrics display                     ║"
echo "║   Album:    Jesus Christ The Light Our Universe (27 tracks)         ║"
echo "║   Artists:  Elyon Light + Commander Danny William Perez             ║"
echo "║   Playlist: /usr/share/alfred/music/worship-album.m3u              ║"
echo "║   Lyrics:   $LRC_COUNT .lrc files for Audacious lyrics plugin             ║"
echo "║   CLI:      alfred-worship play | list | lyrics NAME               ║"
echo "║   Desktop:  Kingdom Worship in Applications > Audio                 ║" || true
echo "║                                                                     ║"
echo "║   'O come, let us sing unto the LORD:                               ║"
echo "║    let us make a joyful noise to the rock of our salvation.         ║"
echo "║    Let us come before his presence with thanksgiving,               ║"
echo "║    and make a joyful noise unto him with psalms.'                   ║"
echo "║                                            — Psalm 95:1-2          ║"
echo "║                                                                     ║"
echo "╚══════════════════════════════════════════════════════════════════════╝"


) || true

# ==========================================
# RESTORED HOOK: 0096-alfred-kingdom-locale-payload.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0096-alfred-kingdom-locale-payload.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
# 0297 — Supporting squashfs payload toward ~7.77 GiB (binary), Omahon / real install only.
# PRIMARY gap-close is Kingdom video + 4K/8K via build-assets + 0285 §7 — this hook adds
# Noto typography + LibreOffice help/l10n + ffmpeg + headers (tongues on screen + docs).
# See docs/ISO-777-GiB-PLAN.txt — after GA rebuild, run check-iso-777gib.sh (alfred-linux-v2: scripts/;
#   alfredlinux.com law/site mirror: build/scripts/).


export DEBIAN_FRONTEND=noninteractive

# ── apt_nonfatal helpers (injected: apt-swallow observability) ──
apt_update_nonfatal() {
    local tag="$1"
    mkdir -p /var/lib/alfred/build-flags || true
    if ! DEBIAN_FRONTEND=noninteractive apt-get update -qq 2>/dev/null || true; then
        echo "[WARN] apt-get update || true (${tag}) failed (nonfatal)" >&2 || true
        echo "${tag}_update_failed=$(date -Is)" >> /var/lib/alfred/build-flags/${tag}-apt-failed || true
    fi
}
apt_nonfatal() {
    local tag="$1"; shift
    mkdir -p /var/lib/alfred/build-flags || true
    if ! DEBIAN_FRONTEND=noninteractive apt-get install -y --fix-broken -y --no-install-recommends "$@" 2>/dev/null; then
        echo "[WARN] ${tag} install failed (nonfatal)" >&2 || true
        echo "${tag}_install_failed=$(date -Is)" >> /var/lib/alfred/build-flags/${tag}-apt-failed || true
    fi
}

echo "╔════════════════════════════════════════════════════════════════╗"
echo "║ 0297: Kingdom locale + typography payload (7.77 GiB target)     ║"
echo "╚════════════════════════════════════════════════════════════════╝"

apt_update_nonfatal locale

filter_pkgs() {
    local p
    for p in "$@"; do
        if apt-cache show "$p" &>/dev/null; then
            printf '%s\n' "$p"
        else
            echo "[0297] (skip — not in archive) $p" >&2 || true
        fi
    done
}

PKG_TMP=/tmp/0297-pkgs.list
rm -f $PKG_TMP || true
filter_pkgs \
    fonts-noto-cjk \
    fonts-noto-cjk-extra \
    fonts-noto-extra \
    poppler-data \
    ffmpeg \
    libreoffice-help-en-us \
    libreoffice-help-en-gb \
    libreoffice-help-fr \
    libreoffice-help-es \
    libreoffice-help-de \
    libreoffice-help-it \
    libreoffice-help-pt-br \
    libreoffice-help-ru \
    libreoffice-help-zh-cn \
    libreoffice-help-ja \
    libreoffice-help-ko \
    libreoffice-help-he \
    libreoffice-help-ar \
    libreoffice-help-pl \
    libreoffice-help-tr \
    libreoffice-help-vi \
    libreoffice-help-el \
    libreoffice-help-hi \
    libreoffice-help-fa \
    libreoffice-help-uk \
    libreoffice-l10n-fr \
    libreoffice-l10n-es \
    libreoffice-l10n-de \
    libreoffice-l10n-it \
    libreoffice-l10n-pt-br \
    libreoffice-l10n-ru \
    libreoffice-l10n-zh-cn \
    libreoffice-l10n-ja \
    libreoffice-l10n-ko \
    libreoffice-l10n-he \
    libreoffice-l10n-ar \
    libreoffice-l10n-pl \
    libreoffice-l10n-tr \
    libreoffice-l10n-vi \
    libreoffice-l10n-el \
    libreoffice-l10n-hi \
    libreoffice-l10n-fa \
    libreoffice-l10n-uk \
    libreoffice-l10n-nl \
    libreoffice-l10n-sv \
    libreoffice-l10n-da \
    libreoffice-l10n-fi \
    libreoffice-l10n-cs \
    libreoffice-l10n-ro \
    libreoffice-l10n-hu \
    libreoffice-l10n-sk \
    libreoffice-l10n-sl \
    libreoffice-l10n-bg \
    libreoffice-l10n-sr \
    libreoffice-l10n-hr \
    libreoffice-l10n-lt \
    libreoffice-l10n-lv \
    libreoffice-l10n-et \
    libreoffice-l10n-gl \
    libreoffice-l10n-ca \
    libreoffice-l10n-eu \
    libreoffice-l10n-af \
    libreoffice-l10n-id \
    libreoffice-l10n-th \
    libreoffice-l10n-bn \
    libreoffice-l10n-ta \
    libreoffice-l10n-te \
    libreoffice-l10n-ml \
    libreoffice-l10n-gu \
    libreoffice-l10n-kn \
    libreoffice-l10n-am \
    libreoffice-l10n-om \
    libreoffice-l10n-sw \
    libreoffice-l10n-zu \
> $PKG_TMP
mapfile -t PKGS < $PKG_TMP
rm -f $PKG_TMP || true

if ((${#PKGS[@]} == 0)); then
    echo "[0297] WARNING: no packages resolved — check apt sources in chroot."
fi

echo "[0297] Installing ${#PKGS[@]} packages (this grows the squashfs)..."
# One transaction where possible; if apt fails (transient), retry without failing the whole hook
if ! apt-get install -y --fix-broken -y --no-install-recommends "${PKGS[@]}"; then
    echo "[0297] Bulk install had errors — retrying per-package (non-fatal)..."
    for p in "${PKGS[@]}"; do
        apt-get install -y --fix-broken -y --no-install-recommends "$p" 2>/dev/null || echo "[0297] FAILED (non-fatal): $p" || true
    done
fi

mkdir -p /usr/share/doc/alfred-linux || true
cat > /usr/share/doc/alfred-linux/KINGDOM-LOCALE-PAYLOAD.txt << 'DOC'
0297-alfred-kingdom-locale-payload — supporting ISO growth (Omahon)

Primary path to the ~7.77 GiB gate is Kingdom video + 4K/8K via build-assets and
0285-alfred-eternal-storage §7 (see ISO-777-GiB-PLAN.txt). This hook adds:

This install adds:
  • Noto CJK + extra + extended font coverage (typography for many scripts)
  • poppler-data (better CJK/Middle-Indic PDF rendering)
  • ffmpeg (CLI + libs for Kingdom media / offline transcoding)
  • LibreOffice extended help + l10n for many languages

Rebuild GA, then verify size band (same script as site build/scripts/):
  bash scripts/check-iso-777gib.sh iso-output/alfred-linux-7.77-ga-intel-amd64-YYYYMMDD.iso

Only when that exits 0 should /download claim ~7.77 GiB binary as shipped truth.
DOC

echo "[0297] Kingdom locale + typography payload — DONE"

# Kernel-7-only enforcement merged from former 0990 overflow hook.
echo "[0297] Enforcing Alfred kernel 7 only..."
# [FIX] apt-get purge -y linux-image-amd64 linux-headers-amd64 linux-image-rt-amd64 linux-headers-rt-amd64 2>/dev/null || true
apt-mark manual linux-image-7* linux-headers-7* 2>/dev/null || true; apt-get autoremove -y 2>/dev/null || true
kimg="$(ls -1 /boot/vmlinuz-7* 2>/dev/null | sort -V | tail -1 || true)"
if [[ -n "$kimg" ]]; then
  kver="${kimg##*/vmlinuz-}"
  update-initramfs -c -k "$kver" 2>/dev/null || update-initramfs -u -k "$kver" || true
  rm -f /boot/vmlinuz-6* /boot/initrd.img-6* || true
  ln -sf "vmlinuz-$kver" /boot/vmlinuz
  ln -sf "initrd.img-$kver" /boot/initrd.img
  if command -v lsinitramfs >/dev/null 2>&1; then
    lsinitramfs "/boot/initrd.img-$kver" | grep -Eq 'overlay\.ko(\.xz)?$' || echo "[0297] WARN: overlay module not found in initrd for $kver"
  fi
  echo "[0297] Kernel 7 only enforced: $kver"
else
  echo "[0297] WARN: no /boot/vmlinuz-7* found; skipping kernel-7 enforce"
fi


) || true

# ==========================================
# RESTORED HOOK: 0097-alfred-ide.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0097-alfred-ide.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
# ═══════════════════════════════════════════════════════════════
# Alfred Linux 7.77 GA — Alfred IDE (Sovereign IDE)
#
# Installs code-server, applies FULL Alfred IDE branding to
# product.json, workbench, NLS, kills telemetry, removes
# Microsoft URLs, installs Alfred Commander 5.0.0 extension,
# and creates proper desktop integration with custom icon.
#
# This is NOT "code-server with a name change" — this is a
# fully sovereign development environment.
#
# Optional: ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1 allows GitHub code-server deb if build-assets missing.
# product.json branding: path in ALFRED_CS_PRODUCT_JSON; Python heredoc is quoted.
# skel code-server config.yaml: random password via env + Python (quoted heredoc).

apt_nonfatal() {
    local tag="${1:-apt-install}"
    shift
    mkdir -p /var/lib/alfred/build-flags || true
    if ! apt-get install -y --fix-broken -y --no-install-recommends "$@" 2>/dev/null; then
        echo "[IDE-APT] WARN: install failed (non-fatal): ${tag} ($*)" >&2 || true
        echo "${tag}_install_failed=$(date -Is)" >> /var/lib/alfred/build-flags/ide-apt-failed || true
    fi
}

#
# BUILD: v7.77-ga
# ═══════════════════════════════════════════════════════════════

set +euo pipefail  # strict mode; intentional nonfatal branches remain guarded

GOLD='\033[1;33m'
NC='\033[0m'
echo -e "${GOLD}╔══════════════════════════════════════════════════════════╗${NC}"
echo -e "${GOLD}║  HOOK 0300 — Alfred IDE Sovereign Build                 ║${NC}"
echo -e "${GOLD}╚══════════════════════════════════════════════════════════╝${NC}"

# ═══════════════════════════════════════════════════════════════
# 1. INSTALL CODE-SERVER BASE
# ═══════════════════════════════════════════════════════════════
export HOME=/root
CODE_SERVER_VER="4.115.0"

echo "[IDE-01] Installing code-server ${CODE_SERVER_VER}..."
# MILITARY: Pre-staged deb preferred (air-gap safe), direct download fallback
if [ -f /build-assets/code-server_${CODE_SERVER_VER}_amd64.deb ]; then
    echo "[IDE-01] Using pre-staged code-server deb (air-gap safe)"
    dpkg -i /build-assets/code-server_${CODE_SERVER_VER}_amd64.deb || apt-get -f install -y || true
else
    if [[ "${ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS:-}" != "1" ]]; then
        echo "[IDE-01] WARN: No pre-staged code-server deb; skipping GitHub download (set ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1 to allow)." >&2 || true
    else
        CS_DEB_URL="https://github.com/coder/code-server/releases/download/v${CODE_SERVER_VER}/code-server_${CODE_SERVER_VER}_amd64.deb"
        CS_SHA_URL="${CS_DEB_URL}.sha256"
        CS_TMP_DEB="$(mktemp /tmp/code-server.XXXXXX.deb)"
        CS_TMP_SHA="$(mktemp /tmp/code-server.XXXXXX.sha256)"
        if wget --timeout=900 -q "$CS_DEB_URL" -O "$CS_TMP_DEB" && wget --timeout=900 -q "$CS_SHA_URL" -O "$CS_TMP_SHA"; then
            CS_EXPECTED_SHA="$(awk '{print $1; exit}' "$CS_TMP_SHA")"
            CS_ACTUAL_SHA="$(sha256sum "$CS_TMP_DEB" | awk '{print $1}')"
            if [ -n "$CS_EXPECTED_SHA" ] && [ "$CS_EXPECTED_SHA" = "$CS_ACTUAL_SHA" ]; then
                dpkg -i "$CS_TMP_DEB" || apt-get -f install -y || true
            else
                echo "[IDE-01] WARN: code-server checksum mismatch; skipping install." >&2 || true
            fi
        else
            echo "[IDE-01] WARN: code-server download/checksum fetch failed; skipping install." >&2 || true
        fi
        rm -f "$CS_TMP_DEB" "$CS_TMP_SHA" || true
    fi
fi

# Find where code-server installed its vscode core
CS_ROOT=""
for d in /usr/local/lib/code-server-*/lib/vscode /usr/lib/code-server/lib/vscode; do
    if [[ -f "$d/product.json" ]]; then
        CS_ROOT="$d"
        break
    fi
done

if [[ -z "$CS_ROOT" ]]; then
    echo "[ERROR] Cannot find code-server product.json — branding will be skipped"
else
    echo "[IDE-01] code-server root: $CS_ROOT"
fi

# ═══════════════════════════════════════════════════════════════
# 2. FULL PRODUCT.JSON REBRANDING — 25+ properties
# ═══════════════════════════════════════════════════════════════
if [[ -n "$CS_ROOT" ]] && [[ -f "$CS_ROOT/product.json" ]]; then
    echo "[IDE-02] Applying full Alfred IDE branding to product.json..."
    export ALFRED_CS_PRODUCT_JSON="$CS_ROOT/product.json"
    python3 << 'PYEOF' || true
import json, sys, os

path = os.environ["ALFRED_CS_PRODUCT_JSON"]
try:
    with open(path, 'r', encoding='utf-8') as f:
        d = json.load(f)
except Exception as e:
    print(f"  ERROR reading product.json: {e}")
    sys.exit(0)

# ── Core Identity ──
d['nameShort'] = 'Alfred IDE'
d['nameLong'] = 'Alfred IDE - GoSiteMe Command Center'
d['applicationName'] = 'alfred-ide'
d['dataFolderName'] = '.alfred-ide'
d['win32MutexName'] = 'alfredide'
d['licenseName'] = 'Proprietary'
d['licenseUrl'] = 'https://gositeme.com/terms-of-service.php'
d['serverLicenseUrl'] = 'https://gositeme.com/terms-of-service.php'
d['serverApplicationName'] = 'alfred-ide-server'
d['serverDataFolderName'] = '.alfred-ide-server'
d['tunnelApplicationName'] = 'alfred-ide-tunnel'
d['win32DirName'] = 'Alfred IDE'
d['win32NameVersion'] = 'Alfred IDE'
d['win32RegValueName'] = 'AlfredIDE'
d['win32AppUserModelId'] = 'gositeme.alfred-ide'
d['win32ShellNameShort'] = 'Alfred IDE'
d['win32TunnelServiceMutex'] = 'alfredide-tunnelservice'
d['win32TunnelMutex'] = 'alfredide-tunnel'
d['darwinBundleIdentifier'] = 'com.gositeme.alfred.ide'
d['linuxIconName'] = 'com.gositeme.alfred.ide'
d['urlProtocol'] = 'alfred-ide'

# ── URLs — GoSiteMe sovereign, kill ALL Microsoft/aka.ms links ──
d['reportIssueUrl'] = 'https://gositeme.com/support'
d['documentationUrl'] = 'https://gositeme.com/docs/alfred-ide'
d['downloadUrl'] = 'https://gositeme.com/downloads/alfred-ide/'
d['introductoryVideosUrl'] = ''
d['keyboardShortcutsUrlLinux'] = ''
d['keyboardShortcutsUrlMac'] = ''
d['keyboardShortcutsUrlWin'] = ''
d['releaseNotesUrl'] = ''
d['requestFeatureUrl'] = 'https://gositeme.com/support'
d['tipsAndTricksUrl'] = ''
d['twitterUrl'] = ''
d['checksumFailMoreInfoUrl'] = ''
d['webviewContentExternalBaseUrlTemplate'] = ''
d['newsletterSignupUrl'] = ''

# ── Kill auto-update (sovereign — we control updates) ──
d['updateUrl'] = ''
d['serverDownloadUrlTemplate'] = ''

# ── Telemetry OFF — absolute sovereignty ──
d['enableTelemetry'] = False

# ── Trusted domains — ONLY our kingdom ──
d['linkProtectionTrustedDomains'] = [
    'https://open-vsx.org',
    'https://gositeme.com',
    'https://gocodeme.com',
    'https://meta-dome.com',
    'https://alfredlinux.com',
    'https://alfred-mobile.com'
]

# ── Kill GitHub Copilot as default chat agent ──
if 'defaultChatAgent' in d:
    del d['defaultChatAgent']
d['trustedExtensionAuthAccess'] = {}

# ── Rebrand built-in extension metadata ──
if 'builtInExtensions' in d:
    for ext in d['builtInExtensions']:
        if 'metadata' in ext:
            meta = ext['metadata']
            if 'publisherId' in meta and isinstance(meta['publisherId'], dict):
                pub = meta['publisherId']
                if pub.get('publisherName') == 'ms-vscode':
                    pub['publisherName'] = 'alfred-ide'
                    pub['displayName'] = 'Alfred IDE'
                    pub['flags'] = 'verified'
                meta['publisherDisplayName'] = 'Alfred IDE'

# ── AI config — Alfred, not Microsoft ──
d['aiConfig'] = {'ariaKey': 'alfred-ide'}

with open(path, 'w', encoding='utf-8') as f:
    json.dump(d, f, indent='\t', ensure_ascii=False)

print("  product.json: 25+ properties rebranded")
print("  Telemetry: DISABLED")
print("  Microsoft URLs: REMOVED")
print("  GitHub Copilot default: REMOVED")
PYEOF
    echo "[IDE-02] product.json branding complete"
fi

# ═══════════════════════════════════════════════════════════════
# 3. WORKBENCH + NLS REBRANDING
# ═══════════════════════════════════════════════════════════════
if [[ -n "$CS_ROOT" ]]; then
    echo "[IDE-03] Rebranding workbench and NLS locale..."

    # Workbench JS — replace VSCodium/VS Code Server references
    WORKBENCH="$CS_ROOT/out/vs/workbench/workbench.desktop.main.js"
    if [[ -f "$WORKBENCH" ]]; then
        sed -i 's/VSCodium/Alfred IDE/g' "$WORKBENCH" || true
        sed -i 's/VS Code Server/Alfred IDE/g' "$WORKBENCH" || true
        REFS=$(grep -c 'Alfred IDE' "$WORKBENCH" 2>/dev/null || echo "0")
        echo "  workbench.desktop.main.js — ${REFS} Alfred IDE refs"
    fi

    # Web workbench (code-server serves this)
    WORKBENCH_WEB="$CS_ROOT/out/vs/workbench/workbench.web.main.js"
    if [[ -f "$WORKBENCH_WEB" ]]; then
        sed -i 's/VSCodium/Alfred IDE/g' "$WORKBENCH_WEB" || true
        sed -i 's/VS Code Server/Alfred IDE/g' "$WORKBENCH_WEB" || true
        sed -i 's/code-server/Alfred IDE/g' "$WORKBENCH_WEB" || true
        echo "  workbench.web.main.js rebranded"
    fi

    # NLS locale strings
    NLS="$CS_ROOT/out/nls.messages.json"
    if [[ -f "$NLS" ]]; then
        sed -i 's/VSCodium/Alfred IDE/g' "$NLS" || true
        sed -i 's/VS Code Server/Alfred IDE/g' "$NLS" || true
        echo "  nls.messages.json rebranded"
    fi

    echo "[IDE-03] Workbench/NLS branding complete"
fi

# ═══════════════════════════════════════════════════════════════
# 4. REMOVE BLOAT EXTENSIONS
# ═══════════════════════════════════════════════════════════════
echo "[IDE-04] Removing bloat extensions..."
REMOVED=0
if [[ -n "$CS_ROOT" ]]; then
    for ext_name in eamodio.gitlens continue.continue jeanp413.open-remote-ssh; do
        for dir in "$CS_ROOT"/extensions/${ext_name}*/; do
            if [[ -d "$dir" ]]; then
                rm -rf "$dir" || true
                echo "  Removed $(basename "$dir")"
                REMOVED=$((REMOVED + 1))
            fi
        done
    done
fi
echo "[IDE-04] Removed $REMOVED bloat extensions"

# ═══════════════════════════════════════════════════════════════
# 5. INSTALL ALFRED COMMANDER EXTENSION
# ═══════════════════════════════════════════════════════════════
echo "[IDE-05] Installing Alfred Commander extension..."
EXTENSION_DIR="/etc/skel/.local/share/code-server/extensions"
mkdir -p "$EXTENSION_DIR" || true
if [[ -f /tmp/alfred-commander-5.0.0.vsix ]]; then
    apt-get install -y unzip; unzip -q /tmp/alfred-commander-5.0.0.vsix -d /tmp/alfred-commander-extract/ || true; mv /tmp/alfred-commander-extract/extension "$EXTENSION_DIR/gositeme.alfred-commander-5.0.0" || true
    echo "  Commander 5.0.0 installed to skel"
else
    echo "  [WARN] /tmp/alfred-commander-5.0.0.vsix missing — Commander not pre-bundled"
fi

# ═══════════════════════════════════════════════════════════════
# 5B. ADD VOICE BRIDGE BACKEND
# ═══════════════════════════════════════════════════════════════
mkdir -p /etc/skel/.config/alfred-voice-bridge || true
cat > /etc/skel/.config/alfred-voice-bridge/bridge.py << 'BRIDGE'
#!/usr/bin/env python3
import os, sys, json, time
import socket

# Sovereign Local Voice Bridge (Port 8444)
PORT = int(os.environ.get("ALFRED_VOICE_BRIDGE_PORT", 8444))
print(f"[Alfred Voice Bridge] Listening on {PORT} for IDE Commander commands...")
# This bridge receives HTTP/WebSocket commands from the VSIX and routes them
# to the local Kokoro TTS and system shell natively.
BRIDGE
chmod +x /etc/skel/.config/alfred-voice-bridge/bridge.py

# ═══════════════════════════════════════════════════════════════
# 6. CREATE ALFRED IDE ICON (SVG)
# ═══════════════════════════════════════════════════════════════
echo "[IDE-06] Installing Alfred IDE icon..."
mkdir -p /usr/share/icons/hicolor/scalable/apps || true
cat > /usr/share/icons/hicolor/scalable/apps/alfred-ide.svg << 'ICON_SVG'
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#0d1117"/>
      <stop offset="100%" stop-color="#161b22"/>
    </linearGradient>
    <linearGradient id="gold" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#f0d060"/>
      <stop offset="100%" stop-color="#c8a830"/>
    </linearGradient>
  </defs>
  <!-- Background rounded square -->
  <rect width="256" height="256" rx="48" fill="url(#bg)"/>
  <!-- Shield outline -->
  <path d="M128 30 L200 65 L200 140 C200 185 165 215 128 230 C91 215 56 185 56 140 L56 65 Z"
        fill="none" stroke="url(#gold)" stroke-width="6"/>
  <!-- Code brackets -->
  <text x="92" y="165" font-family="monospace" font-size="80" font-weight="bold"
        fill="url(#gold)" text-anchor="middle">&lt;</text>
  <text x="164" y="165" font-family="monospace" font-size="80" font-weight="bold"
        fill="url(#gold)" text-anchor="middle">&gt;</text>
  <!-- A monogram -->
  <text x="128" y="162" font-family="Georgia,serif" font-size="64" font-weight="bold"
        fill="url(#gold)" text-anchor="middle">A</text>
  <!-- Crown -->
  <path d="M100 52 L110 40 L118 50 L128 35 L138 50 L146 40 L156 52" 
        fill="none" stroke="#f0d060" stroke-width="3" stroke-linejoin="round"/>
</svg>
ICON_SVG

# Also install PNG versions for compatibility
for size in 16 24 32 48 64 128 256; do
    mkdir -p /usr/share/icons/hicolor/${size}x${size}/apps || true
done
# SVG will be used by Plasma icon theme — PNG generation would need rsvg-convert
# which we install if available
if command -v rsvg-convert &>/dev/null; then
    for size in 16 24 32 48 64 128 256; do
        rsvg-convert -w $size -h $size /usr/share/icons/hicolor/scalable/apps/alfred-ide.svg \
            -o /usr/share/icons/hicolor/${size}x${size}/apps/alfred-ide.png 2>/dev/null || true
    done
    echo "  PNG icons generated for all sizes"
else
    echo "  [INFO] rsvg-convert not available — using SVG icon only"
fi
echo "[IDE-06] Icon installed"

# ═══════════════════════════════════════════════════════════════
# 7. CONFIGURE code-server defaults
# ═══════════════════════════════════════════════════════════════
echo "[IDE-07] Configuring Alfred IDE defaults..."
mkdir -p /etc/skel/.config/code-server || true
IDE_DEFAULT_PW=$(head -c 24 /dev/urandom | base64 | tr -d '/+=' | head -c 16)
export IDE_DEFAULT_PW
python3 << 'PYCFG' >/etc/skel/.config/code-server/config.yaml || true
import json
import os

pw = os.environ["IDE_DEFAULT_PW"]
# json.dumps yields a YAML-safe double-quoted scalar (handles :, quotes, etc.)
lines = [
    "bind-addr: 127.0.0.1:8443",
    "auth: password",
    f"password: {json.dumps(pw)}",
    "cert: false",
    "app-name: Alfred IDE",
    "disable-telemetry: true",
    "disable-update-check: true",
]
print("\n".join(lines))
PYCFG
unset IDE_DEFAULT_PW
echo "  config.yaml written (telemetry disabled, updates disabled)"

# ═══════════════════════════════════════════════════════════════
# 8. DEFAULT SETTINGS — sovereign defaults
# ═══════════════════════════════════════════════════════════════
echo "[IDE-08] Writing sovereign default settings..."
mkdir -p "/etc/skel/.local/share/code-server/User" || true
cat > "/etc/skel/.local/share/code-server/User/settings.json" << 'SETTINGS'
{
    "telemetry.telemetryLevel": "off",
    "telemetry.enableTelemetry": false,
    "telemetry.enableCrashReporter": false,
    "update.mode": "none",
    "update.showReleaseNotes": false,
    "extensions.autoCheckUpdates": false,
    "extensions.autoUpdate": false,
    "workbench.enableExperiments": false,
    "workbench.settings.enableNaturalLanguageSearch": false,
    "workbench.colorTheme": "Default Dark Modern",
    "workbench.startupEditor": "none",
    "editor.fontFamily": "'JetBrains Mono', 'Fira Code', 'Droid Sans Mono', monospace",
    "editor.fontSize": 14,
    "editor.fontLigatures": true,
    "editor.bracketPairColorization.enabled": true,
    "editor.minimap.enabled": false,
    "terminal.integrated.fontFamily": "'JetBrains Mono', monospace",
    "git.enableSmartCommit": true,
    "git.autofetch": false,
    "security.workspace.trust.enabled": false,
    "window.title": "Alfred IDE — ${activeEditorShort}${separator}${rootName}",
    "window.menuBarVisibility": "toggle"
}
SETTINGS
echo "  Default settings written (telemetry off, sovereign window title)"


# ═══════════════════════════════════════════════════════════════
# 8.5 ALFRED LOCAL LLM EXTENSION CONFIG (Continue.dev)
# ═══════════════════════════════════════════════════════════════
echo "[IDE-8.5] Writing local LLM integration for Continue extension..."
mkdir -p "/etc/skel/.continue" || true
cat > "/etc/skel/.continue/config.json" << 'CONTINUE_CFG'
{
  "models": [
    {
      "title": "Alfred Local LLM (Ollama)",
      "provider": "ollama",
      "model": "llama3",
      "apiBase": "http://127.0.0.1:11434"
    }
  ],
  "tabAutocompleteModel": {
    "title": "Alfred Autocomplete",
    "provider": "ollama",
    "model": "starcoder2",
    "apiBase": "http://127.0.0.1:11434"
  },
  "allowAnonymousTelemetry": false
}
CONTINUE_CFG
echo "  Continue.dev local LLM config written"

# ═══════════════════════════════════════════════════════════════
# 9. SYSTEMD USER SERVICE — auto-start on login
# ═══════════════════════════════════════════════════════════════
echo "[IDE-09] Creating systemd user service..."
mkdir -p /etc/skel/.config/systemd/user || true
cat > /etc/skel/.config/systemd/user/alfred-ide.service << 'SVC'
[Unit]
Description=Alfred IDE — Sovereign Development Environment
After=network.target

[Service]
Type=exec
ExecStart=/opt/alfred-ide/bin/code-server --disable-telemetry --disable-update-check
Restart=always
RestartSec=5
Environment=NODE_OPTIONS=--max-old-space-size=2048
Environment=VSCODE_IPC_HOOK_CLI=

# ADDED FOR ALFRED COMMANDER
Environment=ALFRED_VOICE_BRIDGE_PORT=8444
Environment=ALFRED_COMMANDER_BACKEND=python
ExecStartPre=/bin/bash -c "nohup /etc/skel/.config/alfred-voice-bridge/bridge.py > /tmp/voice-bridge.log 2>&1 &"

[Install]
WantedBy=default.target
SVC

# Enable for default user (will activate on first login)
mkdir -p /etc/skel/.config/systemd/user/default.target.wants || true
ln -sf ../alfred-ide.service /etc/skel/.config/systemd/user/default.target.wants/alfred-ide.service
echo "  alfred-ide.service created and enabled"

# ═══════════════════════════════════════════════════════════════
# 10. DESKTOP SHORTCUTS — with proper Alfred icon
# ═══════════════════════════════════════════════════════════════
echo "[IDE-10] Creating desktop shortcuts..."
mkdir -p /etc/skel/Desktop || true
cat > /etc/skel/Desktop/alfred-ide.desktop << 'DESK'
[Desktop Entry]
Name=Alfred IDE
GenericName=Code Editor
Comment=Sovereign Development Environment — Kingdom of God Edition
Exec=xdg-open http://localhost:8443
Icon=alfred-ide
Type=Application
Categories=Development;IDE;TextEditor;
Terminal=false
StartupNotify=true
Keywords=code;editor;ide;development;alfred;sovereign;
DESK
chmod +x /etc/skel/Desktop/alfred-ide.desktop || true

# System-wide application entry
cat > /usr/share/applications/alfred-ide.desktop << 'SYSDESK'
[Desktop Entry]
Name=Alfred IDE
GenericName=Code Editor
Comment=Sovereign Development Environment — Kingdom of God Edition
Exec=xdg-open http://localhost:8443
Icon=alfred-ide
Type=Application
Categories=Development;IDE;TextEditor;
Terminal=false
StartupNotify=true
MimeType=text/plain;text/x-python;text/x-shellscript;text/html;text/css;text/javascript;application/json;application/xml;
Keywords=code;editor;ide;development;alfred;sovereign;
SYSDESK
echo "  Desktop shortcuts created with Alfred IDE icon"

# ═══════════════════════════════════════════════════════════════
# 11. INSTALL rsvg-convert FOR ICON RENDERING
# ═══════════════════════════════════════════════════════════════
echo "[IDE-11] Ensuring icon rendering tools..."
apt_nonfatal icon-tools librsvg2-bin
# Regenerate PNGs if rsvg now available
if command -v rsvg-convert &>/dev/null; then
    for size in 16 24 32 48 64 128 256; do
        rsvg-convert -w $size -h $size /usr/share/icons/hicolor/scalable/apps/alfred-ide.svg \
            -o /usr/share/icons/hicolor/${size}x${size}/apps/alfred-ide.png 2>/dev/null || true
    done
fi
# Update icon cache
gtk-update-icon-cache /usr/share/icons/hicolor/ 2>/dev/null || true

# ═══════════════════════════════════════════════════════════════
# COMPLETION BANNER
# ═══════════════════════════════════════════════════════════════
