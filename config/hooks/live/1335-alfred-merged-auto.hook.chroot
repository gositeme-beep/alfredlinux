  suggest) shift; income="${1:?income}"; awk -v i="$income" "BEGIN{printf \"10%% tithe = %.2f\n\", i*0.10}" ;;
  *) echo "usage: alfred-tithe {add <amt> <note>|total|show|suggest <income>}"; exit 0 ;;
esac
EOS
