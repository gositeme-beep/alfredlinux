echo "=== Alfred Linux: Installing Missing KDE Settings Modules ==="

# We need to make sure the time/regional settings and other KDE system settings modules are present.
# 'systemsettings' provides the System Settings app.
# 'locales-all' ensures all regions are available for selection.
# 'polkit-kde-agent-1' provides the authentication dialog for changing time.

