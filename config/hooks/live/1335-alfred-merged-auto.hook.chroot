echo "â•‘  [0725] The Assembly â€” COMPLETE                          â•‘"
echo "â•‘  âœ“ Assembly start â†’ sends invite to all mesh peers       â•‘"
echo "â•‘  âœ“ Assembly watch â†’ listens for invitations              â•‘"
