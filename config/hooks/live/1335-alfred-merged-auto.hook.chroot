cat << 'EOF' > /opt/alfred/ebpf/vanguard.py
#!/usr/bin/env python3
# The Omahon Vanguard - eBPF Active Denial Shield
from bcc import BPF
import time
import sys

# 1. BPF C Program
bpf_code = """
#include <uapi/linux/ptrace.h>
#include <linux/sched.h>
#include <linux/fs.h>
#include <uapi/linux/bpf.h>
#include <linux/if_ether.h>
#include <linux/ip.h>
#include <linux/tcp.h>
#include <linux/in.h>

// --- KPROBE: Execution Blocking ---
// We intercept sys_execve to prevent unauthorized binaries from running
// especially from /tmp or /dev/shm
BPF_HASH(blocked_paths, u64, u32);

int kprobe__sys_execve(struct pt_regs *ctx, const char __user *filename, const char __user *const __user *argv, const char __user *const __user *envp) {
    char comm[TASK_COMM_LEN];
    bpf_get_current_comm(&comm, sizeof(comm));
    
    char path[256];
    bpf_probe_read_user_str(&path, sizeof(path), filename);
    
    // Check if path starts with /tmp/ or /dev/shm/
    if (path[0] == '/' && path[1] == 't' && path[2] == 'm' && path[3] == 'p' && path[4] == '/') {
        // Send SIGKILL immediately
        bpf_send_signal(9);
        bpf_trace_printk("VANGUARD DENY: Blocked execution from /tmp: %s\\n", path);
        return 0;
    }
    if (path[0] == '/' && path[1] == 'd' && path[2] == 'e' && path[3] == 'v' && path[4] == '/' && path[5] == 's' && path[6] == 'h' && path[7] == 'm' && path[8] == '/') {
        bpf_send_signal(9);
        bpf_trace_printk("VANGUARD DENY: Blocked execution from /dev/shm: %s\\n", path);
        return 0;
    }
    
    return 0;
}

// --- XDP: Network Packet Dropping ---
// Drops malformed TCP packets (e.g. Xmas tree scans) before they hit the IP stack
int vanguard_xdp(struct xdp_md *ctx) {
    void *data = (void *)(long)ctx->data;
    void *data_end = (void *)(long)ctx->data_end;
    
    struct ethhdr *eth = data;
    if (data + sizeof(struct ethhdr) > data_end)
        return XDP_PASS;
        
    if (eth->h_proto == bpf_htons(ETH_P_IP)) {
        struct iphdr *ip = data + sizeof(struct ethhdr);
        if ((void*)ip + sizeof(struct iphdr) > data_end)
            return XDP_PASS;
            
        if (ip->protocol == IPPROTO_TCP) {
            struct tcphdr *tcp = (void*)ip + ip->ihl * 4;
            if ((void*)tcp + sizeof(struct tcphdr) > data_end)
                return XDP_PASS;
                
            // Drop packets with all flags set (Xmas Scan)
            if (tcp->fin && tcp->syn && tcp->rst && tcp->psh && tcp->ack && tcp->urg) {
                bpf_trace_printk("VANGUARD XDP: Dropped Xmas Tree Scan\\n");
                return XDP_DROP;
            }
            // Drop packets with no flags set (Null Scan)
            if (!tcp->fin && !tcp->syn && !tcp->rst && !tcp->psh && !tcp->ack && !tcp->urg) {
                bpf_trace_printk("VANGUARD XDP: Dropped Null Scan\\n");
                return XDP_DROP;
            }
        }
    }
    return XDP_PASS;
}
"""

try:
    print("[*] Compiling and loading Vanguard eBPF Shield...")
    b = BPF(text=bpf_code)
    
    print("[*] Kprobes armed. Monitoring execve calls...")
    
    # Optional: Attach XDP to eth0 if available
    # device = "eth0"
    # try:
    #     b.attach_xdp(device, fn=b.load_func("vanguard_xdp", BPF.XDP))
    #     print(f"[*] XDP attached to {device}")
    # except Exception as e:
    #     print(f"[!] Could not attach XDP to {device}: {e}")
        
    print("[*] Omahon Vanguard is fully operational. Press Ctrl+C to stop.")
    
    # Loop and print trace output
    while True:
        try:
            (task, pid, cpu, flags, ts, msg) = b.trace_fields()
            print(f"{ts:10.6f} [PID {pid}] {msg.decode('utf-8')}")
        except ValueError:
            continue
        except KeyboardInterrupt:
            break
            
finally:
    # try:
    #     b.remove_xdp(device)
    # except:
    #     pass
    print("\n[*] Vanguard Shield offline.")
EOF
