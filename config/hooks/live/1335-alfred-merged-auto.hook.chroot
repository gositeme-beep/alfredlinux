# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
# 3. ALFRED-FAMILY-BIBLE CLI GENERATOR
# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
echo "[BIBLE-GEN-03] Creating alfred-family-bible generator..."

cat > /usr/local/bin/alfred-family-bible << 'BIBCLI'
# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
# alfred-family-bible â€” Personalized Family Bible Generator
# Creates a dedicated Bible for your family with:
#   - Personalized cover with family name & Kingdom seal
#   - Covenant certificate (dedication page)
#   - Family tree (fill in your heritage)
#   - SHA-256 integrity seal
# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
TEMPLATE_DIR="/usr/share/alfred/bible/templates"
export TEMPLATE_DIR
BIBLE_DIR="/usr/share/alfred/bible"
CYAN='\033[0;36m'; GREEN='\033[0;32m'; YELLOW='\033[0;33m'
BOLD='\033[1m'; NC='\033[0m'

banner() {
    echo -e "${CYAN}â•”â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•—${NC}"
    echo -e "${CYAN}â•‘${NC}  ${BOLD}âœï¸  Alfred Family Bible Generator${NC}                 ${CYAN}â•‘${NC}"
    echo -e "${CYAN}â•‘${NC}  'Train up a child in the way he should go'       ${CYAN}â•‘${NC}"
    echo -e "${CYAN}â•‘${NC}  â€” Proverbs 22:6                                  ${CYAN}â•‘${NC}"
    echo -e "${CYAN}â•šâ•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•${NC}"
}

cmd_generate() {
    banner
    echo ""
    
    # Get family name
    if [ -n "$1" ]; then
        FAMILY_NAME="$1"
    else
        echo -ne "${BOLD}Enter your family name: ${NC}"
        read -r FAMILY_NAME
    fi
    
    if [ -z "$FAMILY_NAME" ]; then
        echo -e "${YELLOW}Family name is required.${NC}"
        return 1
    fi
    
    # Slug for paths only â€” disallow / and path traversal in output directory name
    FAMILY_SLUG="${FAMILY_NAME//\//-}"
    FAMILY_SLUG="${FAMILY_SLUG//\\/}"
    FAMILY_UPPER=$(printf '%s' "$FAMILY_NAME" | tr '[:lower:]' '[:upper:]')
    YEAR=$(date +%Y)
    DATE=$(date '+%B %d, %Y')
    OUTPUT_DIR="$HOME/Documents/Family-Bible-${FAMILY_SLUG}"
    
    echo -e "${BOLD}Generating the ${FAMILY_NAME} Family Bible...${NC}"
    mkdir -p "$OUTPUT_DIR" || true
    
    # Ask for dedication
    echo ""
    echo -e "${BOLD}Enter a dedication (or press Enter for default):${NC}"
    echo -ne "> " || true
    read -r DEDICATION
    if [ -z "$DEDICATION" ]; then
        DEDICATION="This Bible is lovingly dedicated to the ${FAMILY_NAME} family. May the Word of God be a lamp unto your feet and a light unto your path. â€” Psalm 119:105"
    fi
    
    echo ""
    echo "[1/4] Generating Bible cover..."
    export FB_OUT="$OUTPUT_DIR" FB_FAMILY_UPPER="$FAMILY_UPPER" FB_YEAR="$YEAR"
    python3 << 'PYFB1' || true
import os
from pathlib import Path
out = Path(os.environ["FB_OUT"])
tpl = Path(os.environ.get("TEMPLATE_DIR", "/usr/share/alfred/bible/templates"))
text = (tpl / "bible-cover.html").read_text(encoding="utf-8", errors="replace")
text = text.replace("{{FAMILY_NAME}}", os.environ["FB_FAMILY_UPPER"]).replace("{{YEAR}}", os.environ["FB_YEAR"])
(out / "01-cover.html").write_text(text, encoding="utf-8", errors="replace")
PYFB1
    
    echo "[2/4] Generating covenant certificate..."
    HASH_INPUT="${FAMILY_NAME}-${DATE}-${DEDICATION}"
    HASH=$(printf '%s' "$HASH_INPUT" | sha256sum | cut -d' ' -f1)
    export FB_OUT="$OUTPUT_DIR" FB_FAMILY_UPPER="$FAMILY_UPPER" FB_DATE="$DATE" FB_DEDICATION="$DEDICATION" FB_HASH="$HASH"
    python3 << 'PYFB2' || true
import os
from pathlib import Path
out = Path(os.environ["FB_OUT"])
tpl = Path(os.environ.get("TEMPLATE_DIR", "/usr/share/alfred/bible/templates"))
text = (tpl / "covenant-certificate.html").read_text(encoding="utf-8", errors="replace")
text = (
    text.replace("{{FAMILY_NAME}}", os.environ["FB_FAMILY_UPPER"])
    .replace("{{DATE}}", os.environ["FB_DATE"])
    .replace("{{DEDICATION}}", os.environ["FB_DEDICATION"])
    .replace("{{HASH}}", os.environ["FB_HASH"])
)
(out / "02-covenant-certificate.html").write_text(text, encoding="utf-8", errors="replace")
PYFB2
    
    echo "[3/4] Generating family tree template..."
    export FB_OUT="$OUTPUT_DIR" FB_FAMILY_UPPER="$FAMILY_UPPER"
    python3 << 'PYFB3' || true
import os, re
from pathlib import Path
out = Path(os.environ["FB_OUT"])
tpl = Path(os.environ.get("TEMPLATE_DIR", "/usr/share/alfred/bible/templates"))
text = (tpl / "family-tree.html").read_text(encoding="utf-8", errors="replace")
text = text.replace("{{FAMILY_NAME}}", os.environ["FB_FAMILY_UPPER"])
text = re.sub(r"\{\{[A-Z_]+\}\}", "", text)
(out / "03-family-tree.html").write_text(text, encoding="utf-8", errors="replace")
PYFB3
    
    echo "[4/4] Generating PDFs..."
    if command -v weasyprint &>/dev/null; then
            "$OUTPUT_DIR/01-cover.pdf" 2>/dev/null || true
            "$OUTPUT_DIR/02-covenant-certificate.pdf" 2>/dev/null || true
            "$OUTPUT_DIR/03-family-tree.pdf" 2>/dev/null || true
        echo -e "  ${GREEN}PDFs generated!${NC}"
    else
        echo -e "  ${YELLOW}weasyprint not found â€” HTML files created (open in browser)${NC}"
    fi
    
    # Generate integrity manifest
    echo "[+] Creating integrity seal..."
    cd "$OUTPUT_DIR" || true
    sha256sum *.html *.pdf 2>/dev/null > INTEGRITY-SEAL.sha256
    MANIFEST_HASH=$(sha256sum INTEGRITY-SEAL.sha256 | cut -d' ' -f1)
    
    export FB_README="$OUTPUT_DIR/README.md" FB_FM="$FAMILY_NAME" FB_DATE="$DATE" FB_MH="$MANIFEST_HASH" FB_SLUG="$FAMILY_SLUG"
    python3 << 'PYREADME' || true
import os
from pathlib import Path

name = os.environ["FB_FM"]
date = os.environ["FB_DATE"]
mh = os.environ["FB_MH"]
slug = os.environ["FB_SLUG"]
body = f"""# The {name} Family Bible

Generated on {date} by Alfred Linux â€” Family Bible Generator

## Contents
- **01-cover** â€” Personalized Bible cover
- **02-covenant-certificate** â€” Family dedication & covenant page
- **03-family-tree** â€” Fill in your family heritage

## How to Use
1. Print the cover and certificate on quality paper
2. Fill in the family tree with your ancestors
3. Bind together with your AKJV Bible printout
4. The AKJV Bible text is at: /usr/share/alfred/bible/

## Integrity Seal
Manifest Hash: {mh}
Verify with: cd ~/Documents/Family-Bible-{slug} && sha256sum -c INTEGRITY-SEAL.sha256

## About the AKJV
The Authorized King Jesus Version includes 94 books (including the
traditionally excluded books) with 39,482 verses â€” the complete canon
of Scripture as preserved through history.

---
âšœï¸ Sealed by the Alfred Kingdom â€” Kingdom of God Edition
"""
Path(os.environ["FB_README"]).write_text(body, encoding="utf-8", errors="replace")
PYREADME

