    import sounddevice as sd
    
    FS = 44100
    THRESHOLD = 50.0  # Ultrasonic energy threshold
    
    def scan_ultrasonic(indata, frames, time, status):
        fft_data = np.abs(np.fft.rfft(indata[:, 0]))
        freqs = np.fft.rfftfreq(len(indata[:, 0]), 1/FS)
        ultra_mask = freqs > 18000
        ultra_energy = np.sum(fft_data[ultra_mask])
        
