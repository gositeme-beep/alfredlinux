# ==========================================
# RESTORED HOOK: 0150-alfred-hardware.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0150-alfred-hardware.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
# ═══════════════════════════════════════════════════════════════════
# HOOK 0150 — Alfred Universal Hardware Compatibility
# ═══════════════════════════════════════════════════════════════════
# Every keyboard. Every mouse. Every touchpad. Every trackpoint.
# Every WiFi card from 2006 to 2026. Every GPU that can push pixels.
# The oldest laptop known to mankind with an SSD gets the greatest
# experience — AND still contributes to the mesh, VPN, and blockchain.
#
# "No device left behind."
# zram-swap.service unit body: written via Python (size_mb validated), not unquoted heredoc.
# ═══════════════════════════════════════════════════════════════════

echo "═══════════════════════════════════════════════════"
echo "  HOOK 0150 — Universal Hardware Compatibility"
echo "  Every input device. Every network card. Every GPU."
echo "═══════════════════════════════════════════════════"

export DEBIAN_FRONTEND=noninteractive

# ── FIX DEBCONF LOCKS & DPKG ZOMBIES ──
echo "[HW] Annihilating debconf locks and dpkg zombies..."
rm -f /var/cache/debconf/*.dat.lock /var/cache/debconf/*.dat-new /var/lib/dpkg/lock* /var/cache/apt/archives/lock
mkdir -p /var/cache/debconf
touch /var/cache/debconf/config.dat /var/cache/debconf/passwords.dat /var/cache/debconf/templates.dat
rm -f /var/lib/dpkg/info/postgresql-*
dpkg --remove --force-all postgresql-common postgresql-18 postgresql-client-18 postgresql 2>/dev/null || true
dpkg --configure -a || true
apt-get clean

# ─────────────────────────────────────────────────────
# 1. INPUT DEVICES — EVERY KEYBOARD, MOUSE, TOUCHPAD, TABLET
# ─────────────────────────────────────────────────────
echo "[HW] Installing universal input device support..."
apt-get install -y --fix-broken -y --no-install-recommends \
    xserver-xorg-input-all \
    xserver-xorg-input-evdev \
    xserver-xorg-input-libinput \
    xserver-xorg-input-synaptics \
    xserver-xorg-input-wacom \
    xserver-xorg-input-kbd \
    xserver-xorg-input-mouse \
    xserver-xorg-input-aiptek \
    xserver-xorg-input-elographics \
    xserver-xorg-input-joystick \
    xserver-xorg-input-mutouch \
    xserver-xorg-input-multitouch \
    xinput \
    xdotool \
    xbindkeys \
    evtest \
    input-utils \
    joystick \
    2>/dev/null || true

# libinput is the modern default — synaptics is fallback for ancient hardware
# Both installed so EITHER works depending on the laptop generation

echo "[HW] Input devices: DONE"

# ─────────────────────────────────────────────────────
# 2. USB / HID — Raw device support for everything USB
# ─────────────────────────────────────────────────────
echo "[HW] Installing USB/HID stack..."
apt-get install -y --fix-broken -y --no-install-recommends \
    usbutils \
    usb-modeswitch \
    usb-modeswitch-data \
    usbmuxd \
    libusb-1.0-0 \
    libhidapi-hidraw0 \
    libhidapi-libusb0 \
    2>/dev/null || true

# Ensure all HID kernel modules load at boot
cat > /etc/modules-load.d/alfred-hid.conf << 'HIDMOD'
# Alfred Linux — Universal HID input support
hid-generic
hid-multitouch
hid-microsoft
hid-apple
hid-logitech
hid-logitech-dj
hid-logitech-hidpp
hid-lenovo
hid-cherry
hid-corsair
hid-razer
hid-steelseries
hid-hyperx
hid-sony
hid-nintendo
hid-roccat
hid-kensington
hid-belkin
hid-keytouch
hid-alps
hid-elecom
hid-holtek
hid-sunplus
hid-chicony
hid-uclogic
usbhid
HIDMOD

echo "[HW] USB/HID: DONE"

# ─────────────────────────────────────────────────────
# 3. PS/2 + Serial — Ancient keyboards and mice
# ─────────────────────────────────────────────────────
echo "[HW] Ensuring PS/2 and serial input support..."
cat >> /etc/modules-load.d/alfred-hid.conf << 'PS2MOD'
# PS/2 and serial — for ancient laptops/desktops
atkbd
psmouse
i8042
serio_raw
sermouse
PS2MOD

# Force psmouse protocol detection to auto (handles TrackPoint, ALPS, Synaptics, Elantech)
cat > /etc/modprobe.d/alfred-trackpad.conf << 'TRACKPAD'
# Alfred Linux — Maximum trackpad compatibility
# Forces auto-detection for all PS/2 pointing devices
# Covers: Synaptics, ALPS, Elantech, TrackPoint, BYD, Sentelic, FocalTech, Cypress
options psmouse proto=auto
options psmouse resolution=200
options psmouse smartscroll=1

# Elantech touchpad quirks (common on ASUS/Acer/Lenovo)
options psmouse elantech_smbus=0

# TrackPoint (ThinkPad) — enable scroll with middle button + TrackPoint
options psmouse tp_scroll=1
TRACKPAD

echo "[HW] PS/2 + Serial: DONE"

# ─────────────────────────────────────────────────────
# 4. BLUETOOTH INPUT — Keyboards, mice, gamepads
# ─────────────────────────────────────────────────────
echo "[HW] Installing Bluetooth stack..."
apt-get install -y --fix-broken -y --no-install-recommends \
    bluetooth \
    bluez \
    bluez-firmware \
    bluez-tools \
    pulseaudio-module-bluetooth \
    2>/dev/null || true

# Enable bluetooth service
systemctl enable bluetooth || true || true.service 2>/dev/null || true

echo "[HW] Bluetooth: DONE"

# ─────────────────────────────────────────────────────
# 5. GPU / VIDEO — Every possible display driver
# ─────────────────────────────────────────────────────
echo "[HW] Installing GPU/video drivers..."
apt-get install -y --fix-broken -y --no-install-recommends \
    xserver-xorg-video-all \
    xserver-xorg-video-fbdev \
    xserver-xorg-video-vesa \
    xserver-xorg-video-intel \
    xserver-xorg-video-amdgpu \
    xserver-xorg-video-ati \
    xserver-xorg-video-radeon \
    xserver-xorg-video-nouveau \
    xserver-xorg-video-vmware \
    xserver-xorg-video-qxl \
    xserver-xorg-video-cirrus \
    xserver-xorg-video-mach64 \
    xserver-xorg-video-mga \
    xserver-xorg-video-r128 \
    xserver-xorg-video-savage \
    xserver-xorg-video-siliconmotion \
    xserver-xorg-video-sis \
    xserver-xorg-video-sisusb \
    xserver-xorg-video-tdfx \
    xserver-xorg-video-trident \
    xserver-xorg-video-openchrome \
    mesa-utils \
    mesa-vulkan-drivers \
    libgl1-mesa-dri \
    libglx-mesa0 \
    vainfo \
    vdpauinfo \
    intel-media-va-driver \
    2>/dev/null || true

echo "[HW] GPU/Video: DONE"

# ─────────────────────────────────────────────────────
# 6. FIRMWARE — Every non-free firmware blob for WiFi, BT, GPU
# ─────────────────────────────────────────────────────
echo "[HW] Installing firmware blobs — ALL of them..."
apt-get install -y --fix-broken -y --no-install-recommends \
    firmware-linux \
    firmware-linux-free \
    firmware-linux-nonfree \
    firmware-misc-nonfree \
    firmware-realtek \
