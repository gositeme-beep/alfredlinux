# 3. HEBREW CALENDAR ENGINE (Python â€” proper computation)
# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
echo "[SABBATH-03] Installing Hebrew Calendar Engine..."

cat > /usr/share/alfred/sabbath/hebrew-calendar.py << 'HEBREWCAL'
#!/usr/bin/env python3
"""
Alfred Hebrew Calendar Engine â€” God's Time, Computed Faithfully.

"And God said, Let there be lights in the firmament of the heaven
 to divide the day from the night; and let them be for signs,
 and for seasons, and for days, and years." â€” Genesis 1:14

This implements the fixed Hebrew calendar (Hillel II, 359 CE) which
Israel has used since the Sanhedrin set it. It computes:
- Hebrew date from Gregorian date
- Sunset times by latitude/longitude
- Feast day detection
- Torah portion for the week
- New Moon (Rosh Chodesh) tracking
- Day begins at sunset (erev), not midnight

No internet needed. Runs fully offline.
"""

import sys, math, json
from datetime import datetime, date, timedelta

# â”€â”€â”€â”€â”€ Hebrew Month Data â”€â”€â”€â”€â”€
HEBREW_MONTHS = [
    ("Nisan", 30), ("Iyyar", 29), ("Sivan", 30), ("Tammuz", 29),
    ("Av", 30), ("Elul", 29), ("Tishrei", 30), ("Cheshvan", 29),
    ("Kislev", 30), ("Tevet", 29), ("Shevat", 30), ("Adar", 29)
]
HEBREW_MONTHS_LEAP = [
    ("Nisan", 30), ("Iyyar", 29), ("Sivan", 30), ("Tammuz", 29),
    ("Av", 30), ("Elul", 29), ("Tishrei", 30), ("Cheshvan", 29),
    ("Kislev", 30), ("Tevet", 29), ("Shevat", 30), ("Adar I", 30), ("Adar II", 29)
]

# Hebrew days of week
HEBREW_DAYS = ["Yom Rishon", "Yom Sheni", "Yom Shlishi", "Yom Revi'i",
               "Yom Chamishi", "Yom Shishi", "Yom Shabbat"]

def is_hebrew_leap(year):
    """Hebrew leap year: years 3,6,8,11,14,17,19 of 19-year Metonic cycle."""
    return (7 * year + 1) % 19 < 7

def hebrew_year_days(year):
    """Total days in a Hebrew year."""
    return hebrew_delay(year + 1) - hebrew_delay(year)

def hebrew_delay(year):
    """Days from epoch (molad of Tishrei year 1) to Tishrei 1 of given year.
    Uses the four postponement rules (dehiyot)."""
    months_elapsed = (235 * ((year - 1) // 19) +
                      12 * ((year - 1) % 19) +
                      (7 * ((year - 1) % 19) + 1) // 19)
    parts_elapsed = 204 + 793 * (months_elapsed % 1080)
    hours_elapsed = (5 + 12 * months_elapsed +
                     793 * (months_elapsed // 1080) +
                     parts_elapsed // 1080)
    parts = (parts_elapsed % 1080) + 1080 * (hours_elapsed % 24)
    day = 1 + 29 * months_elapsed + hours_elapsed // 24

    # Dehiyot (postponement rules)
    if (parts >= 19440 or
        (2 == day % 7 and parts >= 9924 and not is_hebrew_leap(year)) or
        (1 == day % 7 and parts >= 16789 and is_hebrew_leap(year - 1))):
        day += 1
    if day % 7 in (0, 3, 5):
        day += 1
    return day

def hebrew_month_days(year, month_idx):
    """Days in a specific Hebrew month (0-indexed from Tishrei)."""
    year_length = hebrew_year_days(year)
    leap = is_hebrew_leap(year)
    # Standard month lengths from Tishrei
    month_lengths = [30]  # Tishrei always 30
    # Cheshvan: 29 normally, 30 in "complete" years
    if year_length in (355, 385):
        month_lengths.append(30)
    else:
        month_lengths.append(29)
    # Kislev: 30 normally, 29 in "deficient" years
    if year_length in (353, 383):
        month_lengths.append(29)
    else:
        month_lengths.append(30)
    month_lengths.extend([29, 30, 29])  # Tevet, Shevat, Adar/Adar I
    if leap:
        month_lengths.extend([30, 29])  # Adar I 30, Adar II 29
    else:
        pass  # Adar already added as 29
    month_lengths.extend([30, 29, 30, 29, 30, 29])  # Nisan through Elul
    if month_idx < len(month_lengths):
        return month_lengths[month_idx]
    return 30

HEBREW_EPOCH = 347995  # Julian day of Hebrew epoch

def gregorian_to_jd(year, month, day):
    """Convert Gregorian date to Julian Day Number."""
    if month <= 2:
        year -= 1
        month += 12
    A = year // 100
    B = 2 - A + A // 4
    return int(365.25 * (year + 4716)) + int(30.6001 * (month + 1)) + day + B - 1524.5

def gregorian_to_hebrew(gyear, gmonth, gday):
    """Convert Gregorian date to Hebrew date."""
    jd = gregorian_to_jd(gyear, gmonth, gday)
    # Approximate Hebrew year
    hyear = gyear + 3761
    # Adjust â€” Hebrew new year (Tishrei) falls in Sept/Oct
    jd_tishrei = hebrew_delay(hyear) + HEBREW_EPOCH
    if jd < jd_tishrei:
        hyear -= 1
        jd_tishrei = hebrew_delay(hyear) + HEBREW_EPOCH
    # Next year's Tishrei for validation
    jd_next = hebrew_delay(hyear + 1) + HEBREW_EPOCH
    if jd >= jd_next:
        hyear += 1
        jd_tishrei = jd_next

    day_of_year = int(jd - jd_tishrei)
    leap = is_hebrew_leap(hyear)
    year_len = hebrew_year_days(hyear)

    # Walk through months from Tishrei
    month_names_tishrei = ["Tishrei", "Cheshvan", "Kislev", "Tevet", "Shevat"]
    if leap:
        month_names_tishrei.extend(["Adar I", "Adar II"])
    else:
        month_names_tishrei.append("Adar")
    month_names_tishrei.extend(["Nisan", "Iyyar", "Sivan", "Tammuz", "Av", "Elul"])

    remaining = day_of_year
    for i, mname in enumerate(month_names_tishrei):
        mdays = hebrew_month_days(hyear, i)
        if remaining < mdays:
            return hyear, mname, remaining + 1
        remaining -= mdays
    return hyear, month_names_tishrei[-1], 1

def sunset_time(lat, lon, dt):
    """Calculate sunset time for given coordinates and date.
    Returns (hour, minute) in local solar time.
    Uses simplified astronomical calculation â€” no internet needed."""
    day_of_year = dt.timetuple().tm_yday
    # Solar declination
    B = math.radians((360.0 / 365.0) * (day_of_year - 81))
    decl = math.radians(23.45) * math.sin(B)
    # Hour angle at sunset
    lat_rad = math.radians(lat)
    cos_ha = -math.tan(lat_rad) * math.tan(decl)
    cos_ha = max(-1, min(1, cos_ha))  # Clamp for polar regions
    ha = math.degrees(math.acos(cos_ha))
    # Solar noon offset (approximate equation of time)
    eot = 9.87 * math.sin(2 * B) - 7.53 * math.cos(B) - 1.5 * math.sin(B)
    solar_noon = 12.0 - lon / 15.0 + eot / 60.0
    # Sunset
    sunset_decimal = solar_noon + ha / 15.0
    # Adjust to local timezone offset (rough: lon/15)
    tz_offset = round(lon / 15.0)
    sunset_local = sunset_decimal + tz_offset
    hours = int(sunset_local) % 24
    minutes = int((sunset_local - int(sunset_local)) * 60)
    return hours, minutes

def detect_feast(hmonth, hday):
    """Detect if today is a Biblical feast day."""
    feasts = {
        ("Nisan", 14): ("Passover (Pesach)", "Exodus 12:14", "The Lord's Passover â€” remember the blood of the Lamb"),
        ("Nisan", 15): ("Unleavened Bread begins", "Leviticus 23:6", "Seven days of eating unleavened bread"),
        ("Nisan", 16): ("Firstfruits", "Leviticus 23:10", "The first of the harvest belongs to God"),
        ("Nisan", 21): ("Unleavened Bread ends", "Leviticus 23:8", "Holy convocation â€” the seventh day"),
        ("Sivan", 6): ("Pentecost (Shavuot)", "Leviticus 23:15-16", "The giving of Torah and the Holy Spirit"),
        ("Tishrei", 1): ("Feast of Trumpets (Yom Teruah)", "Leviticus 23:24", "A day of blowing trumpets â€” awake!"),
        ("Tishrei", 2): ("Feast of Trumpets Day 2", "Leviticus 23:24", "The long day â€” the day no man knows"),
        ("Tishrei", 10): ("Day of Atonement (Yom Kippur)", "Leviticus 23:27", "Afflict your souls â€” the most holy day"),
        ("Tishrei", 15): ("Tabernacles begins (Sukkot)", "Leviticus 23:34", "Dwell in booths â€” God tabernacles with man"),
        ("Tishrei", 22): ("Shemini Atzeret", "Leviticus 23:36", "The eighth day assembly â€” rejoicing in Torah"),
        ("Kislev", 25): ("Hanukkah begins", "John 10:22", "The dedication â€” Jesus walked in Solomon's porch"),
        ("Adar", 14): ("Purim", "Esther 9:21", "For such a time as this â€” Esther's deliverance"),
    }
    # Check exact date
    feast = feasts.get((hmonth, hday))
    if feast:
        return feast
    # Check multi-day ranges
    if hmonth == "Nisan" and 15 <= hday <= 21:
        return ("Chol HaMoed Pesach", "Leviticus 23:6-8", "Intermediate days of Unleavened Bread")
    if hmonth == "Tishrei" and 15 <= hday <= 21:
        return ("Chol HaMoed Sukkot", "Leviticus 23:34-36", "Intermediate days of Tabernacles")
    if hmonth == "Kislev" and 25 <= hday <= 30:
        return ("Hanukkah", "John 10:22-23", f"Hanukkah Day {hday - 24}")
    if hmonth == "Tevet" and 1 <= hday <= 2:
        return ("Hanukkah", "John 10:22-23", f"Hanukkah Day {hday + 5}")
    return None

def next_feast(hmonth, hday, hyear):
    """Find the next upcoming feast."""
    feast_dates = [
        ("Nisan", 14, "Passover"), ("Nisan", 16, "Firstfruits"),
        ("Sivan", 6, "Shavuot"), ("Tishrei", 1, "Yom Teruah"),
        ("Tishrei", 10, "Yom Kippur"), ("Tishrei", 15, "Sukkot"),
        ("Kislev", 25, "Hanukkah"), ("Adar", 14, "Purim"),
    ]
    month_order = ["Tishrei", "Cheshvan", "Kislev", "Tevet", "Shevat",
                   "Adar", "Adar I", "Adar II", "Nisan", "Iyyar",
                   "Sivan", "Tammuz", "Av", "Elul"]
    cur_idx = month_order.index(hmonth) if hmonth in month_order else 0
    best = None
    for fm, fd, fn in feast_dates:
        fi = month_order.index(fm) if fm in month_order else 0
        if fi > cur_idx or (fi == cur_idx and fd > hday):
            if best is None or fi < best[0] or (fi == best[0] and fd < best[1]):
                best = (fi, fd, fn, fm)
    if best:
        return f"{best[3]} {best[1]} â€” {best[2]}"
    return f"Nisan 14 â€” Passover (next year)"

def get_torah_portion(gyear, gmonth, gday):
    """Get this week's Torah portion based on the Shabbat cycle.
    Simchat Torah resets the cycle on Tishrei 23."""
    import os
    conf = "/usr/share/alfred/sabbath/torah-portions.conf"
    if not os.path.exists(conf):
        return None
    portions = []
    with open(conf) as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith('#'):
                continue
            parts = line.split('|')
            if len(parts) >= 5:
                portions.append(parts)
    if not portions:
        return None
    # Calculate week since Simchat Torah (Tishrei 23 of current Hebrew year)
    # Approximate: use Gregorian week offset from October
    d = date(gyear, gmonth, gday)
    # Find last October (approximate Simchat Torah)
    if gmonth >= 10:
        simchat = date(gyear, 10, 10)
    else:
        simchat = date(gyear - 1, 10, 10)
    weeks_since = (d - simchat).days // 7
    idx = weeks_since % len(portions)
    return portions[idx]

def main():
    now = datetime.now()
    today = now.date()
    gyear, gmonth, gday = today.year, today.month, today.day
    hyear, hmonth, hday = gregorian_to_hebrew(gyear, gmonth, gday)

    # Day of week (0=Monday in Python, but Hebrew week starts Sunday)
    dow_py = today.weekday()  # 0=Mon ... 6=Sun
    hebrew_dow = (dow_py + 1) % 7  # 0=Sun ... 6=Sat
    hebrew_day_name = HEBREW_DAYS[hebrew_dow]

    # Default latitude: Ottawa, Canada (45.42N, 75.70W)
    # User can override via ~/.config/alfred/location.conf
    lat, lon, city = 45.42, -75.70, "Ottawa"
    import os
    loc_file = os.path.expanduser("~/.config/alfred/location.conf")
    if os.path.exists(loc_file):
        with open(loc_file) as f:
            for line in f:
                if line.startswith("lat="):
                    lat = float(line.split("=")[1].strip())
                elif line.startswith("lon="):
                    lon = float(line.split("=")[1].strip())
                elif line.startswith("city="):
                    city = line.split("=")[1].strip()

    sh, sm = sunset_time(lat, lon, today)
    sunset_str = f"{sh:02d}:{sm:02d}"
    after_sunset = now.hour > sh or (now.hour == sh and now.minute >= sm)

    # If after sunset, advance Hebrew date by 1 day (day begins at sunset)
    if after_sunset:
        tomorrow = today + timedelta(days=1)
        hyear, hmonth, hday = gregorian_to_hebrew(tomorrow.year, tomorrow.month, tomorrow.day)
        hebrew_dow = (hebrew_dow + 1) % 7
        hebrew_day_name = HEBREW_DAYS[hebrew_dow]

    feast = detect_feast(hmonth, hday)
    nxt = next_feast(hmonth, hday, hyear)
    portion = get_torah_portion(gyear, gmonth, gday)

    cmd = sys.argv[1] if len(sys.argv) > 1 else "status"

    if cmd == "json":
        data = {
            "hebrew_date": f"{hday} {hmonth} {hyear}",
            "hebrew_day": hebrew_day_name,
            "gregorian": today.isoformat(),
            "sunset": sunset_str,
            "after_sunset": after_sunset,
            "is_shabbat": hebrew_dow == 6,
            "is_feast": feast is not None,
            "feast": {"name": feast[0], "ref": feast[1], "desc": feast[2]} if feast else None,
            "next_feast": nxt,
            "city": city,
            "torah_portion": portion[1] if portion else None,
        }
        print(json.dumps(data, indent=2))
    elif cmd == "oneliner":
        parts = [f"{hday} {hmonth} {hyear}"]
        parts.append(f"({hebrew_day_name})")
        if feast:
            parts.append(f"â€” {feast[0]}")
        parts.append(f"| Sunset: {sunset_str}")
        print(" ".join(parts))
    else:
        # Full display
        is_shabbat = hebrew_dow == 6
        print(f"  Hebrew Date:  {hday} {hmonth} {hyear}")
        print(f"  Day:          {hebrew_day_name}" + (" â€” SHABBAT" if is_shabbat else ""))
        print(f"  Gregorian:    {today.strftime('%A, %B %d, %Y')}")
        print(f"  Sunset:       {sunset_str} ({city})" + (" â† day has turned" if after_sunset else ""))
        if feast:
            print(f"  TODAY:        {feast[0]} â€” {feast[1]}")
            print(f"                {feast[2]}")
        print(f"  Next Feast:   {nxt}")
        if portion:
            print(f"  Torah:        Parashat {portion[1]} â€” {portion[4]}")
            print(f"                {portion[2]} | Haftarah: {portion[3]}")

if __name__ == "__main__":
    main()
HEBREWCAL

chmod +x /usr/share/alfred/sabbath/hebrew-calendar.py || true

cat > /usr/local/bin/alfred-sabbath << 'SABBATH'
# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
# alfred-sabbath â€” Biblical Calendar & Sabbath Mode
#
# "Remember the sabbath day, to keep it holy. Six days shalt thou
#  labour, and do all thy work: But the seventh day is the sabbath
#  of the LORD thy God." â€” Exodus 20:8-10
# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•

GOLD='\033[38;5;220m'; GREEN='\033[0;32m'; CYAN='\033[0;36m'
RED='\033[0;31m'; BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'

SABBATH_DIR="/usr/share/alfred/sabbath"
SABBATH_STATE="$HOME/.config/alfred/sabbath-mode"
SABBATH_LOG="$HOME/.alfred/sabbath-log"

get_day_of_week() {
    date +%u  # 1=Monday, 5=Friday, 6=Saturday, 7=Sunday
}

get_sunset_approx() {
    # Approximate sunset time by month (for notification purposes)
    MONTH=$(date +%m)
    case $MONTH in
        01|02|11|12) echo "17:00" ;;
        03|04|09|10) echo "18:30" ;;
        05|06|07|08) echo "20:00" ;;
    esac
}

case "${1:-status}" in
    status)
        echo -e "${GOLD}â•â•â• Sabbath & Biblical Calendar â•â•â•${NC}"
        echo ""

        # Use Hebrew Calendar Engine for full status
        if [ -x /usr/share/alfred/sabbath/hebrew-calendar.py ]; then
            python3 /usr/share/alfred/sabbath/hebrew-calendar.py status || true
        else
            # Fallback if Python engine not available
            DOW=$(get_day_of_week)
            SUNSET=$(get_sunset_approx)
            case $DOW in
                5) echo -e "  Today: ${GOLD}FRIDAY${NC} â€” Sabbath preparation day"
                   echo -e "  Sunset (approx): ${CYAN}$SUNSET${NC} â€” Sabbath begins" ;;
                6) echo -e "  Today: ${GOLD}SHABBAT${NC} â€” The day of rest" ;;
                7) echo -e "  Today: ${CYAN}Sunday${NC} â€” The Lord rose. Begin with worship." ;;
                *) DAYS_TO_SABBATH=$((5 - DOW))
                   [ "$DAYS_TO_SABBATH" -le 0 ] && DAYS_TO_SABBATH=$((DAYS_TO_SABBATH + 7))
                   echo -e "  Days until Sabbath: ${CYAN}$DAYS_TO_SABBATH${NC}" ;;
            esac
        fi
        echo ""

        # Sabbath mode status
        if [ -f "$SABBATH_STATE" ]; then
            echo -e "  Sabbath mode: ${GREEN}ACTIVE${NC} â€” only Bible & worship available"
        else
            echo -e "  Sabbath mode: ${CYAN}inactive${NC}"
        fi
        echo ""

        # Quick commands
        echo "  alfred-sabbath enter    â€” Enter Sabbath mode"
        echo "  alfred-sabbath exit     â€” Exit Sabbath mode"
        echo "  alfred-sabbath feasts   â€” Show Biblical feasts"
        echo "  alfred-sabbath torah    â€” This week's Torah portion"
        echo "  alfred-sabbath prep     â€” Friday preparation checklist"
        echo "  alfred-sabbath json     â€” Machine-readable Hebrew date (JSON)"
        echo ""
        ;;

    enter)
        mkdir -p "$(dirname "$SABBATH_STATE")" || true
        echo "$(date -Is)" > "$SABBATH_STATE" || true

        echo -e "${GOLD}"
        echo "  â•”â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•—"
        echo "  â•‘                                                   â•‘"
        echo "  â•‘          âœ  SHABBAT SHALOM  âœ                    â•‘"
        echo "  â•‘                                                   â•‘"
        echo "  â•‘  \"Come unto me, all ye that labour and are        â•‘"
        echo "  â•‘   heavy laden, and I will give you rest.\"         â•‘"
        echo "  â•‘                           â€” Matthew 11:28         â•‘"
        echo "  â•‘                                                   â•‘"
        echo "  â•‘  Sabbath mode is now ACTIVE.                      â•‘"
        echo "  â•‘  Only Bible and worship commands are available.    â•‘"
        echo "  â•‘  Your work can wait. God cannot.                  â•‘"
        echo "  â•‘                                                   â•‘"
        echo "  â•šâ•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•"
        echo -e "${NC}"

        # Log entry
        mkdir -p "$SABBATH_LOG" || true
        echo "ENTER $(date -Is)" >> "$SABBATH_LOG/sabbath-history.log" || true
        ;;

    exit)
        rm -f "$SABBATH_STATE" || true
        echo -e "${GOLD}Sabbath mode ended.${NC}"
        echo ""
        echo "  Havdalah â€” separation of the holy from the ordinary."
        echo "  May the coming week be blessed."
        echo ""
        echo -e "  ${DIM}\"The LORD bless thee, and keep thee.\" â€” Numbers 6:24${NC}"

        mkdir -p "$SABBATH_LOG" || true
        echo "EXIT $(date -Is)" >> "$SABBATH_LOG/sabbath-history.log" || true
        ;;

    feasts)
        echo -e "${GOLD}â•â•â• Biblical Feasts â€” The Appointed Times of the LORD â•â•â•${NC}"
        echo -e "${DIM}\"These are the feasts of the LORD, even holy convocations.\" â€” Lev 23:2${NC}"
        echo ""
        while IFS='|' read -r month day dur name scripture desc; do
            [[ "$month" =~ ^# ]] && continue
            echo -e "  ${GOLD}$name${NC}"
            echo -e "    $month $day ($dur day(s)) â€” ${CYAN}$scripture${NC}"
            echo -e "    ${DIM}$desc${NC}"
            echo ""
        done < "$SABBATH_DIR/feasts.conf"
        ;;

    torah)
        echo -e "${GOLD}â•â•â• This Week's Torah Portion â•â•â•${NC}"
        echo ""

        # Use Hebrew Calendar Engine for proper Torah portion tracking
        if [ -x /usr/share/alfred/sabbath/hebrew-calendar.py ]; then
            PORTION_JSON=$(python3 /usr/share/alfred/sabbath/hebrew-calendar.py json 2>/dev/null)
            PORTION_NAME=$(echo "$PORTION_JSON" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('torah_portion',''))" 2>/dev/null)
            if [ -n "$PORTION_NAME" ] && [ "$PORTION_NAME" != "None" ]; then
                LINE=$(grep "|${PORTION_NAME}|" "$SABBATH_DIR/torah-portions.conf" 2>/dev/null | head -1)
                if [ -n "$LINE" ]; then
                    IFS='|' read -r week name torah haftarah desc <<< "$LINE"
                    echo -e "  ${BOLD}Parashat $name${NC} â€” $desc"
                    echo -e "  Torah: ${CYAN}$torah${NC}"
                    echo -e "  Haftarah: ${CYAN}$haftarah${NC}"
                    echo ""
                    _tb=$(echo "$torah" | cut -d' ' -f1)
                    _tc=""
                    [[ "$torah" =~ ([0-9]+) ]] && _tc="${BASH_REMATCH[1]}"
                    echo -e "  ${DIM}Read with: alfred-bible read ${_tb} ${_tc:-1}${NC}"
                else
                    echo "  This week: Parashat $PORTION_NAME"
                fi
            else
                echo "  Torah portion calculation unavailable."
            fi
        else
            # Fallback: cycle through all 54 portions by week number
            WEEK_NUM=$(date +%U)
            PORTION_IDX=$(( (WEEK_NUM % 54) + 1 ))
            LINE=$(grep "^${PORTION_IDX}|" "$SABBATH_DIR/torah-portions.conf" 2>/dev/null)
            if [ -n "$LINE" ]; then
                IFS='|' read -r week name torah haftarah desc <<< "$LINE"
                echo -e "  ${BOLD}Parashat $name${NC} â€” $desc"
                echo -e "  Torah: ${CYAN}$torah${NC}"
                echo -e "  Haftarah: ${CYAN}$haftarah${NC}"
            else
                echo "  Torah portion data not available for this week."
            fi
        fi
        echo ""
        ;;

    prep)
        echo -e "${GOLD}â•â•â• Friday Preparation â€” Getting Ready for Sabbath â•â•â•${NC}"
        echo ""
        echo "  Before sunset on Friday:"
        echo ""
        echo -e "  ${CYAN}â–¡${NC} Finish your work for the week"
        echo -e "  ${CYAN}â–¡${NC} Save and close all projects"
        echo -e "  ${CYAN}â–¡${NC} Prepare Scripture for Sabbath reading"
        echo -e "  ${CYAN}â–¡${NC} Set worship music ready"
        echo -e "  ${CYAN}â–¡${NC} Clean your workspace (physical and digital)"
        echo -e "  ${CYAN}â–¡${NC} Light candles (physical, not digital)"
        echo -e "  ${CYAN}â–¡${NC} Enter Sabbath mode: ${BOLD}alfred-sabbath enter${NC}"
        echo ""
        echo -e "  ${DIM}\"And on the seventh day God ended his work which he had made;${NC}"
        echo -e "  ${DIM} and he rested on the seventh day.\" â€” Genesis 2:2${NC}"
        echo ""
        ;;

    json)
        # Machine-readable Hebrew date for other tools
        if [ -x /usr/share/alfred/sabbath/hebrew-calendar.py ]; then
            python3 /usr/share/alfred/sabbath/hebrew-calendar.py json || true
        else
            echo '{"error": "Hebrew calendar engine not installed"}'
        fi
        ;;

    help|*)
        echo -e "${GOLD}â•â•â• alfred-sabbath â€” The Lord's Calendar â•â•â•${NC}"
        echo ""
        echo "  alfred-sabbath status   â€” Show Sabbath status (Hebrew date primary)"
        echo "  alfred-sabbath enter    â€” Enter Sabbath mode"
        echo "  alfred-sabbath exit     â€” Exit Sabbath mode (Havdalah)"
        echo "  alfred-sabbath feasts   â€” Biblical feasts calendar"
        echo "  alfred-sabbath torah    â€” This week's Torah portion (all 54)"
        echo "  alfred-sabbath prep     â€” Friday preparation checklist"
        echo "  alfred-sabbath json     â€” Machine-readable Hebrew date (JSON)"
        echo ""
        echo "  \"Remember the sabbath day, to keep it holy.\""
        echo "                                 â€” Exodus 20:8"
        ;;
esac
SABBATH
