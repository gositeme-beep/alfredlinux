# 1. BIBLICAL FEAST CALENDAR DATA
# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
echo "[SABBATH-01] Creating Biblical feast calendar..."

cat > /usr/share/alfred/sabbath/feasts.conf << 'FEASTS'
# Biblical Feasts â€” Based on Hebrew calendar
# Format: month_hebrew|day_start|duration_days|name|scripture|description
# Nisan = March/April, Tishrei = September/October
Nisan|14|1|Passover (Pesach)|Exodus 12:14|Remember the Lord's deliverance from Egypt
Nisan|15|7|Unleavened Bread|Leviticus 23:6|Seven days of eating unleavened bread
Nisan|16|1|Firstfruits|Leviticus 23:10|The first of the harvest belongs to God
Sivan|6|2|Pentecost (Shavuot)|Leviticus 23:15-16|Fifty days after Firstfruits â€” the giving of Torah
Tishrei|1|2|Feast of Trumpets (Rosh Hashanah)|Leviticus 23:24|A day of blowing trumpets â€” wake up!
Tishrei|10|1|Day of Atonement (Yom Kippur)|Leviticus 23:27|The most holy day â€” afflict your souls
Tishrei|15|7|Feast of Tabernacles (Sukkot)|Leviticus 23:34|Dwell in booths â€” remember the wilderness
Tishrei|22|1|Shemini Atzeret / Simchat Torah|Leviticus 23:36|The eighth day â€” rejoicing in Torah
Kislev|25|8|Hanukkah (Dedication)|John 10:22|Jesus walked in Solomon's porch â€” the temple rededicated
Adar|14|1|Purim|Esther 9:21|Remember Esther's deliverance â€” for such a time as this
FEASTS

