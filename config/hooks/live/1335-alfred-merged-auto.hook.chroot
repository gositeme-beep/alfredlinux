# 3) The PyQt5 Welcome Center
cat > /usr/local/bin/alfred-welcome-app.py << 'EOF'
#!/usr/bin/env python3
import sys
import os
import subprocess
from PyQt5.QtWidgets import QApplication, QWidget, QVBoxLayout, QPushButton, QLabel
from PyQt5.QtGui import QPixmap, QFont, QIcon
from PyQt5.QtCore import Qt

class AlfredWelcome(QWidget):
    def __init__(self):
        super().__init__()
        self.initUI()

    def initUI(self):
        self.setWindowTitle('Welcome to Alfred Linux - Kingdom of God Edition')
        self.setFixedSize(600, 500)
        self.setStyleSheet("background-color: #0f1e33; color: #f5e6b3;")

        layout = QVBoxLayout()
        layout.setAlignment(Qt.AlignCenter)

        # Image
        img_label = QLabel(self)
        pixmap = QPixmap('/usr/share/alfred/welcome/al-2.png')
        if not pixmap.isNull():
            pixmap = pixmap.scaled(400, 200, Qt.KeepAspectRatio, Qt.SmoothTransformation)
            img_label.setPixmap(pixmap)
            img_label.setAlignment(Qt.AlignCenter)
        layout.addWidget(img_label)

        # Title
        title = QLabel("Kingdom of God Edition")
        title.setFont(QFont("Georgia", 24, QFont.Bold))
        title.setAlignment(Qt.AlignCenter)
        layout.addWidget(title)

        subtitle = QLabel("Sovereign Computing. No Tracking. Pure Worship.")
        subtitle.setFont(QFont("Georgia", 12))
        subtitle.setAlignment(Qt.AlignCenter)
        layout.addWidget(subtitle)
        
        layout.addSpacing(20)

        # Buttons
        btn_bible = QPushButton("📖 Launch Alfred Bible")
        btn_bible.setStyleSheet("background-color: #142845; border: 1px solid #d4af37; padding: 10px; font-size: 14px;")
        btn_bible.clicked.connect(lambda: subprocess.Popen(['alfred-bible']))
        layout.addWidget(btn_bible)

        btn_drivers = QPushButton("⚙️ Install System Drivers (NVIDIA/Wi-Fi)")
        btn_drivers.setStyleSheet("background-color: #142845; border: 1px solid #d4af37; padding: 10px; font-size: 14px;")
        btn_drivers.clicked.connect(lambda: subprocess.Popen(['pkexec', 'software-properties-gtk']))
        layout.addWidget(btn_drivers)

        btn_snapshot = QPushButton("🔄 Setup System Rollback (Timeshift)")
        btn_snapshot.setStyleSheet("background-color: #142845; border: 1px solid #d4af37; padding: 10px; font-size: 14px;")
        btn_snapshot.clicked.connect(lambda: subprocess.Popen(['pkexec', 'timeshift-launcher']))
        layout.addWidget(btn_snapshot)

        self.setLayout(layout)

if __name__ == '__main__':
    app = QApplication(sys.argv)
    ex = AlfredWelcome()
    ex.show()
    sys.exit(app.exec_())
EOF
chmod 0755 /usr/local/bin/alfred-welcome-app.py || true

# 4) First boot runner
cat > /usr/local/bin/alfred-first-boot.sh << 'EOF'
STAMP_FILE="/var/lib/alfred/welcome.done"
if [[ -f "$STAMP_FILE" ]]; then
fi
/usr/local/bin/alfred-set-wallpaper.sh || true
/usr/local/bin/alfred-welcome-app.py &
if command -v paplay &>/dev/null && [ -f /usr/share/sounds/freedesktop/stereo/complete.oga ]; then
  paplay /usr/share/sounds/freedesktop/stereo/complete.oga 2>/dev/null &
fi
touch "$STAMP_FILE"
EOF
chmod 0755 /usr/local/bin/alfred-first-boot.sh || true

cat > /etc/xdg/autostart/alfred-first-boot.desktop << 'EOF'
[Desktop Entry]
Type=Application
Name=Alfred First Boot
Comment=Kingdom of God Edition - first-boot blessing
Exec=/usr/local/bin/alfred-first-boot.sh
Terminal=false
X-GNOME-Autostart-enabled=true
OnlyShowIn=KDE;GNOME;LXQt;
EOF
chmod 0644 /etc/xdg/autostart/alfred-first-boot.desktop || true

echo "[0700] Kingdom Welcome COMPLETE"


) || true

# ==========================================
# RESTORED HOOK: 0543-alfred-stranger.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0543-alfred-stranger.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
# ═══════════════════════════════════════════════════════════════════════════════
# HOOK 0701: The Stranger — Hospitality for All Who Enter
#
# "I was a stranger, and ye took me in." — Matthew 25:35
#
# Updates the first-boot experience to gently welcome those who may not
# share our faith. God is NOT hidden. But the door is open to everyone.
# The Kingdom doesn't chase people away — it leaves the door open.
#
# BUILD: v7.77 Kingdom of God Edition
# ═══════════════════════════════════════════════════════════════════════════════

chmod 1777 /tmp 2>/dev/null || true

echo "╔═══════════════════════════════════════════════════════════╗"
echo "║  [0701] The Stranger — Hospitality for All               ║"
echo "║  'I was a stranger, and ye took me in.' — Matt 25:35     ║"
echo "╚═══════════════════════════════════════════════════════════╝"

# ═══════════════════════════════════════════════════
# 1. WELCOME NOTE FOR ALL USERS
# ═══════════════════════════════════════════════════
echo "[STRANGER-01] Creating universal welcome..."

mkdir -p /etc/skel/Desktop || true
cat > /etc/skel/Desktop/Welcome.txt << 'WELCOME'
═══════════════════════════════════════════════════════════════
  Welcome to Alfred Linux 7.77 — Kingdom of God Edition
═══════════════════════════════════════════════════════════════

  This operating system was built in faith,
  but it was built for everyone.

  The Bible, the music, and the tools are here if you
  want them. If you don't, they'll wait quietly.
  Nothing is forced. Everything is offered.

  You are welcome here.

  ── What's Inside ──

  📖  39,482 Bible verses (type: alfred-bible)
  ♪   27 worship tracks (type: alfred-worship)
  🔐  Post-quantum encryption (Kyber-1024)
  🌐  Sovereign mesh network
  🛡️  Military-grade security hardening

  ── Your Privacy ──

  This OS collects NOTHING. No telemetry. No tracking.
  No data is sent anywhere. Your computer is yours.
  Your files are yours. Your thoughts are yours.

  ── Who Built This ──

  Commander Danny William Perez and his daughter Eden,
  with love, for the glory of God and the service of all.

  alfredlinux.com
═══════════════════════════════════════════════════════════════
WELCOME

# ═══════════════════════════════════════════════════
# 2. FIRST-BOOT GENTLE PATH
# ═══════════════════════════════════════════════════
echo "[STRANGER-02] Installing gentle first-boot choice..."

cat > /usr/local/bin/alfred-welcome-choice.sh << 'CHOICE'
# Runs AFTER the main first-boot blessing (0700)
# Offers the user a gentle choice about spiritual content

STAMP="/var/lib/alfred/welcome-choice.done"
[ -f "$STAMP" ] && exit 0

# Only run in GUI
[ -z "${DISPLAY:-}" ] && exit 0
command -v zenity &>/dev/null || exit 0

RESULT=$(zenity --list \
    --radiolist \
    --width=560 --height=350 2>/dev/null) || RESULT="Kingdom"

mkdir -p /etc/alfred || true
case "$RESULT" in
    "Kingdom")
        echo "kingdom" > /etc/alfred/experience || true
        ;;
    "Gentle")
        echo "gentle" > /etc/alfred/experience || true
        # Disable autostart reminders but keep everything installed
        rm -f ~/.config/autostart/kingdom-worship-reminder.desktop 2>/dev/null || true
        ;;
    "Sovereign")
        echo "sovereign" > /etc/alfred/experience || true
        # Disable autostart reminders and daily verse
        rm -f ~/.config/autostart/kingdom-worship-reminder.desktop 2>/dev/null || true
        # Create flag that profile.d script checks
        touch ~/.alfred-no-verse
        ;;
esac

touch "$STAMP"
CHOICE
chmod +x /usr/local/bin/alfred-welcome-choice.sh || true

cat > /etc/xdg/autostart/alfred-welcome-choice.desktop << 'AUTOSTART'
[Desktop Entry]
Type=Application
Name=Alfred Welcome Choice
Comment=Choose your Kingdom experience level
Exec=/usr/local/bin/alfred-welcome-choice.sh
Terminal=false
X-GNOME-Autostart-enabled=true
OnlyShowIn=KDE;GNOME;LXQt;
AUTOSTART

# ═══════════════════════════════════════════════════
# 3. MAKE DAILY VERSE RESPECT THE CHOICE
# ═══════════════════════════════════════════════════
echo "[STRANGER-03] Patching daily verse for experience level..."

cat > /etc/profile.d/alfred-experience-gate.sh << 'GATE'
# Alfred Linux — respect the user's experience choice
# If they chose "sovereign" and created ~/.alfred-no-verse,
# the daily verse script in alfred-daily-verse.sh will check this.
# This file just exports the experience level for other scripts.
if [ -f /etc/alfred/experience ]; then
    export ALFRED_EXPERIENCE=$(cat /etc/alfred/experience 2>/dev/null)
else
    export ALFRED_EXPERIENCE="kingdom"
fi
GATE

echo "╔═══════════════════════════════════════════════════════════╗"
echo "║  [0701] The Stranger — COMPLETE                          ║"
echo "║  ✓ Universal welcome note on Desktop                     ║"
echo "║  ✓ First-boot experience chooser (Kingdom/Gentle/Sov)   ║"
echo "║  ✓ Daily verse respects user choice                      ║"
echo "║  The door is open. The stranger is welcome.              ║"
echo "╚═══════════════════════════════════════════════════════════╝"


) || true

# ==========================================
# RESTORED HOOK: 0544-alfred-systemd-sandbox-100.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0544-alfred-systemd-sandbox-100.hook.chroot"
(
set +e
