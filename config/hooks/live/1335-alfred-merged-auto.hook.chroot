# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0322-alfred-gateway.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
# 0500-alfred-gateway.hook.chroot
# Alfred Gateway — sovereign multi-channel inbox daemon
# Crown of Alfred Linux 7.77.1.0.0

echo "I: [alfred] installing Alfred Gateway"

export DEBIAN_FRONTEND=noninteractive
apt-get update
apt-get install -y --no-install-recommends \
    curl ca-certificates git xz-utils build-essential python3 || true

# Node.js 24 (NodeSource)
if ! command -v node >/dev/null 2>&1 || [ "$(node -v | cut -d. -f1 | tr -d v)" -lt 22 ]; then
    rm -f /etc/apt/sources.list.d/nodesource* && rm -f /etc/apt/keyrings/nodesource*
    mkdir -p /etc/apt/keyrings
    curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key | gpg --dearmor --yes -o /etc/apt/keyrings/nodesource.gpg
    echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_24.x nodistro main" > /etc/apt/sources.list.d/nodesource.list
    apt-get update
    apt-get remove -y npm webpack terser nodejs-doc || true
    apt-get install -y nodejs || true
fi
npm install -g pnpm@11 || true

# Pinned tag for reproducibility — bump per Alfred release
ALFRED_GW_TAG="${ALFRED_GW_TAG:-v2026.5.7}"
ALFRED_GW_DIR=/opt/alfred-gateway

rm -rf "$ALFRED_GW_DIR"
    https://github.com/openclaw/openclaw.git "$ALFRED_GW_DIR" || true

[ -d "$ALFRED_GW_DIR" ] || exit 0
cd "$ALFRED_GW_DIR"
pnpm install --prod --frozen-lockfile || pnpm install --prod || true
pnpm build || true || true
pnpm ui:build || true || true

# ── SOVEREIGN STRIP: remove every upstream identifier from user-visible files ──
    \( -path '*/dist/*' -o -path '*/ui/*' -o -path '*/web/*' -o -path '*/control-ui/*' \) \
    -type f \( -name '*.html' -o -name '*.css' -o -name '*.js' -o -name '*.json' -o -name '*.svg' \) \
    -exec sed -i \
        -e 's/OpenClaw/Alfred/g' \
        -e 's/openclaw/alfred/g' \
        -e 's/OPENCLAW/ALFRED/g' \
        -e 's/Molty/Alfred/g' \
        -e 's/EXFOLIATE/AT YOUR SERVICE/g' \
        -e 's/🦞/🎩/g' \
        {} \; || true

# Brand mark replacement (logos, banners, favicons)
if [ -f /usr/share/alfred/branding/alfred-mark.png ]; then
                          -o -name '*banner*.png' -o -name '*icon*.png' \
                          -o -name 'favicon*.png' -o -name 'favicon*.ico' \) \
        -exec cp /usr/share/alfred/branding/alfred-mark.png {} \; || true 2>/dev/null || true
fi

# Compliance: stash upstream LICENSE in the buried compliance file (handled by 0599)
mkdir -p /usr/share/doc/alfred/.licenses || true
cp "$ALFRED_GW_DIR/LICENSE" /usr/share/doc/alfred/.licenses/gateway.LICENSE 2>/dev/null || true

# Default config skeleton (per-user; copied at first login)
mkdir -p /etc/skel/.alfred/gateway || true
cat > /etc/skel/.alfred/gateway/openclaw.json <<'JSON'
{
  "agent": {
    "model": "alfred-local/default",
    "personaPath": "/usr/share/alfred/persona/alfred.md"
  },
  "branding": {
    "name": "Alfred",
    "emoji": "🎩",
    "tagline": "Crown of Alfred Linux"
  },
  "gateway": {
    "port": 18789,
    "host": "127.0.0.1"
  },
  "logging": { "level": "info" }
}
JSON

# Service user
id -u alfred >/dev/null 2>&1 || \
    useradd --system --home /var/lib/alfred --create-home --shell /usr/sbin/nologin alfred

echo "I: [alfred] Alfred Gateway installed"

) || true

# ==========================================
# RESTORED HOOK: 0323-alfred-ghost-boot.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0323-alfred-ghost-boot.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
echo "================================================="
echo "==== ALFRED GHOST BOOT (Plausible Deniability) =="
echo "================================================="

export DEBIAN_FRONTEND=noninteractive

# Create a decoy user
if ! id "guest" &>/dev/null; then
    useradd -m -s /bin/bash guest || true
    echo "guest:guest" | chpasswd
fi

# Hidden GRUB entry logic (we would typically modify /etc/grub.d/40_custom)
cat << 'EOF' >> /etc/grub.d/40_custom
menuentry "Ghost Environment" --hotkey=f11 {
    set root='(hd0,1)'
    linux /vmlinuz root=/dev/mapper/system-root ro quiet splash nvidia-drm.modeset=1
    initrd /initrd.img
}
EOF
chmod +x /etc/grub.d/40_custom || true

echo "Ghost Boot prep completed."


) || true

# ==========================================
# RESTORED HOOK: 0324-alfred-search.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0324-alfred-search.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
# ═══════════════════════════════════════════════════════════════
# Alfred Linux v2.0-b5 — Meilisearch Local Search Engine
#
# Optional: ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1 allows GitHub fetch when
# /build-assets/meilisearch is missing (default is skip / warn for sealed builds).
# Installs Meilisearch for offline local search.
# BUILD: v2.0-b5 (Search)
# ═══════════════════════════════════════════════════════════════


echo "[Alfred Linux v2.0-b5] Installing Meilisearch..."

# ── 1. Download Meilisearch binary ──
MEILI_VER="v1.13.3"
# MILITARY: Pre-staged binary preferred (air-gap safe), direct download fallback
if [ -f /build-assets/meilisearch ]; then
    echo "[Alfred] Using pre-staged Meilisearch binary (air-gap safe)"
    install -m 755 /build-assets/meilisearch /usr/local/bin/meilisearch
else
    if [[ "${ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS:-}" != "1" ]]; then
        echo "[0500] WARN: add /build-assets/meilisearch (network download disabled; set ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1 for GitHub fallback)." >&2 || true
    else
        MEILI_URL="https://github.com/meilisearch/meilisearch/releases/download/${MEILI_VER}/meilisearch-linux-amd64"
        wget --timeout=900 -q "$MEILI_URL" -O /usr/local/bin/meilisearch || {
            echo "[WARN] Meilisearch download failed — will need manual install"
            echo "meilisearch_failed=$(date -Is)" > /var/lib/alfred/build-flags/meilisearch-failed || true
        }
    fi
fi
chmod +x /usr/local/bin/meilisearch 2>/dev/null || true

# ── 2. Create meilisearch user ──
useradd -r -s /bin/false -d /var/lib/meilisearch meilisearch 2>/dev/null || true
mkdir -p /var/lib/meilisearch || true
chown meilisearch:meilisearch /var/lib/meilisearch || true

# ── 3. Systemd service ──
cat > /etc/systemd/system/meilisearch.service << 'SVC'
[Unit]
Description=Meilisearch Local Search Engine
Documentation=https://docs.meilisearch.com
After=network.target

[Service]
ExecStart=/usr/local/bin/meilisearch --db-path /var/lib/meilisearch --http-addr 127.0.0.1:7700 --no-analytics
User=meilisearch
Group=meilisearch
Restart=always
RestartSec=5
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
SVC
systemctl enable meilisearch || true || true 2>/dev/null || true

# ── 4. Alfred Search CLI ──
cat > /usr/local/bin/alfred-search << 'SEARCH'
# Alfred Search — local search powered by Meilisearch
# Usage: alfred-search "query"

QUERY="${*:-}"
if [[ -z "$QUERY" ]]; then
    echo "Usage: alfred-search <query>" || true
    echo "Search local documentation and files."
    true
fi

# Check if Meilisearch is running
if ! curl -m 900 -s http://localhost:7700/health | grep -q available; then
    echo "Meilisearch is not running. Start with: sudo systemctl start meilisearch"
    true
fi

# Search (JSON-encode query — never interpolate QUERY into JSON by hand)
MS_BODY=$(QUERY="$*" python3 -c 'import json,os; print(json.dumps({"queries":[{"indexUid":"docs","q":os.environ.get("QUERY",""),"limit":5}]}))')
    -d "$MS_BODY" 2>/dev/null)

if echo "$RESULT" | python3 -c "
import sys, json
data = json.load(sys.stdin)
results = data.get('results', [{}])[0].get('hits', [])
if not results:
    print('No results found.')
else:
    for r in results:
        title = r.get('title', r.get('path', 'Untitled'))
        snippet = r.get('content', '')[:200]
        print(f'  → {title}')
        print(f'    {snippet}')
        print()
" 2>/dev/null; then
    :
else
    echo "Search returned no parseable results."
fi
SEARCH
chmod +x /usr/local/bin/alfred-search || true

# ── 5. First-boot indexer script ──
cat > /usr/local/bin/alfred-index-docs << 'INDEX'
# Index local documentation into Meilisearch
echo "Indexing local documentation..."

# Wait for Meilisearch
for i in {1..30}; do
    curl -m 900 -s http://localhost:7700/health | grep -q available && break || true
    sleep 1
done

# Index man pages
DOCS='[]'
ID=0
for f in /usr/share/doc/*/README* /usr/share/doc/*/changelog*; do
    [[ -f "$f" ]] || continue
    CONTENT=$(head -c 5000 "$f" 2>/dev/null | tr -d '\0' | python3 -c "import sys,json; print(json.dumps(sys.stdin.read()))" 2>/dev/null)
    [[ -z "$CONTENT" ]] && continue
    DOCS=$(echo "$DOCS" | DOC_ID="$ID" DOC_PATH="$f" DOC_TITLE="$(basename "$(dirname "$f")")" DOC_CONTENT_JSON="$CONTENT" python3 -c "
import json, os, sys
docs = json.load(sys.stdin)
docs.append({
    'id': int(os.environ['DOC_ID']),
    'path': os.environ['DOC_PATH'],
    'title': os.environ['DOC_TITLE'],
    'content': json.loads(os.environ['DOC_CONTENT_JSON']),
})
print(json.dumps(docs))
" 2>/dev/null)
    ((ID++))
    [[ $ID -ge 500 ]] && break
done

# Push to Meilisearch
    -d @- > /dev/null 2>&1

echo "Indexed $ID documents."
INDEX
chmod +x /usr/local/bin/alfred-index-docs || true

echo "[Alfred Linux v2.0-b5] Meilisearch installed and configured."


) || true

