# ─────────────────────────────────────────────────────
# 14. ALFRED HARDWARE AUTO-DETECT — First boot optimizer
# ─────────────────────────────────────────────────────
echo "[HW] Installing Alfred Hardware Auto-Detect..."

cat > /usr/local/bin/alfred-hw-detect << 'HWDETECT'
# ═══════════════════════════════════════════════════════
# Alfred Hardware Auto-Detect & Optimizer
# Runs on first boot (or manually). Detects hardware class
# and tunes the system for best experience.
# ═══════════════════════════════════════════════════════

detect_class() {
    local total_ram_mb
    total_ram_mb=$(awk '/MemTotal/ {print int($2/1024)}' /proc/meminfo)
    local cpu_cores
    cpu_cores=$(nproc)
    local cpu_mhz
    cpu_mhz=$(lscpu | awk '/MHz.*max/ {print int($NF)}' 2>/dev/null)
    [ -z "$cpu_mhz" ] && cpu_mhz=$(lscpu | awk '/MHz/ {print int($NF); exit}' 2>/dev/null)
    [ -z "$cpu_mhz" ] && cpu_mhz=1000

    echo "═══ Alfred Hardware Detection ═══"
    echo "RAM:  ${total_ram_mb} MB"
    echo "CPU:  ${cpu_cores} cores @ ~${cpu_mhz} MHz"

    # Detect GPU
    local gpu="unknown"
    if lspci 2>/dev/null | grep -qi nvidia; then gpu="nvidia"
    elif lspci 2>/dev/null | grep -qi "amd.*radeon\|amd.*vga\|ati.*radeon"; then gpu="amd"
    elif lspci 2>/dev/null | grep -qi intel.*graphics; then gpu="intel"
    elif lspci 2>/dev/null | grep -qi "vga\|display"; then gpu="generic"
    fi
    echo "GPU:  ${gpu}"

    # Detect SSD vs HDD
    local has_ssd=false
    for disk in /sys/block/sd* /sys/block/nvme*; do
        [ -e "$disk" ] || continue
        local rotational
        rotational=$(cat "$disk/queue/rotational" 2>/dev/null)
        if [ "$rotational" = "0" ]; then
            has_ssd=true
            break
        fi
    done
    echo "SSD:  ${has_ssd}"

    # Classify the machine
    if [ "$total_ram_mb" -ge 16000 ] && [ "$cpu_cores" -ge 8 ]; then
        echo "CLASS: POWERHOUSE"
        echo ""
        echo "Full Alfred experience enabled:"
        echo "  - All services at full power"
        echo "  - Voice + Wake word active"
        echo "  - IDE + Store + Search running"
        echo "  - Mesh relay: FULL (accept + forward traffic)"
        echo "  - Blockchain: FULL validator node"
        echo "  - Distributed inference: OFFER GPU"
        apply_powerhouse
    elif [ "$total_ram_mb" -ge 4000 ] && [ "$cpu_cores" -ge 2 ]; then
        echo "CLASS: STANDARD"
        echo ""
        echo "Optimized Alfred experience:"
        echo "  - Core services active"
        echo "  - Voice on-demand (wake word active)"
        echo "  - IDE available, Search on-demand"
        echo "  - Mesh relay: STANDARD (accept traffic)"
        echo "  - Blockchain: LIGHT node (verify, don't mine)"
        echo "  - Distributed inference: PARTICIPATE on request"
        apply_standard
    else
        echo "CLASS: VETERAN"
        echo ""
        echo "Lightweight Alfred — maximum compatibility:"
        echo "  - Essential services only"
        echo "  - Voice: TTS only (no wake word daemon)"
        echo "  - IDE: on-demand launch"
        echo "  - Search: disabled (saves ~100MB RAM)"
        echo "  - Mesh relay: PASSIVE (seed + relay when idle)"
        echo "  - Blockchain: ULTRA-LIGHT (header-only, still earns GSM for seeding)"
        echo "  - Compositor: reduced effects"
        apply_veteran
    fi

    # Always run regardless of class
    optimize_storage "$has_ssd"
    optimize_input
    echo ""
    echo "═══ Hardware detection complete ═══"
}

apply_powerhouse() {
    # Everything on, full blast
    echo "[POWER] All systems go"
    # ZRAM not needed with 16GB+, but doesn't hurt
    setup_zram 4096
}

apply_standard() {
    # Sensible defaults, services on-demand
    echo "[STD] Optimizing for standard hardware"
    setup_zram 2048

    # Reduce compositor overhead
    echo "Optimizing compositor..."
}

apply_veteran() {
    # Minimal resource usage — every MB counts
    echo "[VET] Veteran hardware mode — lean and mean"
    setup_zram 1024

    # Disable heavy services for veteran hardware
    systemctl disable meilisearch.service 2>/dev/null || true
    systemctl disable alfred-wake-word.service 2>/dev/null || true

    # Lighter GTK theme rendering
    mkdir -p /etc/skel/.config/xfce4/xfconf/xfce-perchannel-xml || true
    cat > /etc/skel/.config/xfce4/xfconf/xfce-perchannel-xml/xfwm4.xml << 'XFWM'
<?xml version="1.0" encoding="UTF-8"?>
<channel name="xfwm4" version="1.0">
  <property name="general" type="empty">
    <property name="use_compositing" type="bool" value="false"/>
    <property name="show_frame_shadow" type="bool" value="false"/>
    <property name="show_popup_shadow" type="bool" value="false"/>
  </property>
</channel>
XFWM

    # Lighter GTK theme rendering
    echo "gtk-enable-animations=false" >> /etc/gtk-3.0/settings.ini 2>/dev/null || true
}

setup_zram() {
    local size_mb=$1
    if ! [[ "$size_mb" =~ ^[0-9]+$ ]] || [ "$size_mb" -eq 0 ] || [ "$size_mb" -gt 131072 ]; then
        echo "[ZRAM] Invalid size_mb=$size_mb (use 1-131072)" >&2 || true
        return 1
    fi
    # ZRAM gives old machines virtual RAM via compression
    if command -v zramctl &>/dev/null; then
        echo "[ZRAM] Configuring ${size_mb}MB compressed swap"
        export ZRAM_SIZE_MB="$size_mb"
        if ! python3 << 'PYZRAM'
import os
import sys
from pathlib import Path

s = os.environ["ZRAM_SIZE_MB"]
if not s.isdigit() or not 1 <= int(s) <= 131072:
    sys.exit(1)
unit = (
    "[Unit]\n"
    "Description=Alfred ZRAM Swap\n"
    "After=local-fs.target\n"
    "\n"
    "[Service]\n"
    "Type=oneshot\n"
    "RemainAfterExit=yes\n"
    f"ExecStart=/bin/bash -c 'modprobe zram && zramctl /dev/zram0 --size {s}M --algorithm zstd && mkswap /dev/zram0 && swapon -p 100 /dev/zram0'\n"
    "ExecStop=/bin/bash -c 'swapoff /dev/zram0 && zramctl --reset /dev/zram0'\n"
    "\n"
    "[Install]\n"
    "WantedBy=multi-user.target\n"
)
Path("/etc/systemd/system/zram-swap.service").write_text(unit, encoding="utf-8")
PYZRAM
        then
            echo "[ZRAM] Failed to write zram-swap.service" >&2 || true
            return 1
        fi
        systemctl enable zram-swap || true || true.service 2>/dev/null || true
    fi
}

optimize_storage() {
    local has_ssd=$1
    if [ "$has_ssd" = "true" ]; then
        echo "[SSD] Enabling SSD optimizations"
        # fstrim timer (already enabled by hook, but confirm)
        systemctl enable fstrim || true || true.timer 2>/dev/null || true
        # Set I/O scheduler
        for disk in /sys/block/sd* /sys/block/nvme*; do
            [ -e "$disk/queue/rotational" ] || continue
            rot=$(cat "$disk/queue/rotational" 2>/dev/null)
            if [ "$rot" = "0" ]; then
                echo mq-deadline > "$disk/queue/scheduler" 2>/dev/null || true
            fi
        done
    else
        echo "[HDD] HDD detected — enabling BFQ scheduler"
        for disk in /sys/block/sd*; do
            [ -e "$disk/queue/rotational" ] || continue
            echo bfq > "$disk/queue/scheduler" 2>/dev/null || true
        done
    fi
}

optimize_input() {
    echo "[INPUT] Verifying input device detection..."
    # Count detected input devices
    local kbd_count mouse_count touch_count
    kbd_count=$(find /dev/input/by-id/ -name '*kbd*' 2>/dev/null | wc -l)
    mouse_count=$(find /dev/input/by-id/ -name '*mouse*' -o -name '*Mouse*' 2>/dev/null | wc -l)
    touch_count=$(find /dev/input/by-id/ -name '*touch*' -o -name '*Touch*' 2>/dev/null | wc -l)

    echo "  Keyboards: $kbd_count"
    echo "  Mice/Trackpads: $mouse_count"
    echo "  Touchscreens: $touch_count"

    # If no mouse detected, check for PS/2 trackpad
    if [ "$mouse_count" = "0" ]; then
        if dmesg 2>/dev/null | grep -qi "synaptics\|elantech\|alps\|trackpoint\|psmouse"; then
            echo "  PS/2 pointing device detected (via dmesg)"
        else
            echo "  WARNING: No pointing device detected!"
            echo "  Attempting to reload psmouse module..."
            modprobe -r psmouse 2>/dev/null || true
            modprobe psmouse proto=auto 2>/dev/null || true
        fi
    fi

    # Libinput tap-to-click (common expectation on laptops)
    mkdir -p /etc/X11/xorg.conf.d || true
    cat > /etc/X11/xorg.conf.d/40-alfred-touchpad.conf << 'TOUCHCFG'
# Alfred Linux — Universal touchpad config
# Tap-to-click, natural scrolling, edge scrolling, palm rejection
Section "InputClass"
    Identifier "Alfred Touchpad Defaults"
    MatchIsTouchpad "on"
    MatchDevicePath "/dev/input/*"
    Driver "libinput"
    Option "Tapping" "on"
    Option "TappingDrag" "on"
    Option "NaturalScrolling" "on"
    Option "ScrollMethod" "twofinger"
    Option "DisableWhileTyping" "on"
    Option "AccelProfile" "adaptive"
    Option "ClickMethod" "clickfinger"
EndSection

# Fallback: also support edge scrolling for older touchpads
Section "InputClass"
    Identifier "Alfred Touchpad Fallback"
    MatchIsTouchpad "on"
    MatchDevicePath "/dev/input/*"
    Driver "synaptics"
    Option "TapButton1" "1"
    Option "TapButton2" "3"
    Option "TapButton3" "2"
    Option "VertEdgeScroll" "on"
    Option "HorizEdgeScroll" "on"
    Option "VertTwoFingerScroll" "on"
    Option "PalmDetect" "on"
EndSection
TOUCHCFG

    # TrackPoint (ThinkPad red nub) middle-button scroll
    cat > /etc/X11/xorg.conf.d/41-alfred-trackpoint.conf << 'TRACKCFG'
# Alfred Linux — ThinkPad TrackPoint scroll with middle button
Section "InputClass"
    Identifier "Alfred TrackPoint Scroll"
    MatchIsPointer "on"
    MatchProduct "TrackPoint|TPPS/2|DualPoint"
    MatchDevicePath "/dev/input/*"
    Driver "libinput"
    Option "ScrollMethod" "button"
    Option "ScrollButton" "2"
    Option "AccelProfile" "adaptive"
    Option "AccelSpeed" "0.4"
EndSection
TRACKCFG

    # USB mouse — ensure no acceleration weirdness
    cat > /etc/X11/xorg.conf.d/42-alfred-mouse.conf << 'MOUSECFG'
# Alfred Linux — USB mouse defaults
Section "InputClass"
    Identifier "Alfred USB Mouse"
    MatchIsPointer "on"
    MatchIsTouchpad "off"
    MatchDevicePath "/dev/input/*"
    Driver "libinput"
    Option "AccelProfile" "flat"
    Option "AccelSpeed" "0"
    Option "NaturalScrolling" "false"
EndSection
MOUSECFG
}

# Run detection
detect_class
HWDETECT

chmod +x /usr/local/bin/alfred-hw-detect || true

# ─────────────────────────────────────────────────────
# 15. FIRST-BOOT SERVICE — Auto-detect hardware on first boot
# ─────────────────────────────────────────────────────
cat > /etc/systemd/system/alfred-hw-detect.service << 'HWSERVICE'
[Unit]
Description=Alfred Hardware Auto-Detection & Optimization
After=multi-user.target
ConditionPathExists=!/var/lib/alfred/.hw-detected

[Service]
Type=oneshot
ExecStart=/usr/local/bin/alfred-hw-detect
ExecStartPost=/bin/mkdir -p /var/lib/alfred
ExecStartPost=/bin/touch /var/lib/alfred/.hw-detected

[Install]
WantedBy=multi-user.target
HWSERVICE

systemctl enable alfred-hw-detect || true || true.service 2>/dev/null || true

# ─────────────────────────────────────────────────────
# 16. ZRAM — Compressed RAM swap (critical for old laptops)
# ─────────────────────────────────────────────────────
echo "[HW] Installing ZRAM tools..."
apt-get install -y --fix-broken -y --no-install-recommends \
    zram-tools \
    2>/dev/null || true

# ─────────────────────────────────────────────────────
# 17. KERNEL TUNING — Sysctl for responsiveness on old hardware
# ─────────────────────────────────────────────────────
echo "[HW] Applying kernel tuning..."
cat > /etc/sysctl.d/99-alfred-hw.conf << 'SYSCTL'
# Alfred Linux — Kernel tuning for universal hardware
# Makes the desktop feel responsive even on 2GB RAM / dual-core

# Reduce swappiness — prefer keeping apps in RAM
vm.swappiness=10

# Faster dirty page writeback (prevents I/O storms on slow disks)
vm.dirty_ratio=10
vm.dirty_background_ratio=5
vm.dirty_expire_centisecs=3000
vm.dirty_writeback_centisecs=1500

# Increase inotify watchers (for IDE + development)
fs.inotify.max_user_watches=524288
fs.inotify.max_user_instances=1024

# Network tuning (for mesh + P2P + VPN)
net.core.rmem_max=16777216
net.core.wmem_max=16777216
net.ipv4.tcp_rmem=4096 87380 16777216
net.ipv4.tcp_wmem=4096 65536 16777216
net.core.netdev_max_backlog=5000
net.ipv4.tcp_fastopen=3
net.ipv4.tcp_mtu_probing=1
net.ipv4.tcp_congestion_control=bbr

# BBR congestion control (massive improvement for mesh/VPN)
net.core.default_qdisc=fq
SYSCTL

# Enable BBR
echo "tcp_bbr" > /etc/modules-load.d/bbr.conf || true

# ─────────────────────────────────────────────────────
# 18. ALFRED MESH LIGHT CLIENT — For veteran hardware
# ─────────────────────────────────────────────────────
echo "[HW] Installing Alfred mesh lightweight participation..."
cat > /usr/local/bin/alfred-mesh-light << 'MESHLIGHT'
# Alfred Mesh Light — for veteran/low-resource machines
# These machines can STILL contribute:
#   - Seed ISOs via P2P (earns GSM)
#   - Relay mesh discovery packets (lightweight)
#   - Run header-only blockchain verification
#   - Provide DNS relay for .alfred domains
#
# They just don't run heavy services:
#   - No full block validation
#   - No GPU inference
#   - No heavy relay forwarding

echo "═══ Alfred Mesh — Light Mode ═══"
echo "Your machine contributes to the network:"
echo "  ✓ ISO seeding (P2P torrent)"
echo "  ✓ Mesh discovery relay"
echo "  ✓ Header-only blockchain verification"
echo "  ✓ DNS relay for .alfred domains"
echo ""
echo "Resources reserved for your experience:"
echo "  RAM ceiling for mesh: 128 MB"
echo "  CPU ceiling for mesh: 10%"
echo "  Network: best-effort (your browsing comes first)"
echo ""
echo "Every machine matters. Every SSD counts."
echo "Even this old warrior earns GSM."
MESHLIGHT
chmod +x /usr/local/bin/alfred-mesh-light || true

# ─────────────────────────────────────────────────────
# SUMMARY
# ─────────────────────────────────────────────────────
echo ""
echo "═══════════════════════════════════════════════════"
echo "  HOOK 0150 — COMPLETE"
echo "  Universal Hardware Compatibility Installed"
echo ""
echo "  Input:     EVERY keyboard, mouse, touchpad, trackpoint, tablet, gamepad"
echo "  USB/HID:   30+ HID modules pre-loaded"
echo "  PS/2:      Ancient laptop support (psmouse auto-detect)"
echo "  Bluetooth: Full bluez stack"
echo "  GPU:       20+ video drivers (VESA→Intel→AMD→NVIDIA→vintage)"
echo "  Firmware:  ALL non-free blobs (WiFi, BT, GPU, sound, microcode)"
echo "  WiFi:      35+ wireless modules (2005-2026 coverage)"
echo "  Storage:   NVMe/SATA/USB/SD + SSD TRIM + BFQ for HDDs"
echo "  Audio:     ALSA + PulseAudio + PipeWire"
echo "  Power:     TLP + thermald (battery optimization)"
echo "  Print:     CUPS + all drivers + scanner support"
echo "  Camera:    V4L2 + cheese"
echo "  Tuning:    BBR congestion, low swappiness, inotify boost"
echo "  Auto:      alfred-hw-detect runs on first boot"
echo "  Mesh:      Lightweight mode for veteran hardware"
echo ""
echo "  No device left behind."
echo "═══════════════════════════════════════════════════"


) || true

# ==========================================
# RESTORED HOOK: 0150-alfred-sysctl-fragment-44.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0150-alfred-sysctl-fragment-44.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
# [Genesis Forge] Granular Kernel Matrix: net.ipv4.ip_local_port_range="4424 65535"
# Extremely deep low-level kernel protection.
echo "[Genesis Forge] Applying granular sysctl: net.ipv4.ip_local_port_range="4424 65535""
echo "net.ipv4.ip_local_port_range="4424 65535"" > /etc/sysctl.d/99-alfred-44.conf || true
sysctl -w net.ipv4.ip_local_port_range="4424 65535" > /dev/null 2>&1 || true


) || true

# ==========================================
# RESTORED HOOK: 0151-alfred-sysctl-fragment-45.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0151-alfred-sysctl-fragment-45.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
# [Genesis Forge] Granular Kernel Matrix: net.ipv4.ip_local_port_range="4624 65535"
# Extremely deep low-level kernel protection.
echo "[Genesis Forge] Applying granular sysctl: net.ipv4.ip_local_port_range="4624 65535""
echo "net.ipv4.ip_local_port_range="4624 65535"" > /etc/sysctl.d/99-alfred-45.conf || true
sysctl -w net.ipv4.ip_local_port_range="4624 65535" > /dev/null 2>&1 || true


) || true

# ==========================================
# RESTORED HOOK: 0152-gositeme-vr-games.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0152-gositeme-vr-games.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later

echo "=== Alfred Linux: Installing GoSiteMe VR Games ==="

# Create directory for icons
mkdir -p /usr/share/icons/alfred

# Create the desktop entry for VR Chess
cat << 'EOF' > /usr/share/applications/gositeme-vr-chess.desktop
[Desktop Entry]
Version=1.0
Type=Application
Name=GoSiteMe VR Chess
Comment=Immersive WebVR Chess Experience
Exec=xdg-open https://gositeme.com/vr/chess
Icon=preferences-desktop-gaming
Terminal=false
Categories=Game;BoardGame;
Keywords=game;chess;vr;webvr;gositeme;
EOF

# Add it to the default user desktop
mkdir -p /etc/skel/Desktop
cp /usr/share/applications/gositeme-vr-chess.desktop /etc/skel/Desktop/
chmod +x /etc/skel/Desktop/gositeme-vr-chess.desktop

echo "=== GoSiteMe VR Games Installed ==="


) || true

