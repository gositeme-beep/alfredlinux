echo "â•‘  âœ“ Orca screen reader installed                          â•‘"
echo "â•‘  âœ“ espeak-ng text-to-speech                              â•‘"
echo "â•‘  âœ“ High contrast + large text modes                      â•‘"
echo "â•‘  âœ“ On-screen keyboard (Onboard)                          â•‘"
echo "â•‘  âœ“ alfred-bible-speak â€” hear the Word                    â•‘"
echo "â•‘  âœ“ alfred-a11y CLI â€” one-command accessibility           â•‘"
echo "â•‘  The blind shall see. The deaf shall hear.               â•‘"
echo "â•šâ•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•"


) || true

