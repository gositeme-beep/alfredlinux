echo "Ascension lock service enabled for runtime."

) || true

# ==========================================
# RESTORED HOOK: 0005-disable-kexec-tools.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0005-disable-kexec-tools.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
# Description: Disable kexec-tools auto-load via debconf preseed


# Disable kexec-tools

if [ -e /sbin/kexec ]
then
	echo "kexec-tools kexec-tools/load_kexec boolean false" > /root/preseed || true

