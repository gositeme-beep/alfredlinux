# === INJECTED: The Book of Remembrance (Immutable Creation Ledger) ===
apt_nonfatal omahon inotify-tools
cat > /usr/local/bin/alfred-remembrance << 'EOF_REM'
WATCH_DIR="/var/lib/alfred/remembrance"
LOG_FILE="/var/log/book_of_remembrance.log"
mkdir -p "$WATCH_DIR" || true
inotifywait -m -e close_write "$WATCH_DIR" |
while read -r directory events filename; do
    FILEPATH="$directory$filename"
    HASH=$(sha256sum "$FILEPATH" | awk '{print $1}')
    echo "[$(date -u +"%Y-%m-%dT%H:%M:%SZ")] SIGNED: $filename | HASH: $HASH" >> "$LOG_FILE"
    logger -t alfred-remembrance "Recorded $filename into the Book of Remembrance."
done
EOF_REM
chmod +x /usr/local/bin/alfred-remembrance

cat > /etc/systemd/system/alfred-remembrance.service << 'EOF_REM_SVC'
[Unit]
Description=The Book of Remembrance
After=network.target
[Service]
Type=simple
User=root
ExecStart=/usr/local/bin/alfred-remembrance
Restart=always
[Install]
WantedBy=multi-user.target
EOF_REM_SVC
systemctl enable alfred-remembrance || true || true.service 2>/dev/null || true
echo "[$(date -Is)] The Book of Remembrance is open."


) || true

