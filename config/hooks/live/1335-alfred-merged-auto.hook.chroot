# ==========================================
# RESTORED HOOK: 0082-alfred-brain-systemd.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0082-alfred-brain-systemd.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
# Hook 0258 — systemd units for Alfred-LLM + Alfred-Bridge

echo "═══════════════════════════════════════════════════════"
echo "  ALFRED-LLM systemd — auto-start brain on boot"
echo "═══════════════════════════════════════════════════════"

mkdir -p /etc/systemd/system /etc/alfred-llm || true

# Dedicated low-priv user
if ! getent passwd alfred-llm >/dev/null; then
  useradd --system --no-create-home --shell /usr/sbin/nologin alfred-llm || true
fi
chown -R alfred-llm:alfred-llm /opt/alfred-models /etc/alfred-llm 2>/dev/null || true

# llama-server: serves the active model on :8080 (haiku tier)
cat > /etc/systemd/system/alfred-llm@.service <<'UNIT'
[Unit]
Description=Alfred-LLM (%i tier) — local language model server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=alfred-llm
Group=alfred-llm
EnvironmentFile=-/etc/alfred-llm/%i.env
ExecStart=/usr/local/bin/llama-server-auto \
  --model /opt/alfred-models/alfred-%i.gguf \
  --host 127.0.0.1 \
  --port ${ALFRED_LLM_PORT} \
  --ctx-size ${ALFRED_LLM_CTX:-8192} \
  --threads ${ALFRED_LLM_THREADS:-4} \
  --n-gpu-layers ${ALFRED_LLM_NGL:-0} \
  --jinja
Restart=on-failure
RestartSec=5
# Hardening
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
ReadWritePaths=/var/log/alfred-llm

[Install]
WantedBy=multi-user.target
UNIT

# Per-tier env files (port assignments)
cat > /etc/alfred-llm/haiku.env  <<'EOF'
ALFRED_LLM_PORT=8080
ALFRED_LLM_CTX=8192
EOF
cat > /etc/alfred-llm/sonnet.env <<'EOF'
ALFRED_LLM_PORT=8081
ALFRED_LLM_CTX=8192
EOF
cat > /etc/alfred-llm/opus.env   <<'EOF'
ALFRED_LLM_PORT=8082
ALFRED_LLM_CTX=16384
EOF
cat > /etc/alfred-llm/opus-iq3.env <<'EOF'
ALFRED_LLM_PORT=8082
ALFRED_LLM_CTX=16384
EOF

# Bridge: LiteLLM Anthropic↔OpenAI on :4000
cat > /etc/systemd/system/alfred-bridge.service <<'UNIT'
[Unit]
Description=Alfred-Bridge — Anthropic compat layer (LiteLLM)
After=alfred-llm@haiku.service
Wants=alfred-llm@haiku.service

[Service]
Type=simple
User=alfred-llm
Group=alfred-llm
ExecStart=/usr/local/bin/litellm --config /etc/alfred-llm/litellm.yaml
Restart=on-failure
RestartSec=5
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes

[Install]
WantedBy=multi-user.target
UNIT

mkdir -p /var/log/alfred-llm || true
chown alfred-llm:alfred-llm /var/log/alfred-llm || true

# Enable Haiku by default (works on every machine), bridge always on
systemctl enable alfred-llm || true || true@haiku.service 2>/dev/null || true
systemctl enable alfred-bridge || true || true.service 2>/dev/null || true

echo "[SYSTEMD] alfred-llm@haiku + alfred-bridge enabled for boot"


) || true

# ==========================================
# RESTORED HOOK: 0083-alfred-vision.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0083-alfred-vision.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
# 0259-alfred-vision.hook.chroot
# Installs Prophetic Vision (ComfyUI / Stable Diffusion) wrapper

echo "[0259] Configuring Prophetic Vision (GPU AI Image Generation)"

# Setup the environment structure
mkdir -p /opt/alfred-vision || true
# Assuming build-assets/vision contains the ComfyUI source, we would copy it here
if [ -d "/build-assets/vision" ]; then
    cp -r /build-assets/vision/* /opt/alfred-vision/ || true
    chown -R 1000:1000 /opt/alfred-vision || true
fi

# Create the wrapper script
cat << 'EOF' > /usr/local/bin/alfred-vision
# Prophetic Vision Launcher
echo "=========================================="
echo "    PROPHETIC VISION (GPU GENERATOR)      "
echo "=========================================="
echo "Starting local diffusion engine..."

cd /opt/alfred-vision || true
if [ -f "main.py" ]; then
    # We run the ComfyUI backend
    if [ ! -d "venv" ]; then
        python3 -m venv venv || true
    fi
    source venv/bin/activate
    # Run the server in the background
    python3 main.py --listen 127.0.0.1 --port 8188 & || true
    VISION_PID=$!
    
    # Wait for the server to spin up
    sleep 5
    
    # Launch browser (KDE Plasma)
    xdg-open http://127.0.0.1:8188
    
    echo "Vision engine running. Press Ctrl+C to shut down."
    wait $VISION_PID
else
    echo "Vision assets not fully downloaded yet. Please connect to internet and run update-vision.sh"
    read -p "Press Enter to exit..."
fi
EOF

chmod 0755 /usr/local/bin/alfred-vision || true

echo "[0259] Prophetic Vision configured."


) || true

# ==========================================
# RESTORED HOOK: 0084-alfred-terminal-power.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0084-alfred-terminal-power.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
# ═══════════════════════════════════════════════════════════════
# 0260-alfred-terminal-power.hook.chroot — "The Forge"
# ═══════════════════════════════════════════════════════════════
# Ubuntu's terminal: ls, grep, cat, find.
# Alfred's terminal: eza, ripgrep, bat, fd, fzf, lazygit,
#   starship, zoxide, neovim, tldr, duf, ncdu, httpie.
#
# You open a terminal on Alfred and feel like a god.
# You open a terminal on Ubuntu and feel like it's 1995.
#
# Optional: ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1 allows GitHub fetches when
# apt has no package and /build-assets has no staged binary; also gates pip tldr.
# zoxide/starship: init scripts baked at hook time to /etc/profile.d/80-alfred-*.sh;
# login shells source those files (no eval of command substitution).
# ═══════════════════════════════════════════════════════════════

echo "═══════════════════════════════════════════════════════"

apt_nonfatal() {
    local tag="${1:-apt-install}"
    shift
    mkdir -p /var/lib/alfred/build-flags || true
    if ! apt-get install -y python3-pip --fix-broken -y --no-install-recommends "$@" 2>/dev/null; then
        echo "[TERM-APT] WARN: install failed (non-fatal): ${tag} ($*)" >&2 || true
        echo "${tag}_install_failed=$(date -Is)" >> /var/lib/alfred/build-flags/terminal-apt-failed || true
    fi
}

echo "  ALFRED TERMINAL POWER — Feel like a god"
echo "═══════════════════════════════════════════════════════"

export DEBIAN_FRONTEND=noninteractive
ARCH=$(dpkg --print-architecture)

# ── 1. APT-installable power tools ──
echo "[TERM] Installing terminal power tools from repos..."
apt_nonfatal terminal-tools \
    bat \
    fd-find \
    ripgrep \
    fzf \
    neovim \
    ncdu \
    httpie \
    fish \
    tmux \

# ── 2. btop (better top) ──
echo "[TERM] Installing btop..."
apt_nonfatal btop btop

# ── 3. eza (modern ls — may not be in Trixie repos yet) ──
echo "[TERM] Installing eza..."
apt-get install -y python3-pip --fix-broken -y --no-install-recommends eza 2>/dev/null || {
    echo "[TERM] eza not in repos, fetching from GitHub..."
    EZA_VERSION="0.20.14"
    if [ "$ARCH" = "amd64" ] && [[ "${ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS:-}" == "1" ]]; then
            tar xzf /tmp/eza.tar.gz -C /usr/local/bin/ \
            && rm -f /tmp/eza.tar.gz || true
    elif [ "$ARCH" = "amd64" ]; then
        echo "[TERM] WARN: skipping eza GitHub fetch (set ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1)." >&2 || true
    fi
}

# ── 4. lazygit (TUI git client) ──
echo "[TERM] Installing lazygit..."
LAZYGIT_VERSION="0.44.1"
if [ "$ARCH" = "amd64" ] && [[ "${ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS:-}" == "1" ]]; then
    wget --timeout=900 -qO /tmp/lazygit.tar.gz \
        && tar xzf /tmp/lazygit.tar.gz -C /usr/local/bin/ lazygit \
        && rm -f /tmp/lazygit.tar.gz || true
elif [ "$ARCH" = "amd64" ]; then
    echo "[TERM] WARN: skipping lazygit GitHub fetch (set ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1)." >&2 || true
fi

# ── 5. duf (better df) ──
echo "[TERM] Installing duf..."
apt-get install -y python3-pip --fix-broken -y --no-install-recommends duf 2>/dev/null || {
    if [ "$ARCH" = "amd64" ] && [[ "${ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS:-}" == "1" ]]; then
        DUF_VERSION="0.8.1"
        DUF_DEB_URL="https://github.com/muesli/duf/releases/download/v${DUF_VERSION}/duf_${DUF_VERSION}_linux_amd64.deb"
        DUF_SUM_URL="https://github.com/muesli/duf/releases/download/v${DUF_VERSION}/duf_${DUF_VERSION}_checksums.txt"
        DUF_TMP_DEB="$(mktemp /tmp/duf.XXXXXX.deb)"
        DUF_TMP_SUM="$(mktemp /tmp/duf.XXXXXX.checksums)"
        if wget --timeout=900 -qO "$DUF_TMP_DEB" "$DUF_DEB_URL" && wget --timeout=900 -qO "$DUF_TMP_SUM" "$DUF_SUM_URL"; then
            DUF_EXPECTED_SHA="$(grep -E "[[:space:]]duf_${DUF_VERSION}_linux_amd64.deb$" "$DUF_TMP_SUM" | awk '{print $1}' | head -n1)"
            DUF_ACTUAL_SHA="$(sha256sum "$DUF_TMP_DEB" | awk '{print $1}')"
            if [ -n "$DUF_EXPECTED_SHA" ] && [ "$DUF_EXPECTED_SHA" = "$DUF_ACTUAL_SHA" ]; then
                dpkg -i "$DUF_TMP_DEB"
            else
                echo "[TERM] WARN: duf checksum mismatch; skipping deb install." >&2 || true
            fi
        else
            echo "[TERM] WARN: duf download/checksum fetch failed; skipping deb install." >&2 || true
        fi
        rm -f "$DUF_TMP_DEB" "$DUF_TMP_SUM" || true
    elif [ "$ARCH" = "amd64" ]; then
        echo "[TERM] WARN: skipping duf GitHub fetch (set ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1)." >&2 || true
    fi
}

# ── 6. zoxide (smart cd) ──
echo "[TERM] Installing zoxide..."
apt-get install -y python3-pip --fix-broken -y --no-install-recommends zoxide 2>/dev/null || {
    # MILITARY: Pre-staged binary preferred (air-gap safe)
    if [ -f /build-assets/zoxide ]; then
        echo "[TERM] Using pre-staged zoxide (air-gap safe)"
        install -m 755 /build-assets/zoxide /usr/local/bin/zoxide
    elif [ "$ARCH" = "amd64" ] && [[ "${ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS:-}" == "1" ]]; then
        ZOXIDE_VERSION="0.9.6"
        wget --timeout=900 -qO /tmp/zoxide.tar.gz \
            && tar xzf /tmp/zoxide.tar.gz -C /usr/local/bin/ zoxide \
            && chmod +x /usr/local/bin/zoxide \
            && rm -f /tmp/zoxide.tar.gz || true
    elif [ "$ARCH" = "amd64" ]; then
        echo "[TERM] WARN: skipping zoxide GitHub fetch (set ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1 or stage /build-assets/zoxide)." >&2 || true
    fi
}

# ── 7. Starship prompt ──
echo "[TERM] Installing Starship prompt..."
# MILITARY: Pre-staged binary preferred (air-gap safe)
if [ -f /build-assets/starship ]; then
    echo "[TERM] Using pre-staged Starship (air-gap safe)"
    install -m 755 /build-assets/starship /usr/local/bin/starship
elif [ "$ARCH" = "amd64" ] && [[ "${ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS:-}" == "1" ]]; then
    STARSHIP_VERSION="1.22.1"
    wget --timeout=900 -qO /tmp/starship.tar.gz \
        && tar xzf /tmp/starship.tar.gz -C /usr/local/bin/ starship \
        && chmod +x /usr/local/bin/starship \
        && rm -f /tmp/starship.tar.gz || true
elif [ "$ARCH" = "amd64" ]; then
    echo "[TERM] WARN: skipping starship GitHub fetch (set ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1 or stage /build-assets/starship)." >&2 || true
fi

# ── 7b. Bake zoxide & Starship bash hooks (login sources — no eval) ──
echo "[TERM] Baking zoxide/starship profile snippets..."
_zo_tmp=$(mktemp)
if command -v zoxide &>/dev/null; then
    if zoxide init bash >"$_zo_tmp" 2>/dev/null && [ -s "$_zo_tmp" ]; then
        install -m 644 "$_zo_tmp" /etc/profile.d/80-alfred-zoxide.sh
    else
        rm -f /etc/profile.d/80-alfred-zoxide.sh 2>/dev/null || true
    fi
else
    rm -f /etc/profile.d/80-alfred-zoxide.sh 2>/dev/null || true
fi
rm -f "$_zo_tmp" || true
_st_tmp=$(mktemp)
if command -v starship &>/dev/null; then
    if starship init bash >"$_st_tmp" 2>/dev/null && [ -s "$_st_tmp" ]; then
        install -m 644 "$_st_tmp" /etc/profile.d/80-alfred-starship.sh
    else
        rm -f /etc/profile.d/80-alfred-starship.sh 2>/dev/null || true
    fi
else
    rm -f /etc/profile.d/80-alfred-starship.sh 2>/dev/null || true
fi
rm -f "$_st_tmp" || true

# Create Alfred Starship config
mkdir -p /etc/skel/.config || true
cat > /etc/skel/.config/starship.toml << 'STARSHIP'
# Alfred Linux — Starship Configuration
format = """
[╭─](bold cyan) $os$username$hostname$directory$git_branch$git_status$rust$nodejs$golang$python
[╰─](bold cyan) $character"""

[os]
disabled = false
style = "bold cyan"

[os.symbols]
Linux = "🛡 "

[character]
success_symbol = "[❯](bold green)"
error_symbol = "[❯](bold red)"

[directory]
style = "bold blue"
truncation_length = 4

[git_branch]
style = "bold purple"
format = "[$symbol$branch]($style) "

[git_status]
