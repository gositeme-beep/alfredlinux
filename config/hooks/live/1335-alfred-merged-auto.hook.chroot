# SPDX-License-Identifier: AGPL-3.0-or-later

echo "=== Alfred Linux: Injecting Cutting-Edge Features (Bypassing Debian) ==="

# 1. Install Tailscale (Zero-config VPN) directly from Tailscale's repo
echo "Installing Tailscale..."
curl -m 900 -fsSL https://pkgs.tailscale.com/stable/debian/trixie.noarmor.gpg | tee /usr/share/keyrings/tailscale-archive-keyring.gpg >/dev/null || true
curl -m 900 -fsSL https://pkgs.tailscale.com/stable/debian/trixie.tailscale-keyring.list | tee /etc/apt/sources.list.d/tailscale.list || true
sed -i 's/deb https/deb [arch=amd64] https/g' /etc/apt/sources.list.d/tailscale.list
apt-get update || true || true
apt-get install -y --fix-broken -y tailscale || true

# 2. Install modern CLI tools via Cargo/Rust if missing
echo "Ensuring cutting edge Rust tools..."
# eza and fastfetch are already installed via apt, but if we wanted to build from source, we'd do it here.

echo "=== Cutting-Edge Injection Complete ==="


) || true

