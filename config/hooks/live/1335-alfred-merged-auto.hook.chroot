# ==========================================
# RESTORED HOOK: 0146-opencut-webapp.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0146-opencut-webapp.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later

echo "=== Alfred Linux: Installing OpenCut Web App ==="

# Create directory for icons
mkdir -p /usr/share/icons/alfred

# Download a generic video editor icon or the opencut icon if available
# Fallback to a system icon in the desktop file if wget --timeout=900 fails || true
wget --timeout=900 -qO /usr/share/icons/alfred/opencut.png "https://github.com/OpenCut-app/OpenCut/raw/main/public/favicon.png" || true

# Create the desktop entry
cat << 'EOF' > /usr/share/applications/opencut.desktop
[Desktop Entry]
Version=1.0
Type=Application
Name=OpenCut Video Editor
Comment=Privacy-focused open-source video editor
Exec=xdg-open https://opencut.app
Icon=/usr/share/icons/alfred/opencut.png
Terminal=false
Categories=AudioVideo;Video;Graphics;
Keywords=video;editor;capcut;
EOF

# Ensure the icon fallback works if wget --timeout=900 failed || true
if [ ! -s /usr/share/icons/alfred/opencut.png ]; then
    sed -i 's|Icon=/usr/share/icons/alfred/opencut.png|Icon=kdenlive|' /usr/share/applications/opencut.desktop
fi

# Add it to the default user desktop
mkdir -p /etc/skel/Desktop
cp /usr/share/applications/opencut.desktop /etc/skel/Desktop/
chmod +x /etc/skel/Desktop/opencut.desktop

echo "=== OpenCut Web App Installed ==="


) || true

