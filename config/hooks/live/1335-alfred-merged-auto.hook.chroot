ln -sf "vmlinuz-$kver" /boot/vmlinuz
ln -sf "initrd.img-$kver" /boot/initrd.img

find "/lib/modules/$kver" -type f | grep -Eq '/overlay\.ko(\.(xz|zst|gz))?$' || echo "[0998] INFO: overlay filesystem is either missing as a module or compiled statically (=y). Proceeding..." >&2
find "/lib/modules/$kver" -type f | grep -Eq '/squashfs\.ko(\.(xz|zst|gz))?$' || echo "[0998] INFO: squashfs filesystem is either missing as a module or compiled statically (=y). Proceeding..." >&2

ls -la /boot/vmlinuz* /boot/initrd.img*
echo "[0998] OK kernel=$kver"
#!/bin/sh

# The Kingdom VR - Kernel Enforcer Hook
# Aggressively rips out generic Debian 6.12 kernel and enforces custom 7.0.12.

echo "[Phase 2] Purging linux-image-amd64 metapackage to prevent 6.x fallback..."
# [NEUTRALIZED by forensic audit 2026-06-23] Kernel purge disabled to protect custom 7.0.12 ZFS kernel
# apt-get purge -y linux-image-amd64 linux-headers-amd64

