# --- BEGIN MERGED: 0099-alfred-ufw-firewall.hook.chroot ---
#!/bin/bash
set +e
echo "=> Deploying Alfred Zero-Trust UFW Firewall..."
apt-get install -y --no-install-recommends ufw iptables 2>/dev/null || true
ufw default deny incoming || true
ufw default allow outgoing || true
if [ -f /etc/ufw/ufw.conf ]; then
    sed -i 's/ENABLED=no/ENABLED=yes/g' /etc/ufw/ufw.conf
fi
echo "=> UFW default drop-rules enabled for boot initialization."
exit 0
# --- END MERGED: 0099-alfred-ufw-firewall.hook.chroot ---

#!/bin/sh
set +e

echo "Installing tshark and wifite manually to bypass apt-get deadlock..."
export DEBIAN_FRONTEND=noninteractive

# Pre-seed wireshark-common to silently allow non-root users to capture packets
echo "wireshark-common wireshark-common/install-setuid boolean true" | debconf-set-selections

# Clean up any broken dpkg state just in case
dpkg --configure -a || true

# Explicitly install them
apt-get update
apt-get install -y --no-install-recommends tshark wifite

echo "Successfully installed tshark and wifite!"
