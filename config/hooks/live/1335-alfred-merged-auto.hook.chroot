# [Genesis Forge] Systemd Hardening: alfred-daemon-86.service
# Enforces deep PrivateTmp, ProtectSystem, and ProtectHome on native daemons.
echo "[Genesis Forge] Hardening systemd service: alfred-daemon-86.service"
mkdir -p /etc/systemd/system/alfred-daemon-86.service.d/ || true
cat > /etc/systemd/system/alfred-daemon-86.service.d/override.conf << 'EOF'
