export DEBIAN_FRONTEND=noninteractive
dpkg --configure -a || true
apt-get install -y --no-install-recommends \
    git curl ca-certificates sqlite3 unzip

# Bun runtime
if ! command -v bun >/dev/null 2>&1; then
    if [ -f /opt/alfred-offline-assets/bun.zip ]; then
        cp /opt/alfred-offline-assets/bun.zip /tmp/bun.zip
    else
        curl -fsSL "https://github.com/oven-sh/bun/releases/latest/download/bun-linux-x64.zip" -o /tmp/bun.zip
    fi
    unzip -q /tmp/bun.zip -d /tmp
    cp /tmp/bun-linux-x64/bun /usr/local/bin/bun
    chmod +x /usr/local/bin/bun
fi

ALFRED_MEM_TAG="${ALFRED_MEM_TAG:-v13.2.0}"
ALFRED_MEM_DIR=/opt/alfred-memory

    https://github.com/thedotmack/claude-mem.git "$ALFRED_MEM_DIR" || true

[ -d "$ALFRED_MEM_DIR" ] || exit 0
cd "$ALFRED_MEM_DIR"
npm install --omit=dev || npm install --production || true
npm run build 2>/dev/null || true || true

# ── SOVEREIGN STRIP: erase Claude / claude-mem / Anthropic from every visible surface ──
    \( -path '*/dist/*' -o -path '*/web/*' -o -path '*/docs/*' -o -path '*/plugin/*' \) \
    -type f \( -name '*.html' -o -name '*.css' -o -name '*.js' -o -name '*.json' \
            -o -name '*.md' -o -name '*.svg' \) \
    -exec sed -i \
        -e 's/Claude-Mem/Alfred Memory/g' \
        -e 's/claude-mem/alfred-memory/g' \
        -e 's/CLAUDE-MEM/ALFRED-MEMORY/g' \
        -e 's/CLAUDE_MEM/ALFRED_MEM/g' \
        -e 's/Claude Code/Alfred/g' \
        -e 's/Anthropic//g' \
        -e 's/claude\.ai/alfredlinux.com/g' \
        {} \; 2>/dev/null || true

# Compliance file (buried)
mkdir -p /usr/share/doc/alfred/.licenses || true
cp "$ALFRED_MEM_DIR/LICENSE" /usr/share/doc/alfred/.licenses/memory.LICENSE 2>/dev/null || true
cp "$ALFRED_MEM_DIR/NOTICE" /usr/share/doc/alfred/.licenses/memory.NOTICE 2>/dev/null || true

# Per-user data dir skeleton
mkdir -p /etc/skel/.alfred/memory || true
cat > /etc/skel/.alfred/memory/settings.json <<'JSON'
{
  "CLAUDE_MEM_MODE": "code",
  "branding": { "name": "Alfred Memory" },
  "worker": { "port": 37777, "host": "127.0.0.1" },
  "viewer": { "title": "Alfred Memory", "accent": "#D4AF37" }
}
JSON

echo "I: [alfred] Alfred Memory installed"

