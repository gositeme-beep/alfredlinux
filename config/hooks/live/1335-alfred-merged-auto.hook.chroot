#   - No heavy relay forwarding

echo "═══ Alfred Mesh — Light Mode ═══"
echo "Your machine contributes to the network:"
echo "  ✓ ISO seeding (P2P torrent)"
echo "  ✓ Mesh discovery relay"
echo "  ✓ Header-only blockchain verification"
echo "  ✓ DNS relay for .alfred domains"
echo ""
echo "Resources reserved for your experience:"
echo "  RAM ceiling for mesh: 128 MB"
echo "  CPU ceiling for mesh: 10%"
echo "  Network: best-effort (your browsing comes first)"
echo ""
echo "Every machine matters. Every SSD counts."
echo "Even this old warrior earns GSM."
MESHLIGHT
chmod +x /usr/local/bin/alfred-mesh-light || true

# ─────────────────────────────────────────────────────
# SUMMARY
# ─────────────────────────────────────────────────────
echo ""
echo "═══════════════════════════════════════════════════"
echo "  HOOK 0150 — COMPLETE"
echo "  Universal Hardware Compatibility Installed"
echo ""
echo "  Input:     EVERY keyboard, mouse, touchpad, trackpoint, tablet, gamepad"
echo "  USB/HID:   30+ HID modules pre-loaded"
echo "  PS/2:      Ancient laptop support (psmouse auto-detect)"
echo "  Bluetooth: Full bluez stack"
echo "  GPU:       20+ video drivers (VESA→Intel→AMD→NVIDIA→vintage)"
echo "  Firmware:  ALL non-free blobs (WiFi, BT, GPU, sound, microcode)"
echo "  WiFi:      35+ wireless modules (2005-2026 coverage)"
echo "  Storage:   NVMe/SATA/USB/SD + SSD TRIM + BFQ for HDDs"
echo "  Audio:     ALSA + PulseAudio + PipeWire"
echo "  Power:     TLP + thermald (battery optimization)"
echo "  Print:     CUPS + all drivers + scanner support"
echo "  Camera:    V4L2 + cheese"
echo "  Tuning:    BBR congestion, low swappiness, inotify boost"
echo "  Auto:      alfred-hw-detect runs on first boot"
echo "  Mesh:      Lightweight mode for veteran hardware"
echo ""
echo "  No device left behind."
echo "═══════════════════════════════════════════════════"


) || true

# ==========================================
# RESTORED HOOK: 0035-kernel-single-gate.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0035-kernel-single-gate.hook.chroot"
(
set +e
# Description: Build-time gate: purge any non-7.x kernel packages, keep only Alfred Kernel 7
set +euo pipefail

echo "[0150-kernel-single-gate] Installing custom Alfred 7.0 kernel first..."


echo "[0150-kernel-single-gate] checking installed kernel packages..."
mapfile -t KPKGS < <(dpkg-query -W -f='${Package}\n' 'linux-image-*' 2>/dev/null | sed '/^$/d' || true)
if ((${#KPKGS[@]} == 0)); then
  echo "[0150-kernel-single-gate] WARN: no linux-image-* packages installed yet"
fi
BAD=()
for p in "${KPKGS[@]}"; do
  [[ "$p" == linux-image-7* ]] || BAD+=("$p")
done
if ((${#BAD[@]} > 0)); then
  echo "[0150-kernel-single-gate] PURGING non-7 kernel packages: ${BAD[*]}"
  apt-get purge -y --allow-remove-essential "${BAD[@]}" 2>/dev/null || dpkg --purge --force-depends "${BAD[@]}" 2>/dev/null || true
  apt-mark manual linux-image-7* linux-headers-7* 2>/dev/null || true; apt-get autoremove -y 2>/dev/null || true
  echo "[0150-kernel-single-gate] non-7 kernels removed successfully"
fi
kimg="$(ls -1 /boot/vmlinuz-7* 2>/dev/null | sort -V | tail -1 || true)"
if [[ -z "$kimg" ]]; then
  echo "[0150-kernel-single-gate] FATAL: missing /boot/vmlinuz-7*" >&2 || true
  true
fi
echo "[0150-kernel-single-gate] OK: kernel set is 7-only ($(basename "$kimg"))"

) || true

# ==========================================
# RESTORED HOOK: 0036-alfred-sanctuary.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0036-alfred-sanctuary.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
# 0155-alfred-sanctuary.hook.chroot
# Configures the Sanctuary Hypervisor isolation layer (libvirt)

echo "[0155] Configuring Sanctuary Hypervisor (KVM/QEMU Isolation)"

# We ensure the libvirtd service is enabled
systemctl enable libvirtd || true || true || true

# Add default users to libvirt groups so they can manage VMs
# In live-build, user is often 'user' or we can do it dynamically later.
# For now, we make sure the groups exist.
groupadd -f libvirt || true
groupadd -f kvm || true

# Create the isolated "Holy of Holies" libvirt network definition
mkdir -p /etc/libvirt/qemu/networks/autostart || true
cat << 'EOF' > /etc/libvirt/qemu/networks/sanctuary-isolated.xml
<network>
  <name>sanctuary-isolated</name>
  <uuid>c51cd864-16a7-4ab2-990a-11a5871221b6</uuid>
  <bridge name="virbr-sanct" stp="on" delay="0"/>
  <mac address="52:54:00:13:ab:cd"/>
  <domain name="sanctuary.local"/>
  <!-- NO <forward> tag means this network is physically isolated from the host NIC -->
  <ip address="10.77.7.1" netmask="255.255.255.0">
    <dhcp>
      <range start="10.77.7.2" end="10.77.7.254"/>
    </dhcp>
  </ip>
</network>
EOF

# Link it so it autostarts
ln -sf ../sanctuary-isolated.xml /etc/libvirt/qemu/networks/autostart/sanctuary-isolated.xml

echo "[0155] Sanctuary Hypervisor configured."

