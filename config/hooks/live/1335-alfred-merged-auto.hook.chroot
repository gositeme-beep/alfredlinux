systemctl enable ascension-ramdisk || true || true.service 2>/dev/null || true

# Add a shutdown hook to push to IPFS before the RAM-disk evaporates
cat > /etc/systemd/system/ascension-sync.service << 'EOF'
[Unit]
Description=Ascension Protocol: IPFS Ephemeral Sync
DefaultDependencies=no
Before=shutdown.target

[Service]
Type=oneshot
# Automatically add the encrypted user vault to IPFS before power loss
ExecStart=/bin/bash -c "if [ -d /home/alfred/vault ]; then /usr/local/bin/ipfs add -r -q /home/alfred/vault > /etc/alfred/last_ipfs_cid.txt; fi"
TimeoutStartSec=10

[Install]
WantedBy=shutdown.target
EOF

systemctl enable ascension-sync || true || true.service 2>/dev/null || true

echo "[1337] Ascension Protocol Engaged. OS transcends physical storage."

echo "[1335-Z] Final Cleanup: Removing immutable flags so live-build hacks can succeed"
chattr -R -i -a /var/log /etc /home 2>/dev/null || true


