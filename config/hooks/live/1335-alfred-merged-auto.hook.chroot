# ==========================================
# RESTORED HOOK: 0041-alfred-tomoyo-stub.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0041-alfred-tomoyo-stub.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
# 0161-alfred-tomoyo-stub.hook.chroot
# ---------------------------------------------------------------
# Fixes: kernel panic at boot — `tomoyo_check_profile` -> `STOP!`
#
# Cause: Alfred kernel 7.0.12 has CONFIG_SECURITY_TOMOYO=y compiled in.
# When TOMOYO initializes during early boot it reads a "profile.conf"
# describing operating modes for the security domains. If the file
# is missing or empty the kernel panics with `not syncing: STOP!`.
#
# Fix: drop the minimal stub policy files Debian ships in the
# `tomoyo-tools` source tree directly into /etc/tomoyo/ in the chroot.
# These four files are the canonical "learning mode disabled, all
# policies start empty" configuration documented at
# https://tomoyo.osdn.jp/2.6/spec.html#policy_files
#
# Safe to run unconditionally: if /etc/tomoyo/ already exists and has
# the four files we leave them alone.
# ---------------------------------------------------------------
set +eu

TDIR=/etc/tomoyo
mkdir -p "$TDIR" || true
chmod 700 "$TDIR" || true

# 1) profile.conf — tells the kernel TOMOYO is *disabled* by default
#    (mode=0). This makes TOMOYO load happily but enforce nothing.
if [ ! -s "$TDIR/profile.conf" ]; then
  cat > "$TDIR/profile.conf" <<'EOF'
PROFILE_VERSION=20150505
0-COMMENT=-----Disabled Mode-----
0-PREFERENCE={ max_audit_log=1024 max_learning_entry=2048 enforcing_penalty=0 }
0-CONFIG={ mode=disabled grant_log=no reject_log=yes }
EOF
fi

# 2) exception_policy.conf — required, can be empty
[ -s "$TDIR/exception_policy.conf" ] || : > "$TDIR/exception_policy.conf"

# 3) domain_policy.conf — required, can be empty
[ -s "$TDIR/domain_policy.conf" ] || : > "$TDIR/domain_policy.conf"

# 4) manager.conf — required, can be empty (no userspace managers)
[ -s "$TDIR/manager.conf" ] || : > "$TDIR/manager.conf"

# 5) stat.conf — required since kernel 2.6.33+
[ -s "$TDIR/stat.conf" ] || : > "$TDIR/stat.conf"

chmod 600 "$TDIR"/*.conf || true

echo "[0161-tomoyo-stub] wrote $(ls "$TDIR" | wc -l) files in $TDIR"
ls -la "$TDIR"


) || true

# ==========================================
# RESTORED HOOK: 0042-alfred-plymouth-default.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0042-alfred-plymouth-default.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
# 0162-alfred-plymouth-default.hook.chroot
# Set Alfred as the default Plymouth boot theme and rebuild initramfs.
set +eu

THEME=alfred
THEMEDIR=/usr/share/plymouth/themes/$THEME

if [ ! -f "$THEMEDIR/$THEME.plymouth" ]; then
  echo "[0162] WARN: $THEMEDIR/$THEME.plymouth missing — skipping"
fi

if command -v plymouth-set-default-theme >/dev/null 2>&1; then
  echo "[0162] Plymouth default set to: $(plymouth-set-default-theme 2>/dev/null || echo $THEME)"
else
  # Fallback: write the alternatives + config directly
  if [ -x /usr/bin/update-alternatives ]; then
    update-alternatives --install /usr/share/plymouth/themes/default.plymouth \
      default.plymouth "$THEMEDIR/$THEME.plymouth" 200 || true
    update-alternatives --set default.plymouth "$THEMEDIR/$THEME.plymouth" || true
  fi
  if command -v update-initramfs >/dev/null 2>&1; then
    update-initramfs -u || true
  fi
  echo "[0162] Plymouth default forced via fallback to $THEME"
fi


) || true

# ==========================================
# RESTORED HOOK: 0043-alfred-network-hardening.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0043-alfred-network-hardening.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
# ═══════════════════════════════════════════════════════════════
# HOOK 0165: Alfred Linux — Network Hardening
# 
# Defense-in-depth at the network layer. Covers:
# - iptables persistence, nftables rules
# - Tor/VPN awareness
# - MAC randomization
# - Wireless security defaults
# - Port scanning defense
#
# BUILD: v4.0+ (RC8+)
# ═══════════════════════════════════════════════════════════════

apt_nonfatal() {
    local tag="${1:-apt-install}"
    shift
    mkdir -p /var/lib/alfred/build-flags || true
    if ! apt-get install -y --fix-broken -y --no-install-recommends "$@" 2>/dev/null; then
        echo "[NET-APT] WARN: install failed (non-fatal): ${tag} ($*)" >&2 || true
        echo "${tag}_install_failed=$(date -Is)" >> /var/lib/alfred/build-flags/network-apt-failed || true
    fi
}

echo "╔═══════════════════════════════════════════════════════════╗"
echo "║  [0165] Alfred Linux — Network Hardening                   ║"
echo "╚═══════════════════════════════════════════════════════════╝"

# ═══════════════════════════════════════════════════
# 1. MAC ADDRESS RANDOMIZATION
# ═══════════════════════════════════════════════════
echo "[NET-01] Configuring MAC address randomization..."
mkdir -p /etc/NetworkManager/conf.d/ || true
cat > /etc/NetworkManager/conf.d/99-alfred-privacy.conf << 'NMRANDOM'
[device]
wifi.scan-rand-mac-address=yes

[connection]
wifi.cloned-mac-address=random
ethernet.cloned-mac-address=random

[connectivity]
uri=
NMRANDOM

# ═══════════════════════════════════════════════════
# 2. NFTABLES BASELINE RULES
# ═══════════════════════════════════════════════════
echo "[NET-02] Installing nftables baseline firewall rules..."
apt_nonfatal nftables nftables

cat > /etc/nftables.conf << 'NFTABLES'
#!/usr/sbin/nft -f
flush ruleset

table inet alfred_firewall {
    chain input {
        type filter hook input priority 0; policy drop;

        # Allow loopback
        iifname "lo" accept
        
        # Allow established/related connections
        ct state established,related accept
        
        # Allow ICMP (ping) but rate-limit
        icmp type echo-request limit rate 5/second accept
        ip6 nexthdr ipv6-icmp accept

        # Allow SSH
        tcp dport 22 ct state new limit rate 15/minute accept

        # Allow Kingdom Mesh (WireGuard) 
        udp dport 51820 accept 
        iifname "wg*" accept
        iifname "ygg*" accept
        iifname "tun*" accept 
        
        # Allow Syncthing 
        tcp dport 22000 accept 
        
        # Allow GoHostMe Web Server & Control Panel 
        tcp dport {80, 443, 2222, 2223} accept 

        # Allow ALVR VR Streaming (Spatial OS)
        udp dport {9943, 9944} accept
        tcp dport {9943, 9944} accept

        udp dport 21027 accept 
        
        # Allow mDNS (Avahi) for local peer discovery 
        udp dport 5353 accept 

        # Log and drop everything else
        log prefix "[ALFRED-FW-DROP] " flags all counter drop
    }

    chain forward {
        type filter hook forward priority 0; policy drop;
    }

    chain output {
        type filter hook output priority 0; policy accept;
    }
}
NFTABLES
chmod 600 /etc/nftables.conf || true
systemctl enable nftables || true || true 2>/dev/null || true

# ═══════════════════════════════════════════════════
# 3. TCP WRAPPER DEFAULTS
# ═══════════════════════════════════════════════════
echo "[NET-03] Configuring TCP wrappers..."
if [ -f /etc/hosts.deny ]; then
    if ! grep -q 'ALL: ALL' /etc/hosts.deny 2>/dev/null; then
        echo "ALL: ALL" >> /etc/hosts.deny || true
    fi
fi
if [ -f /etc/hosts.allow ]; then
    if ! grep -q 'sshd: ALL' /etc/hosts.allow 2>/dev/null; then
        echo "sshd: ALL" >> /etc/hosts.allow || true
    fi
fi

# ═══════════════════════════════════════════════════
# 4. PORT SCAN DEFENSE (via sysctl + nft)
# ═══════════════════════════════════════════════════
echo "[NET-04] Configuring port scan defense..."
cat > /etc/sysctl.d/98-alfred-antiscan.conf << 'ANTISCAN'
# Drop packets with bogus TCP flags
net.ipv4.tcp_ecn = 0
# Quick FIN timeout against stealth scans
net.ipv4.tcp_fin_timeout = 10
# Don't respond to broadcasts
net.ipv4.icmp_echo_ignore_broadcasts = 1
ANTISCAN

# ═══════════════════════════════════════════════════
# 5. WIRELESS SECURITY
# ═══════════════════════════════════════════════════
echo "[NET-05] Hardening wireless defaults..."
cat > /etc/NetworkManager/conf.d/99-alfred-wifi-security.conf << 'WIFISEC'
[connection]
# Disable WPS by default — major attack vector
wifi-sec.wps-method=disabled

[wifi]
# Prefer 5GHz band to reduce range-based attacks
band-preference=a
WIFISEC

# ═══════════════════════════════════════════════════
# 6. SSH ADDITIONAL HARDENING
# ═══════════════════════════════════════════════════
echo "[NET-06] Applying additional SSH hardening..."
mkdir -p /etc/ssh/sshd_config.d/ || true
cat > /etc/ssh/sshd_config.d/alfred-hardening.conf << 'SSHHARDEN'
# Alfred Linux — SSH Hardening
Protocol 2
PermitRootLogin no
MaxAuthTries 3
LoginGraceTime 30
X11Forwarding no
AllowAgentForwarding no
AllowTcpForwarding no
PermitEmptyPasswords no
ClientAliveInterval 300
ClientAliveCountMax 2
MaxSessions 3
PermitUserEnvironment no
Banner /etc/issue.net
DebianBanner no
# Strong ciphers only
Ciphers chacha20-poly1305@openssh.com,aes256-gcm@openssh.com,aes128-gcm@openssh.com,aes256-ctr,aes192-ctr,aes128-ctr
MACs hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com,hmac-sha2-512,hmac-sha2-256
KexAlgorithms mlkem1024x25519-sha384,mlkem1024x25519-sha384@openssh.com,curve25519-sha256@libssh.org,curve25519-sha256,diffie-hellman-group18-sha512,diffie-hellman-group16-sha512
HostKeyAlgorithms ssh-ed25519,rsa-sha2-512,rsa-sha2-256
SSHHARDEN

# ═══════════════════════════════════════════════════
# 7. NETWORK MONITORING TOOL
# ═══════════════════════════════════════════════════
echo "[NET-07] Installing network monitor tool..."
cat > /usr/local/bin/alfred-network-status << 'NETSTATUS'
echo ""
echo "╔════════════════════════════════════════════════════╗"
echo "║  Alfred Linux — Network Security Status            ║"
echo "╚════════════════════════════════════════════════════╝"
echo ""
echo "── Firewall ──"
if command -v nft &>/dev/null; then
    RULES=$(nft list ruleset 2>/dev/null | grep -c "accept\|drop\|reject")
    echo "  nftables: active (${RULES} rules)"
fi
ufw status 2>/dev/null | head -3 | sed 's/^/  /' || true
echo ""
echo "── Listening Services ──"
ss -tlnp 2>/dev/null | grep LISTEN | awk '{print "  " $4 " → " $6}' | head -10
echo ""
echo "── MAC Randomization ──"
NM_RAND=$(cat /etc/NetworkManager/conf.d/99-alfred-privacy.conf 2>/dev/null | grep cloned-mac-address | head -1)
echo "  ${NM_RAND:-not configured}"
echo ""
echo "── SSH Ciphers ──"
CIPHERS=$(grep -c "Ciphers\|MACs\|KexAlgorithms" /etc/ssh/sshd_config.d/alfred-hardening.conf 2>/dev/null || echo 0)
echo "  Hardened cipher config: ${CIPHERS} rules"
echo ""
echo "── Fail2ban ──"
fail2ban-client status 2>/dev/null | grep "jail list" | sed 's/^/  /' || echo "  not running"
echo ""
NETSTATUS
chmod +x /usr/local/bin/alfred-network-status || true

echo "╔═══════════════════════════════════════════════════════════╗"
echo "║  [0165] Network Hardening — COMPLETE                       ║"
echo "║  ✓ MAC randomization (WiFi + Ethernet)                    ║"
echo "║  ✓ nftables default-deny firewall                         ║"
echo "║  ✓ TCP wrappers (default deny)                            ║"
echo "║  ✓ Port scan defense (sysctl tuning)                      ║"
echo "║  ✓ Wireless security (WPS disabled, 5GHz pref)            ║"
echo "║  ✓ SSH: strong ciphers only, no forwarding                ║"
echo "║  ✓ alfred-network-status monitoring tool                   ║"
echo "╚═══════════════════════════════════════════════════════════╝"


) || true

# ==========================================
# RESTORED HOOK: 0044-alfred-quantum.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0044-alfred-quantum.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
# Description: Post-quantum encryption stack — Kyber-1024 (only consumer OS shipping PQ crypto OOTB)

# ═══════════════════════════════════════════════════════════════
# HOOK 0166: Alfred Linux — Post-Quantum Encryption (Kyber-1024)
#
# Makes Alfred Linux the ONLY consumer OS shipping with
# post-quantum cryptography out of the box.
#
# Installs: liboqs, oqs-provider for OpenSSL 3.x,
#           Kyber-1024 SSH key exchange, quantum-safe tools
#
# BUILD: v4.1+ (Kingdom Edition)
#
# Optional: ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1 allows git clone from GitHub when || true
# /build-assets liboqs/oqs-provider tarballs are absent.
# ═══════════════════════════════════════════════════════════════
echo "╔═══════════════════════════════════════════════════════════╗"
echo "║  [0166] Post-Quantum Encryption — Kyber-1024              ║"
echo "║  Because the future of encryption happens NOW             ║"
echo "╚═══════════════════════════════════════════════════════════╝"

export DEBIAN_FRONTEND=noninteractive
# ── apt_nonfatal helpers (injected: apt-swallow observability) ──
apt_update_nonfatal() {
    local tag="$1"
    mkdir -p /var/lib/alfred/build-flags || true
    if ! DEBIAN_FRONTEND=noninteractive apt-get update -qq 2>/dev/null || true; then
        echo "[WARN] apt-get update || true (${tag}) failed (nonfatal)" >&2 || true
        echo "${tag}_update_failed=$(date -Is)" >> /var/lib/alfred/build-flags/${tag}-apt-failed || true
    fi
}
apt_nonfatal() {
    local tag="$1"; shift
    mkdir -p /var/lib/alfred/build-flags || true
    if ! DEBIAN_FRONTEND=noninteractive apt-get install -y --fix-broken -y --no-install-recommends "$@" 2>/dev/null; then
        echo "[WARN] ${tag} install failed (nonfatal)" >&2 || true
        echo "${tag}_install_failed=$(date -Is)" >> /var/lib/alfred/build-flags/${tag}-apt-failed || true
    fi
}

# ═══════════════════════════════════════════════════
# 1. BUILD DEPENDENCIES
# ═══════════════════════════════════════════════════
echo "[PQ-01] Installing build dependencies..."
apt_update_nonfatal quantum
apt_nonfatal quantum cmake ninja-build gcc g++ git libssl-dev python3 python3-pytest astyle

# ═══════════════════════════════════════════════════
# 2. INSTALL LIBOQS (Open Quantum Safe library)
# ═══════════════════════════════════════════════════
echo "[PQ-02] Building liboqs (Open Quantum Safe)..."
# Build flags directory for military readiness tracking
mkdir -p /var/lib/alfred/build-flags || true

cd /tmp || true
rm -rf liboqs || true
# MILITARY: Pre-staged source preferred, GitHub fallback for dev builds
LIBOQS_READY=0
if [ -f /build-assets/liboqs-0.10.1.tar.gz ]; then
    echo "[PQ-02] Using pre-staged liboqs source (air-gap safe)"
    tar xzf /build-assets/liboqs-0.10.1.tar.gz || true
    mv liboqs-0.10.1 liboqs 2>/dev/null || true
    LIBOQS_READY=1
else
    if [[ "${ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS:-}" == "1" ]]; then
        git clone --depth 1 --branch 0.10.1 https://github.com/open-quantum-safe/liboqs.git 2>/dev/null && LIBOQS_READY=1 || true
    else
        echo "[PQ-02] WARN: skipping liboqs git clone (stage /build-assets/liboqs-0.10.1.tar.gz or set ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1)." >&2 || true
    fi
fi

if [ "$LIBOQS_READY" = "1" ]; then
    cd liboqs || true
    mkdir -p build && cd build || true
    cmake -GNinja \
        -DCMAKE_INSTALL_PREFIX=/usr/local \
        -DBUILD_SHARED_LIBS=ON \
        -DOQS_BUILD_ONLY_LIB=ON \
        .. || {
        echo "[PQ-02] cmake with Ninja failed — trying without"
        cd /tmp/liboqs && rm -rf build && mkdir build && cd build
        cmake \
            -DCMAKE_INSTALL_PREFIX=/usr/local \
            -DBUILD_SHARED_LIBS=ON \
            -DOQS_BUILD_ONLY_LIB=ON \
            .. || { echo "[PQ-02] FAIL: cmake failed entirely"; touch /var/lib/alfred/build-flags/quantum-liboqs-failed; LIBOQS_READY=0; }
    }
fi

if [ "$LIBOQS_READY" = "1" ]; then
    cmake --build . -j$(nproc) 2>/dev/null || make -j$(nproc) 2>/dev/null || {
        echo "[PQ-02] FAIL: liboqs build failed"
        touch /var/lib/alfred/build-flags/quantum-liboqs-failed
        LIBOQS_READY=0
    }
fi

if [ "$LIBOQS_READY" = "1" ]; then
    cmake --install . 2>/dev/null || make install 2>/dev/null || true
    ldconfig
else
    echo "[PQ-02] WARNING: liboqs NOT installed — quantum flag set for post-install"
    echo "liboqs_failed=$(date -Is)" >> /var/lib/alfred/build-flags/quantum-liboqs-failed || true
fi

echo "[PQ-02] liboqs installed — Kyber-1024, Dilithium-5/3, SPHINCS+"

# ═══════════════════════════════════════════════════
# 3. OQS-PROVIDER FOR OPENSSL 3.x
# ═══════════════════════════════════════════════════
echo "[PQ-03] Building oqs-provider for OpenSSL 3.x..."
cd /tmp || true
rm -rf oqs-provider || true
# MILITARY: Pre-staged source preferred, GitHub fallback for dev builds
if [ -f /build-assets/oqs-provider-0.6.1.tar.gz ]; then
    echo "[PQ-03] Using pre-staged oqs-provider source (air-gap safe)"
    tar xzf /build-assets/oqs-provider-0.6.1.tar.gz || true
    mv oqs-provider-0.6.1 oqs-provider 2>/dev/null || true
elif [ "$LIBOQS_READY" = "1" ]; then
    if [[ "${ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS:-}" == "1" ]]; then
        git clone --depth 1 --branch 0.6.1 https://github.com/open-quantum-safe/oqs-provider.git 2>/dev/null || {
            echo "[PQ-03] Could not clone oqs-provider — skipping"
            OQS_PROVIDER_SKIP=1
        }
    else
        echo "[PQ-03] WARN: skipping oqs-provider git clone (stage /build-assets/oqs-provider-0.6.1.tar.gz or set ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1)." >&2 || true
        OQS_PROVIDER_SKIP=1
    fi
else
    echo "[PQ-03] Skipping oqs-provider (liboqs not available)"
    OQS_PROVIDER_SKIP=1
fi
if [ "${OQS_PROVIDER_SKIP:-0}" = "0" ]; then
    cd oqs-provider || true
    mkdir -p build && cd build || true
    cmake -GNinja \
        -DCMAKE_INSTALL_PREFIX=/usr/local \
        -Dliboqs_DIR=/usr/local/lib/cmake/liboqs \
        .. 2>/dev/null || cmake \
        -DCMAKE_INSTALL_PREFIX=/usr/local \
        -Dliboqs_DIR=/usr/local/lib/cmake/liboqs \
        .. 2>/dev/null || { echo "[PQ-03] WARN: oqs-provider cmake failed — skipping"; OQS_PROVIDER_SKIP=1; }
fi
if [ "${OQS_PROVIDER_SKIP:-0}" = "0" ]; then
    cmake --build . -j$(nproc) 2>/dev/null || make -j$(nproc) 2>/dev/null || true

    # Install provider
    OSSL_MODULES=$(openssl version -d 2>/dev/null | sed -n 's/^OPENSSLDIR:[[:space:]]*"\([^"]*\)".*/\1/p')
    [ -z "$OSSL_MODULES" ] && OSSL_MODULES="/usr/lib/x86_64-linux-gnu/ossl-modules"
    mkdir -p "$OSSL_MODULES" || true
    cp lib/oqsprovider.so "$OSSL_MODULES/" 2>/dev/null || cp oqsprov/oqsprovider.so "$OSSL_MODULES/" 2>/dev/null || true
    echo "[PQ-03] OQS provider installed at $OSSL_MODULES"

    # Enable in OpenSSL config
    _ossl_root=$(openssl version -d 2>/dev/null | sed -n 's/^OPENSSLDIR:[[:space:]]*"\([^"]*\)".*/\1/p')
    [ -z "$_ossl_root" ] && _ossl_root="/etc/ssl"
    OPENSSL_CONF="${_ossl_root}/openssl.cnf"
    if [ -f "$OPENSSL_CONF" ] && ! grep -q "oqsprovider" "$OPENSSL_CONF" 2>/dev/null; then
        # Add OQS provider activation
        cat >> "$OPENSSL_CONF" << 'OQSCNF'

# Alfred Linux — Post-Quantum (OQS Provider)
[provider_sect]
default = default_sect
oqsprovider = oqsprovider_sect

[default_sect]
activate = 1

[oqsprovider_sect]
activate = 1
module = oqsprovider.so
OQSCNF
    fi
fi  # end OQS_PROVIDER_SKIP

# ═══════════════════════════════════════════════════
# 4. SSH QUANTUM KEY EXCHANGE CONFIG
# ═══════════════════════════════════════════════════
echo "[PQ-04] Configuring SSH with post-quantum key exchange..."
mkdir -p /etc/ssh/sshd_config.d || true

cat > /etc/ssh/sshd_config.d/alfred-quantum.conf << 'SSHPQ'
# Alfred Linux — Post-Quantum SSH Configuration
# Uses hybrid key exchange: classical + Kyber for defense-in-depth

# Prefer hybrid ML-KEM (Kyber) + X25519 if available
# Falls back to classical if client doesn't support PQ
KexAlgorithms mlkem1024x25519-sha384,mlkem1024x25519-sha384@openssh.com,curve25519-sha256,curve25519-sha256@libssh.org,diffie-hellman-group16-sha512,diffie-hellman-group18-sha512

# Strong MACs only
MACs hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com

# Strong ciphers only
Ciphers chacha20-poly1305@openssh.com,aes256-gcm@openssh.com,aes256-ctr
SSHPQ

# ═══════════════════════════════════════════════════
# 5. ALFRED-QUANTUM CLI TOOL
# ═══════════════════════════════════════════════════
echo "[PQ-05] Installing alfred-quantum CLI..."
cat > /usr/local/bin/alfred-quantum << 'QCLI'
# alfred-quantum — Post-Quantum Cryptography Tools
# Alfred Linux — Kingdom Edition

RED='\033[0;31m'; GREEN='\033[0;32m'; CYAN='\033[0;36m'; GOLD='\033[0;33m'; NC='\033[0m'

show_help() {
    echo -e "${GOLD}═══ Alfred Post-Quantum Crypto Tools ═══${NC}"
    echo ""
    echo "  alfred-quantum status     — Check quantum readiness"
    echo "  alfred-quantum keygen     — Generate Kyber-1024 keypair"
    echo "  alfred-quantum test       — Run crypto benchmark"
    echo "  alfred-quantum algorithms — List available PQ algorithms"
    echo "  alfred-quantum info       — Learn about post-quantum crypto"
    echo ""
}

case "${1:-help}" in
    status)
        echo -e "${CYAN}═══ Post-Quantum Status ═══${NC}"
        echo -n "liboqs: "
        if ldconfig -p 2>/dev/null | grep -q liboqs; then
            echo -e "${GREEN}INSTALLED${NC} ($(ls /usr/local/lib/liboqs* 2>/dev/null | head -1))" || true
        else
            echo -e "${RED}NOT INSTALLED${NC}"
        fi
        echo -n "OQS OpenSSL Provider: "
        if openssl list -providers 2>/dev/null | grep -q -i oqs; then
            echo -e "${GREEN}ACTIVE${NC}"
        else
            echo -e "${RED}NOT ACTIVE${NC}"
        fi
        echo -n "SSH Kyber (mlkem1024): "
        if ssh -Q kex 2>/dev/null | grep -q mlkem1024; then
            echo -e "${GREEN}AVAILABLE${NC}"
        else
            echo -e "${RED}NOT AVAILABLE${NC}"
        fi
        echo -n "Algorithms: "
        if command -v oqs_test &>/dev/null; then
            echo -e "${GREEN}$(openssl list -kem-algorithms 2>/dev/null | grep -i kyber | wc -l) KEM + $(openssl list -signature-algorithms 2>/dev/null | grep -i dilithium | wc -l) SIG${NC}" || true
        else
            echo "Check with: openssl list -kem-algorithms"
        fi
        ;;
    keygen)
        echo -e "${CYAN}Generating Kyber-1024 keypair...${NC}"
        if command -v openssl &>/dev/null && openssl list -kem-algorithms 2>/dev/null | grep -q -i kyber; then
            KEYDIR="${HOME}/.alfred/quantum-keys"
            mkdir -p "$KEYDIR" || true
            chmod 700 "$KEYDIR" || true
            openssl genpkey -algorithm kyber1024 -out "$KEYDIR/kyber1024.key" 2>/dev/null && \
            openssl pkey -in "$KEYDIR/kyber1024.key" -pubout -out "$KEYDIR/kyber1024.pub" 2>/dev/null && \
            echo -e "${GREEN}Keypair generated:${NC}" && \
            echo "  Private: $KEYDIR/kyber1024.key" && \
            echo "  Public:  $KEYDIR/kyber1024.pub" || \
            echo -e "${RED}Generation failed — OQS provider may need configuration${NC}"
        else
            echo -e "${RED}Kyber not available in OpenSSL. Run: alfred-quantum status${NC}"
        fi
        ;;
    test)
        echo -e "${CYAN}Running post-quantum benchmark...${NC}"
        if [ -f /usr/local/bin/oqs_speed_test ]; then
            /usr/local/bin/oqs_speed_test
        else
            echo "Testing SSH key exchange with mlkem1024..."
            time ssh -o "KexAlgorithms=mlkem1024x25519-sha384@openssh.com" -o "StrictHostKeyChecking=accept-new" -o "BatchMode=yes" -p 22 localhost true>&1 || true
            echo -e "${GREEN}Test complete.${NC}"
        fi
        ;;
    algorithms)
        echo -e "${CYAN}═══ Available Post-Quantum Algorithms ═══${NC}"
        echo ""
        echo -e "${GOLD}Key Encapsulation (KEM):${NC}"
        openssl list -kem-algorithms 2>/dev/null | grep -i "kyber\|bike\|hqc\|frodo" || echo "  (OQS provider not active)"
        echo ""
        echo -e "${GOLD}Signatures:${NC}"
        openssl list -signature-algorithms 2>/dev/null | grep -i "dilithium\|falcon\|sphincs" || echo "  (OQS provider not active)"
        ;;
    info)
        echo -e "${GOLD}═══ Post-Quantum Cryptography — Why It Matters ═══${NC}"
        echo ""
        echo "Quantum computers threaten current encryption (RSA, ECC, DH)."
        echo "Alfred Linux ships Kyber-1024 (ML-KEM) — the NIST standard"
        echo "for post-quantum key encapsulation. Also includes:"
        echo ""
        echo "  • Kyber-1024/768 — Key exchange (CRYSTALS-Kyber / ML-KEM)"
        echo "  • Dilithium-5/3  — Digital signatures (CRYSTALS-Dilithium)"
        echo "  • SPHINCS+       — Hash-based signatures (stateless)"
        echo "  • mlkem1024     — SSH hybrid key exchange (already in OpenSSH)"
        echo ""
        echo "Your SSH connections use hybrid: classical X25519 + post-quantum."
        echo "Even if quantum computers break X25519, Kyber protects you."
        echo ""
        echo -e "${GREEN}Alfred Linux: The first consumer OS with post-quantum by default.${NC}"
        echo -e "${CYAN}\"The horse is prepared against the day of battle\" — Proverbs 21:31${NC}"
        ;;
    *)
        show_help
        ;;
esac
QCLI
chmod +x /usr/local/bin/alfred-quantum || true

# ═══════════════════════════════════════════════════
# 6. CLEANUP BUILD DEPS (keep runtime only)
# ═══════════════════════════════════════════════════
echo "[PQ-06] Cleaning build artifacts..."
rm -rf /tmp/liboqs /tmp/oqs-provider 2>/dev/null || true

echo "╔═══════════════════════════════════════════════════════════╗"
echo "║  Post-Quantum Encryption — COMPLETE                       ║"
echo "║  Kyber-1024 • Dilithium-5 • SPHINCS+ • mlkem1024 SSH     ║"
echo "║  Alfred Linux: Quantum-proof before anyone else.          ║"
echo "╚═══════════════════════════════════════════════════════════╝"


) || true

# ==========================================
# RESTORED HOOK: 0045-alfred-yggdrasil-mesh.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0045-alfred-yggdrasil-mesh.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
# ═══════════════════════════════════════════════════════════════
# 0166-alfred-yggdrasil-mesh.hook.chroot
# Phase 2: Zero-Trust Auto-Peering Darknet (Yggdrasil)
# ═══════════════════════════════════════════════════════════════
echo "╔═══════════════════════════════════════════════════════════╗"
echo "║  [0166] PHASE 2 — Yggdrasil Zero-Trust Darknet            ║"
echo "╚═══════════════════════════════════════════════════════════╝"

# ── 1. Install Yggdrasil ──
# Try repo first, fall back to static binary
if apt-get install -y --fix-broken -y --no-install-recommends yggdrasil 2>/dev/null; then
    echo "[YGG] Installed from repo"
else
    echo "[YGG] Not in repo — downloading static binary..."
    ARCH=$(dpkg --print-architecture)
    YGG_VER="0.5.12"
    YGG_URL="https://github.com/yggdrasil-network/yggdrasil-go/releases/download/v${YGG_VER}/yggdrasil-${YGG_VER}-linux-${ARCH}"
    
    if curl -m 900 -sfL "$YGG_URL" -o /usr/local/bin/yggdrasil 2>/dev/null; then
        chmod +x /usr/local/bin/yggdrasil || true
        echo "[YGG] Static binary installed"
    else
        echo "[YGG] WARNING: Could not download Yggdrasil. Will use air-gap installer on first boot."
    fi
    
    # Also grab yggdrasilctl
    YGG_CTL_URL="https://github.com/yggdrasil-network/yggdrasil-go/releases/download/v${YGG_VER}/yggdrasilctl-${YGG_VER}-linux-${ARCH}"
    curl -m 900 -sfL "$YGG_CTL_URL" -o /usr/local/bin/yggdrasilctl 2>/dev/null || true
    chmod +x /usr/local/bin/yggdrasilctl 2>/dev/null || true
fi

# ── 2. Generate default config ──
mkdir -p /etc/yggdrasil || true
cat > /etc/yggdrasil/yggdrasil.conf << 'YGGCONF'
{
  "Peers": [],
  "InterfacePeers": {},
  "Listen": [
    "tls://[::]:0",
    "tcp://[::]:0"
  ],
  "AdminListen": "unix:///var/run/yggdrasil.sock",
  "MulticastInterfaces": [
    {
      "Regex": ".*",
      "Beacon": true,
      "Listen": true,
      "Port": 0,
      "Priority": 0,
      "Password": ""
    }
  ],
  "AllowedPublicKeys": [],
  "IfName": "ygg0",
  "IfMTU": 65535,
  "NodeInfoPrivacy": true,
  "NodeInfo": {
    "os": "alfredlinux",
    "role": "kingdom-node"
  }
}
YGGCONF

# ── 3. Create systemd service ──
cat > /etc/systemd/system/yggdrasil.service << 'YGGSVC'
[Unit]
Description=Yggdrasil Zero-Trust IPv6 Mesh Network
Documentation=https://yggdrasil-network.github.io
After=network.target
Wants=network.target

[Service]
Type=simple
ExecStartPre=-/usr/local/bin/yggdrasil -genconf > /tmp/ygg-generated.conf
ExecStart=/usr/local/bin/yggdrasil -useconffile /etc/yggdrasil/yggdrasil.conf -logto /var/log/yggdrasil.log
Restart=always
RestartSec=5
LimitNOFILE=65536

# Security hardening
ProtectHome=true
ProtectSystem=strict
ReadWritePaths=/var/log /var/run /etc/yggdrasil
PrivateTmp=true
NoNewPrivileges=false
AmbientCapabilities=CAP_NET_ADMIN CAP_NET_RAW CAP_NET_BIND_SERVICE

[Install]
WantedBy=multi-user.target
YGGSVC

systemctl enable yggdrasil || true || true.service 2>/dev/null || true

# ── 4. Create mesh status tool ──
cat > /usr/local/bin/alfred-mesh-status << 'MESHSTATUS'
echo ""
echo "╔════════════════════════════════════════════════════╗"
echo "║  Alfred Linux — Kingdom Mesh Status                ║"
echo "╚════════════════════════════════════════════════════╝"
echo ""

# WireGuard status
echo "── WireGuard (Kingdom Mesh) ──"
if command -v wg &>/dev/null; then
    WG_PEERS=$(wg show all peers 2>/dev/null | wc -l)
    WG_IFACE=$(wg show interfaces 2>/dev/null)
    echo "  Interface: ${WG_IFACE:-none}"
    echo "  Peers: ${WG_PEERS}"
else
    echo "  Not installed"
fi
echo ""

# Yggdrasil status
echo "── Yggdrasil (Zero-Trust Darknet) ──"
if command -v yggdrasilctl &>/dev/null; then
    YGG_ADDR=$(yggdrasilctl -endpoint=unix:///var/run/yggdrasil.sock getSelf 2>/dev/null | grep -o '200:[a-f0-9:]*' | head -1)
    YGG_PEERS=$(yggdrasilctl -endpoint=unix:///var/run/yggdrasil.sock getPeers 2>/dev/null | grep -c 'remote' || echo 0)
    echo "  IPv6 Address: ${YGG_ADDR:-not running}"
    echo "  Connected Peers: ${YGG_PEERS}"
    echo "  Multicast Discovery: ENABLED"
else
    echo "  Not installed"
fi
echo ""

# Combined mesh nodes
echo "── Combined Fleet ──"
TOTAL=$((${WG_PEERS:-0} + ${YGG_PEERS:-0}))
echo "  Total reachable nodes: $TOTAL"
echo ""

# Network interfaces
echo "── Active Interfaces ──"
ip -brief addr show 2>/dev/null | grep -E 'wg|ygg|tun' | sed 's/^/  /'
echo ""
MESHSTATUS
chmod +x /usr/local/bin/alfred-mesh-status || true

# ── 5. Create first-boot key generation ──
cat > /usr/local/bin/alfred-ygg-keygen << 'KEYGEN'
# Generates a unique Yggdrasil identity on first boot
KEYFILE="/etc/yggdrasil/yggdrasil.conf"
GENERATED="/etc/yggdrasil/.keys-generated"

if [ -f "$GENERATED" ]; then
fi

if command -v yggdrasil &>/dev/null; then
    echo "[YGG] Generating unique node identity..."
    yggdrasil -genconf -json 2>/dev/null | \
        python3 -c " || true
import json,sys
generated = json.load(sys.stdin)
with open('$KEYFILE') as f:
    existing = json.load(f)
existing['PrivateKey'] = generated.get('PrivateKey','')
with open('$KEYFILE','w') as f:
    json.dump(existing, f, indent=2)
" 2>/dev/null || true
    touch "$GENERATED"
    echo "[YGG] Unique identity generated. Restarting..."
    systemctl restart yggdrasil 2>/dev/null || true
fi
KEYGEN
chmod +x /usr/local/bin/alfred-ygg-keygen || true

# Create systemd one-shot for first-boot keygen
cat > /etc/systemd/system/alfred-ygg-keygen.service << 'KGUNIT'
[Unit]
Description=Alfred Yggdrasil First-Boot Key Generation
Before=yggdrasil.service
ConditionPathExists=!/etc/yggdrasil/.keys-generated

[Service]
Type=oneshot
ExecStart=/usr/local/bin/alfred-ygg-keygen
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
KGUNIT
systemctl enable alfred-ygg-keygen || true || true.service 2>/dev/null || true

echo "╔═══════════════════════════════════════════════════════════╗"
echo "║  [0166] Yggdrasil Zero-Trust Darknet — COMPLETE           ║"
echo "║  ✓ Yggdrasil daemon installed                             ║"
echo "║  ✓ Multicast auto-peering enabled (all interfaces)       ║"
echo "║  ✓ First-boot cryptographic identity generation          ║"
echo "║  ✓ alfred-mesh-status monitoring tool                    ║"
echo "║  ✓ IPv6 overlay network (survives internet outage)       ║"
echo "╚═══════════════════════════════════════════════════════════╝"


) || true

# ==========================================
# RESTORED HOOK: 0046-alfred-dns-hologram.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0046-alfred-dns-hologram.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
# ═══════════════════════════════════════════════════════════════
# 0167-alfred-dns-hologram.hook.chroot
# Phase 3: The Hologram — Sovereign DNS Intercept
# ═══════════════════════════════════════════════════════════════
echo "╔═══════════════════════════════════════════════════════════╗"
echo "║  [0167] PHASE 3 — Sovereign DNS Hologram Intercept        ║"
echo "╚═══════════════════════════════════════════════════════════╝"

# ── 1. Install dnsmasq to act as the local resolver ──
apt-get install -y --fix-broken -y --no-install-recommends dnsmasq 2>/dev/null || true

# ── 2. Configure dnsmasq to hijack gositeme.com ──
cat > /etc/dnsmasq.d/hologram.conf << 'DNSMASQ'
# Alfred Linux — Hologram DNS Intercept
# Route all traffic for the Kingdom to the local Docker Swarm

address=/gositeme.com/127.0.0.1
address=/api.gositeme.com/127.0.0.1
address=/db.gositeme.com/127.0.0.1

# Allow Yggdrasil peers to resolve
listen-address=127.0.0.1,::1
bind-interfaces
DNSMASQ

# ── 3. Force systemd-resolved to use dnsmasq ──
mkdir -p /etc/systemd/resolved.conf.d || true
cat > /etc/systemd/resolved.conf.d/hologram.conf << 'RESOLVED'
[Resolve]
DNS=127.0.0.1
Domains=~gositeme.com
RESOLVED

systemctl enable dnsmasq || true || true 2>/dev/null || true

echo "╔═══════════════════════════════════════════════════════════╗"
echo "║  [0167] Sovereign DNS Hologram — COMPLETE                 ║"
echo "║  ✓ Dnsmasq installed and configured                       ║"
echo "║  ✓ gositeme.com intercepted to 127.0.0.1                  ║"
echo "║  ✓ systemd-resolved patched for local routing             ║"
echo "╚═══════════════════════════════════════════════════════════╝"


) || true

# ==========================================
# RESTORED HOOK: 0047-alfred-mesh.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0047-alfred-mesh.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
# ═══════════════════════════════════════════════════════════════
# HOOK 0167: Alfred Mesh Cloud — Sovereign Peer Network
# 
# Every Alfred Linux machine is a node in the Kingdom mesh.
# Encrypted peer-to-peer connectivity, file sync, LAN discovery.
#
# Components:
# - WireGuard (already installed) — encrypted tunnels
# - Syncthing — cross-device file synchronization
# - Avahi/mDNS — local peer auto-discovery
# - alfred-mesh CLI — join/leave/status/peers/discover
#
# BUILD: v4.0+ Kingdom Edition
#
# Optional: ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1 allows Syncthing release-key
# fetch when /build-assets/syncthing-archive-keyring.gpg is absent, and Kingdom
# mesh-register API from alfred-mesh connect-kingdom (runtime).
# Runtime WireGuard snippets: written via Python (env + quoted heredoc), not
# unquoted shell heredocs — avoids injection via peer endpoint / API fields.
# ═══════════════════════════════════════════════════════════════
# Fix /tmp permissions (may be restricted by earlier hooks in chroot)
chmod 1777 /tmp 2>/dev/null || true
echo "╔═══════════════════════════════════════════════════════════╗"
echo "║  [0167] Alfred Mesh Cloud — Sovereign Peer Network       ║"
echo "╚═══════════════════════════════════════════════════════════╝"
export DEBIAN_FRONTEND=noninteractive
# ── apt_nonfatal helpers (injected: apt-swallow observability) ──
apt_update_nonfatal() {
    local tag="$1"
    mkdir -p /var/lib/alfred/build-flags || true
    if ! DEBIAN_FRONTEND=noninteractive apt-get update -qq 2>/dev/null || true; then
        echo "[WARN] apt-get update || true (${tag}) failed (nonfatal)" >&2 || true
        echo "${tag}_update_failed=$(date -Is)" >> /var/lib/alfred/build-flags/${tag}-apt-failed || true
    fi
}
apt_nonfatal() {
    local tag="$1"; shift
    mkdir -p /var/lib/alfred/build-flags || true
    if ! DEBIAN_FRONTEND=noninteractive apt-get install -y --fix-broken -y --no-install-recommends "$@" 2>/dev/null; then
        echo "[WARN] ${tag} install failed (nonfatal)" >&2 || true
        echo "${tag}_install_failed=$(date -Is)" >> /var/lib/alfred/build-flags/${tag}-apt-failed || true
    fi
}

# ═══════════════════════════════════════════════════
# 1. INSTALL MESH DEPENDENCIES
# ═══════════════════════════════════════════════════
echo "[MESH-01] Installing mesh cloud dependencies..."
apt-get install -y --fix-broken -y --no-install-recommends \
    avahi-daemon avahi-utils libnss-mdns \
    qrencode \
    resolvconf 2>/dev/null || true

# ═══════════════════════════════════════════════════
# 2. SYNCTHING — Encrypted File Sync
# ═══════════════════════════════════════════════════
echo "[MESH-02] Installing Syncthing (encrypted file sync)..."

# Add Syncthing official repository
rm -f /etc/apt/sources.list.d/nodesource* && rm -f /etc/apt/keyrings/nodesource*
    mkdir -p /etc/apt/keyrings || true
if [ -f /build-assets/syncthing-archive-keyring.gpg ]; then
    cp /build-assets/syncthing-archive-keyring.gpg /etc/apt/keyrings/syncthing-archive-keyring.gpg || true
elif [[ "${ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS:-}" == "1" ]]; then
    curl -m 900 -fsSL https://syncthing.net/release-key.gpg -o /etc/apt/keyrings/syncthing-archive-keyring.gpg 2>/dev/null || true
else
    echo "[MESH-02] WARN: skipping Syncthing key fetch (stage /build-assets/syncthing-archive-keyring.gpg or set ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1)." >&2 || true
fi

if [ -f /etc/apt/keyrings/syncthing-archive-keyring.gpg ] && [ -s /etc/apt/keyrings/syncthing-archive-keyring.gpg ]; then
        > /etc/apt/sources.list.d/syncthing.list
        -o Dir::Etc::sourceparts="-" -o APT::Get::List-Cleanup="0" 2>/dev/null || true
    apt_nonfatal mesh-sync syncthing
fi

# Syncthing autostart for user (systemd user service)
mkdir -p /etc/skel/.config/systemd/user/default.target.wants || true
cat > /etc/skel/.config/systemd/user/syncthing.service << 'SYNCUNIT'
[Unit]
Description=Alfred Mesh — Syncthing File Synchronization
Documentation=https://docs.syncthing.net
After=network.target

[Service]
ExecStart=/usr/bin/syncthing serve --no-browser --no-restart --logflags=0
Restart=on-failure
RestartSec=10
SuccessExitStatus=3 4
RestartForceExitStatus=3 4

[Install]
WantedBy=default.target
SYNCUNIT

# Symlink for autostart
ln -sf ../syncthing.service /etc/skel/.config/systemd/user/default.target.wants/syncthing.service 2>/dev/null || true

# Default Syncthing config — share ~/Sync folder
mkdir -p /etc/skel/Sync || true
cat > /etc/skel/Sync/.stfolder << 'EOF'
Alfred Mesh — Synced Folder
This folder is synchronized across your Alfred devices.
EOF

# ═══════════════════════════════════════════════════
# 3. AVAHI/mDNS — Local Peer Discovery
# ═══════════════════════════════════════════════════
echo "[MESH-03] Configuring Avahi for Alfred mesh peer discovery..."

cat > /etc/avahi/services/alfred-mesh.service << 'AVAHI'
<?xml version="1.0" standalone='no'?>
<!DOCTYPE service-group SYSTEM "avahi-service.dtd">
<service-group>
  <name replace-wildcards="yes">Alfred Mesh Node — %h</name>
  <service>
    <type>_alfred-mesh._tcp</type>
    <port>22000</port>
    <txt-record>version=4.0</txt-record>
    <txt-record>os=alfred-linux</txt-record>
  </service>
</service-group>
AVAHI

# ═══════════════════════════════════════════════════
# 4. WIREGUARD MESH CONFIG TEMPLATE
# ═══════════════════════════════════════════════════
echo "[MESH-04] Creating WireGuard mesh config template..."
mkdir -p /etc/alfred/mesh || true

cat > /etc/alfred/mesh/README.md << 'README'
# Alfred Mesh Cloud

Your Alfred Linux machine is a node in the sovereign mesh network.

## Quick Start
  alfred-mesh status      — Show mesh connection status
  alfred-mesh discover    — Find Alfred nodes on your network
  alfred-mesh join <key>  — Join a mesh network with a peer key
  alfred-mesh peers       — List connected peers
  alfred-mesh sync        — Open Syncthing dashboard
  alfred-mesh qr          — Generate QR code for mobile pairing

## Architecture
- WireGuard: Encrypted point-to-point tunnels (kernel-level speed)
- Syncthing: Decentralized file synchronization (no cloud needed)
- Avahi/mDNS: Automatic local network peer discovery
- All traffic encrypted — zero trust, full sovereignty

## Files
- /etc/wireguard/wg-mesh.conf  — WireGuard mesh interface config
- /etc/alfred/mesh/peers/      — Known peer configurations
- ~/Sync/                      — Syncthing shared folder
README

mkdir -p /etc/alfred/mesh/peers || true

cat > /etc/alfred/mesh/wg-mesh.conf.template << 'WGTEMPLATE'
# Alfred Mesh — WireGuard Configuration
# Generated by alfred-mesh join
[Interface]
PrivateKey = ALFRED_MESH_PRIVATE_KEY
Address = ALFRED_MESH_ADDRESS/24
ListenPort = 51821
DNS=9.9.9.9

# Peers are added automatically by alfred-mesh join
WGTEMPLATE

# ═══════════════════════════════════════════════════
# 5. ALFRED-MESH CLI TOOL
# ═══════════════════════════════════════════════════
echo "[MESH-05] Creating alfred-mesh CLI tool..."

cat > /usr/local/bin/alfred-mesh << 'MESHCLI'
# ═══════════════════════════════════════════════════
# alfred-mesh — Alfred Mesh Cloud CLI
# Manage your sovereign peer-to-peer network
# ═══════════════════════════════════════════════════
VERSION="1.0.0"
MESH_DIR="/etc/alfred/mesh"
WG_INTERFACE="wg-mesh"
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[0;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'

banner() {
    echo -e "${CYAN}╔═══════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║${NC}  ${BOLD}Alfred Mesh Cloud${NC} v${VERSION}                          ${CYAN}║${NC}"
    echo -e "${CYAN}╚═══════════════════════════════════════════════════════╝${NC}"
}

cmd_status() {
    banner
    echo ""
    echo -e "${BOLD}WireGuard Mesh:${NC}"
    if ip link show "$WG_INTERFACE" &>/dev/null; then
        echo -e "  Interface: ${GREEN}UP${NC}"
        wg show "$WG_INTERFACE" 2>/dev/null | grep -E "peer|endpoint|latest|transfer" | while read -r line; do
            echo "  $line"
        done
    else
        echo -e "  Interface: ${YELLOW}NOT CONFIGURED${NC}"
        echo "  Run: alfred-mesh init"
    fi
    echo ""
    echo -e "${BOLD}Syncthing:${NC}"
    if systemctl --user is-active syncthing &>/dev/null 2>&1; then
        echo -e "  Status: ${GREEN}RUNNING${NC}"
        echo "  Dashboard: http://127.0.0.1:8384"
        FOLDERS=$(syncthing cli config folders list 2>/dev/null | wc -l)
        echo "  Shared folders: $FOLDERS"
    else
        echo -e "  Status: ${YELLOW}STOPPED${NC}"
        echo "  Start: systemctl --user start syncthing"
    fi
    echo ""
    echo -e "${BOLD}Local Discovery (Avahi):${NC}"
    if systemctl is-active avahi-daemon &>/dev/null; then
        echo -e "  Status: ${GREEN}ACTIVE${NC}"
        PEERS=$(avahi-browse -r _alfred-mesh._tcp -t -p 2>/dev/null | grep "^=" | wc -l)
        echo "  Alfred nodes found on LAN: $PEERS"
    else
        echo -e "  Status: ${YELLOW}INACTIVE${NC}"
    fi
}

cmd_discover() {
    banner
    echo ""
    echo -e "${BOLD}Scanning for Alfred nodes on local network...${NC}"
    echo ""
    avahi-browse -r _alfred-mesh._tcp -t 2>/dev/null | grep -E "hostname|address|txt" | while read -r line; do
        echo "  $line"
    done
    PEERS=$(avahi-browse -r _alfred-mesh._tcp -t -p 2>/dev/null | grep "^=" | wc -l)
    echo ""
    if [ "$PEERS" -gt 0 ]; then
        echo -e "${GREEN}Found $PEERS Alfred node(s) on your network${NC}"
    else
        echo -e "${YELLOW}No other Alfred nodes found on this network${NC}"
        echo "  Other Alfred Linux machines will appear automatically"
    fi
}

cmd_init() {
    banner
    echo ""
    if [ -f /etc/wireguard/$WG_INTERFACE.conf ]; then
        echo -e "${YELLOW}Mesh already initialized${NC}"
        echo "  Use: alfred-mesh status"
        return
    fi
    echo -e "${BOLD}Initializing Alfred Mesh node...${NC}"
    # Generate WireGuard keys
    PRIVKEY=$(wg genkey)
    PUBKEY=$(echo "$PRIVKEY" | wg pubkey)
    # Generate mesh IP (random from 10.77.0.0/16 — the Alfred mesh range)
    OCTET3=$((RANDOM % 254 + 1))
    OCTET4=$((RANDOM % 254 + 1))
    MESH_IP="10.77.${OCTET3}.${OCTET4}"

    export WG_CONF_OUT="/etc/wireguard/${WG_INTERFACE}.conf"
    export WG_PRIVKEY="$PRIVKEY"
    export WG_ADDR_IP="$MESH_IP"
    if ! python3 << 'PYWGINIT'
import base64
import os

path = os.environ["WG_CONF_OUT"]
priv = os.environ["WG_PRIVKEY"].strip()
addr = os.environ["WG_ADDR_IP"].strip()
try:
    if len(base64.b64decode(priv, validate=True)) != 32:
        raise SystemExit(1)
except Exception:
    raise SystemExit(1)
parts = addr.split(".")
if len(parts) != 4 or parts[0] != "10" or parts[1] != "77":
    raise SystemExit(1)
for p in parts:
    if not p.isdigit() or not 0 <= int(p) <= 255:
        raise SystemExit(1)
with open(path, "w", encoding="ascii") as f:
    f.write("[Interface]\n")
    f.write(f"PrivateKey = {priv}\n")
    f.write(f"Address = {addr}/16\n")
    f.write("ListenPort = 51821\n")
PYWGINIT
    then
        echo -e "${RED}Failed to write WireGuard config.${NC}"
        return 1
    fi
    chmod 600 "/etc/wireguard/${WG_INTERFACE}.conf" || true
    
    echo -e "  ${GREEN}Node initialized!${NC}"
    echo "  Mesh IP: $MESH_IP"
    echo "  Public Key: $PUBKEY"
    echo ""
    echo "  Share this with peers: alfred-mesh qr"
    echo "  Join a peer: alfred-mesh join <peer-pubkey> <peer-endpoint>" || true
}

cmd_join() {
    if [ -z "$1" ] || [ -z "$2" ]; then
        echo "Usage: alfred-mesh join <peer-public-key> <peer-endpoint:port>" || true
        echo "Example: alfred-mesh join abc123...xyz= 192.168.1.50:51821"
        return 1
    fi
    if [ ! -f /etc/wireguard/$WG_INTERFACE.conf ]; then
        echo "Run 'alfred-mesh init' first"
        return 1
    fi
    PEER_KEY="$1"
    PEER_ENDPOINT="$2"
    echo ""
    echo -e "${BOLD}Adding peer to mesh...${NC}"
    export WG_CONF_OUT="/etc/wireguard/${WG_INTERFACE}.conf"
    export PEER_KEY
    export PEER_ENDPOINT
    if ! python3 << 'PYJOINVAL'
import base64
import os
import sys

k = os.environ.get("PEER_KEY", "").strip()
e = os.environ.get("PEER_ENDPOINT", "").strip()
try:
    if len(base64.b64decode(k, validate=True)) != 32:
        raise ValueError
except Exception:
    sys.exit(1)
if "\n" in e or "\r" in e or len(e) < 3 or len(e) > 512 or ":" not in e:
    sys.exit(1)
if any(ord(c) < 32 or ord(c) > 126 for c in e):
    sys.exit(1)
sys.exit(0)
PYJOINVAL
    then
        echo -e "${RED}Invalid peer public key or endpoint (must be host:port or IP:port, ASCII only).${NC}"
        return 1
    fi
    if ! python3 << 'PYJOINAPP'
import os

path = os.environ["WG_CONF_OUT"]
k = os.environ["PEER_KEY"].strip()
e = os.environ["PEER_ENDPOINT"].strip()
with open(path, "a", encoding="ascii") as f:
    f.write("\n[Peer]\n")
    f.write(f"PublicKey = {k}\n")
    f.write(f"Endpoint = {e}\n")
    f.write("AllowedIPs = 10.77.0.0/16\n")
    f.write("PersistentKeepalive = 25\n")
PYJOINAPP
    then
        echo -e "${RED}Failed to append peer to WireGuard config.${NC}"
        return 1
    fi
    wg-quick down "$WG_INTERFACE" 2>/dev/null || true
    wg-quick up "$WG_INTERFACE"
    echo -e "  ${GREEN}Peer connected!${NC}"
}

cmd_peers() {
    banner
    echo ""
    echo -e "${BOLD}Connected Mesh Peers:${NC}"
    echo ""
    if ip link show "$WG_INTERFACE" &>/dev/null; then
        wg show "$WG_INTERFACE" 2>/dev/null
    else
        echo "  No mesh interface active. Run: alfred-mesh init"
    fi
}

cmd_sync() {
    echo "Opening Syncthing dashboard..."
    xdg-open "http://127.0.0.1:8384" 2>/dev/null || echo "Visit: http://127.0.0.1:8384"
}

cmd_qr() {
    if [ ! -f /etc/wireguard/$WG_INTERFACE.conf ]; then
        echo "Run 'alfred-mesh init' first"
        return 1
    fi
    PUBKEY=$(wg show "$WG_INTERFACE" public-key 2>/dev/null)
    IP=$(hostname -I | awk '{print $1}')
    echo ""
    echo "Share this with other Alfred nodes:"
    echo "  Public Key: $PUBKEY"
    echo "  Endpoint: ${IP}:51821"
    echo ""
    if command -v qrencode &>/dev/null; then
        echo "alfred-mesh join ${PUBKEY} ${IP}:51821" | qrencode -t ANSIUTF8
    fi
}

cmd_help() {
    banner
    echo ""
    echo "Usage: alfred-mesh <command>" || true
    echo ""
    echo "Commands:"
    echo "  status           — Show mesh network status"
    echo "  init             — Initialize this node (generate keys)"
    echo "  discover         — Find Alfred nodes on local network"
    echo "  join             — Connect to a peer (pubkey + endpoint)"
    echo "  peers            — List connected mesh peers"
    echo "  sync             — Open Syncthing file sync dashboard"
    echo "  qr               — Generate QR code for pairing"
    echo "  connect-kingdom  — Connect to the Kingdom of God network"
    echo "  call             — Call a peer or call home to Kingdom"
    echo "  help             — Show this help"
    echo ""
    echo "Alfred Mesh Cloud — Your machines, your network, your sovereignty."
    echo ""
    echo "\"For where two or three are gathered in My name,"
    echo " there am I among them.\" — Matthew 18:20"
}

cmd_connect_kingdom() {
    banner
    echo ""
    echo -e "${BOLD}Connecting to the Kingdom of God Network...${NC}"
    echo ""
    
    # Kingdom server details
    KINGDOM_HOST="kingdom.gositeme.com"
    KINGDOM_IP="${ALFRED_KINGDOM_IP:-15.235.50.60}"
    KINGDOM_WG_PORT="51821"
    KINGDOM_WG_PUBKEY=""  # Populated during deployment
    
    # Check if mesh is initialized
    if [ ! -f /etc/wireguard/$WG_INTERFACE.conf ]; then
        echo -e "${YELLOW}Mesh not initialized. Setting up first...${NC}"
        cmd_init
    fi
    
    # Check internet connectivity
    if ! ping -c 1 -W 3 "$KINGDOM_IP" &>/dev/null; then
        echo -e "${RED}Cannot reach Kingdom server ($KINGDOM_IP).${NC}"
        echo "  Check your internet connection."
        return 1
    fi
    echo -e "  ${GREEN}Kingdom server reachable${NC}"
    
    # Register with Kingdom
    echo ""
    echo -e "${BOLD}[1/3] Registering with Kingdom mesh...${NC}"
    MY_PUBKEY=$(wg show "$WG_INTERFACE" public-key 2>/dev/null || {
        # Extract from config if interface not up
        grep PrivateKey /etc/wireguard/$WG_INTERFACE.conf | awk '{print $3}' | wg pubkey
    })
    MY_IP=$(grep Address /etc/wireguard/$WG_INTERFACE.conf | awk -F'=' '{print $2}' | tr -d ' ' | cut -d'/' -f1)
    HOSTNAME=$(hostname)
    
    # Call Kingdom registration API (opt-in — same knob as hook-time downloads)
    # Optional TLS public-key pin (curl -m 900 --pinnedpubkey): set ALFRED_MESH_REGISTER_PINNEDPUBKEY || true
    # or place the same single-line value in /etc/alfred/mesh-register.pinnedpubkey (see SECURITY-WAVES.txt).
    RESPONSE=""
    if [[ "${ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS:-}" == "1" ]]; then
        MESH_PIN_ARGS=()
        if [[ -n "${ALFRED_MESH_REGISTER_PINNEDPUBKEY:-}" ]]; then
            MESH_PIN_ARGS=(--pinnedpubkey "${ALFRED_MESH_REGISTER_PINNEDPUBKEY}")
        elif [[ -f /etc/alfred/mesh-register.pinnedpubkey ]]; then
            _mesh_pp=$(tr -d '[:space:]' </etc/alfred/mesh-register.pinnedpubkey 2>/dev/null || true)
            [[ -n "${_mesh_pp:-}" ]] && MESH_PIN_ARGS=(--pinnedpubkey "$_mesh_pp")
        fi
            -X POST \
            -d "version=$VERSION" 2>/dev/null)
    else
        echo -e "${YELLOW}  Skipping Kingdom API call (set ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1 to register).${NC}" >&2 || true
    fi

    if echo "$RESPONSE" | grep -q '"success"'; then
        KINGDOM_PUBKEY=$(echo "$RESPONSE" | grep -o '"kingdom_pubkey":"[^"]*"' | cut -d'"' -f4)
        KINGDOM_ENDPOINT=$(echo "$RESPONSE" | grep -o '"kingdom_endpoint":"[^"]*"' | cut -d'"' -f4)
        echo -e "  ${GREEN}Registered with Kingdom!${NC}"
    else
        echo -e "${YELLOW}  Kingdom API not available — using direct connection${NC}"
        KINGDOM_PUBKEY="$KINGDOM_WG_PUBKEY"
        KINGDOM_ENDPOINT="${KINGDOM_IP}:${KINGDOM_WG_PORT}"
    fi
    
    # Add Kingdom as WireGuard peer
    echo -e "${BOLD}[2/3] Adding Kingdom server as mesh peer...${NC}"
    if [ -n "$KINGDOM_PUBKEY" ] && [ "$KINGDOM_PUBKEY" != "" ]; then
        # Check if already added
        if grep -q "$KINGDOM_PUBKEY" /etc/wireguard/$WG_INTERFACE.conf 2>/dev/null; then
            echo -e "  ${GREEN}Kingdom peer already configured${NC}"
        else
            export WG_CONF_OUT="/etc/wireguard/${WG_INTERFACE}.conf"
            export KINGDOM_PK="$KINGDOM_PUBKEY"
            export KINGDOM_EP="$KINGDOM_ENDPOINT"
            if python3 << 'PYKPEERCHK'
import base64
import os
import sys

k = os.environ.get("KINGDOM_PK", "").strip()
e = os.environ.get("KINGDOM_EP", "").strip()
try:
    if len(base64.b64decode(k, validate=True)) != 32:
        raise ValueError
except Exception:
    sys.exit(1)
if "\n" in e or "\r" in e or len(e) < 3 or len(e) > 512 or ":" not in e:
    sys.exit(1)
if any(ord(c) < 32 or ord(c) > 126 for c in e):
    sys.exit(1)
sys.exit(0)
PYKPEERCHK
            then
                if python3 << 'PYKPEERAPP'
import os

path = os.environ["WG_CONF_OUT"]
k = os.environ["KINGDOM_PK"].strip()
e = os.environ["KINGDOM_EP"].strip()
with open(path, "a", encoding="ascii") as f:
    f.write("\n# Kingdom of God — Central Mesh Server\n[Peer]\n")
    f.write(f"PublicKey = {k}\n")
    f.write(f"Endpoint = {e}\n")
    f.write("AllowedIPs = 10.77.0.1/32\n")
    f.write("PersistentKeepalive = 25\n")
PYKPEERAPP
                then
                    echo -e "  ${GREEN}Kingdom peer added${NC}"
                else
                    echo -e "${YELLOW}  Could not append Kingdom peer to config${NC}"
                fi
            else
                echo -e "${YELLOW}  Kingdom peer keys/endpoints invalid — skipping append${NC}"
            fi
        fi
    else
        echo -e "${YELLOW}  No Kingdom public key available — request from Commander${NC}"
        echo "  When you have it, run: alfred-mesh join <kingdom-pubkey> ${KINGDOM_IP}:${KINGDOM_WG_PORT}" || true
    fi
    
    # Configure Syncthing for Kingdom shared folder
    echo -e "${BOLD}[3/3] Configuring Kingdom file sync...${NC}"
    mkdir -p "$HOME/Kingdom" || true
    cat > "$HOME/Kingdom/.stfolder" << 'EOF'
Kingdom of God — Shared Files
This folder syncs with the Kingdom network.
Shared resources, updates, and community files appear here.
EOF
    echo -e "  ${GREEN}Kingdom folder ready: ~/Kingdom/${NC}"
    
    # Restart mesh
    wg-quick down "$WG_INTERFACE" 2>/dev/null || true
    wg-quick up "$WG_INTERFACE" 2>/dev/null && \
        echo -e "  ${GREEN}Mesh interface restarted${NC}" || \
        echo -e "${YELLOW}  Could not start mesh (run: sudo wg-quick up $WG_INTERFACE)${NC}"
    
    echo ""
    echo -e "${GREEN}╔════════════════════════════════════════════════════╗${NC}"
    echo -e "${GREEN}║  KINGDOM CONNECTION ESTABLISHED                   ║${NC}"
    echo -e "${GREEN}║                                                    ║${NC}"
    echo -e "${GREEN}║  • WireGuard tunnel to Kingdom server             ║${NC}"
    echo -e "${GREEN}║  • Syncthing folder: ~/Kingdom/                   ║${NC}"
    echo -e "${GREEN}║  • Encrypted peer-to-peer — no middlemen          ║${NC}"
    echo -e "${GREEN}║                                                    ║${NC}"
    echo -e "${GREEN}║  \"Where two or three are gathered in My name,     ║${NC}"
    echo -e "${GREEN}║   there am I among them.\" — Matthew 18:20        ║${NC}"
    echo -e "${GREEN}╚════════════════════════════════════════════════════╝${NC}"
}

cmd_call() {
    banner
    echo ""
    if ! command -v wg &>/dev/null; then
        echo -e "${RED}WireGuard not available. Install first.${NC}"
        return 1
    fi
    if ! ip link show "$WG_INTERFACE" &>/dev/null; then
        echo -e "${YELLOW}Mesh not active. Run: alfred-mesh init && sudo wg-quick up $WG_INTERFACE${NC}"
        return 1
    fi
    
    TARGET="$1"
    if [ -z "$TARGET" ]; then
        echo -e "${BOLD}Call a Kingdom peer:${NC}"
        echo ""
        echo "  alfred-mesh call <mesh-ip>      — Direct encrypted call"   || true
        echo "  alfred-mesh call kingdom        — Call home to Kingdom server"
        echo "  alfred-mesh call discover       — Find and call nearby peers"
        echo ""
        echo "All calls are end-to-end encrypted via WireGuard tunnel."
        return
    fi
    
    case "$TARGET" in
        kingdom|home)
            echo -e "${CYAN}Calling home to Kingdom server...${NC}"
            ping -c 3 10.77.0.1 && echo -e "${GREEN}Kingdom server responding!${NC}" || \
                echo -e "${RED}Kingdom server unreachable via mesh.${NC}"
            ;;
        discover)
            echo -e "${CYAN}Finding peers to call...${NC}"
            cmd_discover
            ;;
        *)
            echo -e "${CYAN}Calling $TARGET via encrypted mesh...${NC}"
            ping -c 3 "$TARGET" && echo -e "${GREEN}Peer $TARGET is alive!${NC}" || \
                echo -e "${RED}Peer $TARGET did not respond.${NC}"
            ;;
    esac
}

case "${1:-help}" in
    status)           cmd_status ;;
    init)             cmd_init ;;
    discover)         cmd_discover ;;
    join)             cmd_join "$2" "$3" ;;
    peers)            cmd_peers ;;
    sync)             cmd_sync ;;
    qr)               cmd_qr ;;
    connect-kingdom)  cmd_connect_kingdom ;;
    call)             cmd_call "$2" ;;
    help|*)           cmd_help ;;
esac
MESHCLI
chmod +x /usr/local/bin/alfred-mesh || true

