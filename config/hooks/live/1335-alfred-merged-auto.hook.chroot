# ── Shared JavaScript engine that reads TSV Bible data ──
cat > "$EDITIONS_DIR/bible-engine.js" << 'JSEOF'
// Alfred Bible Engine — reads TSV data and renders chapters
const BibleEngine = {
  data: [], books: [], loaded: false,
  async load(path) {
    if (this.loaded) return;
    // Try paths in order: relative (via local HTTP server), root, file://
    const paths = [path, '../akjv-bible.tsv', '/akjv-bible.tsv'].filter(Boolean);
    for (const p of paths) {
      try {
        const r = await fetch(p);
        if (!r.ok) continue;
        const t = await r.text();
        this.data = t.trim().split('\n').slice(1).map(l => {
          const [book, ch, vs, text] = l.split('\t');
          return { book, ch: +ch, vs: +vs, text };
        });
        this.books = [...new Set(this.data.map(v => v.book))];
        this.loaded = true;
        return;
      } catch(e) { continue; }
    }
    console.error('Bible load failed: no path worked');
  },
  getBooks() { return this.books; },
  getChapters(book) {
    const chs = new Set(this.data.filter(v => v.book.toLowerCase() === book.toLowerCase()).map(v => v.ch));
    return [...chs].sort((a,b) => a-b);
  },
  getVerses(book, ch) {
    return this.data.filter(v => v.book.toLowerCase() === book.toLowerCase() && v.ch === ch)
      .sort((a,b) => a.vs - b.vs);
  },
  search(q, max=50) {
    const lq = q.toLowerCase();
    return this.data.filter(v => v.text.toLowerCase().includes(lq)).slice(0, max);
  },
  random() { return this.data[Math.floor(Math.random() * this.data.length)]; },
  daily() {
    const d = Math.floor((Date.now() / 86400000) % this.data.length);
    return this.data[d];
  }
};
JSEOF

# ── Shared CSS for all offline editions ──
cat > "$EDITIONS_DIR/editions.css" << 'CSSEOF'
*{margin:0;padding:0;box-sizing:border-box}
:root{--bg:#0a0a0f;--surface:rgba(255,255,255,.03);--border:rgba(255,215,0,.12);--gold:#ffd700;--white:#f0f0f5;--muted:rgba(240,240,245,.5);--dim:rgba(240,240,245,.3)}
body{background:var(--bg);color:var(--white);font-family:Georgia,'Times New Roman',serif;line-height:1.7}
.app{max-width:900px;margin:0 auto;padding:1rem 1.5rem 4rem}
header{text-align:center;padding:2rem 0;border-bottom:1px solid var(--border)}
header h1{font-size:2rem;color:var(--gold);margin-bottom:.3rem}
header .sub{color:var(--muted);font-style:italic;font-size:.95rem}
header .scripture{color:rgba(255,215,0,.6);font-size:.8rem;margin-top:.5rem}
nav.books{display:flex;flex-wrap:wrap;gap:.4rem;padding:1rem 0;border-bottom:1px solid var(--border)}
nav.books a{color:var(--muted);text-decoration:none;padding:.25rem .5rem;border-radius:4px;font-size:.82rem;border:1px solid transparent;transition:.2s}
nav.books a:hover,nav.books a.active{color:var(--gold);border-color:var(--border);background:var(--surface)}
.chapter-nav{display:flex;flex-wrap:wrap;gap:.3rem;padding:.8rem 0}
.chapter-nav a{color:var(--dim);text-decoration:none;padding:.2rem .45rem;border-radius:3px;font-size:.8rem;border:1px solid transparent;transition:.2s}
.chapter-nav a:hover,.chapter-nav a.active{color:var(--gold);border-color:var(--border);background:var(--surface)}
.verses{padding:1rem 0}
.verse{margin-bottom:.6rem;line-height:1.8}
.verse .vnum{color:var(--gold);font-size:.75rem;vertical-align:super;margin-right:.2rem;font-weight:700}
.search-box{width:100%;padding:.6rem 1rem;background:var(--surface);border:1px solid var(--border);border-radius:6px;color:var(--white);font-size:1rem;margin:1rem 0;outline:none}
.search-box:focus{border-color:var(--gold)}
.search-results .result{padding:.6rem 0;border-bottom:1px solid rgba(255,255,255,.05)}
.search-results .ref{color:var(--gold);font-size:.85rem;font-weight:700}
.back-hub{display:inline-block;color:var(--gold);text-decoration:none;padding:.5rem 0;font-size:.85rem;margin-bottom:1rem}
.back-hub:hover{text-decoration:underline}
footer{text-align:center;padding:2rem 0;color:var(--dim);font-size:.8rem;border-top:1px solid var(--border);margin-top:2rem}
/* RTL support */
[dir="rtl"] .verse{direction:rtl;text-align:right}
[dir="rtl"] .vnum{margin-right:0;margin-left:.2rem}
/* Children's edition overrides */
.children-mode .verse{font-size:1.15rem;line-height:2;background:rgba(34,197,94,.04);padding:.8rem 1rem;border-radius:8px;margin-bottom:.8rem;border-left:3px solid #22c55e}
/* Chabad overrides */
