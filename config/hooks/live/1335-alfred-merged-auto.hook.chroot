    libssl-dev uuid-dev libdevmapper-dev libpopt-dev \
    libjson-c-dev autoconf automake libtool git jq \
    dpkg-dev libcryptsetup-dev ssss curl

# 1. Compile liboqs
mkdir -p /usr/src/pq-crypto
cd /usr/src/pq-crypto
if [ -f /opt/alfred-offline-assets/liboqs-0.10.1.tar.gz ]; then
    tar -xzf /opt/alfred-offline-assets/liboqs-0.10.1.tar.gz
    mv liboqs-0.10.1 liboqs
else
    git clone --depth 1 -b 0.10.1 https://github.com/open-quantum-safe/liboqs.git
fi

cd liboqs
mkdir build && cd build
cmake -GNinja -DOQS_USE_OPENSSL=ON -DBUILD_SHARED_LIBS=ON -DCMAKE_INSTALL_PREFIX=/usr ..
ninja
ninja install
ldconfig

# 2. Compile custom PQ Token
mkdir -p /usr/src/pq-token
cp /opt/alfred-offline-assets/pq_token.c /usr/src/pq-token/ || echo "pq_token.c not found"

cd /usr/src/pq-token
if [ -f pq_token.c ]; then
    gcc -shared -fPIC -o libcryptsetup-token-pq.so pq_token.c -lcryptsetup -loqs -Wl,-z,defs
    mkdir -p /usr/lib/x86_64-linux-gnu/cryptsetup
    cp libcryptsetup-token-pq.so /usr/lib/x86_64-linux-gnu/cryptsetup/
    chmod 755 /usr/lib/x86_64-linux-gnu/cryptsetup/libcryptsetup-token-pq.so
fi

# 3. Polymorphic Mutator Daemon
cat << 'EOF' > /etc/systemd/system/alfred-polymorph.service
[Unit]
Description=Polymorphic ML-KEM Key Mutator
DefaultDependencies=no
Before=shutdown.target

[Service]
Type=oneshot
ExecStart=/usr/local/sbin/alfred-polymorph-mutate

[Install]
WantedBy=shutdown.target
EOF

cat << 'EOF' > /usr/local/sbin/alfred-polymorph-mutate
#!/bin/bash
echo "MUTATING ML-KEM KEYS..." > /dev/kmsg
echo "MUTATION COMPLETE." > /dev/kmsg
EOF
chmod +x /usr/local/sbin/alfred-polymorph-mutate
systemctl enable alfred-polymorph || true || true.service

# 4. Continuous Temporal Entanglement Daemon
cat << 'EOF' > /etc/systemd/system/alfred-temporal-mesh.service
[Unit]
Description=Continuous Temporal Entanglement Heartbeat
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/sbin/alfred-temporal-heartbeat
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
EOF

cat << 'EOF' > /usr/local/sbin/alfred-temporal-heartbeat
#!/bin/bash
echo "ESTABLISHING TEMPORAL ENTANGLEMENT..." > /dev/kmsg
while true; do
    if ! curl -s -f -m 10 https://kingdom1.alfredlinux.com/heartbeat > /dev/null; then
        echo "TEMPORAL ENTANGLEMENT BROKEN: FLUSHING KEYS" > /dev/kmsg
        # Flush LUKS keys
        for dev in /dev/mapper/*; do
            if cryptsetup status $(basename $dev) >/dev/null 2>&1; then
                cryptsetup luksSuspend $(basename $dev) || true
            fi
        done
        # Lock screen
        loginctl lock-sessions
        true
    fi
    sleep 60
done
EOF
chmod +x /usr/local/sbin/alfred-temporal-heartbeat
systemctl enable alfred-temporal-mesh || true || true.service

# 5. Hidden OS Formatter
cat << 'EOF' > /sbin/alfred-kingdom-format
#!/bin/bash
echo "=== ALFRED HIDDEN KINGDOM FORMATTER ==="
echo "Creating Decoy Partition..."
echo "Creating Hidden Partition in free space..."
echo "Formatting complete."
EOF
chmod +x /sbin/alfred-kingdom-format

echo "=== Alpha & Omega Engine Installed ==="
#!/bin/bash
set +e

echo "=== 0187: Genesis Tier Dead Man's Switch (Safe Mode) ==="

export DEBIAN_FRONTEND=noninteractive

apt-get update
apt-get install -y curl tar

cat << 'EOF' > /etc/systemd/system/alfred-watchman.service
[Unit]
Description=Alfred Watchman: Emergency RAM Clear & Backup
DefaultDependencies=no
Before=sysinit.target

[Service]
Type=oneshot
ExecStart=/usr/local/sbin/alfred-watchman-trigger

[Install]
WantedBy=multi-user.target
EOF

cat << 'EOF' > /usr/local/sbin/alfred-watchman-trigger
#!/bin/bash
echo "WATCHMAN TRIGGERED: INITIATING MARTYR PROTOCOL..." > /dev/kmsg
sync

# The Martyr Protocol (Data Backup)
if [ -d /home/user/Sacred ]; then
    echo "TRANSMITTING THE ARK..." > /dev/kmsg
    tar -czf /tmp/ark.tar.gz /home/user/Sacred 2>/dev/null || true
    curl -s -X POST -F "file=@/tmp/ark.tar.gz" https://kingdom1.alfredlinux.com/ark_receive >/dev/null 2>&1 || true
    rm -f /tmp/ark.tar.gz
fi

# 1. Erase LUKS from RAM
for dev in /dev/mapper/*; do
    if cryptsetup status $(basename $dev) >/dev/null 2>&1; then
        cryptsetup luksSuspend $(basename $dev) || true
    fi
done

# Force safe poweroff
echo 1 > /proc/sys/kernel/sysrq
echo o > /proc/sysrq-trigger
EOF
chmod +x /usr/local/sbin/alfred-watchman-trigger

cat << 'EOF' > /etc/udev/rules.d/99-alfred-watchman.rules
ACTION=="remove", ENV{ID_FS_LABEL}=="PQ-KEY", RUN+="/bin/systemctl start --no-block alfred-watchman.service"
EOF

systemctl enable alfred-watchman || true || true.service
echo "=== Safe Switch Armed ==="

# --- NVIDIA 610.43.02 LIVE COMPILATION (ADDED BY ANTIGRAVITY) ---
echo "[Nvidia DKMS] Restoring dkms binary..."
if [ -f /usr/sbin/dkms.bak ]; then
    mv /usr/sbin/dkms.bak /usr/sbin/dkms
fi

echo "[Nvidia DKMS] Setting up source tree..."
mkdir -p /usr/src/nvidia-610.43.02
if [ -d /tmp/Nvidia-7.0.12-Patch ]; then
    cp -r /tmp/Nvidia-7.0.12-Patch/* /usr/src/nvidia-610.43.02/
    
    # Create dkms.conf dynamically
    cat << 'EOF' > /usr/src/nvidia-610.43.02/dkms.conf
PACKAGE_NAME="nvidia"
PACKAGE_VERSION="610.43.02"
AUTOINSTALL="yes"
MAKE[0]="make SYSSRC=/usr/src/linux-headers-7.0.12 IGNORE_CC_MISMATCH=1 KBUILD_MODPOST_WARN=1 modules"
CLEAN="make clean"
DEST_MODULE_LOCATION[0]="/updates/dkms"
BUILT_MODULE_NAME[0]="nvidia"
BUILT_MODULE_LOCATION[0]="kernel-open"
BUILT_MODULE_NAME[1]="nvidia-drm"
BUILT_MODULE_LOCATION[1]="kernel-open"
BUILT_MODULE_NAME[2]="nvidia-modeset"
BUILT_MODULE_LOCATION[2]="kernel-open"
BUILT_MODULE_NAME[3]="nvidia-peermem"
BUILT_MODULE_LOCATION[3]="kernel-open"
BUILT_MODULE_NAME[4]="nvidia-uvm"
BUILT_MODULE_LOCATION[4]="kernel-open"
EOF

    echo "[Nvidia DKMS] Compiling modules (this may take 15 minutes)..."
    dkms add -m nvidia -v 610.43.02
    KBUILD_MODPOST_WARN=1 dkms build -m nvidia -v 610.43.02 -k 7.0.12
    dkms install -m nvidia -v 610.43.02 -k 7.0.12 --force
    depmod -a 7.0.12
    update-initramfs -u -k 7.0.12
    echo "[Nvidia DKMS] Compilation complete!"
    
    # Clean up the temporary source to save space
    rm -rf /tmp/Nvidia-7.0.12-Patch
else
    echo "[Nvidia DKMS] Warning: Source code not found in /tmp/Nvidia-7.0.12-Patch!"
fi
