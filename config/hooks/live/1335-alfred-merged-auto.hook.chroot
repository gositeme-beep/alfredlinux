      explain "..."     # alias for quick explanations
      commit            # auto-write git commit message from diff

Backends:
  ALFRED_BACKEND=cleanroom (default) — Rust binary, MIT licensed
  ALFRED_BACKEND=original             — Original TypeScript harness (advanced)

Models:
  alfred-haiku   — fast, low RAM (7B parameters, ~5GB)
