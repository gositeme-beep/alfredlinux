echo "[Korah] Binary: $BIN_PAYLOAD"

echo "\n[Korah] Modulating binary into 15Hz and 20Hz seismic impulses..."
echo "[Korah] WARNING: Actuator engagement in 3 seconds. Stand clear of the coupling plate."
