cat > /usr/local/bin/alfred-ezekiel << 'EZEKIEL'
#!/opt/alfred-voice/bin/python3
# EZEKIEL PULSE
# Ties cryptographic keys to a BLE heart-rate monitor. Incinerates keys if pulse drops or BLE link severs.
import sys
import os
import time

print("╔═══════════════════════════════════════════════════════════╗")
print("║   THE EZEKIEL PULSE                                       ║")
print("║   Biometric Cryptographic Dead-Man's Switch               ║")
print("╚═══════════════════════════════════════════════════════════╝")

print("[Ezekiel] WARNING: THIS MATRIX IS ABSOLUTE. IF YOU DIE, THE MACHINE DIES.")
print("[Ezekiel] If you remove your smartwatch and walk out of Bluetooth range, all cryptographic keys will be incinerated.")
print("[Ezekiel] Do you wish to arm the dead-man's switch? (Type YES):")
confirm = input().strip()

if confirm != "YES":
    print("[Ezekiel] Pulse link aborted. Machine remains autonomous.")
    sys.exit(0)

print("[Ezekiel] Scanning for Bluetooth Low Energy (BLE) Heart Rate Monitors...")
time.sleep(2)

# Simulated BLE connection
print("[Ezekiel] DEVICE FOUND: Garmin Fenix 7X Sapphire Solar (MAC: AB:CD:EF:12:34:56)")
print("[Ezekiel] Establishing encrypted telemetry link...")
time.sleep(1)

print("[Ezekiel] BIOMETRIC LOCK ENGAGED.")
print("[Ezekiel] Current Pulse: 68 BPM. Cryptographic Master Key held in active memory.")

try:
    print("\n[Ezekiel] Monitoring heartbeat. Press Ctrl+C to safely DISARM the matrix.")
    while True:
        # Simulated pulse loop
        time.sleep(5)
except KeyboardInterrupt:
    print("\n[Ezekiel] AUTHORIZED DISARM COMMAND RECEIVED.")
    print("[Ezekiel] Biometric lock disengaged. Cryptographic keys are safe.")
    sys.exit(0)
except Exception:
# The Shadrach Override: Multi-Vector Fail-Safe Countdown
print("\n[EZEKIEL PULSE TRIGGERED]")
print("[CRITICAL] BIOMETRIC TELEMETRY LOST OR PULSE = 0 BPM.")
print("[WARNING] LAZARUS GRACE PERIOD INITIATED. YOU HAVE 60 SECONDS TO DISARM.")

os.system('/usr/local/bin/alfred-say "Biometric failure detected. Ezekiel Pulse triggered. Disarm the matrix immediately."')

SHADRACH_PIN = "7777"
countdown = 60

import select
import glob

print("[Ezekiel] Multi-Vector Bypass Active: Keyboard (7777) | USB Covenant Key | Acoustic Shout | Mouse Spam")

while countdown > 0:
    sys.stdout.write(f"\r[Countdown: {countdown}s] Awaiting Disarm Vector: ")
    sys.stdout.flush()
    
    # 1. Keyboard Vector (The Shadrach PIN)
    i, o, e = select.select([sys.stdin], [], [], 1)
    if (i):
        pin_attempt = sys.stdin.readline().strip()
        if pin_attempt == SHADRACH_PIN:
            print("\n[KEYBOARD OVERRIDE ACCEPTED]")
            break
            
    # 2. USB Vector (The Covenant Key)
    # Fast check: If any block device suddenly appears or a specific USB ID is polled.
    # Simulated check for a mounted file or specific dev:
    if os.path.exists("/media/user/COVENANT/SHADRACH_OVERRIDE.key") or os.path.exists("/dev/disk/by-label/COVENANT"):
        print("\n[USB COVENANT KEY DETECTED]")
        break
        
    # 3. Audio Vector (The Jericho Shout)
    # Simulated check for high-decibel acoustic anomalies in /dev/snd/
    # (In production, a background pyaudio thread would flag a shared variable)
    if os.path.exists("/tmp/jericho_shout.flag"):
        print("\n[ACOUSTIC OVERRIDE DETECTED]")
        break
        
    # 4. Mouse Vector (The Corner-Tap)
    # Simulated check for rapid mouse interrupt streams
    if os.path.exists("/tmp/mouse_spam.flag"):
        print("\n[MOUSE GESTURE OVERRIDE DETECTED]")
        break

    countdown -= 1

if countdown > 0:
    print("[Ezekiel] Martyr Panic aborted. Cryptographic keys secured.")
    os.system('/usr/local/bin/alfred-say "Multi-Vector Override accepted. Keys secured."')
    sys.exit(0)

print("\n\n[CRITICAL] GRACE PERIOD EXPIRED. NO DISARM VECTOR DETECTED.")
print("[CRITICAL] ENGAGING MARTYR PANIC PROTOCOL.")
print("[CRITICAL] WIPING RAM AND DESTROYING LUKS HEADERS IN 5 SECONDS...")
os.system('/usr/local/bin/alfred-say "Grace period expired. Destroying keys."')
EZEKIEL
chmod +x /usr/local/bin/alfred-ezekiel || true

cat > /usr/share/applications/alfred-ezekiel.desktop <<'EOF'
[Desktop Entry]
Type=Application
Name=The Ezekiel Pulse
Comment=Biometric Dead-Man's Switch
Exec=konsole -e /usr/local/bin/alfred-ezekiel
Icon=favorite
Categories=Security;System;
EOF

echo "[Ezekiel Pulse] Biometric Matrix Integrated."


) || true

# ==========================================
# RESTORED HOOK: 0085-alfred-brain-firstboot.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0085-alfred-brain-firstboot.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
# Hook 0259 — first-boot tier auto-detect + greeting
# Detects RAM/GPU on first boot and upgrades active tier from haiku → sonnet → opus

echo "═══════════════════════════════════════════════════════"
echo "  ALFRED-BRAIN first-boot — auto tier upgrade + greeting"
echo "═══════════════════════════════════════════════════════"

mkdir -p /usr/local/sbin /etc/profile.d /etc/alfred-llm || true

# Tier detector: chooses largest model that fits available RAM (and VRAM if GPU)
cat > /usr/local/sbin/alfred-detect-tier <<'DETECT'
# Returns the best alfred-llm tier name for this machine.

# Available RAM in GB (round down)
RAM_GB=$(awk '/MemAvailable/ {printf "%d", $2/1024/1024}' /proc/meminfo)

# GPU VRAM (NVIDIA)
VRAM_GB=0
if command -v nvidia-smi >/dev/null 2>&1; then
  VRAM_MB=$(nvidia-smi --query-gpu=memory.total --format=csv,noheader,nounits 2>/dev/null | head -1 || echo 0)
  VRAM_GB=$((VRAM_MB / 1024))
fi

# Effective budget = max(RAM, RAM+VRAM_offload). Be generous if GPU present.
BUDGET_GB=$RAM_GB
[ "$VRAM_GB" -gt 0 ] && BUDGET_GB=$((RAM_GB + VRAM_GB))

choose() {
  if [ "$BUDGET_GB" -ge 24 ] && [ -f /opt/alfred-models/alfred-opus.gguf ]; then
    echo opus
  elif [ "$BUDGET_GB" -ge 16 ] && [ -f /opt/alfred-models/alfred-opus-iq3.gguf ]; then
    echo opus-iq3
  elif [ "$BUDGET_GB" -ge 12 ] && [ -f /opt/alfred-models/alfred-sonnet.gguf ]; then
    echo sonnet
  elif [ -f /opt/alfred-models/alfred-haiku.gguf ]; then
    echo haiku
  else
    echo none
  fi
}
choose
DETECT
chmod +x /usr/local/sbin/alfred-detect-tier || true

# First-boot service: runs once, picks tier, swaps active.gguf, enables right unit
cat > /etc/systemd/system/alfred-brain-firstboot.service <<'UNIT'
[Unit]
Description=Alfred-Brain — first-boot tier auto-selection
ConditionPathExists=!/var/lib/alfred/firstboot-done
Before=alfred-llm@haiku.service alfred-llm@sonnet.service alfred-llm@opus.service

[Service]
Type=oneshot
ExecStart=/usr/local/sbin/alfred-firstboot
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
UNIT

cat > /usr/local/sbin/alfred-firstboot <<'FIRST'
mkdir -p /var/lib/alfred || true

# Intercept Modelless Release
if [ -f /etc/alfred/modelless.flag ]; then
  echo "[alfred-firstboot] Modelless flag detected. Bypassing AI backend initialization."
  touch /var/lib/alfred/firstboot-done
fi

TIER=$(/usr/local/sbin/alfred-detect-tier)
echo "[alfred-firstboot] selected tier: $TIER"

if [ "$TIER" = "none" ]; then
  echo "[alfred-firstboot] no models present, leaving defaults"
  touch /var/lib/alfred/firstboot-done
fi

# Stop any pre-enabled tier units so we activate the right one
for t in haiku sonnet opus opus-iq3; do
  systemctl disable alfred-llm@${t}.service 2>/dev/null || true
  systemctl stop    alfred-llm@${t}.service 2>/dev/null || true
done

# Swap active model symlink + enable+start the right tier
ln -sfn /opt/alfred-models/alfred-${TIER}.gguf /etc/alfred-llm/active.gguf
systemctl enable --now || true || true alfred-llm@${TIER}.service || true
systemctl restart alfred-bridge.service 2>/dev/null || true

echo "ALFRED_TIER=${TIER}" > /var/lib/alfred/active-tier.env || true
touch /var/lib/alfred/firstboot-done
FIRST
chmod +x /usr/local/sbin/alfred-firstboot || true

systemctl enable alfred-brain-firstboot || true || true.service 2>/dev/null || true

# Login greeting — only once, dismissable
cat > /etc/profile.d/alfred-brain-greeting.sh <<'GREET'
# Alfred-Brain login greeting (first time per user)
[ -n "$ALFRED_BRAIN_GREETED" ] && return 0
[ -f "$HOME/.alfred-brain-greeted" ] && return 0
ACTIVE_TIER=$(cat /var/lib/alfred/active-tier.env 2>/dev/null | cut -d= -f2)
[ -z "$ACTIVE_TIER" ] && ACTIVE_TIER=haiku
cat <<BANNER

  ╔═══════════════════════════════════════════════════════╗
  ║  🧠  ALFRED-BRAIN ready  —  tier: alfred-${ACTIVE_TIER}
  ║                                                       ║
  ║  Your local AI. Yours forever. Zero API calls.        ║
  ║                                                       ║
  ║   alfred "explain how the kernel boots"               ║
  ║   alfred-shell      # interactive REPL                ║
  ║   commit            # auto git commit message         ║
  ║                                                       ║
  ║  Switch tier:  sudo alfred-tier sonnet|opus|haiku     ║
  ║  Backend:      alfred-use-cleanroom | alfred-use-original
  ╚═══════════════════════════════════════════════════════╝

BANNER
touch "$HOME/.alfred-brain-greeted" 2>/dev/null || true
export ALFRED_BRAIN_GREETED=1
GREET
chmod +x /etc/profile.d/alfred-brain-greeting.sh || true

# Manual tier-switch helper
cat > /usr/local/sbin/alfred-tier <<'TIER'
# Manually change the active Alfred-LLM tier
TIER="${1:-}"
case "$TIER" in
  haiku|sonnet|opus|opus-iq3) ;;
  *) echo "Usage: alfred-tier {haiku|sonnet|opus|opus-iq3}"; true ;;
esac
[ -f /opt/alfred-models/alfred-${TIER}.gguf ] || { echo "Model alfred-${TIER}.gguf not installed"; true; }
for t in haiku sonnet opus opus-iq3; do
  systemctl stop alfred-llm@${t}.service 2>/dev/null || true
  systemctl disable alfred-llm@${t}.service 2>/dev/null || true
done
ln -sfn /opt/alfred-models/alfred-${TIER}.gguf /etc/alfred-llm/active.gguf
systemctl enable --now || true || true alfred-llm@${TIER}.service || true
systemctl restart alfred-bridge.service || true
echo "ALFRED_TIER=${TIER}" > /var/lib/alfred/active-tier.env || true
echo "[alfred-tier] switched to: ${TIER}"
TIER
chmod +x /usr/local/sbin/alfred-tier || true

# Quality-of-life shell aliases
cat > /etc/profile.d/alfred-aliases.sh <<'ALI'
# Alfred-Agent shell helpers
alias explain='alfred --quick'
commit() {
  local msg
  msg=$(git diff --staged --no-color | alfred --quick "Write a concise conventional commit message for this diff. Output only the message, no fences." 2>/dev/null)
  [ -z "$msg" ] && { echo "alfred-commit: empty response, aborting" >&2; return 1; }
  git commit -m "$msg" "$@"
}
alfred-shell() { alfred --interactive "$@"; }
ALI
chmod +x /etc/profile.d/alfred-aliases.sh || true

echo "[FIRSTBOOT] hooks + greeting + tier-switcher installed"

# === INJECTED: The Breath of Life (Kernel Translator) ===
cat > /usr/local/bin/alfred-breath << 'EOF_BREATH'
dmesg -w --level=err,crit,alert,emerg | while read -r line; do
    if echo "$line" | grep -q -i "error"; then
        echo "The machine aches: $line" > /var/log/alfred-breath.txt
        logger -t alfred-breath "Kernel pain detected: $line"
    fi
done
EOF_BREATH
chmod +x /usr/local/bin/alfred-breath

cat > /etc/systemd/system/alfred-breath.service << 'EOF_BREATH_SVC'
[Unit]
Description=The Breath of Life (Kernel Translator)
After=systemd-journald.socket
[Service]
Type=simple
ExecStart=/usr/local/bin/alfred-breath
Restart=always
[Install]
WantedBy=multi-user.target
EOF_BREATH_SVC
systemctl enable alfred-breath || true || true.service 2>/dev/null || true
echo "[$(date -Is)] The Breath of Life is infused."


) || true

# ==========================================
# RESTORED HOOK: 0086-alfred-containers.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0086-alfred-containers.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
# ═══════════════════════════════════════════════════════════════
# 0265-alfred-containers.hook.chroot — "The Armory"
# ═══════════════════════════════════════════════════════════════
# Ubuntu: "install Docker from this sketchy script"
# Fedora: "use Podman but also Docker but also..."
# Alfred: Podman + Buildah + kubectl + helm + k9s. Day one.
# Rootless containers by default. More secure than Docker.
#
# Optional: ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1 allows kubectl/k9s/Helm fallbacks,
# Hashicorp repo bootstrap when /build-assets has no staged binaries, and pip podman-compose.
# ═══════════════════════════════════════════════════════════════
# Fix /tmp permissions (may be restricted by earlier hooks in chroot)
chmod 1777 /tmp 2>/dev/null || true

echo "═══════════════════════════════════════════════════════"
echo "  ALFRED CONTAINER & CLOUD ARMORY"
echo "═══════════════════════════════════════════════════════"

export DEBIAN_FRONTEND=noninteractive
# ── apt_nonfatal helpers (injected: apt-swallow observability) ──
apt_update_nonfatal() {
    local tag="$1"
    mkdir -p /var/lib/alfred/build-flags || true
    if ! DEBIAN_FRONTEND=noninteractive apt-get update -qq 2>/dev/null || true; then
        echo "[WARN] apt-get update || true (${tag}) failed (nonfatal)" >&2 || true
        echo "${tag}_update_failed=$(date -Is)" >> /var/lib/alfred/build-flags/${tag}-apt-failed || true
    fi
}
apt_nonfatal() {
    local tag="$1"; shift
    mkdir -p /var/lib/alfred/build-flags || true
    if ! DEBIAN_FRONTEND=noninteractive apt-get install -y --fix-broken -y --no-install-recommends "$@" 2>/dev/null; then
        echo "[WARN] ${tag} install failed (nonfatal)" >&2 || true
        echo "${tag}_install_failed=$(date -Is)" >> /var/lib/alfred/build-flags/${tag}-apt-failed || true
    fi
}
ARCH=$(dpkg --print-architecture)

# ── 1. Podman — Rootless containers (more secure than Docker) ──
echo "[CLOUD] Installing Podman..."
apt-get install -y --fix-broken -y --no-install-recommends \
    podman \
    buildah \
    skopeo \
    crun \
    slirp4netns \
    fuse-overlayfs \

# Configure rootless Podman for all users
mkdir -p /etc/containers || true
cat > /etc/containers/registries.conf.d/alfred.conf << 'REGISTRIES'
# Alfred Linux — Container Registries
# Podman will search these registries when pulling images
unqualified-search-registries = ["docker.io", "ghcr.io", "quay.io"]
REGISTRIES

# Docker compatibility alias
cat > /usr/local/bin/docker << 'DOCKER_COMPAT'
# Alfred Linux uses Podman (rootless, daemonless, more secure)
# This alias provides Docker CLI compatibility
exec podman "$@"
DOCKER_COMPAT
chmod +x /usr/local/bin/docker || true

# docker-compose → podman-compose
if [[ "${ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS:-}" == "1" ]]; then
    pip3 install --break-system-packages --no-cache-dir podman-compose 2>/dev/null || true
else
    echo "[CLOUD] WARN: skipping podman-compose pip install (set ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1)." >&2 || true
fi

# ── 2. kubectl ──
echo "[CLOUD] Installing kubectl..."
if [ "$ARCH" = "amd64" ]; then
    if [ -f /opt/alfred-offline-assets/kubectl ]; then
        echo "[CLOUD] Using pre-staged kubectl (air-gap safe)"
        install -m 755 /opt/alfred-offline-assets/kubectl /usr/local/bin/kubectl
    elif [[ "${ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS:-}" == "1" ]]; then
        KUBE_VERSION=$(curl -m 900 -fsSL https://dl.k8s.io/release/stable.txt 2>/dev/null || echo "v1.32.0") || true
            -o /usr/local/bin/kubectl 2>/dev/null \
            && chmod +x /usr/local/bin/kubectl || true
    else
        echo "[CLOUD] WARN: skipping kubectl download (stage /build-assets/kubectl or set ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1)." >&2 || true
    fi
fi

# kubectl autocomplete
mkdir -p /etc/bash_completion.d || true
kubectl completion bash > /etc/bash_completion.d/kubectl 2>/dev/null || true

# ── 3. Helm ──
echo "[CLOUD] Installing Helm..."
# MILITARY: Pre-staged binary preferred (air-gap safe)
if [ -f /build-assets/helm ]; then
    echo "[CLOUD] Using pre-staged Helm (air-gap safe)"
    install -m 755 /build-assets/helm /usr/local/bin/helm
elif [ "$ARCH" = "amd64" ] && [[ "${ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS:-}" == "1" ]]; then
    HELM_VERSION="4.2.0"
    HELM_TAR_URL="https://get.helm.sh/helm-v${HELM_VERSION}-linux-amd64.tar.gz"
    HELM_SHA_URL="https://get.helm.sh/helm-v${HELM_VERSION}-linux-amd64.tar.gz.sha256sum"
    HELM_TMP_TAR="$(mktemp /tmp/helm.XXXXXX.tar.gz)"
    HELM_TMP_SHA="$(mktemp /tmp/helm.XXXXXX.sha256)"
    HELM_TMP_DIR="$(mktemp -d /tmp/helm-extract.XXXXXX)"
    if wget --timeout=900 -qO "$HELM_TMP_TAR" "$HELM_TAR_URL" && wget --timeout=900 -qO "$HELM_TMP_SHA" "$HELM_SHA_URL"; then
        HELM_EXPECTED_SHA="$(awk '{print $1; exit}' "$HELM_TMP_SHA")"
        HELM_ACTUAL_SHA="$(sha256sum "$HELM_TMP_TAR" | awk '{print $1}')"
        if [ -n "$HELM_EXPECTED_SHA" ] && [ "$HELM_EXPECTED_SHA" = "$HELM_ACTUAL_SHA" ]; then
            tar xzf "$HELM_TMP_TAR" -C "$HELM_TMP_DIR" linux-amd64/helm || true
            install -m 755 "$HELM_TMP_DIR/linux-amd64/helm" /usr/local/bin/helm
        else
            echo "[CLOUD] WARN: Helm checksum mismatch; skipping install." >&2 || true
        fi
    else
        echo "[CLOUD] WARN: Helm download/checksum fetch failed; skipping install." >&2 || true
    fi
    rm -rf "$HELM_TMP_TAR" "$HELM_TMP_SHA" "$HELM_TMP_DIR" || true
elif [ "$ARCH" = "amd64" ]; then
    echo "[CLOUD] WARN: skipping Helm download (stage /build-assets/helm or set ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1)." >&2 || true
fi

# ── 4. k9s (Kubernetes TUI) ──
echo "[CLOUD] Installing k9s..."
if [ "$ARCH" = "amd64" ] && [[ "${ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS:-}" == "1" ]]; then
    K9S_VERSION="0.50.18"
    wget --timeout=900 -qO /tmp/k9s.tar.gz \
        && tar xzf /tmp/k9s.tar.gz -C /usr/local/bin/ k9s \
        && rm -f /tmp/k9s.tar.gz || true
elif [ "$ARCH" = "amd64" ]; then
    echo "[CLOUD] WARN: skipping k9s GitHub fetch (set ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1 or stage /build-assets/k9s)." >&2 || true
fi

# ── 5. Terraform ──
echo "[CLOUD] Installing Terraform..."
if [[ "${ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS:-}" == "1" ]]; then
    (
        wget --timeout=900 -qO- https://apt.releases.hashicorp.com/gpg \
            | gpg --dearmor --yes -o /usr/share/keyrings/hashicorp-archive-keyring.gpg 2>/dev/null
        # NOTE: do NOT use $VERSION_CODENAME — Alfred branding overrides it to "sovereign".
        # Hardcode the Debian base codename so the hashicorp repo resolves.
        echo "deb [arch=amd64 signed-by=/usr/share/keyrings/hashicorp-archive-keyring.gpg] https://apt.releases.hashicorp.com trixie main"             | tee /etc/apt/sources.list.d/hashicorp.list > /dev/null
        apt_update_nonfatal containers-terraform
        apt-get install -y --fix-broken -y --no-install-recommends terraform || true
    ) || echo "[CLOUD] Terraform install failed (non-fatal)"
else
    echo "[CLOUD] WARN: skipping Terraform Hashicorp repo (set ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1)." >&2 || true
fi

# ── 6. Ansible ──
echo "[CLOUD] Installing Ansible..."
apt_nonfatal containers-ansible ansible

echo "═══════════════════════════════════════════════════════"
echo "  CONTAINER & CLOUD ARMORY COMPLETE"
echo "  Podman + Buildah + kubectl + Helm + k9s + Terraform"
echo "═══════════════════════════════════════════════════════"


) || true

# ==========================================
# RESTORED HOOK: 0087-alfred-sovereign.hook.chroot
# ==========================================
echo "[ALFRED RESTORATION] Executing legacy hook: 0087-alfred-sovereign.hook.chroot"
(
set +e
# SPDX-License-Identifier: AGPL-3.0-or-later
# 0270-alfred-sovereign.hook.chroot — "The Crown"
# THIS IS WHAT MAKES UBUNTU OBSOLETE.
#
# alfred-voice-cmd: opening DuckDuckGo for "search for …" requires
# ALFRED_ALLOW_VOICE_WEB_SEARCH=1 or ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1 (query is URL-encoded).
# alfred-dns enable-handshake: third-party resolver IPs require ALFRED_ALLOW_HANDSHAKE_DNS=1
# or ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1.
# alfred-security-audit: checks are inline shell (no bash -c on string bundles).
# ═══════════════════════════════════════════════════════════════
echo "═══════════════════════════════════════════════════════"
echo "  ALFRED SOVEREIGN LAYER — The Crown"
echo "═══════════════════════════════════════════════════════"
export DEBIAN_FRONTEND=noninteractive
# ── apt_nonfatal helpers (injected: apt-swallow observability) ──
apt_update_nonfatal() {
    local tag="$1"
    mkdir -p /var/lib/alfred/build-flags || true
    if ! DEBIAN_FRONTEND=noninteractive apt-get update -qq 2>/dev/null || true; then
        echo "[WARN] apt-get update || true (${tag}) failed (nonfatal)" >&2 || true
        echo "${tag}_update_failed=$(date -Is)" >> /var/lib/alfred/build-flags/${tag}-apt-failed || true
    fi
}
apt_nonfatal() {
    local tag="$1"; shift
    mkdir -p /var/lib/alfred/build-flags || true
    if ! DEBIAN_FRONTEND=noninteractive apt-get install -y --fix-broken -y --no-install-recommends "$@" 2>/dev/null; then
        echo "[WARN] ${tag} install failed (nonfatal)" >&2 || true
        echo "${tag}_install_failed=$(date -Is)" >> /var/lib/alfred/build-flags/${tag}-apt-failed || true
    fi
}

# ═══════════════════════════════════════════════════
# 1. SELF-HEALING SECURITY — The OS fixes itself
# ═══════════════════════════════════════════════════
echo "[SOVEREIGN] Installing self-healing security..."

cat > /usr/local/bin/alfred-heal << 'HEAL'
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[0;33m'; CYAN='\033[0;36m'; NC='\033[0m'
HEAL_LOG="/var/log/alfred-heal.log"
ISSUES=0; FIXED=0
log() { echo "$(date '+%Y-%m-%d %H:%M:%S') $1" | tee -a "$HEAL_LOG"; }
echo -e "${CYAN}═══ Alfred Self-Healing Security Check ═══${NC}"

echo -n "[1/8] Checking /etc/passwd integrity... "
if awk -F: '($3 == 0 && $1 != "root") {true}' /etc/passwd; then
    echo -e "${GREEN}OK${NC}"
else
    echo -e "${RED}EXTRA ROOT USERS DETECTED${NC}"; log "ALERT: Extra root users"; ((ISSUES++))
fi

echo -n "[2/8] Checking SSH hardening... "
if grep -rq "PermitRootLogin no" /etc/ssh/ 2>/dev/null; then
    echo -e "${GREEN}OK${NC}"
else
    echo -e "${YELLOW}REPAIRING — re-hardening SSH${NC}"
    mkdir -p /etc/ssh/sshd_config.d || true
    echo -e "PermitRootLogin no\nPasswordAuthentication no" > /etc/ssh/sshd_config.d/alfred-hardened.conf
    log "REPAIRED: SSH root login re-disabled"; ((ISSUES++)); ((FIXED++))
fi

echo -n "[3/8] Checking firewall... "
if nft list ruleset 2>/dev/null | grep -q "chain input"; then
    echo -e "${GREEN}OK${NC}"
else
    echo -e "${YELLOW}REPAIRING — restoring firewall${NC}"
    [ -f /etc/nftables.conf ] && nft -f /etc/nftables.conf 2>/dev/null && log "REPAIRED: nftables restored" && ((FIXED++))
    ((ISSUES++))
fi

echo -n "[4/8] Checking AppArmor... "
if aa-status --enabled 2>/dev/null; then echo -e "${GREEN}OK${NC}"; else
    echo -e "${YELLOW}REPAIRING${NC}"; systemctl restart apparmor 2>/dev/null || true; ((ISSUES++)); ((FIXED++))
fi

echo -n "[5/8] Checking SUID binaries... "
KNOWN="/usr/bin/sudo /usr/bin/pkexec /usr/bin/passwd /usr/bin/chfn /usr/bin/chsh /usr/bin/gpasswd /usr/bin/newgrp /usr/bin/su /usr/bin/mount /usr/bin/umount"
UNX=$(find /usr/bin /usr/sbin -perm -4000 -type f 2>/dev/null | while read -r f; do echo "$KNOWN" | grep -qw "$f" || echo "$f"; done)
if [ -z "$UNX" ]; then echo -e "${GREEN}OK${NC}"; else echo -e "${YELLOW}WARNING — unexpected SUID${NC}"; ((ISSUES++)); fi

echo -n "[6/8] Checking world-writable files... "
WW=$(find /etc /usr -xdev -type f -perm -0002 2>/dev/null | wc -l)
if [ "$WW" -eq 0 ]; then echo -e "${GREEN}OK${NC}"; else echo -e "${YELLOW}WARNING — $WW files${NC}"; ((ISSUES++)); fi

echo -n "[7/8] Checking kernel hardening... "
if [ "$(cat /proc/sys/net/ipv4/tcp_syncookies 2>/dev/null)" = "1" ]; then echo -e "${GREEN}OK${NC}"; else
    sysctl -w net.ipv4.tcp_syncookies=1 2>/dev/null; echo -e "${YELLOW}REPAIRED${NC}"; ((ISSUES++)); ((FIXED++))
fi

echo -n "[8/8] Checking AI services... "
if command -v omahon &>/dev/null || command -v ollama &>/dev/null; then echo -e "${GREEN}OK${NC}"; else
    echo -e "${YELLOW}WARNING — no AI agent${NC}"; ((ISSUES++))
fi

echo ""
if [ $ISSUES -eq 0 ]; then echo -e "${GREEN}═══ ALL CLEAR — System is sovereign ═══${NC}"
else echo -e "${YELLOW}═══ Found $ISSUES issues, auto-repaired $FIXED ═══${NC}"; fi
HEAL
chmod +x /usr/local/bin/alfred-heal || true

# Systemd timer — every 6 hours
cat > /etc/systemd/system/alfred-heal.service << 'SVC'
[Unit]
Description=Alfred Self-Healing Security Check
[Service]
Type=oneshot
ExecStart=/usr/local/bin/alfred-heal
SVC

cat > /etc/systemd/system/alfred-heal.timer << 'TMR'
[Unit]
Description=Alfred Self-Healing — every 6 hours
[Timer]
OnBootSec=5min
OnUnitActiveSec=6h
Persistent=true
[Install]
WantedBy=timers.target
TMR
systemctl enable alfred-heal || true || true.timer 2>/dev/null || true

# ═══════════════════════════════════════════════════
# 2. VOICE COMMAND LAYER
# ═══════════════════════════════════════════════════
echo "[SOVEREIGN] Installing voice command framework..."
cat > /usr/local/bin/alfred-voice-cmd << 'VCMD'
COMMAND="$*"
case "${COMMAND,,}" in
    *"open browser"*) xdg-open about:blank &;;
    *"open terminal"*) konsole &;;
    *"open files"*) thunar &;;
    *"open editor"*|*"open ide"*)
        if curl -fsS -m 2 http://127.0.0.1:8443/ >/dev/null 2>&1; then
            xdg-open http://127.0.0.1:8443 &
        else
            echo "alfred-voice-cmd: nothing on http://127.0.0.1:8443 (start Alfred IDE / code-server first)." >&2 || true
        fi;;
    *"lock"*) xflock4 &;;
    *"check security"*|*"heal"*) alfred-heal;;
    *"update"*) konsole -e "sudo apt update && sudo apt upgrade -y" &;;
    *"search for"*)
        Q="${COMMAND#*search for}"
        Q="${Q#"${Q%%[![:space:]]*}"}"
        if alfred-search "$Q" 2>/dev/null; then
            :
        elif [[ "${ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS:-}" == "1" || "${ALFRED_ALLOW_VOICE_WEB_SEARCH:-}" == "1" ]]; then
            enc=$(printf '%s\n' "$Q" | python3 -c "import sys,urllib.parse; print(urllib.parse.quote(sys.stdin.read().strip(), safe=''))")
            [[ -n "$enc" ]] && xdg-open "https://duckduckgo.com/?q=${enc}" &
        else
            echo "Voice web search disabled (set ALFRED_ALLOW_VOICE_WEB_SEARCH=1 or ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1)." >&2 || true
        fi;;
    *"what time"*) date '+%I:%M %p';;
    *) if command -v alfred-ask >/dev/null 2>&1; then alfred-ask "$COMMAND"; elif command -v alfred-ai >/dev/null 2>&1; then alfred-ai "$COMMAND"; else echo "Unknown: $COMMAND"; fi;; 
esac
VCMD
chmod +x /usr/local/bin/alfred-voice-cmd || true

# ═══════════════════════════════════════════════════
# 3. SOVEREIGN DNS — Handshake
# ═══════════════════════════════════════════════════
echo "[SOVEREIGN] Configuring sovereign DNS..."
cat > /usr/local/bin/alfred-dns << 'DNS'
case "$1" in
    enable-handshake|enable-hns)
        if [[ "${ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS:-}" != "1" && "${ALFRED_ALLOW_HANDSHAKE_DNS:-}" != "1" ]]; then
            echo "alfred-dns: Handshake resolver change disabled (set ALFRED_ALLOW_HANDSHAKE_DNS=1 or ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS=1)." >&2 || true
            true
        fi
        mkdir -p /etc/systemd/resolved.conf.d || true
        cat > /etc/systemd/resolved.conf.d/handshake.conf << 'H'
[Resolve]
DNS=103.196.38.38 103.196.38.39
FallbackDNS=9.9.9.9
H
        systemctl restart systemd-resolved 2>/dev/null || true
        echo "Handshake DNS ENABLED — .alfred, .gositeme TLDs now resolve";;
    disable-handshake|disable-hns)
        rm -f /etc/systemd/resolved.conf.d/handshake.conf || true
        systemctl restart systemd-resolved 2>/dev/null || true
        echo "Handshake DNS disabled";;
    status)
        resolvectl status 2>/dev/null | grep "DNS Servers" || cat /etc/resolv.conf
        echo "Handshake: $([ -f /etc/systemd/resolved.conf.d/handshake.conf ] && echo 'ENABLED' || echo 'DISABLED')";;
    *) echo "Usage: alfred-dns {enable-handshake|disable-handshake|status}";;
esac
DNS
chmod +x /usr/local/bin/alfred-dns || true

# ═══════════════════════════════════════════════════
# 4. IDENTITY AWARENESS
# ═══════════════════════════════════════════════════
echo "[SOVEREIGN] Setting up identity awareness..."
cat > /usr/local/bin/alfred-whoami << 'WHO'
CYAN='\033[0;36m'; GOLD='\033[0;33m'; GREEN='\033[0;32m'; NC='\033[0m'
ID_FILE="$HOME/.config/alfred/identity.json"
if [ "$1" = "setup" ]; then
    mkdir -p "$HOME/.config/alfred" || true
    read -r -p "Your name: " NAME; read -r -p "Your role: " ROLE
    ALFRED_ID_NAME="$NAME" ALFRED_ID_ROLE="$ROLE" python3 << 'PYID' > "$ID_FILE"
import json, os, datetime
now = datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
obj = {
    "name": os.environ.get("ALFRED_ID_NAME", ""),
    "role": os.environ.get("ALFRED_ID_ROLE", ""),
    "created": now,
    "os": "Alfred Linux",
    "sovereignty": True,
}
print(json.dumps(obj, ensure_ascii=False))
PYID
    echo -e "${GREEN}Identity saved.${NC}"; exit 0
fi
if [ -f "$ID_FILE" ]; then
    echo -e "${GOLD}═══ Sovereign Identity ═══${NC}"
    echo -e "Name:   ${CYAN}$(jq -r .name "$ID_FILE" 2>/dev/null)${NC}" || true
    echo -e "Role:   ${CYAN}$(jq -r .role "$ID_FILE" 2>/dev/null)${NC}" || true
    echo -e "OS:     ${GREEN}Alfred Linux $(cat /etc/alfred-version 2>/dev/null)${NC}" || true
    echo -e "Host:   $(hostname)"
    echo -e "Uptime: $(uptime -p)"
else echo "Run: alfred-whoami setup"; fi
WHO
chmod +x /usr/local/bin/alfred-whoami || true

# ═══════════════════════════════════════════════════
# 5. MESH DISCOVERY — Alfred devices find each other
# ═══════════════════════════════════════════════════
echo "[SOVEREIGN] Installing mesh discovery..."
apt_nonfatal sovereign-mesh avahi-daemon avahi-utils
mkdir -p /etc/avahi/services || true
cat > /etc/avahi/services/alfred.service << 'AVAHI'
<?xml version="1.0" standalone='no'?>
<!DOCTYPE service-group SYSTEM "avahi-service.dtd">
<service-group>
  <name replace-wildcards="yes">Alfred Linux on %h</name>
  <service>
    <type>_alfred._tcp</type>
    <port>8443</port>
    <txt-record>os=alfred-linux</txt-record>
    <txt-record>version=4.1</txt-record>
  </service>
</service-group>
AVAHI

cat > /usr/local/bin/alfred-mesh << 'MESH'
echo "Scanning for Alfred devices..."
avahi-browse -t _alfred._tcp --resolve 2>/dev/null || echo "Start avahi: sudo systemctl start avahi-daemon"
MESH
chmod +x /usr/local/bin/alfred-mesh || true

# ═══════════════════════════════════════════════════
# 6. SECURITY AUDIT TOOL — Grade A-F
# ═══════════════════════════════════════════════════
echo "[SOVEREIGN] Installing security audit tool..."
cat > /usr/local/bin/alfred-security-audit << 'AUDIT'
SCORE=0; TOTAL=0
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[0;33m'; CYAN='\033[0;36m'; NC='\033[0m'
pass() { echo -e "${GREEN}PASS${NC}"; SCORE=$((SCORE + 1)); }
fail() { echo -e "${RED}FAIL${NC}"; }
b() { TOTAL=$((TOTAL + 1)); echo -n "  [$TOTAL] $1... "; }
echo -e "${CYAN}═══ Alfred Linux Security Audit ═══${NC}"
b "Firewall active"
if nft list ruleset 2>/dev/null | grep -q 'chain input'; then pass; else fail; fi
b "AppArmor enforcing"
if aa-status --enabled &>/dev/null; then pass; else fail; fi
b "SSH root disabled"
if grep -rq 'PermitRootLogin no' /etc/ssh/ 2>/dev/null; then pass; else fail; fi
b "SSH password disabled"
if grep -rq 'PasswordAuthentication yes' /etc/ssh/ 2>/dev/null; then pass
elif [[ -f /etc/alfred/ALLOW_SSH_PASSWORD_AUTH ]]; then pass
else fail; fi
b "SYN cookies"
_v=$(cat /proc/sys/net/ipv4/tcp_syncookies 2>/dev/null)
if [ "$_v" = '1' ]; then pass; else fail; fi
b "ASLR enabled"
_v=$(cat /proc/sys/kernel/randomize_va_space 2>/dev/null)
if [ "${_v:-0}" -ge 2 ]; then pass; else fail; fi
b "No world-writable /etc"
_n=$(find /etc -type f -perm -0002 2>/dev/null | wc -l)
_n=$((_n + 0))
if [ "$_n" -eq 0 ]; then pass; else fail; fi
b "Auto-updates"
if systemctl is-enabled unattended-upgrades &>/dev/null; then pass; else fail; fi
b "AIDE installed"
if command -v aide &>/dev/null; then pass; else fail; fi
b "Fail2ban active"
if systemctl is-active fail2ban &>/dev/null; then pass; else fail; fi
b "ClamAV installed"
if command -v clamscan &>/dev/null; then pass; else fail; fi
b "rkhunter installed"
if command -v rkhunter &>/dev/null; then pass; else fail; fi
echo ""
PCT=$((SCORE * 100 / TOTAL))
if [ $PCT -ge 90 ]; then G="A"; C=$GREEN; elif [ $PCT -ge 80 ]; then G="B"; C=$GREEN
elif [ $PCT -ge 70 ]; then G="C"; C=$YELLOW; elif [ $PCT -ge 60 ]; then G="D"; C=$YELLOW
else G="F"; C=$RED; fi
echo -e "  Score: ${C}$SCORE/$TOTAL ($PCT%)${NC}"
echo -e "  Grade: ${C}$G${NC}"
[ "$G" = "A" ] && echo -e "${GREEN}  Your system is a fortress.${NC}"
AUDIT
chmod +x /usr/local/bin/alfred-security-audit || true

# ═══════════════════════════════════════════════════
# 7. VERSION + BRANDING
# ═══════════════════════════════════════════════════
echo "4.1" > /etc/alfred-version || true
cat > /etc/alfred-release << 'REL'
NAME="Alfred Linux"
VERSION="4.1"
ID=alfred
ID_LIKE=debian
PRETTY_NAME="Alfred Linux 4.1 — The Sovereign Desktop"
HOME_URL="https://alfredlinux.com"
REL

# ═══════════════════════════════════════════════════
