#!/bin/bash
# Auto-generated phase hook. Idempotent. Safe.
# Phase: 990-prerelease-base
set +e

LOG=/var/log/alfred-build-phases.log
mkdir -p /var/log
TS="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
echo "[${TS}] PHASE=990-prerelease-base HOOK=0990-alfred.hook.chroot START" >> "$LOG"

# Phase verification block (non-fatal warnings only; enforcer hooks decide hard fail).
ok=1
for p in ; do
  if [ -n "$p" ] && [ ! -e "$p" ]; then
    echo "[${TS}] WARN phase=990-prerelease-base missing-artifact: $p" >> "$LOG"
    ok=0
  fi
done
[ "$ok" = 1 ] && echo "[${TS}] PHASE=990-prerelease-base HOOK=0990-alfred.hook.chroot OK" >> "$LOG"               || echo "[${TS}] PHASE=990-prerelease-base HOOK=0990-alfred.hook.chroot WARN" >> "$LOG"

# Mark completion stamp (used by 0999 release manifest).
mkdir -p /var/lib/alfred/phases
touch "/var/lib/alfred/phases/990-prerelease-base.done"

