# Bypass live-build's local repository entirely and install directly from the includes.chroot payload.
if ls /root/masterstroke_kernel/*.deb 1> /dev/null 2>&1; then
    echo "[*] Found custom kernel payload in /root/masterstroke_kernel. Installing..."
    dpkg -i --force-all /root/masterstroke_kernel/*.deb || true
    DEBIAN_FRONTEND=noninteractive apt-get install -f -y --allow-unauthenticated || true
else
    echo "[!] FATAL ERROR: /root/masterstroke_kernel/*.deb not found!"
fi

# Verify if installation succeeded
if dpkg -l | grep -q "linux-image-amd64"; then
    echo "[*] 7.0.12 KERNEL SUCCESSFULLY INJECTED INTO CHROOT."
else
    echo "[!] APT FAILED TO INSTALL KERNEL."
fi

echo "[*] KERNEL 7.0.12 INJECTION COMPLETE."

echo "=========================================="
