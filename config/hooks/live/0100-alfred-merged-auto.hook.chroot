# --- BEGIN MERGED CONTENT FROM: 0100-install-7012.hook.chroot ---
#!/bin/bash
set +e

echo "[*] VANGUARD OVERRIDE: FORCING INSTALLATION OF 7.0.12 KERNEL..."

# live-build creates a local repository for packages.chroot files.
# We must explicitly force apt to install them because the default Debian dependency tree ignores them.
DEBIAN_FRONTEND=noninteractive apt-get install -y --allow-unauthenticated linux-image-7.0.12 linux-headers-7.0.12 linux-libc-dev || true

# Verify if installation succeeded
if dpkg -l | grep -q "linux-image-7.0.12"; then
    echo "[*] 7.0.12 KERNEL SUCCESSFULLY INJECTED INTO CHROOT."
else
    echo "[!] APT FAILED TO INSTALL FROM LOCAL REPO. FALLING BACK TO DIRECT DPKG INSTALLATION..."
    # If the local repo isn't accessible, we find the debs in the live-build cache/archives
    find /var/cache/apt/archives /root -name "linux-*7.0.12*.deb" -exec dpkg -i --force-all {} \; || true
 DEBIAN_FRONTEND=noninteractive apt-get install -f -y || true
fi

echo "[*] KERNEL 7.0.12 INJECTION COMPLETE."

# --- END MERGED CONTENT FROM: 0100-install-7012.hook.chroot ---


