echo "=========================================="
export DEBIAN_FRONTEND=noninteractive

# Ensure headers and DKMS framework are ready
apt-get install -y --no-install-recommends dkms || true

# Install ZFS and Wireguard DKMS modules 
# (This runs AFTER the custom kernel is installed and AFTER the ZFS 32-bit trap is patched)
apt-get install -y zfs-dkms zfsutils-linux wireguard-dkms || true

