#!/bin/bash
set +e

echo "[*] VANGUARD OVERRIDE: PHYSICAL PACKAGE INJECTION..."

# Debian apt aggressively deleted the custom local repo from the chroot earlier in the pipeline.
# We have physically secured the .deb files inside /root/custom-packages/ to survive the wipe.
# Now we execute a raw, low-level installation directly against the filesystem.

if ls /root/custom-packages/*.deb >/dev/null 2>&1; then
    echo "[*] Found custom packages. Forcing raw dpkg installation..."
    dpkg -i --force-all /root/custom-packages/*.deb || true
    
    echo "[*] Resolving dependency graph..."
 DEBIAN_FRONTEND=noninteractive apt-get install -f -y || true
    
    echo "[*] INJECTION COMPLETE. The kernel and all custom assets are secured."
else
    echo "[!] FATAL: Custom packages missing from /root/custom-packages/!" >&2
    echo "Warning only: bypassing fatal exit."
fi

# --- END MERGED CONTENT FROM: 0100-vanguard-injector.hook.chroot ---


