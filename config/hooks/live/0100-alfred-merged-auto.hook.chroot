#!/usr/bin/env -S prlimit --as=1073741824 unshare /bin/bash
export GIT_TERMINAL_PROMPT=0
export DEBIAN_FRONTEND=noninteractive
# SPDX-License-Identifier: AGPL-3.0-or-later
set +e
# [Genesis Forge] Granular Kernel Matrix: kernel.dmesg_restrict=1
# Extremely deep low-level kernel protection.
echo "[Genesis Forge] Applying granular sysctl: kernel.dmesg_restrict=1"
echo "kernel.dmesg_restrict=1" > /etc/sysctl.d/99-alfred-1.conf || true
sysctl -w kernel.dmesg_restrict=1 > /dev/null 2>&1 || true


