echo alfred > /etc/hostname
if ! grep -q "127.0.1.1[[:space:]]*alfred" /etc/hosts; then
  sed -i '/^127\.0\.1\.1/d' /etc/hosts
  echo -e "127.0.1.1\talfred" >> /etc/hosts
fi

# ---------- 3. NOPASSWD sudo for alfred ----------
