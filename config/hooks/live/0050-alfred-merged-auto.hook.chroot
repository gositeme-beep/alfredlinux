cat > /usr/local/bin/alfred-firstboot-password <<'EOF'
#!/bin/bash
# Friendly first-login password wizard.
# Three choices: change now / keep for this session / keep forever (kiosk).
SENTINEL=/var/lib/alfred/firstboot-password.done
KEEP=/var/lib/alfred/keep-default-password
[ -f "$SENTINEL" ] && exit 0
[ "$(id -u)" -eq 0 ] && exit 0
[ "$(id -un)" != "alfred" ] && exit 0
