if ! command -v ollama &>/dev/null; then
    echo "Ollama is not installed or running. The Burning Bush requires local AI."
exit 0
fi
curl -m 900 -s -X POST http://127.0.0.1:11434/api/generate -d "$PAYLOAD" | jq -r '.response' || echo "Failed to commune with the local AI." || true
BUSHEOF
