cat > /usr/local/bin/alfred-burning-bush << 'BUSHEOF'
#!/bin/bash
# alfred-burning-bush — Semantic AI Scripture Engine (King Jesus Version)
BOLD='\033[1m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

if [ -z "$1" ]; then
    echo -e "${BOLD}The Burning Bush Semantic Engine${NC}"
    echo -e "Usage: alfred-burning-bush \"<your concept or question>\""
    echo -e "Example: alfred-burning-bush \"Show me where water symbolizes judgment\""
exit 0
fi
