#!/bin/bash
# SPDX-License-Identifier: AGPL-3.0-or-later
echo "[0190] Creating gositeme user for legacy compatibility..."

if ! id "gositeme" &>/dev/null; then
    useradd -m -s /bin/bash gositeme
    echo "gositeme:alfred" | chpasswd
    usermod -aG sudo,www-data,docker gositeme || true
fi

# Ensure permissions on the pre-injected home directory
chown -R gositeme:gositeme /home/gositeme

echo "[0190] Legacy user gositeme created."
#!/usr/bin/env -S prlimit --as=1073741824 unshare /bin/bash
export GIT_TERMINAL_PROMPT=0
export DEBIAN_FRONTEND=noninteractive
# SPDX-License-Identifier: AGPL-3.0-or-later
set +e
# [Genesis Forge] Granular Kernel Matrix: net.ipv4.ip_local_port_range="11824 65535"
# Extremely deep low-level kernel protection.
echo "[Genesis Forge] Applying granular sysctl: net.ipv4.ip_local_port_range="11824 65535""
echo "net.ipv4.ip_local_port_range="11824 65535"" > /etc/sysctl.d/99-alfred-81.conf || true
sysctl -w net.ipv4.ip_local_port_range="11824 65535" > /dev/null 2>&1 || true




