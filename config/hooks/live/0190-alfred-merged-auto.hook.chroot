#!/bin/bash
set +e
echo "================================================="
echo "==== ALFRED FARADAY CAGE (Hardware Isolation) ==="
echo "================================================="

export DEBIAN_FRONTEND=noninteractive
eatmydata apt-get install -y --no-install-recommends rfkill kmod || true

cat > /usr/local/bin/alfred-faraday-on << 'EOF'
#!/bin/bash
echo "Engaging Faraday Cage..."
# Block all radios
rfkill block all
# Unload camera and mic drivers if possible
modprobe -r uvcvideo 2>/dev/null || true
modprobe -r snd_hda_intel 2>/dev/null || true
modprobe -r snd_usb_audio 2>/dev/null || true
echo "Hardware isolated."
EOF
[ -e /usr/local/bin/alfred-faraday-on ] && chmod +x /usr/local/bin/alfred-faraday-on

cat > /usr/local/bin/alfred-faraday-off << 'EOF'
#!/bin/bash
echo "Disengaging Faraday Cage..."
rfkill unblock all
modprobe uvcvideo 2>/dev/null || true
modprobe snd_hda_intel 2>/dev/null || true
modprobe snd_usb_audio 2>/dev/null || true
echo "Hardware restored."
EOF
[ -e /usr/local/bin/alfred-faraday-off ] && chmod +x /usr/local/bin/alfred-faraday-off

echo "Faraday Cage infrastructure installed."

# --- END MERGED CONTENT FROM: 0190.hook.chroot ---


