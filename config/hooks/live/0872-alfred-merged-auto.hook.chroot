    cat > /etc/apparmor.d/alfred-isolated/profile-34 << 'EOF'
profile alfred-sandbox-34 /usr/local/bin/alfred-util-21 flags=(complain) {
  #include <abstractions/base>
  /usr/local/bin/alfred-util-21 rmix,
  /dev/null rw,
}
EOF
