#!/bin/bash
# 0407-alfred-tribe-levi — 🕎 levi — priestly-service
set -euo pipefail
echo "[0407-tribe-levi] begin"
install -d /etc/alfred/tribes /usr/share/alfred/tribes
cat >/etc/alfred/tribes/levi.flag <<EOS
TRIBE=levi
EMOJI=🕎
GIFT=priestly-service
VERSE="Genesis 49:5 / Numbers 3:6 — set apart for service."
EOS
cat >/usr/share/alfred/tribes/levi.txt <<EOS
🕎  Tribe of levi
Genesis 49:5 / Numbers 3:6 — set apart for service.
Gift: priestly-service
EOS
echo "[0407-tribe-levi] done"

