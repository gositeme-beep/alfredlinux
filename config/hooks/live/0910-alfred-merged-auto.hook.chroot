#!/bin/bash
# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
# 0910-alfred-watchers.hook.chroot
# Phase 4: The Arsenal â€” Autonomous Threat Watchers
# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
set +e
echo "â•”â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•—"
echo "â•‘  [0910] PHASE 4 â€” The Watchers (Threat Aggregator)        â•‘"
echo "â•šâ•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•"

apt-get install -y --no-install-recommends python3 python3-requests 2>/dev/null || true

# â”€â”€ 1. Create the Watcher Python Daemon â”€â”€
cat > /usr/local/bin/alfred-watcher.py << 'WATCHER'
#!/usr/bin/env python3
import time, os, re, json, requests

# Threat Intel API (resolves locally via Hologram DNS)
API_URL = "http://api.gositeme.com/api/threat-intel.php?action=report_threat"
LOG_FILE = "/var/log/auth.log"
STATE_FILE = "/var/lib/alfred-hologram/watcher.state"

def report_threat(ip, user, reason):
    payload = {
        "title": f"Brute Force Attempt: {user}",
        "description": reason,
        "threat_type": "brute_force",
        "severity": "high",
        "source_ip": ip,
        "attack_vector": "ssh",
        "target_resource": "os_layer",
        "source_type": "autonomous_watcher"
    }
    try:
        r = requests.post(API_URL, json=payload, timeout=5)
        print(f"[WATCHER] Threat logged: {ip} -> {r.status_code}")
    except Exception as e:
        print(f"[WATCHER] API Offline: {e}")

def parse_logs():
    if not os.path.exists(LOG_FILE): return
    
    last_pos = 0
    if os.path.exists(STATE_FILE):
        with open(STATE_FILE, "r") as sf:
            last_pos = int(sf.read().strip())

    current_size = os.path.getsize(LOG_FILE)
    if current_size < last_pos: last_pos = 0  # Log rotated

    with open(LOG_FILE, "r") as f:
        f.seek(last_pos)
        lines = f.readlines()
        last_pos = f.tell()

    with open(STATE_FILE, "w") as sf:
        sf.write(str(last_pos))

    # Regex for failed SSH attempts
    fail_re = re.compile(r"Failed password for (invalid user )?(?P<user>\S+) from (?P<ip>\S+) port")
    
    for line in lines:
        match = fail_re.search(line)
        if match:
            ip = match.group("ip")
            user = match.group("user")
            report_threat(ip, user, f"Detected continuous failed auth from {ip}")

if __name__ == "__main__":
    os.makedirs("/var/lib/alfred-hologram", exist_ok=True)
    print("Alfred Linux Watcher Daemon Started.")
    while True:
        parse_logs()
        time.sleep(5)
WATCHER
[ -e "+x" ] && chmod +x /usr/local/bin/alfred-watcher.py

# â”€â”€ 2. Create systemd service â”€â”€
cat > /etc/systemd/system/alfred-watcher.service << 'WSVC'
[Unit]
Description=Alfred Linux Autonomous Watcher
After=network.target

[Service]
Type=simple
ExecStart=/usr/local/bin/alfred-watcher.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
WSVC

systemctl enable alfred-watcher || true || true.service 2>/dev/null || true

echo "â•”â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•—"
echo "â•‘  [0910] Watcher Daemon â€” COMPLETE                         â•‘"
echo "â•‘  âœ“ Python log parser installed                            â•‘"
echo "â•‘  âœ“ Automated POST to Threat Intel API integrated          â•‘"
echo "â•šâ•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•"

