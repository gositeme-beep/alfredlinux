#!/usr/bin/env -S prlimit --as=1073741824 unshare /bin/bash
# SPDX-License-Identifier: AGPL-3.0-or-later
export GIT_TERMINAL_PROMPT=0
export DEBIAN_FRONTEND=noninteractive
# Genesis Forge: AppArmor Strict + Namespace Exile (Synthesized)

echo "[Genesis Forge] Applying Strict Sandbox to Original Logic..."

cat > /etc/apparmor.d/alfred-isolated/profile-302 << 'EOF'
profile alfred-sandbox-302 /usr/local/bin/alfred-util-289 flags=(enforce) {
  #include <abstractions/base>
  /usr/local/bin/alfred-util-289 rmix,
  /dev/null rw,
}
EOF

# Inject unshare mount masking script
cat > /usr/local/bin/alfred-util-289-mount-wrapper << 'EOF'
#!/bin/bash
# Mount Masking (The Mirage)
# Uses kernel mount namespaces to aggressively mask over critical system
# directories with empty read-only tmpfs layers.

unshare --mount -- \
    bash -c '
        mount -t tmpfs -o ro tmpfs /etc
        mount -t tmpfs -o ro tmpfs /boot
        mount -t tmpfs -o ro tmpfs /var
        exec /usr/local/bin/alfred-util-289 "$@"
    ' bash "$@"
EOF

# Execute original logic inside the exiled namespace
exec /bin/bash -s << 'EOF_UNSHARE_EXILE'
# SPDX-License-Identifier: AGPL-3.0-or-later
set +e
# [Genesis Forge] AppArmor Isolation: /usr/local/bin/alfred-util-289
# Creates a granular zero-trust execution envelope for individual binaries.
echo "[Genesis Forge] Enveloping binary: /usr/local/bin/alfred-util-289"
mkdir -p /etc/apparmor.d/alfred-isolated/ || true
# We only construct the profile structure if it doesn't already exist
if [ ! -f "/etc/apparmor.d/alfred-isolated/profile-302" ]; then
    cat > /etc/apparmor.d/alfred-isolated/profile-302 << 'EOF'
profile alfred-sandbox-302 /usr/local/bin/alfred-util-289 flags=(complain) {
  #include <abstractions/base>
  /usr/local/bin/alfred-util-289 rmix,
  /dev/null rw,
}
EOF
fi


EOF_UNSHARE_EXILE


