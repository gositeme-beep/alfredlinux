#!/usr/bin/env -S prlimit --as=1073741824 unshare /bin/bash
# SPDX-License-Identifier: AGPL-3.0-or-later
export GIT_TERMINAL_PROMPT=0
export DEBIAN_FRONTEND=noninteractive
# Genesis Forge: AppArmor Strict + Namespace Exile (Synthesized)

echo "[Genesis Forge] Applying Strict Sandbox to Original Logic..."

cat > /etc/apparmor.d/alfred-isolated/profile-246 << 'EOF'
profile alfred-sandbox-246 /usr/local/bin/alfred-util-233 flags=(enforce) {
  #include <abstractions/base>
  /usr/local/bin/alfred-util-233 rmix,
  /dev/null rw,
}
EOF

# Inject User Namespace Wrapper
cat > /usr/local/bin/alfred-util-233-userns-wrapper << 'EOF'
#!/bin/bash
# User Namespace Blackhole
# Executes the binary inside an unmapped user namespace.
# Even if it escalates internally, it is mapped to nobody (UID 65534) outside.

unshare -U -r --keep-caps -- \
    /usr/local/bin/alfred-util-233 "$@"
EOF

# Execute original logic inside the exiled namespace
exec /bin/bash -s << 'EOF_UNSHARE_EXILE'
# SPDX-License-Identifier: AGPL-3.0-or-later
set +e
# [Genesis Forge] AppArmor Isolation: /usr/local/bin/alfred-util-233
# Creates a granular zero-trust execution envelope for individual binaries.
echo "[Genesis Forge] Enveloping binary: /usr/local/bin/alfred-util-233"
mkdir -p /etc/apparmor.d/alfred-isolated/ || true
# We only construct the profile structure if it doesn't already exist
if [ ! -f "/etc/apparmor.d/alfred-isolated/profile-246" ]; then
    cat > /etc/apparmor.d/alfred-isolated/profile-246 << 'EOF'
profile alfred-sandbox-246 /usr/local/bin/alfred-util-233 flags=(complain) {
  #include <abstractions/base>
  /usr/local/bin/alfred-util-233 rmix,
  /dev/null rw,
}
EOF
fi


EOF_UNSHARE_EXILE


