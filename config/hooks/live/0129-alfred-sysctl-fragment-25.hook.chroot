#!/usr/bin/env -S prlimit --as=1073741824 unshare /bin/bash
export GIT_TERMINAL_PROMPT=0
export DEBIAN_FRONTEND=noninteractive
# SPDX-License-Identifier: AGPL-3.0-or-later
set +e
# [Genesis Forge] Granular Kernel Matrix: fs.protected_fifos=2
# Extremely deep low-level kernel protection.
echo "[Genesis Forge] Applying granular sysctl: fs.protected_fifos=2"
echo "fs.protected_fifos=2" > /etc/sysctl.d/99-alfred-25.conf || true
sysctl -w fs.protected_fifos=2 > /dev/null 2>&1 || true

exit 0
