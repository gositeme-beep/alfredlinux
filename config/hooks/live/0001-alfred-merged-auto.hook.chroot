echo "When prompted for a password, create a temporary one (e.g., 'alfred')."
echo "You will enter this password during the next reboot to confirm the key."
mokutil --import "$MOK_DIR/MOK.der"
echo "Please reboot to complete the Secure Boot chain of trust."
EOF
