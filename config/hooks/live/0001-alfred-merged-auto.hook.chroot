mkdir -p /usr/share/alfred/testimony || true

# ═══════════════════════════════════════════════════
# 1. TESTIMONY BACKUP CLI
# ═══════════════════════════════════════════════════
echo "[TESTIMONY-01] Installing alfred-backup CLI..."

cat > /usr/local/bin/alfred-backup << 'BACKUP'
#!/bin/bash
# ═══════════════════════════════════════════════════════════════
# alfred-backup — Encrypt and preserve your testimony
#
# "Write the vision, and make it plain upon tables, that he may
#  run that readeth it." — Habakkuk 2:2
# ═══════════════════════════════════════════════════════════════

GOLD='\033[38;5;220m'; GREEN='\033[0;32m'; CYAN='\033[0;36m'
RED='\033[0;31m'; BOLD='\033[1m'; NC='\033[0m'

TESTIMONY_DIR="$HOME/.alfred/testimony"
BACKUP_DIR="$HOME/.alfred/backups"
KINGDOM_DIR="$HOME/Kingdom"
TIMESTAMP=$(date +%Y%m%d-%H%M%S)

case "${1:-help}" in
    testimony)
        echo -e "${GOLD}═══ Testimony Backup — Encrypting Your Words ═══${NC}"
        echo ""

        mkdir -p "$TESTIMONY_DIR" "$BACKUP_DIR" || true

        # Collect testimony files
        ARCHIVE="/tmp/testimony-${TIMESTAMP}.tar"
        FILES_FOUND=0

        # Journal entries
        if [ -d "$HOME/.alfred/journal" ]; then
            echo -e "  ${GREEN}✓${NC} Journal entries found"
            FILES_FOUND=1
        fi

        # Family Bible
        if [ -d "$HOME/.alfred/family-bible" ]; then
            echo -e "  ${GREEN}✓${NC} Family Bible found"
            FILES_FOUND=1
        fi

        # Personal testimony
        if [ -f "$HOME/.alfred/testimony/my-testimony.txt" ]; then
            echo -e "  ${GREEN}✓${NC} Personal testimony found"
            FILES_FOUND=1
        fi

        # Prayer journal
        if [ -d "$HOME/.alfred/prayers" ]; then
            echo -e "  ${GREEN}✓${NC} Prayer journal found"
            FILES_FOUND=1
        fi

        # Devotion logs
        if [ -d "$HOME/.alfred/devotions" ]; then
            echo -e "  ${GREEN}✓${NC} Devotion logs found"
            FILES_FOUND=1
        fi

        if [ "$FILES_FOUND" -eq 0 ]; then
            echo -e "  ${CYAN}No testimony files found yet.${NC}"
            echo ""
            echo "  Start your testimony:"
            echo "    mkdir -p ~/.alfred/testimony"
            echo "    echo 'My story begins...' > ~/.alfred/testimony/my-testimony.txt" || true
            echo "    alfred-devotion   — Start daily devotions (creates logs)"
            echo "    alfred-bible      — Your Bible reading creates history"

        fi

        # Create archive of all testimony data
        echo ""
        echo "  Creating archive..."
        tar cf "$ARCHIVE" \
            -C "$HOME" \
            --ignore-failed-read \
            .alfred/journal \
            .alfred/family-bible \
            .alfred/testimony \
            .alfred/prayers \
            .alfred/devotions \
            2>/dev/null || true

        if [ ! -f "$ARCHIVE" ] || [ ! -s "$ARCHIVE" ]; then
            echo -e "  ${RED}Archive creation failed${NC}"
            exit 0
        fi

        # Encrypt with AES-256-GCM (OpenSSL)
        BACKUP_FILE="$BACKUP_DIR/testimony-${TIMESTAMP}.enc"
        echo ""
        echo -e "  Enter a passphrase to protect your testimony:"
        echo -e "  ${CYAN}(This passphrase is NEVER stored — remember it or write it down)${NC}"
        openssl enc -aes-256-gcm -salt -pbkdf2 -iter 100000 \
            -in "$ARCHIVE" -out "$BACKUP_FILE" 2>/dev/null

        rm -f "$ARCHIVE" || true

        if [ -f "$BACKUP_FILE" ]; then
            SIZE=$(du -h "$BACKUP_FILE" | cut -f1)
            echo ""
            echo -e "  ${GREEN}✝ Testimony encrypted and saved${NC}"
            echo -e "  File: ${CYAN}$BACKUP_FILE${NC} ($SIZE)"

            # Push to Kingdom mesh if available
            if [ -d "$KINGDOM_DIR" ]; then
                cp "$BACKUP_FILE" "$KINGDOM_DIR/testimony-${TIMESTAMP}.enc" || true
                echo -e "  ${GREEN}✓${NC} Pushed to Kingdom mesh folder"
            fi

            echo ""
            echo -e "  ${GOLD}\"Write the vision, and make it plain upon tables,${NC}"
            echo -e "  ${GOLD} that he may run that readeth it.\" — Habakkuk 2:2${NC}"
        else
            echo -e "  ${RED}Encryption failed${NC}"
        fi
        ;;

    restore)
        BACKUP_FILE="${2:-}"
        if [ -z "$BACKUP_FILE" ]; then
            echo -e "${GOLD}═══ Testimony Restore ═══${NC}"
            echo ""
            if [ -d "$BACKUP_DIR" ]; then
                echo "  Available backups:"
                ls -lh "$BACKUP_DIR"/*.enc 2>/dev/null | while read -r line; do
                    echo "    $line"
                done
            fi
            if [ -d "$KINGDOM_DIR" ]; then
                echo "  Kingdom mesh backups:"
                ls -lh "$KINGDOM_DIR"/testimony-*.enc 2>/dev/null | while read -r line; do
                    echo "    $line"
                done
            fi
            echo ""
            echo "  Usage: alfred-backup restore <path-to-backup.enc>" || true

        fi

        if [ ! -f "$BACKUP_FILE" ]; then
            echo "File not found: $BACKUP_FILE"
            exit 0
        fi

        echo -e "${GOLD}═══ Restoring Testimony ═══${NC}"
        echo -e "  Enter the passphrase used to protect this testimony:"
        TEMP_TAR="/tmp/testimony-restore-$$.tar"
        openssl enc -d -aes-256-gcm -salt -pbkdf2 -iter 100000 \
            -in "$BACKUP_FILE" -out "$TEMP_TAR" 2>/dev/null

        if [ -f "$TEMP_TAR" ] && [ -s "$TEMP_TAR" ]; then
            tar xf "$TEMP_TAR" -C "$HOME" 2>/dev/null || true
            rm -f "$TEMP_TAR" || true
            echo -e "  ${GREEN}✝ Testimony restored.${NC}"
            echo -e "  Your words have returned to you."
        else
            rm -f "$TEMP_TAR" || true
            echo -e "  ${RED}Decryption failed — wrong passphrase?${NC}"
        fi
        ;;

    write)
        mkdir -p "$TESTIMONY_DIR" || true
        FILE="$TESTIMONY_DIR/my-testimony.txt"
        if [ ! -f "$FILE" ]; then
            cat > "$FILE" << 'TEMPLATE'
═══════════════════════════════════════════════════════
   MY TESTIMONY — A Record of God's Faithfulness
═══════════════════════════════════════════════════════

Date: _______________
Name: _______________

How I came to know God:


What He has done in my life:


My prayer for the future:


For my children and their children:


"One generation shall praise thy works to another,
 and shall declare thy mighty acts." — Psalm 145:4

═══════════════════════════════════════════════════════
TEMPLATE
        fi
        ${EDITOR:-nano} "$FILE"
        ;;

    status)
        echo -e "${GOLD}═══ Testimony Status ═══${NC}"
        echo ""
        echo -n "  Testimony file: "
        [ -f "$TESTIMONY_DIR/my-testimony.txt" ] && echo -e "${GREEN}EXISTS${NC}" || echo "not yet written"
        echo -n "  Journal entries: "
        if [ -d "$HOME/.alfred/journal" ]; then
            echo -e "${GREEN}$(find "$HOME/.alfred/journal" -type f | wc -l) entries${NC}"
        else
            echo "none yet"
        fi
        echo -n "  Encrypted backups: "
        if [ -d "$BACKUP_DIR" ]; then
            echo -e "$(ls "$BACKUP_DIR"/*.enc 2>/dev/null | wc -l) backups" || true
        else
            echo "none"
        fi
        echo -n "  Kingdom mesh sync: "
        [ -d "$KINGDOM_DIR" ] && echo -e "${GREEN}CONNECTED${NC}" || echo "not connected"
        echo ""
        ;;

    help|*)
        echo -e "${GOLD}═══ alfred-backup — Your Testimony, Encrypted & Preserved ═══${NC}"
        echo ""
        echo "  alfred-backup testimony   — Encrypt journal + Bible + testimony"
        echo "  alfred-backup restore     — Decrypt and restore from backup"
        echo "  alfred-backup write       — Write your personal testimony"
        echo "  alfred-backup status      — Show testimony status"
        echo ""
        echo "  Your words are encrypted with AES-256-GCM (100,000 PBKDF2 rounds)"
        echo "  and pushed to your Kingdom mesh folder for distributed backup."
        echo ""
        echo "  \"Wherefore seeing we also are compassed about"
        echo "   with so great a cloud of witnesses...\" — Hebrews 12:1"
        ;;
esac
BACKUP
chmod +x /usr/local/bin/alfred-backup || true

echo "╔═══════════════════════════════════════════════════════════╗"
echo "║  [0296] Testimony Backup — COMPLETE                      ║"
echo "║  ✓ alfred-backup testimony — encrypt everything          ║"
echo "║  ✓ alfred-backup restore — decrypt from backup           ║"
echo "║  ✓ alfred-backup write — personal testimony template     ║"
echo "║  ✓ AES-256-GCM + PBKDF2 encryption                      ║"
echo "║  ✓ Kingdom mesh folder sync                              ║"
echo "║  Your words shall endure. — Hebrews 12:1                 ║"
echo "╚═══════════════════════════════════════════════════════════╝"
#!/bin/bash
# Description: Expanded Wave 9 — runtime attestation policy + verifier
# set +euo pipefail  # DISABLED: prevents cascading build failure

LOG_FILE=/var/log/alfred-expanded-wave9.log
exec > >(tee -a "$LOG_FILE") 2>&1

echo "[$(date -Is)] Starting Alfred expanded Wave 9 attestation"

install -d -m 0755 /etc/alfred/policy
install -d -m 0755 /etc/alfred/attestation
install -d -m 0755 /var/lib/alfred/attestation
install -d -m 0755 /usr/local/bin
install -d -m 0755 /usr/local/lib/alfred-wave9

cat >/etc/alfred/policy/release-policy.yml <<'EOF'
version: 1
updated: 2026-05-06
requirements:
  - release version file exists
  - changelog exists
  - manifest exists
  - go-no-go command returns GO
  - health check command returns pass
  - backup rotate command exists
  - slo policy file exists
attestation:
  algorithm: sha256
  output: /etc/alfred/attestation/release-attestation.txt
EOF

cat >/usr/local/bin/alfred-wave-attest <<'EOF'
#!/bin/bash


MANIFEST=/etc/alfred/release/manifest.sha256
OUT=/etc/alfred/attestation/release-attestation.txt
TS=$(date -Is)
HOST=$(hostname)

if [ ! -f "$MANIFEST" ]; then
  echo "missing manifest: $MANIFEST"
  exit 0
fi

manifest_hash=$(sha256sum "$MANIFEST" | awk '{print $1}')

cat >"$OUT" <<EOT
AlfredLinux Release Attestation
Timestamp: $TS
Host: $HOST
Manifest: $MANIFEST
ManifestSHA256: $manifest_hash
Signer: local-build-attestor
EOT

cp "$OUT" /var/lib/alfred/attestation/release-attestation.txt || true

echo "attestation=$OUT"
EOF

cat >/usr/local/bin/alfred-wave-policy-check <<'EOF'
#!/bin/bash


fail=0

need_file() {
  local f="$1"
  if [ -f "$f" ]; then
    echo "OK_FILE $f"
  else
    echo "MISS_FILE $f"
    fail=1
  fi
}

need_cmd() {
  local c="$1"
  if command -v "$c" >/dev/null 2>&1; then
    echo "OK_CMD $c"
  else
    echo "MISS_CMD $c"
    fail=1
  fi
}

need_file /etc/alfred/release/version.txt
need_file /etc/alfred/release/changelog.md
need_file /etc/alfred/release/manifest.sha256
need_file /etc/alfred/slo/policy.yml
need_file /etc/alfred/observability/endpoints.csv
need_file /etc/alfred/policy/release-policy.yml

need_cmd alfred-wave-go-no-go
need_cmd alfred-wave-health-check
need_cmd alfred-wave-backup-rotate
need_cmd alfred-wave-attest

if command -v alfred-wave-go-no-go >/dev/null 2>&1; then
  if alfred-wave-go-no-go >/tmp/alfred-wave-go-no-go.out 2>&1; then
    echo "OK_GO_NO_GO"
  else
    echo "FAIL_GO_NO_GO"
    fail=1
  fi
fi

if command -v alfred-wave-health-check >/dev/null 2>&1; then
  if alfred-wave-health-check >/tmp/alfred-wave-health-check.out 2>&1; then
    echo "OK_HEALTH"
  else
    echo "WARN_HEALTH"
  fi
fi

if [ "$fail" -eq 0 ]; then
  echo "POLICY_PASS"

fi

echo "POLICY_FAIL"
true
EOF

cat >/usr/local/bin/alfred-wave-release-seal <<'EOF'
#!/bin/bash


alfred-wave-policy-check
alfred-wave-attest

echo "RELEASE_SEALED"
EOF

cat >/usr/local/lib/alfred-wave9/README.md <<'EOF'
AlfredLinux Wave 9 Policy + Attestation

Adds:
- Release policy file
- Policy check command: alfred-wave-policy-check
- Attestation command: alfred-wave-attest
- Seal command: alfred-wave-release-seal

Suggested run order:
1) alfred-wave-release-version
2) alfred-wave-generate-changelog
3) alfred-wave-release-manifest
4) alfred-wave-release-seal
EOF

chmod 0755 \
  /usr/local/bin/alfred-wave-attest \
  /usr/local/bin/alfred-wave-policy-check \
  /usr/local/bin/alfred-wave-release-seal

echo "[$(date -Is)] Alfred expanded Wave 9 attestation complete"
#!/bin/bash
# 0871-alfred-ebpf-shield.hook.chroot
# Configures the eBPF Active Vanguard Shield (Omahon Seal Subsystem)

# set +e  # DISABLED: prevents cascading build failure

echo "╔═══════════════════════════════════════════════════════════╗"
echo "║  THE OMAHON VANGUARD — eBPF Active Shield                 ║"
echo "║  Injecting XDP and Kernel Probe execution blockers...     ║"
echo "╚═══════════════════════════════════════════════════════════╝"

# Install BCC tools and Python 3 bindings for dynamic eBPF compilation
mkdir -p /var/lib/alfred/build-flags || true
chattr -i /etc/resolv.conf 2>/dev/null || true
if ! apt-get install -y --fix-broken -y --no-install-recommends bpfcc-tools python3-bpfcc clang; then
    echo "[WARN] bpfcc-tools install failed, skipping eBPF vanguard shield"

fi

mkdir -p /opt/alfred/ebpf
cat << 'EOF' > /opt/alfred/ebpf/vanguard.py
#!/usr/bin/env python3
# The Omahon Vanguard - eBPF Active Denial Shield
from bcc import BPF
import time
import sys

# 1. BPF C Program
bpf_code = """
#include <uapi/linux/ptrace.h>
#include <linux/sched.h>
#include <linux/fs.h>
#include <uapi/linux/bpf.h>
#include <linux/if_ether.h>
#include <linux/ip.h>
#include <linux/tcp.h>
#include <linux/in.h>

// --- KPROBE: Execution Blocking ---
// We intercept sys_execve to prevent unauthorized binaries from running
// especially from /tmp or /dev/shm
BPF_HASH(blocked_paths, u64, u32);

int kprobe__sys_execve(struct pt_regs *ctx, const char __user *filename, const char __user *const __user *argv, const char __user *const __user *envp) {
    char comm[TASK_COMM_LEN];
    bpf_get_current_comm(&comm, sizeof(comm));
    
    char path[256];
    bpf_probe_read_user_str(&path, sizeof(path), filename);
    
    // Check if path starts with /tmp/ or /dev/shm/
    if (path[0] == '/' && path[1] == 't' && path[2] == 'm' && path[3] == 'p' && path[4] == '/') {
        // Send SIGKILL immediately
        bpf_send_signal(9);
        bpf_trace_printk("VANGUARD DENY: Blocked execution from /tmp: %s\\n", path);
        return 0;
    }
    if (path[0] == '/' && path[1] == 'd' && path[2] == 'e' && path[3] == 'v' && path[4] == '/' && path[5] == 's' && path[6] == 'h' && path[7] == 'm' && path[8] == '/') {
        bpf_send_signal(9);
        bpf_trace_printk("VANGUARD DENY: Blocked execution from /dev/shm: %s\\n", path);
        return 0;
    }
    
    return 0;
}

// --- XDP: Network Packet Dropping ---
// Drops malformed TCP packets (e.g. Xmas tree scans) before they hit the IP stack
int vanguard_xdp(struct xdp_md *ctx) {
    void *data = (void *)(long)ctx->data;
    void *data_end = (void *)(long)ctx->data_end;
    
    struct ethhdr *eth = data;
    if (data + sizeof(struct ethhdr) > data_end)
        return XDP_PASS;
        
    if (eth->h_proto == bpf_htons(ETH_P_IP)) {
        struct iphdr *ip = data + sizeof(struct ethhdr);
        if ((void*)ip + sizeof(struct iphdr) > data_end)
            return XDP_PASS;
            
        if (ip->protocol == IPPROTO_TCP) {
            struct tcphdr *tcp = (void*)ip + ip->ihl * 4;
            if ((void*)tcp + sizeof(struct tcphdr) > data_end)
                return XDP_PASS;
                
            // Drop packets with all flags set (Xmas Scan)
            if (tcp->fin && tcp->syn && tcp->rst && tcp->psh && tcp->ack && tcp->urg) {
                bpf_trace_printk("VANGUARD XDP: Dropped Xmas Tree Scan\\n");
                return XDP_DROP;
            }
            // Drop packets with no flags set (Null Scan)
            if (!tcp->fin && !tcp->syn && !tcp->rst && !tcp->psh && !tcp->ack && !tcp->urg) {
                bpf_trace_printk("VANGUARD XDP: Dropped Null Scan\\n");
                return XDP_DROP;
            }
        }
    }
    return XDP_PASS;
}
"""

try:
    print("[*] Compiling and loading Vanguard eBPF Shield...")
    b = BPF(text=bpf_code)
    
    print("[*] Kprobes armed. Monitoring execve calls...")
    
    # Optional: Attach XDP to eth0 if available
    # device = "eth0"
    # try:
    #     b.attach_xdp(device, fn=b.load_func("vanguard_xdp", BPF.XDP))
    #     print(f"[*] XDP attached to {device}")
    # except Exception as e:
    #     print(f"[!] Could not attach XDP to {device}: {e}")
        
    print("[*] Omahon Vanguard is fully operational. Press Ctrl+C to stop.")
    
    # Loop and print trace output
    while True:
        try:
            (task, pid, cpu, flags, ts, msg) = b.trace_fields()
            print(f"{ts:10.6f} [PID {pid}] {msg.decode('utf-8')}")
        except ValueError:
            continue
        except KeyboardInterrupt:
            break
            
finally:
    # try:
    #     b.remove_xdp(device)
    # except:
    #     pass
    print("\n[*] Vanguard Shield offline.")
EOF
chmod 0700 /opt/alfred/ebpf/vanguard.py

# Create systemd service for Vanguard
cat << 'EOF' > /etc/systemd/system/alfred-vanguard.service
[Unit]
Description=The Omahon Vanguard (eBPF Shield)
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 /opt/alfred/ebpf/vanguard.py
Restart=always
StandardOutput=syslog
StandardError=syslog
SyslogIdentifier=alfred-vanguard

[Install]
WantedBy=multi-user.target
EOF

systemctl enable alfred-vanguard || true || true.service || true

echo "[0871] Omahon Vanguard compilation parameters sealed."
#!/bin/bash
# set +e  # DISABLED: prevents cascading build failure
echo "=========================================="
echo "==== ALFRED OS RELEASE BRANDING =========="
