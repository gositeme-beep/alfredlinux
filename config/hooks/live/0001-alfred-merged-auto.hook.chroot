#!/bin/bash
# SPDX-License-Identifier: AGPL-3.0-or-later
set +e
# 0001-alfred-fix-permissions.hook.chroot
# Fixes ownership and permissions of core directories that might have been overwritten or tainted

echo "[0001] Restoring root ownership and secure permissions to core directories"

# Ensure core directories are owned by root and NOT world-writable
for dir in / /etc /etc/default /lib /sbin /bin /usr /usr/sbin /usr/bin /usr/local /usr/local/bin /usr/local/sbin /var /opt /boot /srv /sys /run /proc; do
    if [ -d "$dir" ]; then
        chown root:root "$dir" || true
        chmod 755 "$dir" || true
    fi
done

# Fix Leaked Host File Ownership (root:root bug)
# Files copied from the host bind-mount retain the host UID/GID (e.g. 1000).
# Since this hook runs before any local users are created, any UID >= 1000
# belongs to a leaked host file and MUST be root:root for the ISO to function.
echo "Correcting host-leaked file ownership to root:root..."
if [ ! -f /root/.chgrp_sweep_done ]; then
  touch /root/.chgrp_sweep_done
fi


# We also ensure ufw config directories are secure if they exist
if [ -d "/etc/ufw" ]; then
    chown -R root:root /etc/ufw || true
    chmod -R o-w /etc/ufw || true
fi

if [ -d "/lib/ufw" ]; then
    chown -R root:root /lib/ufw || true
    chmod -R o-w /lib/ufw || true
fi

if [ -d "/sbin/ufw" ]; then
    chown -R root:root /sbin/ufw || true
    chmod -R o-w /sbin/ufw || true
fi

if [ -f "/etc/default/ufw" ]; then
    chown root:root /etc/default/ufw || true
    chmod o-w /etc/default/ufw || true
fi

if [ -d "/usr/share/ufw" ]; then
    chown -R root:root /usr/share/ufw || true
    chmod -R o-w /usr/share/ufw || true
fi

if [ -f "/usr/sbin/ufw" ]; then
    chown root:root /usr/sbin/ufw || true
    chmod o-w /usr/sbin/ufw || true
fi

echo "[0001] Permissions restored and secured against Perl taint mode crashes."

