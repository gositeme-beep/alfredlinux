[ -e "$BACKUP_FILE" ] &&                 cp "$BACKUP_FILE" "$KINGDOM_DIR/testimony-${TIMESTAMP}.enc" || true
                echo -e "  ${GREEN}???${NC} Pushed to Kingdom mesh folder"
            fi

            echo ""
            echo -e "  ${GOLD}\"Write the vision, and make it plain upon tables,${NC}"
            echo -e "  ${GOLD} that he may run that readeth it.\" ??? Habakkuk 2:2${NC}"
        else
            echo -e "  ${RED}Encryption failed${NC}"
        fi
        ;;

    restore)
        BACKUP_FILE="${2:-}"
        if [ -z "$BACKUP_FILE" ]; then
            echo -e "${GOLD}????????? Testimony Restore ?????????${NC}"
            echo ""
            if [ -d "$BACKUP_DIR" ]; then
