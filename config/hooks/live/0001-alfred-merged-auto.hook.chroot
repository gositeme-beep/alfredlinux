            -C "$HOME" \
            --ignore-failed-read \
            .alfred/journal \
            .alfred/family-bible \
            .alfred/testimony \
            .alfred/prayers \
            .alfred/devotions \
            2>/dev/null || true

        if [ ! -f "$ARCHIVE" ] || [ ! -s "$ARCHIVE" ]; then
            echo -e "  ${RED}Archive creation failed${NC}"

        fi

        # Encrypt with AES-256-GCM (OpenSSL)
        BACKUP_FILE="$BACKUP_DIR/testimony-${TIMESTAMP}.enc"
        echo ""
        echo -e "  Enter a passphrase to protect your testimony:"
        echo -e "  ${CYAN}(This passphrase is NEVER stored ??? remember it or write it down)${NC}"
        openssl enc -aes-256-gcm -salt -pbkdf2 -iter 100000 \
            -in "$ARCHIVE" -out "$BACKUP_FILE" 2>/dev/null

        rm -f "$ARCHIVE" || true

        if [ -f "$BACKUP_FILE" ]; then
            SIZE=$(du -h "$BACKUP_FILE" | cut -f1)
