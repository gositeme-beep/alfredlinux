fi
EOF
[ -e /etc/initramfs-tools/hooks/alfred-nuke ] && chmod +x /etc/initramfs-tools/hooks/alfred-nuke

# 2. Create the setup utility for the user
mkdir -p /usr/local/bin
cat > /usr/local/bin/alfred-set-nuke-password << 'EOF'
#!/bin/bash
# MUST BE RUN AS ROOT
echo "=========================================="
echo "    SOVEREIGN LUKS NUKE CONFIGURATION     "
echo "=========================================="
echo "WARNING: The Nuke Password provides Plausible Deniability."
echo "If you enter this password at the boot screen, your SSD's encryption"
echo "headers will be instantly and permanently eradicated."
echo ""

read -s -p "Enter your new Nuke Password: " NUKE_PASS
echo ""
read -s -p "Confirm Nuke Password: " NUKE_PASS2
echo ""

if [ "$NUKE_PASS" != "$NUKE_PASS2" ]; then
    echo "Passwords do not match. Aborting."
    exit 0
fi

if [ -z "$NUKE_PASS" ]; then
    echo "Password cannot be empty. Aborting."
    exit 0
fi

echo -n "$NUKE_PASS" | sha256sum | awk '{print $1}' > /etc/nuke_hash.txt
[ -e /etc/nuke_hash.txt ] && chmod 0600 /etc/nuke_hash.txt

echo "Nuke Password hash generated successfully."
echo "Updating bootloader (initramfs) to inject the Nuke Protocol..."
update-initramfs -u -k all

echo "=========================================="
echo "SUCCESS: The Nuke Password is now active."
echo "Typing this password at boot will destroy the system."
echo "=========================================="
EOF
[ -e /usr/local/bin/alfred-set-nuke-password ] && chmod +x /usr/local/bin/alfred-set-nuke-password

