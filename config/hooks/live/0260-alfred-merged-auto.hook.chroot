#!/bin/bash
# 0260-alfred-comfyui.hook.chroot
# Installs ComfyUI (The Visual Forge) and links it to the downloaded AI models

set +e

echo "I: [alfred] Installing ComfyUI Visual Rendering Engine..."

export DEBIAN_FRONTEND=noninteractive

# Install dependencies (git and python venv dependencies usually exist, but ensure)
apt-get install -y --no-install-recommends git python3-venv python3-pip || true

mkdir -p /opt
cd /opt

if [ ! -d "ComfyUI" ]; then
    # Clone ComfyUI without large history
    if [[ "${ALFRED_ALLOW_HOOK_NETWORK_DOWNLOADS:-}" == "1" ]]; then
        git clone --depth 1 https://github.com/comfyanonymous/ComfyUI.git || true
    else
        echo "I: [alfred] Skipping ComfyUI git clone due to network restrictions."

    fi
fi

cd ComfyUI || { echo " Skipping ComfyUI install; exit 0; }

# Set up virtual environment
python3 -m venv venv
# Install dependencies using the virtual environment
./venv/bin/pip install --break-system-packages --upgrade pip || true
./venv/bin/pip install --break-system-packages torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cpu || true
./venv/bin/pip install --break-system-packages -r requirements.txt || true

# Symlink the models from the Apocalypse Vault into ComfyUI
mkdir -p /usr/share/alfred/models/diffusion || true
mkdir -p /usr/share/alfred/models/video || true

# Link FLUX (unet/checkpoints)
mkdir -p models/unet models/checkpoints
ln -sf /usr/share/alfred/models/diffusion/flux1-schnell.safetensors models/checkpoints/flux1-schnell.safetensors || true

# Link CogVideoX
ln -sf /usr/share/alfred/models/video/cogvideox-5b.safetensors models/checkpoints/cogvideox-5b.safetensors || true

# Create systemd service (Optional: launch on boot or on demand)
cat > /etc/systemd/system/comfyui.service << 'COMFYSVC'
[Unit]
Description=ComfyUI Visual Forge
After=network-online.target

[Service]
Type=simple
User=alfred
WorkingDirectory=/opt/ComfyUI
ExecStart=/opt/ComfyUI/venv/bin/python main.py --listen 127.0.0.1 --port 8188 --cpu
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
COMFYSVC

# Create a desktop shortcut for Alfred Studio
mkdir -p /usr/share/applications || true
cat > /usr/share/applications/alfred-studio.desktop << 'DESK'
[Desktop Entry]
Name=Alfred Studio (Visual Forge)
Comment=Generate Images and Video locally using ComfyUI
Exec=xdg-open http://127.0.0.1:8188
Icon=applications-graphics
Terminal=false
Type=Application
Categories=Graphics;Science;AI;
Keywords=ai;comfyui;image;video;flux;cogvideox;
DESK

echo "I: [alfred] ComfyUI installation complete."

