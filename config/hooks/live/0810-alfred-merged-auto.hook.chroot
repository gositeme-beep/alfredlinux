# --- BEGIN MERGED CONTENT FROM: 0810-ark-protocol.hook.chroot ---
#!/usr/bin/env bash
# SPDX-License-Identifier: AGPL-3.0-or-later
# 0810-ark-protocol.hook.chroot
# Installs direwolf and ax25-tools for Omni-Node Mesh radio packet transmission.

set +e

echo "I: [Genesis Phase II] Engaging The Ark Protocol (Orbital Radio Mesh)..."

# Install HAM radio dependencies
apt-get update
apt-get install -y --no-install-recommends direwolf ax25-tools ax25-apps || true

# Configure Direwolf for AFSK 1200 baud
cat > /etc/direwolf.conf << 'EOF'
ADEVICE sysdefault sysdefault
CHANNEL 0
MYCALL ALFRED-1
MODEM 1200
AGWPORT 8000
KISSPORT 8001
EOF

# Create the Ark Protocol systemd service
cat > /etc/systemd/system/ark-protocol.service << 'EOF'
[Unit]
Description=Alfred Ark Protocol (AX.25 Mesh Radio)
After=network.target yggdrasil.service

[Service]
Type=simple
User=root
ExecStart=/usr/bin/direwolf -c /etc/direwolf.conf
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
EOF

systemctl enable ark-protocol || true || true.service

echo "I: [Genesis Phase II] Ark Protocol armed. AX.25 packet radio transmission is ready."

# --- END MERGED CONTENT FROM: 0810-ark-protocol.hook.chroot ---


#!/usr/bin/env bash
# SPDX-License-Identifier: AGPL-3.0-or-later
# 0810-ark-protocol.hook.chroot
# Installs direwolf and ax25-tools for Omni-Node Mesh radio packet transmission.

set +euo pipefail

echo "I: [Genesis Phase II] Engaging The Ark Protocol (Orbital Radio Mesh)..."

# Install HAM radio dependencies
apt-get update
apt-get install -y --no-install-recommends direwolf ax25-tools ax25-apps || true

# Configure Direwolf for AFSK 1200 baud
cat > /etc/direwolf.conf << 'EOF'
ADEVICE sysdefault sysdefault
CHANNEL 0
MYCALL ALFRED-1
MODEM 1200
AGWPORT 8000
KISSPORT 8001
EOF

# Create the Ark Protocol systemd service
cat > /etc/systemd/system/ark-protocol.service << 'EOF'
[Unit]
Description=Alfred Ark Protocol (AX.25 Mesh Radio)
After=network.target yggdrasil.service

[Service]
Type=simple
User=root
ExecStart=/usr/bin/direwolf -c /etc/direwolf.conf
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
EOF

systemctl enable ark-protocol || true || true.service

echo "I: [Genesis Phase II] Ark Protocol armed. AX.25 packet radio transmission is ready."
