# === INJECTED: The Living Tabernacle & Still Small Voice ===
apt-get install -y --no-install-recommends sox libsox-fmt-all bc cron || true

cat > /usr/local/bin/alfred-tabernacle-resonance << 'EOF_TAB'
#!/bin/bash
DAY=$(date +%u)
HOUR=$(date +%H)
if [ "$DAY" -eq 5 ] && [ "$HOUR" -ge 18 ]; then
    touch /tmp/sabbath_mode_active
elif [ "$DAY" -eq 6 ] && [ "$HOUR" -le 18 ]; then
    touch /tmp/sabbath_mode_active
else
    rm -f /tmp/sabbath_mode_active
fi
# Ambient Resonance
LOAD=$(cat /proc/loadavg | awk '{print $1}')
if (($(echo "$LOAD < 1.0" | bc -l))); then
    play -n synth 10 sine 432 vol 0.05 >/dev/null 2>&1 || sleep 10
else
    play -n synth 10 sine 528 vol 0.05 >/dev/null 2>&1 || sleep 10
fi
EOF_TAB
chmod +x /usr/local/bin/alfred-tabernacle-resonance || true

(crontab -l 2>/dev/null; echo "* * * * * /usr/local/bin/alfred-tabernacle-resonance") | crontab -
echo "[$(date -Is)] The Living Tabernacle and Still Small Voice are active."

# === INJECTED: The Stillness of Eden (Circadian Chronobiology) ===
cat > /usr/local/bin/alfred-eden-stillness << 'EOF_EDEN'
#!/bin/bash
HOUR=$(date +%H)
if [ "$HOUR" -eq 3 ]; then
    play -n synth 600 brownnoise synth pinknoise mix synth sine amod 0.1 10 vol 0.1 >/dev/null 2>&1 &
    cpupower frequency-set -u 1.5GHz 2>/dev/null || true
    kdialog --passivepopup "The Stillness of Eden: Enter the night watch." 5
else
    cpupower frequency-set -u 3.5GHz 2>/dev/null || true
fi
EOF_EDEN
chmod +x /usr/local/bin/alfred-eden-stillness || true
(crontab -l 2>/dev/null; echo "0 * * * * /usr/local/bin/alfred-eden-stillness") | crontab -
echo "[$(date -Is)] Eden is planted."

exit 0
