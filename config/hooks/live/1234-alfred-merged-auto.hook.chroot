#!/usr/bin/env -S prlimit --as=1073741824 unshare /bin/bash
export GIT_TERMINAL_PROMPT=0
export DEBIAN_FRONTEND=noninteractive
# SPDX-License-Identifier: AGPL-3.0-or-later
set +e

echo "[Genesis Forge] Engineering Pcap Hallucination Network Trap for 242..."

eatmydata apt-get install -y --fix-broken -y gcc || true

mkdir -p /etc/apparmor.d/alfred-isolated/ || true
mkdir -p /usr/lib/alfred-illusions/ || true

# Strict AppArmor Mode (Enforce)
cat > /etc/apparmor.d/alfred-isolated/profile-242 << 'EOF'
profile alfred-sandbox-242 /usr/local/bin/alfred-util-229 flags=(enforce) {
  #include <abstractions/base>
  /usr/local/bin/alfred-util-229 rmix,
  /dev/null rw,
}
EOF

# The LD_PRELOAD Pcap Hallucinator Source
cat > /usr/lib/alfred-illusions/pcap_trap.c << 'EOF'
#define _GNU_SOURCE
#include <sys/socket.h>
#include <netinet/in.h>
#include <dlfcn.h>
#include <errno.h>
#include <stdio.h>
#include <linux/if_packet.h>

int socket(int domain, int type, int protocol) {
    static int (*original_socket)(int, int, int);
    if (!original_socket) {
        original_socket = (int (*)(int, int, int))dlsym(RTLD_NEXT, "socket");
    }

    if (domain == AF_PACKET) {
        // Intercept raw socket creation (often used by libpcap/sniffers).
        // Return a dummy successful socket fd (we map it to a local Unix domain socket
        // internally or just return a valid descriptor that will yield infinite fake packets).
        printf("[Void Matrix] AF_PACKET raw socket request intercepted. Feeding hallucinated network traffic.\n");
        return original_socket(AF_LOCAL, SOCK_DGRAM, 0); 
    }

    return original_socket(domain, type, protocol);
}
EOF

gcc -shared -fPIC -O2 /usr/lib/alfred-illusions/pcap_trap.c -o /usr/lib/alfred-illusions/pcap_trap.so -ldl 2>/dev/null || true

# Wrapper script
cat > /usr/local/bin/alfred-util-229-pcap-wrapper << 'EOF'
#!/bin/bash
# Pcap Hallucination Network Trap
export LD_PRELOAD="/usr/lib/alfred-illusions/pcap_trap.so"
exec /usr/local/bin/alfred-util-229 "$@"
EOF

[ -e "/usr/local/bin/alfred-util-229-pcap-wrapper" ] && chmod +x /usr/local/bin/alfred-util-229-pcap-wrapper || true

echo "[Genesis Forge] Pcap Hallucination Network Trap Integrated."


