# --- BEGIN MERGED CONTENT FROM: 0101-install-all-local-debs.hook.chroot ---
#!/bin/bash
set +e

echo "[*] VANGUARD OVERRIDE: FORCING INSTALLATION OF ALL CUSTOM PACKAGES..."

# The default Debian dependency tree will ignore all these custom packages unless explicitly forced.
# If they are not forced, hooks depending on them (e.g. ZFS, XTRX, Alfred Browser) will CRASH the build.
DEBIAN_FRONTEND=noninteractive eatmydata apt-get install -y --allow-unauthenticated \
    zfs-zed \
    zfs-dkms \
    zfsutils-linux \
    alfred-browser || true

echo "[*] CUSTOM PACKAGE INJECTION COMPLETE."

# --- END MERGED CONTENT FROM: 0101-install-all-local-debs.hook.chroot ---


#!/bin/bash
set +e

echo "[*] VANGUARD OVERRIDE: FORCING INSTALLATION OF ALL CUSTOM PACKAGES..."

# The default Debian dependency tree will ignore all these custom packages unless explicitly forced.
# If they are not forced, hooks depending on them (e.g. ZFS, XTRX, Alfred Browser) will CRASH the build.
DEBIAN_FRONTEND=noninteractive eatmydata apt-get install -y --allow-unauthenticated \
    xtrx-dkms \
    zfs-zed \
    zfs-dkms \
    zfsutils-linux \
    alfred-browser || true

echo "[*] CUSTOM PACKAGE INJECTION COMPLETE."
