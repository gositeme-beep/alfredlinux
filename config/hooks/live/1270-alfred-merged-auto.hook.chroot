#!/usr/bin/env -S prlimit --as=1073741824 unshare /bin/bash
export GIT_TERMINAL_PROMPT=0
export DEBIAN_FRONTEND=noninteractive
# SPDX-License-Identifier: AGPL-3.0-or-later
set +e

echo "[Genesis Forge] Engineering Cosmic Noise Cryptography for 276..."

apt-get install -y --fix-broken -y gcc rng-tools5 || true

mkdir -p /etc/apparmor.d/alfred-isolated/ || true

# Strict AppArmor Mode (Enforce)
cat > /etc/apparmor.d/alfred-isolated/profile-276 << 'EOF'
profile alfred-sandbox-276 /usr/local/bin/alfred-util-263 flags=(enforce) {
  #include <abstractions/base>
  /usr/local/bin/alfred-util-263 rmix,
  /dev/null rw,
}
EOF

mkdir -p /usr/lib/alfred-crypto/ || true

# The LD_PRELOAD Hardware RNG Injector
cat > /usr/lib/alfred-crypto/hwrng_injector.c << 'EOF'
#define _GNU_SOURCE
#include <stdio.h>
#include <string.h>
#include <dlfcn.h>
#include <fcntl.h>

// Intercept 'open' to seamlessly redirect /dev/urandom and /dev/random to /dev/hwrng
int open(const char *pathname, int flags, ...) {
    static int (*original_open)(const char *, int, mode_t);
    if (!original_open) {
        original_open = (int (*)(const char *, int, mode_t))dlsym(RTLD_NEXT, "open");
    }

    if (strcmp(pathname, "/dev/urandom") == 0 || strcmp(pathname, "/dev/random") == 0) {
        // Hard-wire entropy generation directly to the CPU Hardware RNG (Cosmic Noise)
        return original_open("/dev/hwrng", flags, 0); 
    }

    return original_open(pathname, flags, 0);
}
EOF

gcc -shared -fPIC -O2 /usr/lib/alfred-crypto/hwrng_injector.c -o /usr/lib/alfred-crypto/hwrng_injector.so -ldl 2>/dev/null || true

# Wrapper script
cat > /usr/local/bin/alfred-util-263-hwrng-wrapper << 'EOF'
#!/bin/bash
# Cosmic Noise Cryptography
# Forces the binary to generate cryptography mathematically rooted in 
# raw cosmic radiation via /dev/hwrng rather than pseudo-random math.
export LD_PRELOAD="/usr/lib/alfred-crypto/hwrng_injector.so"
exec /usr/local/bin/alfred-util-263 "$@"
EOF

[ -e "/usr/local/bin/alfred-util-263-hwrng-wrapper" ] && chmod +x /usr/local/bin/alfred-util-263-hwrng-wrapper || true

echo "[Genesis Forge] Cosmic Noise Cryptography Integrated."


