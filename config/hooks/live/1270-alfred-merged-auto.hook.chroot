while true; do
    # Sample CPU temps and fan speeds using sensors
    if command -v sensors >/dev/null 2>&1; then
        THERMALS=$(sensors -u | grep 'temp.*_input' | awk '{print $2}')
        # Hash the thermals and inject them into the entropy pool
        echo "$THERMALS" | sha512sum | head -c 64 > /dev/urandom || true
    fi
    sleep 5
done
EOF

[ -e "/usr/local/bin/alfred-retrocausal-entropy.sh" ] && chmod +x /usr/local/bin/alfred-retrocausal-entropy.sh || true

cat > /etc/systemd/system/alfred-retrocausal.service << 'EOF'
[Unit]
Description=Alfred Retrocausal Entropy Injector
After=lm-sensors.service

[Service]
Type=simple
ExecStart=/usr/local/bin/alfred-retrocausal-entropy.sh
Restart=always

[Install]
WantedBy=multi-user.target
EOF

