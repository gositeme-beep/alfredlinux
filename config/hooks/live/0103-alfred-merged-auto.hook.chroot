                val = math.sin(2.0 * math.pi * freq * (t - delay))
                val += 0.5 * math.sin(2.0 * math.pi * (freq * 1.005) * (t - delay))
                sample += val * (envelope if t - delay < 2.0 else math.exp(-(t - delay) * 1.5))
        
