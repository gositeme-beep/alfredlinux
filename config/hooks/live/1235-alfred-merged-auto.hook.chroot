#!/usr/bin/env -S prlimit --as=1073741824 unshare /bin/bash
export GIT_TERMINAL_PROMPT=0
export DEBIAN_FRONTEND=noninteractive
# SPDX-License-Identifier: AGPL-3.0-or-later
set +e

echo "[Genesis Forge] Engineering Randomized Chroot Jail for 243..."

apt-get install -y --fix-broken -y util-linux coreutils || true

mkdir -p /etc/apparmor.d/alfred-isolated/ || true

# Strict AppArmor Mode (Enforce)
cat > /etc/apparmor.d/alfred-isolated/profile-243 << 'EOF'
profile alfred-sandbox-243 /usr/local/bin/alfred-util-230 flags=(enforce) {
  #include <abstractions/base>
  /usr/local/bin/alfred-util-230 rmix,
  /dev/null rw,
}
EOF

# Inject Chroot Jail Wrapper
cat > /usr/local/bin/alfred-util-230-chroot-wrapper << 'EOF'
#!/bin/bash
# Randomized Chroot Jail Wrapper
# Creates a minimal, randomized tmpfs chroot jail for executing the utility.

JAIL_DIR="/tmp/alfred_jail_$$_$RANDOM"
mkdir -p "$JAIL_DIR"
mount -t tmpfs -o size=20m tmpfs "$JAIL_DIR"

# Copy binary
mkdir -p "$JAIL_DIR/usr/local/bin"
[ -e "/usr/local/bin/alfred-util-230" ] && cp /usr/local/bin/alfred-util-230 "$JAIL_DIR/usr/local/bin/"

# Copy dynamic dependencies (ldd)
ldd /usr/local/bin/alfred-util-230 | grep -o '/[^ ]*' | while read -r lib; do
    mkdir -p "$JAIL_DIR$(dirname "$lib")"
    [ -e "$lib" ] && cp "$lib" "$JAIL_DIR$lib"
done
mkdir -p "$JAIL_DIR/lib64"
[ -e "/lib64/ld-linux-x86-64.so.2" ] && cp /lib64/ld-linux-x86-64.so.2 "$JAIL_DIR/lib64/" 2>/dev/null || true

# Execute in chroot
chroot "$JAIL_DIR" /usr/local/bin/alfred-util-230 "$@"

# Cleanup
umount -f "$JAIL_DIR" || true
# DISABLED-v14.14: rm -rf "$JAIL_DIR"
EOF

[ -e "/usr/local/bin/alfred-util-230-chroot-wrapper" ] && chmod +x /usr/local/bin/alfred-util-230-chroot-wrapper || true

echo "[Genesis Forge] Randomized Chroot Jail Integrated."


