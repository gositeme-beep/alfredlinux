#!/bin/bash
# 0270-alfred-sovereign.hook.chroot — "The Crown"
# THIS IS WHAT MAKES UBUNTU OBSOLETE.
set -e
echo "═══════════════════════════════════════════════════════"
echo "  ALFRED SOVEREIGN LAYER — The Crown"
echo "═══════════════════════════════════════════════════════"
export DEBIAN_FRONTEND=noninteractive

# ═══════════════════════════════════════════════════
# 1. SELF-HEALING SECURITY — The OS fixes itself
# ═══════════════════════════════════════════════════
echo "[SOVEREIGN] Installing self-healing security..."

cat > /usr/local/bin/alfred-heal << 'HEAL'
#!/bin/bash
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[0;33m'; CYAN='\033[0;36m'; NC='\033[0m'
HEAL_LOG="/var/log/alfred-heal.log"
ISSUES=0; FIXED=0
log() { echo "$(date '+%Y-%m-%d %H:%M:%S') $1" | tee -a "$HEAL_LOG"; }
echo -e "${CYAN}═══ Alfred Self-Healing Security Check ═══${NC}"

echo -n "[1/8] Checking /etc/passwd integrity... "
if awk -F: '($3 == 0 && $1 != "root") {exit 1}' /etc/passwd; then
    echo -e "${GREEN}OK${NC}"
else
    echo -e "${RED}EXTRA ROOT USERS DETECTED${NC}"; log "ALERT: Extra root users"; ((ISSUES++))
fi

echo -n "[2/8] Checking SSH hardening... "
if grep -rq "PermitRootLogin no" /etc/ssh/ 2>/dev/null; then
    echo -e "${GREEN}OK${NC}"
else
    echo -e "${YELLOW}REPAIRING — re-hardening SSH${NC}"
    mkdir -p /etc/ssh/sshd_config.d
    echo -e "PermitRootLogin no\nPasswordAuthentication no" > /etc/ssh/sshd_config.d/alfred-hardened.conf
    log "REPAIRED: SSH root login re-disabled"; ((ISSUES++)); ((FIXED++))
fi

echo -n "[3/8] Checking firewall... "
if nft list ruleset 2>/dev/null | grep -q "chain input"; then
    echo -e "${GREEN}OK${NC}"
else
    echo -e "${YELLOW}REPAIRING — restoring firewall${NC}"
    [ -f /etc/nftables.conf ] && nft -f /etc/nftables.conf 2>/dev/null && log "REPAIRED: nftables restored" && ((FIXED++))
    ((ISSUES++))
fi

echo -n "[4/8] Checking AppArmor... "
if aa-status --enabled 2>/dev/null; then echo -e "${GREEN}OK${NC}"; else
    echo -e "${YELLOW}REPAIRING${NC}"; systemctl restart apparmor 2>/dev/null; ((ISSUES++)); ((FIXED++))
fi

echo -n "[5/8] Checking SUID binaries... "
KNOWN="/usr/bin/sudo /usr/bin/pkexec /usr/bin/passwd /usr/bin/chfn /usr/bin/chsh /usr/bin/gpasswd /usr/bin/newgrp /usr/bin/su /usr/bin/mount /usr/bin/umount"
UNX=$(find /usr/bin /usr/sbin -perm -4000 -type f 2>/dev/null | while read f; do echo "$KNOWN" | grep -qw "$f" || echo "$f"; done)
if [ -z "$UNX" ]; then echo -e "${GREEN}OK${NC}"; else echo -e "${YELLOW}WARNING — unexpected SUID${NC}"; ((ISSUES++)); fi

echo -n "[6/8] Checking world-writable files... "
WW=$(find /etc /usr -xdev -type f -perm -0002 2>/dev/null | wc -l)
if [ "$WW" -eq 0 ]; then echo -e "${GREEN}OK${NC}"; else echo -e "${YELLOW}WARNING — $WW files${NC}"; ((ISSUES++)); fi

echo -n "[7/8] Checking kernel hardening... "
if [ "$(cat /proc/sys/net/ipv4/tcp_syncookies 2>/dev/null)" = "1" ]; then echo -e "${GREEN}OK${NC}"; else
    sysctl -w net.ipv4.tcp_syncookies=1 2>/dev/null; echo -e "${YELLOW}REPAIRED${NC}"; ((ISSUES++)); ((FIXED++))
fi

echo -n "[8/8] Checking AI services... "
if command -v omahon &>/dev/null || command -v ollama &>/dev/null; then echo -e "${GREEN}OK${NC}"; else
    echo -e "${YELLOW}WARNING — no AI agent${NC}"; ((ISSUES++))
fi

echo ""
if [ $ISSUES -eq 0 ]; then echo -e "${GREEN}═══ ALL CLEAR — System is sovereign ═══${NC}"
else echo -e "${YELLOW}═══ Found $ISSUES issues, auto-repaired $FIXED ═══${NC}"; fi
HEAL
chmod +x /usr/local/bin/alfred-heal

# Systemd timer — every 6 hours
cat > /etc/systemd/system/alfred-heal.service << 'SVC'
[Unit]
Description=Alfred Self-Healing Security Check
[Service]
Type=oneshot
ExecStart=/usr/local/bin/alfred-heal
SVC

cat > /etc/systemd/system/alfred-heal.timer << 'TMR'
[Unit]
Description=Alfred Self-Healing — every 6 hours
[Timer]
OnBootSec=5min
OnUnitActiveSec=6h
Persistent=true
[Install]
WantedBy=timers.target
TMR
systemctl enable alfred-heal.timer 2>/dev/null || true

# ═══════════════════════════════════════════════════
# 2. VOICE COMMAND LAYER
# ═══════════════════════════════════════════════════
echo "[SOVEREIGN] Installing voice command framework..."
cat > /usr/local/bin/alfred-voice-cmd << 'VCMD'
#!/bin/bash
COMMAND="$*"
case "${COMMAND,,}" in
    *"open browser"*) xdg-open about:blank &;;
    *"open terminal"*) xfce4-terminal &;;
    *"open files"*) thunar &;;
    *"open editor"*|*"open ide"*) xdg-open http://localhost:8443 &;;
    *"lock"*) xflock4 &;;
    *"check security"*|*"heal"*) alfred-heal;;
    *"update"*) xfce4-terminal -e "sudo apt update && sudo apt upgrade -y" &;;
    *"search for"*) Q="${COMMAND#*search for}"; alfred-search "$Q" 2>/dev/null || xdg-open "https://duckduckgo.com/?q=${Q}" &;;
    *"what time"*) date '+%I:%M %p';;
    *) command -v alfred-ai &>/dev/null && alfred-ai "$COMMAND" || echo "Unknown: $COMMAND";;
esac
VCMD
chmod +x /usr/local/bin/alfred-voice-cmd

# ═══════════════════════════════════════════════════
# 3. SOVEREIGN DNS — Handshake
# ═══════════════════════════════════════════════════
echo "[SOVEREIGN] Configuring sovereign DNS..."
cat > /usr/local/bin/alfred-dns << 'DNS'
#!/bin/bash
case "$1" in
    enable-handshake|enable-hns)
        mkdir -p /etc/systemd/resolved.conf.d
        cat > /etc/systemd/resolved.conf.d/handshake.conf << 'H'
[Resolve]
DNS=103.196.38.38 103.196.38.39
FallbackDNS=1.1.1.1 9.9.9.9
H
        systemctl restart systemd-resolved 2>/dev/null
        echo "Handshake DNS ENABLED — .alfred, .gositeme TLDs now resolve";;
    disable-handshake|disable-hns)
        rm -f /etc/systemd/resolved.conf.d/handshake.conf
        systemctl restart systemd-resolved 2>/dev/null
        echo "Handshake DNS disabled";;
    status)
        resolvectl status 2>/dev/null | grep "DNS Servers" || cat /etc/resolv.conf
        echo "Handshake: $([ -f /etc/systemd/resolved.conf.d/handshake.conf ] && echo 'ENABLED' || echo 'DISABLED')";;
    *) echo "Usage: alfred-dns {enable-handshake|disable-handshake|status}";;
esac
DNS
chmod +x /usr/local/bin/alfred-dns

# ═══════════════════════════════════════════════════
# 4. IDENTITY AWARENESS
# ═══════════════════════════════════════════════════
echo "[SOVEREIGN] Setting up identity awareness..."
cat > /usr/local/bin/alfred-whoami << 'WHO'
#!/bin/bash
CYAN='\033[0;36m'; GOLD='\033[0;33m'; GREEN='\033[0;32m'; NC='\033[0m'
ID_FILE="$HOME/.config/alfred/identity.json"
if [ "$1" = "setup" ]; then
    mkdir -p "$HOME/.config/alfred"
    read -p "Your name: " NAME; read -p "Your role: " ROLE
    cat > "$ID_FILE" << ID
{"name":"$NAME","role":"$ROLE","created":"$(date -Iseconds)","os":"Alfred Linux","sovereignty":true}
ID
    echo -e "${GREEN}Identity saved.${NC}"; exit 0
fi
if [ -f "$ID_FILE" ]; then
    echo -e "${GOLD}═══ Sovereign Identity ═══${NC}"
    echo -e "Name:   ${CYAN}$(jq -r .name "$ID_FILE" 2>/dev/null)${NC}"
    echo -e "Role:   ${CYAN}$(jq -r .role "$ID_FILE" 2>/dev/null)${NC}"
    echo -e "OS:     ${GREEN}Alfred Linux $(cat /etc/alfred-version 2>/dev/null)${NC}"
    echo -e "Host:   $(hostname)"
    echo -e "Uptime: $(uptime -p)"
else echo "Run: alfred-whoami setup"; fi
WHO
chmod +x /usr/local/bin/alfred-whoami

# ═══════════════════════════════════════════════════
# 5. MESH DISCOVERY — Alfred devices find each other
# ═══════════════════════════════════════════════════
echo "[SOVEREIGN] Installing mesh discovery..."
apt-get install -y --no-install-recommends avahi-daemon avahi-utils || true
mkdir -p /etc/avahi/services
cat > /etc/avahi/services/alfred.service << 'AVAHI'
<?xml version="1.0" standalone='no'?>
<!DOCTYPE service-group SYSTEM "avahi-service.dtd">
<service-group>
  <name replace-wildcards="yes">Alfred Linux on %h</name>
  <service>
    <type>_alfred._tcp</type>
    <port>8443</port>
    <txt-record>os=alfred-linux</txt-record>
    <txt-record>version=7.77</txt-record>
  </service>
</service-group>
AVAHI

cat > /usr/local/bin/alfred-mesh << 'MESH'
#!/bin/bash
echo "Scanning for Alfred devices..."
avahi-browse -t _alfred._tcp --resolve 2>/dev/null || echo "Start avahi: sudo systemctl start avahi-daemon"
MESH
chmod +x /usr/local/bin/alfred-mesh

# ═══════════════════════════════════════════════════
# 6. SECURITY AUDIT TOOL — Grade A-F
# ═══════════════════════════════════════════════════
echo "[SOVEREIGN] Installing security audit tool..."
cat > /usr/local/bin/alfred-security-audit << 'AUDIT'
#!/bin/bash
SCORE=0; TOTAL=0
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[0;33m'; CYAN='\033[0;36m'; NC='\033[0m'

_chk_firewall() { nft list ruleset 2>/dev/null | grep -q 'chain input'; }
_chk_apparmor() { aa-status --enabled 2>/dev/null; }
_chk_ssh_root() { grep -rq 'PermitRootLogin no' /etc/ssh/ 2>/dev/null; }
_chk_ssh_pass() { grep -rq 'PasswordAuthentication no' /etc/ssh/ 2>/dev/null; }
_chk_syn_cookies() { [ "$(cat /proc/sys/net/ipv4/tcp_syncookies 2>/dev/null)" = "1" ]; }
_chk_aslr() { [ "$(cat /proc/sys/kernel/randomize_va_space 2>/dev/null)" -ge 2 ]; }
_chk_etc_ww() { [ "$(find /etc -type f -perm -0002 2>/dev/null | wc -l)" -eq 0 ]; }
_chk_unattended() { systemctl is-enabled unattended-upgrades &>/dev/null; }
_chk_aide() { command -v aide >/dev/null; }
_chk_fail2ban() { systemctl is-active --quiet fail2ban 2>/dev/null; }
_chk_clamav() { command -v clamscan >/dev/null; }
_chk_rkhunter() { command -v rkhunter >/dev/null; }

chk() {
    local label=$1 fn=$2
    ((TOTAL++))
    echo -n "  [$TOTAL] $label... "
    if $fn; then echo -e "${GREEN}PASS${NC}"; ((SCORE++)); else echo -e "${RED}FAIL${NC}"; fi
}

echo -e "${CYAN}═══ Alfred Linux Security Audit ═══${NC}"
chk "Firewall active" _chk_firewall
chk "AppArmor enforcing" _chk_apparmor
chk "SSH root disabled" _chk_ssh_root
chk "SSH password disabled" _chk_ssh_pass
chk "SYN cookies" _chk_syn_cookies
chk "ASLR enabled" _chk_aslr
chk "No world-writable /etc" _chk_etc_ww
chk "Auto-updates" _chk_unattended
chk "AIDE installed" _chk_aide
chk "Fail2ban active" _chk_fail2ban
chk "ClamAV installed" _chk_clamav
chk "rkhunter installed" _chk_rkhunter
echo ""
PCT=$((SCORE * 100 / TOTAL))
if [ $PCT -ge 90 ]; then G="A"; C=$GREEN; elif [ $PCT -ge 80 ]; then G="B"; C=$GREEN
elif [ $PCT -ge 70 ]; then G="C"; C=$YELLOW; elif [ $PCT -ge 60 ]; then G="D"; C=$YELLOW
else G="F"; C=$RED; fi
echo -e "  Score: ${C}$SCORE/$TOTAL ($PCT%)${NC}"
echo -e "  Grade: ${C}$G${NC}"
[ "$G" = "A" ] && echo -e "${GREEN}  Your system is a fortress.${NC}"
AUDIT
chmod +x /usr/local/bin/alfred-security-audit

# ═══════════════════════════════════════════════════
# 7. VERSION + BRANDING
# ═══════════════════════════════════════════════════
echo "7.77" > /etc/alfred-version
cat > /etc/alfred-release << 'REL'
NAME="Alfred Linux"
VERSION="7.77"
ID=alfred
ID_LIKE=debian
PRETTY_NAME="Alfred Linux 7.77 — Kingdom of God Edition"
HOME_URL="https://alfredlinux.com"
REL

# ═══════════════════════════════════════════════════
# 8. MOTD — First thing you see
# ═══════════════════════════════════════════════════
cat > /etc/update-motd.d/10-alfred << 'MOTD'
#!/bin/bash
C='\033[0;36m'; G='\033[0;33m'; N='\033[0m'
echo ""
echo -e "${C}  ╔═══════════════════════════════════════════╗${N}"
echo -e "${C}  ║${N}  ${G}A L F R E D   L I N U X${N}   v$(cat /etc/alfred-version 2>/dev/null || echo '7.77')        ${C}║${N}"
echo -e "${C}  ║${N}  Your computer. Your rules. Yours.        ${C}║${N}"
echo -e "${C}  ╠═══════════════════════════════════════════╣${N}"
echo -e "${C}  ║${N}  alfred-ai      → AI agent               ${C}║${N}"
echo -e "${C}  ║${N}  alfred-heal    → Self-healing check     ${C}║${N}"
echo -e "${C}  ║${N}  alfred-search  → Local search           ${C}║${N}"
echo -e "${C}  ║${N}  alfred-dns     → Sovereign DNS          ${C}║${N}"
echo -e "${C}  ║${N}  alfred-mesh    → Find Alfred devices    ${C}║${N}"
echo -e "${C}  ║${N}  alfred-whoami  → Your identity          ${C}║${N}"
echo -e "${C}  ╚═══════════════════════════════════════════╝${N}"
echo ""
MOTD
chmod +x /etc/update-motd.d/10-alfred

echo "═══════════════════════════════════════════════════════"
echo "  THE CROWN IS SET — Alfred Linux is sovereign"
echo "═══════════════════════════════════════════════════════"
