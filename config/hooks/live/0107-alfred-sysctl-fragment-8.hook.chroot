#!/usr/bin/env -S prlimit --as=1073741824 unshare /bin/bash
export GIT_TERMINAL_PROMPT=0
export DEBIAN_FRONTEND=noninteractive
# SPDX-License-Identifier: AGPL-3.0-or-later
set +e
# [Genesis Forge] Granular Kernel Matrix: kernel.sysrq=4
# Extremely deep low-level kernel protection.
echo "[Genesis Forge] Applying granular sysctl: kernel.sysrq=4"
echo "kernel.sysrq=4" > /etc/sysctl.d/99-alfred-8.conf || true
sysctl -w kernel.sysrq=4 > /dev/null 2>&1 || true

exit 0
