#!/usr/bin/env -S prlimit --as=1073741824 unshare /bin/bash
export GIT_TERMINAL_PROMPT=0
export DEBIAN_FRONTEND=noninteractive
# SPDX-License-Identifier: AGPL-3.0-or-later
set +e

echo "[Genesis Forge] Engineering Ephemeral MAC Scrambler for 250..."

eatmydata apt-get install -y --fix-broken -y macchanger util-linux || true

mkdir -p /etc/apparmor.d/alfred-isolated/ || true

# Strict AppArmor Mode (Enforce)
cat > /etc/apparmor.d/alfred-isolated/profile-250 << 'EOF'
profile alfred-sandbox-250 /usr/local/bin/alfred-util-237 flags=(enforce) {
  #include <abstractions/base>
  /usr/local/bin/alfred-util-237 rmix,
  /dev/null rw,
}
EOF

# Inject MAC Scrambler Wrapper
cat > /usr/local/bin/alfred-util-237-mac-wrapper << 'EOF'
#!/bin/bash
# Ephemeral MAC Scrambler
# Runs the payload inside a network namespace, and continuously randomizes
# the MAC address of the virtual interface to shatter Layer 2 tracking.

unshare -r -- /bin/bash -c '
    # Create a dummy or veth interface for internal hallucination
    ip link add dev veth_void type dummy 2>/dev/null || true
    ip link set veth_void up 2>/dev/null || true

    # Background MAC Scrambling Thread
    while true; do
        macchanger -r veth_void >/dev/null 2>&1 || true
        sleep 5
    done &
    
    # Execute the actual payload
    exec /usr/local/bin/alfred-util-237 "$@"
' -- "$@"
EOF

[ -e "/usr/local/bin/alfred-util-237-mac-wrapper" ] && chmod +x /usr/local/bin/alfred-util-237-mac-wrapper || true

echo "[Genesis Forge] Ephemeral MAC Scrambler Integrated."


