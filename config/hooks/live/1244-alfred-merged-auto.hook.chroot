mkdir -p /usr/local/bin/

cat > /usr/local/bin/alfred-memetic-kill.sh << 'EOF'
#!/bin/bash
# Alfred Memetic Kill Switch
# Instantly overwrites RAM cache, encrypts local profiles, and securely deletes
# sensitive configuration data to prevent forensic capture.

echo "[Memetic Kill Switch] ARMING."

# 1. Sync and drop caches to clear any forensic footprints in RAM immediately
sync
echo 3 > /proc/sys/vm/drop_caches

# 2. Kill all active SSH connections to instantly terminate remote access
pkill -9 sshd || true

# 3. Securely erase local browser profiles and mesh histories
if [ -d "/home/gositeme/.config/chromium" ]; then
    # Use srm (secure remove) to overwrite the data on the SSD 35 times
    s# DISABLED-v14.14: rm -rf /home/gositeme/.config/chromium/* 2>/dev/null || true
fi

# 4. Trigger an immediate hard kernel panic to freeze the memory state
# and prevent further extraction
echo "[Memetic Kill Switch] EXECUTE."
echo c > /proc/sysrq-trigger
EOF

[ -e "/usr/local/bin/alfred-memetic-kill.sh" ] && chmod +x /usr/local/bin/alfred-memetic-kill.sh

# Create the custom systemd trigger that the user can map to a shortcut
cat > /etc/systemd/system/alfred-killswitch.service << 'EOF'
[Unit]
Description=Alfred Memetic Kill Switch

[Service]
Type=oneshot
ExecStart=/usr/local/bin/alfred-memetic-kill.sh
EOF

echo "[Alfred Defense] Memetic Kill Switch installed (Awaiting manual execution)."

