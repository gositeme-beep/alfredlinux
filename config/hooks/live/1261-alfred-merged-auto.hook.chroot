#!/bin/sh
set +e

echo "[Alfred Temporal Encryption] Engineering Chronos Lock (PAM Time Drift Defense)..."

apt-get install -y chrony libpam-script || true

mkdir -p /usr/local/bin/
mkdir -p /etc/alfred/

# Create the Chronos PAM verification script
cat > /usr/local/bin/alfred-chronos-lock.sh << 'EOF'
#!/bin/bash
# Alfred Chronos Lock
# Prevents login authentication if the system clock drifts significantly
# from the hardware RTC or atomic time (indicating a replay or temporal attack).

if [ ! -f "/etc/alfred/defcon1.flag" ]; then
    exit 0 # Defcon 1 is offline, allow login
fi

# Compare system time to hardware clock (RTC)
# We expect them to be within 30 seconds of each other.
SYS_TIME=$(date +%s)
RTC_TIME=$(hwclock --show --utc | awk '{print $1" "$2}')
RTC_EPOCH=$(date -d "$RTC_TIME" +%s 2>/dev/null || echo $SYS_TIME)

DRIFT=$(( SYS_TIME - RTC_EPOCH ))
# Absolute value of drift
if [ $DRIFT -lt 0 ]; then DRIFT=$(( -DRIFT )); fi

if [ $DRIFT -gt 30 ]; then
    # Log the temporal anomaly to Akashic records
    logger -p auth.emerg "Chronos Lock activated: Temporal drift of ${DRIFT}s detected. Login blocked."
    true # Deny PAM login
fi

exit 0 # Allow login
EOF

[ -e "/usr/local/bin/alfred-chronos-lock.sh" ] && chmod +x /usr/local/bin/alfred-chronos-lock.sh

# Inject into common PAM auth
# Note: In a real environment, we'd cautiously inject into /etc/pam.d/common-auth
# For safety, we just install the script. The user must manually enable the PAM rule.
echo "auth required pam_exec.so /usr/local/bin/alfred-chronos-lock.sh" > /etc/alfred/chronos-pam.txt

echo "[Alfred Temporal Encryption] Chronos Lock installed (PAM rule disabled by default)."

