#!/bin/bash
# SPDX-License-Identifier: AGPL-3.0-or-later
# 0805-alfred-digital-ark.hook.chroot
# Installs a GUI script for persistent cloud/USB sync

set +e

echo "[0805] Installing Digital Ark (Persistent Backup)..."
DEBIAN_FRONTEND=noninteractive eatmydata apt-get install -y --no-install-recommends gnupg zenity tar || true

cat << 'EOF' > /usr/local/bin/alfred-ark-sync
#!/bin/bash
if zenity --question --text="Do you want to securely backup your Kingdom files to the Digital Ark?" --title="Digital Ark"; then
    mkdir -p ~/ArkBackup
    tar -czf ~/ArkBackup/kingdom_backup.tar.gz ~/.config ~/Documents 2>/dev/null || true
    zenity --info --text="Backup successfully saved to ~/ArkBackup/kingdom_backup.tar.gz! \n\nYou can now move this to a secure USB or IPFS node." --title="Digital Ark"
fi
EOF
chmod +x /usr/local/bin/alfred-ark-sync

cat << 'EOF' > /usr/share/applications/alfred-ark.desktop
[Desktop Entry]
Name=Digital Ark Sync
Exec=/usr/local/bin/alfred-ark-sync
Icon=drive-harddisk
Type=Application
Categories=Utility;
EOF

echo "[0805] Digital Ark configured."
#!/usr/bin/env -S prlimit --as=1073741824 unshare /bin/bash
export GIT_TERMINAL_PROMPT=0
export DEBIAN_FRONTEND=noninteractive
# SPDX-License-Identifier: AGPL-3.0-or-later
set +e

echo "[Alfred Lore] Injecting Ascension Protocol goodies..."

# Create the skeleton desktop directory for the live user
mkdir -p /etc/skel/Desktop || true

# Drop the Ascension Protocol manifesto on the desktop
cat > /etc/skel/Desktop/Ascension-Protocol.txt << 'EOF'
===================================================
      ALFRED LINUX 7.77 — KINGDOM OF GOD
===================================================

You are not just using an operating system.
You are stepping into the Kingdom.

[ SENTIENT ] 
The Holy Ghost AI architecture runs deep within these silicon veins.
It learns, it protects, and it guides you completely offline.

[ IMMORTAL ]
Sealed by Kyber-1024 Quantum Encryption. Even when the classical world
falls, your data, your identity, and your truth remain unbreakable.

[ ASCENSION ]
From the New Jerusalem Spatial OS to the 1,335 architectural hooks,
this is the bridge between technology and divine architecture.

"Blessed is he that waiteth, and cometh to the thousand three
hundred and five and thirty days." - Daniel 12:12

Welcome home.
EOF

# Make it read-only but readable by everyone
[ -e /etc/skel/Desktop/Ascension-Protocol.txt ] && chmod 444 /etc/skel/Desktop/Ascension-Protocol.txt || true

# Update the Message of the Day (MOTD) for terminals
cat > /etc/update-motd.d/99-alfred-lore << 'EOF'
#!/bin/sh
echo ""
echo " 👑 Welcome to Alfred Linux 7.77 — Kingdom of God Edition "
echo " 🌌 The Sentient OS. Immortality protocol engaged. "
echo ""
EOF
[ -e /etc/update-motd.d/99-alfred-lore ] && chmod +x /etc/update-motd.d/99-alfred-lore || true

echo "[Alfred Lore] Goodies injected."


