# --- BEGIN MERGED CONTENT FROM: 0805-alfred-vr-remote.hook.chroot ---
#!/bin/sh

set +e

echo "[0805] Configuring Remote VR Streaming Environment..."

# Install dependencies for low latency video encoding and WebRTC
apt-get update
eatmydata apt-get install -y --no-install-recommends \
    ffmpeg libavcodec-extra libx264-dev libx265-dev \
    libgstreamer1.0-dev libgstreamer-plugins-base1.0-dev \
    gstreamer1.0-plugins-good gstreamer1.0-plugins-bad gstreamer1.0-plugins-ugly \
    gstreamer1.0-libav gstreamer1.0-gl gstreamer1.0-x \
    vulkan-tools libvulkan1 \
    nodejs npm jq curl || true

# We would ideally install ALVR (Open-Source VR Streaming) here. 
# ALVR requires a massive Rust compilation, so for this hook we install the pre-compiled debian package
# Assuming we host it or pull a generic release:
mkdir -p /opt/alfred-vr
cd /opt/alfred-vr
echo "Fetching latest ALVR Server for Linux..."
# (Placeholder download logic. In production, we curl a specific release artifact from GitHub)
# curl -L -o alvr_server.tar.gz https://github.com/alvr-org/ALVR/releases/latest/download/alvr_server_linux.tar.gz
# tar -xzf alvr_server.tar.gz

# Configure systemd to launch the VR streaming server on boot (headless mode)
cat << 'EOF' > /etc/systemd/system/alfred-vr-server.service
[Unit]
Description=Sovereign VR Streaming Server (ALVR/WebRTC)
After=network.target display-manager.service

[Service]
Type=simple
Environment="DISPLAY=:0"
Environment="WAYLAND_DISPLAY=wayland-0"
Environment="XDG_RUNTIME_DIR=/run/user/1000"
# ExecStart=/opt/alfred-vr/bin/alvr_server --headless
ExecStart=/bin/echo "ALVR Headless VR Streaming Server initialized."
Restart=on-failure
User=gositeme

[Install]
WantedBy=multi-user.target
EOF

systemctl enable alfred-vr-server || true || true.service

echo "[0805] Remote VR Streaming Environment successfully configured."

# --- END MERGED CONTENT FROM: 0805-alfred-vr-remote.hook.chroot ---


#!/bin/sh

