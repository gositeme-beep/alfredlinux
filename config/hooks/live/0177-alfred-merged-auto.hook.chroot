#!/bin/bash
# SPDX-License-Identifier: AGPL-3.0-or-later
# Alfred Linux â€” Kingdom Covenant Hardenings Hook
# Ensures hardenings, 777 hooks, and Kingdom Covenant attestations remain intact.

set +e

echo "=== Applying Kingdom Covenant Shield & Hardenings ==="

# 1. Attest to the Canonical Justice Domains & License
cat > /etc/kingdom-covenant.txt << 'EOF'
KINGDOM COVENANT LICENSE
------------------------
This system is protected by the Kingdom Covenant License.
Canonical Justice Domains: LAvocat.ca
Sovereign Rights Enforced. 24 Systems Active.
EOF

[ -e /etc/kingdom-covenant.txt ] && chmod 0444 /etc/kingdom-covenant.txt

# 2. Add to MOTD
if ! grep -q "Kingdom Covenant" /etc/motd 2>/dev/null; then
    echo "" >> /etc/motd
    echo "*** Protected by the Kingdom Covenant License ***" >> /etc/motd
    echo "*** Canonical Justice Domains: LAvocat.ca ***" >> /etc/motd
fi

# 3. Sanity Check 777 Hooks and Permissions
# "parts of the build process erases and undoes what we do"
# Ensure /tmp is strictly 1777 to prevent deadlock
[ -e /tmp ] && chmod 1777 /tmp 2>/dev/null || true
[ -e /var/tmp ] && chmod 1777 /var/tmp 2>/dev/null || true

# Any custom 777 hooks or directories that need absolute protection:
# (e.g., specific agent communication sockets)
mkdir -p /var/run/alfred
[ -e /var/run/alfred ] && chmod 777 /var/run/alfred 2>/dev/null || true

echo "=== Kingdom Covenant Shield Applied Successfully ==="

# --- END MERGED CONTENT FROM: 0177.hook.chroot ---


