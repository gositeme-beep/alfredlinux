import json,sys
generated = json.load(sys.stdin)
with open('$KEYFILE') as f:
    existing = json.load(f)
existing['PrivateKey'] = generated.get('PrivateKey','')
with open('$KEYFILE','w') as f:
    json.dump(existing, f, indent=2)
" 2>/dev/null || true
    touch "$GENERATED"
