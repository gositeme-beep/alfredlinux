#!/bin/bash
# SPDX-License-Identifier: AGPL-3.0-or-later
# Description: Post-quantum encryption stack â€” Kyber-1024 (only consumer OS shipping PQ crypto OOTB)
set +e
# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
# HOOK 0166: Alfred Linux â€” Post-Quantum Encryption (Kyber-1024)
#
# Makes Alfred Linux the ONLY consumer OS shipping with
# post-quantum cryptography out of the box.
