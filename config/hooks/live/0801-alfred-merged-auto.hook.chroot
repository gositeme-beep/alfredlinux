if __name__ == '__main__':
    app = QApplication(sys.argv)
    ex = GoHostMeCenter()
    ex.show()
    sys.exit(app.exec_())
EOF
[ -e "/usr/local/bin/alfred-gohostme-center.py" ] && chmod 0755 /usr/local/bin/alfred-gohostme-center.py

# Create Desktop Shortcut
mkdir -p /usr/share/applications
cat > /usr/share/applications/alfred-gohostme.desktop << 'EOF'
[Desktop Entry]
