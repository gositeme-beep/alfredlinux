#!/bin/bash
# Fetch a random Bible verse to project as a 3D hologram
BIBLE_FILE="/usr/share/alfred/bible/akjv.tsv"
if [ -f "$BIBLE_FILE" ]; then
    VERSE=$(shuf -n 1 "$BIBLE_FILE" | cut -f 2,3,4,5 | tr '\t' ' ')
    echo "$VERSE"
else
    echo "I am the light of the world. - John 8:12"
fi
EOF
[ -e "/usr/local/bin/alfred-screensaver-verse.sh" ] && chmod +x /usr/local/bin/alfred-screensaver-verse.sh

# Configure xscreensaver defaults for the 3D spinning text
mkdir -p /etc/skel
cat > /etc/skel/.xscreensaver <<'EOF'
timeout:	0:03:00
cycle:		0:01:00
lock:		False
mode:		one
selected:	-1
programs: \
  gltext -program /usr/local/bin/alfred-screensaver-verse.sh -front -wireframe -spin Z -wander -fg '#ffaa00' \n\
EOF

# 2. 3D Desktop Cube Effect (KWin)
mkdir -p /etc/xdg
cat > /etc/xdg/kwinrc <<'EOF'
[Plugins]
cubeEnabled=true
wobblywindowsEnabled=true
magiclampEnabled=true
EOF

# 3. Hologram Video Directory Setup
mkdir -p /usr/share/wallpapers/holy-scenes/
