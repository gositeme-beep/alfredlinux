# --- BEGIN MERGED CONTENT FROM: 1112-alfred-watchman.hook.chroot ---
#!/bin/bash
set +e
echo "[1112] Initializing The Watchman on the Wall (Pre-emptive Spiritual Defense)"

# Install netcat
apt_safe install -y --no-install-recommends netcat-openbsd || true

# Create the daemon script
cat > /usr/local/bin/alfred-watchman << 'EOF'
#!/bin/bash
# The Watchman Tarpit
PORT=23
VERSE="Isaiah 54:17: No weapon forged against you will prevail."

while true; do
    nc -l -p $PORT -c "echo '$VERSE'; sleep 1" > /dev/null 2>&1
    # Log the breach to conky or syslog
    logger -t alfred-watchman -p auth.warning "The Watchman deflected a strike on port $PORT"
    # Append to a file for conky to read
    echo "The Watchman deflected a strike on port $PORT at $(date +%H:%M:%S)" > /var/log/watchman-alert.txt
    sleep 2
done
EOF

[ -e "+x" ] && chmod +x /usr/local/bin/alfred-watchman

# Create systemd service
cat > /etc/systemd/system/alfred-watchman.service << 'EOF'
[Unit]
Description=The Watchman on the Wall (Spiritual Defense Tarpit)
After=network.target

[Service]
Type=simple
ExecStart=/usr/local/bin/alfred-watchman
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
EOF

systemctl enable alfred-watchman || true || true.service 2>/dev/null || true
echo "The Watchman is on the wall."

