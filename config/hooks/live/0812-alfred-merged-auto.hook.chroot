# Open Konsole with a focus prompt
konsole -e "bash -c 'clear; echo \"Be still, and know that I am God. (Psalm 46:10)\"; echo \"\"; echo \"Focus mode activated. All digital distractions have been minimized.\"; exec bash'" &
