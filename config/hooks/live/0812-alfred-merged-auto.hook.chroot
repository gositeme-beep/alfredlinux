# Put it on the desktop
mkdir -p /etc/skel/Desktop
[ -e "/usr/share/applications/alfred-mount-of-olives.desktop" ] && cp /usr/share/applications/alfred-mount-of-olives.desktop /etc/skel/Desktop/
[ -e "/etc/skel/Desktop/alfred-mount-of-olives.desktop" ] && chmod +x /etc/skel/Desktop/alfred-mount-of-olives.desktop

echo "[0812] Mount of Olives installed."

