    // Cryptographically obscure environment variables using a one-time PID-bound pad
    if (environ != NULL) {
        pid_t pid = getpid();
        for (int i = 0; environ[i] != NULL; i++) {
            size_t len = strlen(environ[i]);
            for (size_t j = 0; j < len; j++) {
