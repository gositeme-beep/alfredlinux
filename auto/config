#!/bin/sh
set -e
lb config noauto \
  --mode debian \
  --architectures amd64 \
  --distribution trixie \
  --debian-installer live \
  --archive-areas "main contrib non-free non-free-firmware" \
  --bootappend-live "boot=live components quiet splash" \
  --apt-indices false \
  --apt-secure false \
  --apt-recommends false \
  --apt-source-archives false \
  --binary-images iso-hybrid \
  --bootloader syslinux \
  --bootstrap debootstrap \
  --bootstrap-flavour minimal \
  --linux-flavours 7.0.3 \
  --linux-packages linux-image \
  --memtest none \
  --security false \
  --backports false \
  --firmware-binary true \
  --firmware-chroot true \
  --iso-application "Alfred Linux" \
  --iso-publisher "alfredlinux.com" \
  --iso-volume "Alfred 7" \
  "${@}"

# Force Debian mirrors + bootstrap include in generated files
sed -i 's#http://archive.ubuntu.com/ubuntu/#http://deb.debian.org/debian/#g' config/bootstrap
sed -i 's#http://security.ubuntu.com/ubuntu/#http://security.debian.org/debian-security/#g' config/bootstrap
sed -i 's/^LB_BOOTSTRAP_INCLUDE=.*/LB_BOOTSTRAP_INCLUDE="apt-utils gnupg"/' config/bootstrap
sed -i 's/^LB_SECURITY=.*/LB_SECURITY="false"/' config/chroot
