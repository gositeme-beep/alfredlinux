#!/bin/sh
# Alfred Linux live-build auto/config — pins distribution + suites
# so that `lb config` always re-creates a stable, reproducible setup.
set -e
lb config noauto \
    --architectures amd64 \
    --distribution trixie \
    --debian-installer live \
    --archive-areas "main contrib non-free non-free-firmware" \
    --bootappend-live "boot=live components quiet splash" \
    --apt-indices false \
    --apt-recommends false \
    --apt-source-archives false \
    --binary-images iso-hybrid \
    --bootloaders "grub-efi syslinux" \
    --debootstrap-options "--variant=minbase" \
    --linux-flavours 7.0.3 \
    --linux-packages "linux-image" \
    --memtest none \
    --security true \
    --updates true \
    --backports false \
    --firmware-binary true \
    --firmware-chroot true \
    --image-name "alfred-linux-7" \
    --iso-application "Alfred Linux" \
    --iso-publisher "alfredlinux.com" \
    --iso-volume "Alfred 7" \
    "${@}"
